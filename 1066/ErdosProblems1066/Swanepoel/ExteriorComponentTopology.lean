/-- Projection of the complete boundary-cycle package to the pointwise
local-sector rows. -/
noncomputable def localSectorRows_of_boundaryCycle_complete
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
