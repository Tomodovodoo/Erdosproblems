/-- The stricter connected-component local side-selection row implies the
patch-shaped `InteriorEdgeLocalExteriorSideSource`: take the selected side to be
the connected component of the local exterior inside the ball around `z`. -/
theorem interiorEdgeLocalExteriorSideSource_of_component_source
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (local_component_side :
      InteriorEdgeLocalExteriorSideComponentSource C inputs) :
    InteriorEdgeLocalExteriorSideSource C inputs := by
  intro e p he hpEdge hpFrontier q hqEdge hqClosure
  rcases local_component_side he hpEdge hpFrontier q hqEdge hqClosure with
    ⟨r, hrpos, hlocal_component⟩
  refine ⟨r, hrpos, ?_⟩
  intro z hzball hzEdge
  rcases hlocal_component z hzball hzEdge with
    ⟨y, hyLocal, hzComponentClosure⟩
  let localExterior : Set PlanarInterface.Point :=
    (unboundedExteriorComponentRows C inputs).exterior ∩ Metric.ball z r
  let side : Set PlanarInterface.Point := connectedComponentIn localExterior y
  refine ⟨side, ?_, ?_, ?_, ?_, ?_⟩
  · have hlocalOpen : IsOpen localExterior := by
      exact (unboundedExteriorComponentRows C inputs).exterior_open.inter
        Metric.isOpen_ball
    simpa [side, localExterior] using hlocalOpen.connectedComponentIn
  · simpa [side, localExterior] using
      (isPreconnected_connectedComponentIn
        (x := y) (F := localExterior))
  · intro w hw
    exact (connectedComponentIn_subset localExterior y hw).1
  · intro w hw
    exact (connectedComponentIn_subset localExterior y hw).2
  · simpa [side, localExterior] using hzComponentClosure

/-- Claim `S2-agent-interior-edge-nearby-exterior-point-source`.

The source-facing residual is the local edge-side topology row: near every
same-edge closure point, nearby edge points are accumulated by an actual open
preconnected patch of the selected exterior component.  The proof below only
forgets that patch to arbitrary exterior points via the metric closure
criterion. -/
theorem S2_agent_interior_edge_nearby_exterior_point_source
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (local_exterior_side :
      InteriorEdgeLocalExteriorSideSource C inputs) :
    InteriorEdgeNearbyExteriorPointSource C inputs := by
  intro e p he hpEdge hpFrontier q hqEdge hqClosure
  rcases
      local_exterior_side he hpEdge hpFrontier q hqEdge hqClosure with
    ⟨r, hrpos, hlocalSide⟩
  refine ⟨r, hrpos, ?_⟩
  intro z hzball hzEdge eps heps
  rcases hlocalSide z hzball hzEdge with
    ⟨side, _hsideOpen, _hsidePreconnected, hsideExterior,
      _hsideLocal, hzSideClosure⟩
  rw [Metric.mem_closure_iff] at hzSideClosure
  rcases hzSideClosure eps heps with ⟨y, hySide, hydist⟩
  have hyExterior :
      y ∈ (unboundedExteriorComponentRows C inputs).exterior :=
    hsideExterior hySide
  exact ⟨y, hyExterior, by simpa [dist_comm] using hydist⟩

/-- Component-selection variant of
`S2_agent_interior_edge_nearby_exterior_point_source`.  This is the narrow
remaining local-side input after replacing arbitrary patches by connected
components of the local exterior in a ball. -/
theorem S2_agent_interior_edge_nearby_exterior_point_source_of_component_source
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (local_component_side :
      InteriorEdgeLocalExteriorSideComponentSource C inputs) :
    InteriorEdgeNearbyExteriorPointSource C inputs :=
  S2_agent_interior_edge_nearby_exterior_point_source
    (interiorEdgeLocalExteriorSideSource_of_component_source
      local_component_side)

/-- Bookkeeping equivalence between the nearby-exterior-points source and the
local relative-closure row.  The source-facing theorem above reduces the
nearby-points side to the sharper local edge-side patch row; this equivalence
is kept only as the metric adapter used by older closure reducers. -/
theorem interior_edge_nearby_exterior_point_source_iff_relative_ball_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C} :
    InteriorEdgeNearbyExteriorPointSource C inputs ↔
      InteriorRelativeBallClosureRow C inputs := by
  constructor
  · intro hnear
    exact S2_agent_interior_relative_ball_closure_source hnear
  · intro hclosure e p he hpEdge hpFrontier q hqEdge hqClosure
    rcases hclosure he hpEdge hpFrontier q hqEdge hqClosure with
      ⟨r, hrpos, hlocalClosure⟩
    refine ⟨r, hrpos, ?_⟩
    intro z hzball hzEdge eps heps
    have hzClosure :
        z ∈ closure (unboundedExteriorComponentRows C inputs).exterior :=
      hlocalClosure z hzball hzEdge
    rw [Metric.mem_closure_iff] at hzClosure
    rcases hzClosure eps heps with ⟨y, hyExterior, hydist⟩
    exact ⟨y, hyExterior, by simpa [dist_comm] using hydist⟩

/-- The exact carrier-membership source and the relative-ball closure row are
equivalent local residuals.  The forward direction uses the selected
unbounded-frontier edge definition; the reverse direction is the open-edge
closure-locus propagation reducer. -/
theorem interior_frontier_edge_carrier_membership_source_iff_relative_ball_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C} :
    InteriorFrontierEdgeCarrierMembershipSource C inputs ↔
      InteriorRelativeBallClosureRow C inputs := by
  constructor
  · intro interior_edge_mem e p he hpEdge hpFrontier q _hqEdge _hqClosure
    refine ⟨1, by norm_num, ?_⟩
    intro z _hzball hzEdge
    exact
      frontier_subset_closure
        ((mem_unboundedFrontierEdgeSet_iff.1
          (interior_edge_mem he hpEdge hpFrontier)).2 z hzEdge)
  · intro interior_relative_ball_closure
    exact
      interior_frontier_edge_carrier_membership_source_of_relative_ball_closure
        interior_relative_ball_closure

/-- Direct eraser from local preconnected exterior-side patches to the exact
interior frontier-edge carrier membership row.

This is a convenience composition of the checked local-source reducers: once
the geometric proof supplies preconnected exterior-side patches near every
open-edge point, the selected whole-edge carrier membership follows without any
cycle or carrier connectedness assumptions. -/
theorem interior_frontier_edge_carrier_membership_source_of_preconnected_patch
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (patch :
      forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
        e ∈ (canonicalGraph C).edgeSet ->
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
          forall z : PlanarInterface.Point,
            PlanarInterface.InOpenSegment z
              ((canonicalGraph C).point e.1)
              ((canonicalGraph C).point e.2) ->
            forall r : Real,
              0 < r ->
                Exists fun S : Set PlanarInterface.Point =>
                  Exists fun y : PlanarInterface.Point =>
                    IsPreconnected S ∧
                      y ∈ S ∧
                        S ⊆
                          (unboundedExteriorComponentRows C inputs).exterior ∩
                            Metric.ball z r ∧
                          z ∈ closure S) :
    InteriorFrontierEdgeCarrierMembershipSource C inputs :=
  interior_frontier_edge_carrier_membership_source_of_relative_ball_closure
    (S2_agent_interior_relative_ball_closure_source
      (S2_agent_interior_edge_nearby_exterior_point_source_of_component_source
        (interiorEdgeLocalExteriorSideComponentSource_of_openSegment_component_source
          (interiorEdgeOpenSegmentLocalExteriorSideComponentSource_of_preconnected_patch
            patch))))

/-- Reducer from the named local concrete residual to the relative-ball closure
row consumed by the interior edge source path. -/
theorem interior_relative_ball_closure_of_closure_locus_relative_open
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (closure_locus_relative_open :
      InteriorClosureLocusRelativeOpenSource C inputs) :
    InteriorRelativeBallClosureRow C inputs :=
  (interior_frontier_edge_carrier_membership_source_iff_relative_ball_closure).1
    (interior_frontier_edge_carrier_membership_source_of_closure_locus_relative_open
      closure_locus_relative_open)

/-- Reducer in the opposite direction: the pointwise relative-ball closure row
