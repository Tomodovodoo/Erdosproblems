/-- A connected finite two-regular graph mapped injectively into the
unit-distance graph gives the actual boundary edge-membership source, provided
its vertices are exactly the exterior-frontier vertices and its edges are
selected unbounded-frontier edges up to orientation. -/
theorem boundaryCycleEdgeMemSource_of_connected_two_regular_frontier_graph_edge_mem
    {V : Type u} [Fintype V]
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (F : SimpleGraph V) [DecidableRel F.Adj]
    (hconn : F.Connected)
    (hdegree_two : forall v : V,
      @SimpleGraph.degree V F v (F.neighborSetFintype v) = 2)
    (phi : SimpleGraph.Hom F (GraphBridge.unitDistanceSimpleGraph C))
    (hphi : Function.Injective phi)
    (hfrontier :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun x : V => phi x = v)
    (edge_mem :
      forall {x y : V}, F.Adj x y ->
        (phi x, phi y) ∈ unboundedFrontierEdgeSet C inputs ∨
          (phi y, phi x) ∈ unboundedFrontierEdgeSet C inputs) :
    ActualBoundaryCycleFrontierEquivalenceRows.BoundaryCycleEdgeMemSource
      C inputs := by
  classical
  have hdegree_two' : forall v : V, F.degree v = 2 := by
    intro v
    simpa using hdegree_two v
  rcases
      exists_unitDistanceCycleBoundary_covering_spanning_cycle_hom_edge_lifts
        (C := C) F phi hphi
        (connected_two_regular_spanning_cycle F hconn hdegree_two') with
    ⟨B, hcover, himage, hedge_lifts⟩
  refine ⟨B, ?_, ?_⟩
  · intro v
    constructor
    · intro hv
      rcases (hfrontier v).1 hv with ⟨x, hx⟩
      rcases hcover x with ⟨k, hk⟩
      exact ⟨k, hk.trans hx⟩
    · rintro ⟨k, hk⟩
      rcases himage k with ⟨x, hx⟩
      exact (hfrontier v).2 ⟨x, hx.symm.trans hk⟩
  · intro k
    rcases hedge_lifts k with ⟨x, y, hxy, hk, hsucc⟩
    rcases edge_mem hxy with hforward | hreverse
    · left
      simpa [hk, hsucc] using hforward
    · right
      simpa [hk, hsucc] using hreverse

/-- Claim `S2-agent-raw-orbit-cycle-boundary-constructor`, cycle-graph route.

The raw face-successor orbit is used as the finite cycle graph itself:
vertices are raw tails, successor adjacency is supplied by the face-successor
endpoint chaining, and selected boundary-edge membership comes from the raw
open-segment frontier row. -/
theorem S2_agent_raw_cyclegraph_boundary_source_route
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C} {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (period_ge_three : 3 <= O.period)
    (tail_injective :
      Function.Injective fun k : Fin O.period => (O.dart k).tail)
    (frontier_iff_tail : forall v : Fin n,
      (canonicalGraph C).point v ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ↔
        Exists fun k : Fin O.period => (O.dart k).tail = v)
    (edge_openSegment_frontier :
      forall k : Fin O.period, forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (O.dart k).tail)
          ((canonicalGraph C).point
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    ActualBoundaryCycleFrontierEquivalenceRows.BoundaryCycleEdgeMemSource
      C inputs := by
  classical
  let F : SimpleGraph (Fin O.period) := SimpleGraph.cycleGraph O.period
  let phi : SimpleGraph.Hom F (GraphBridge.unitDistanceSimpleGraph C) := {
    toFun := fun k => (O.dart k).tail
    map_rel' := by
      intro i j hij
      rcases cycleGraph_adj_eq_cyclicSucc_or_eq_cyclicPred
          O.period_pos period_ge_three hij with hsucc | hpred
      · subst j
        exact rawFaceSuccOrbit_tail_adj_cyclicSucc O i
      · subst j
        have hpred_succ :
            PlanarInterface.cyclicSucc O.period_pos
                (PlanarInterface.cyclicPred O.period_pos i) = i :=
          PlanarInterface.cyclicSucc_cyclicPred O.period_pos i
        exact (GraphBridge.unitDistanceSimpleGraph C).symm (by
          simpa [hpred_succ] using
            rawFaceSuccOrbit_tail_adj_cyclicSucc O
              (PlanarInterface.cyclicPred O.period_pos i)) }
  exact
    boundaryCycleEdgeMemSource_of_connected_two_regular_frontier_graph_edge_mem
      (inputs := inputs)
      F
      (hconn := by
        rw [SimpleGraph.connected_iff]
        exact ⟨SimpleGraph.cycleGraph_preconnected,
          Fin.pos_iff_nonempty.mp O.period_pos⟩)
      (hdegree_two := by
        intro v
        exact cycleGraph_degree_two_of_three_le period_ge_three v)
      phi
      tail_injective
      (by
        intro v
        simpa [phi] using frontier_iff_tail v)
      (by
        intro x y hxy
        rcases cycleGraph_adj_eq_cyclicSucc_or_eq_cyclicPred
            O.period_pos period_ge_three hxy with hsucc | hpred
        · subst y
          simpa [phi] using
            rawFaceSuccOrbit_edge_mem_unboundedFrontierEdgeSet_or_symm
              O edge_openSegment_frontier x
        · subst y
          have hpred_succ :
              PlanarInterface.cyclicSucc O.period_pos
                  (PlanarInterface.cyclicPred O.period_pos x) = x :=
            PlanarInterface.cyclicSucc_cyclicPred O.period_pos x
          rcases
              rawFaceSuccOrbit_edge_mem_unboundedFrontierEdgeSet_or_symm
                O edge_openSegment_frontier
                (PlanarInterface.cyclicPred O.period_pos x) with
            hforward | hreverse
          · right
            simpa [phi, hpred_succ] using hforward
          · left
            simpa [phi, hpred_succ] using hreverse)

/-- Consecutive raw frontier-edge rows place every raw tail in the concrete
unbounded-frontier carrier vertex set. -/
theorem rawFaceSuccOrbit_tail_mem_unboundedFrontierVertexSet
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    forall k : Fin O.period,
      (O.dart k).tail ∈ unboundedFrontierVertexSet C inputs := by
  intro k
  let hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
    unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
  rcases
      rawFaceSuccOrbit_edge_mem_unboundedFrontierEdgeSet_or_symm
        O edge_openSegment_frontier k with
    hedge | hedge
  · exact
      (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
        hwhole hedge).1
  · exact
      (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
        hwhole hedge).2

/-- Geometric/local-sector source for raw face-orbit nonbacktracking.  At each
raw tail, the consecutive raw frontier edge puts the vertex in the concrete
frontier carrier; the local-sector row supplies a second unit-neighbour
direction there.  The geometric sorted rotation list then prevents the
face-successor from immediately returning along the incoming dart. -/
theorem rawFaceSuccOrbit_pred_succ_tail_ne_of_geometric_localSectorRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {start : UnitDistanceDart C}
    (O :
      UnitDistanceRotationSystem.RawFaceSuccOrbit
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C)
        start)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    forall k : Fin O.period,
      (O.dart (PlanarInterface.cyclicPred O.period_pos k)).tail ≠
        (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail := by
  intro k htail_eq
  let R :=
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
      C
  let pred : Fin O.period := PlanarInterface.cyclicPred O.period_pos k
  let succ : Fin O.period := PlanarInterface.cyclicSucc O.period_pos k
  have hsucc_pred : PlanarInterface.cyclicSucc O.period_pos pred = k := by
    simpa [pred] using PlanarInterface.cyclicSucc_cyclicPred O.period_pos k
  have hface_pred : R.faceSucc (O.dart pred) = O.dart k := by
    simpa [R, pred, hsucc_pred] using
      rawFaceSuccOrbit_faceSucc_eq_cyclicSucc O pred
  have hpred_head : (O.dart pred).head = (O.dart k).tail :=
    R.endpoint_chaining_of_faceSucc_eq_next hface_pred
  let tail_mem :
      forall k : Fin O.period,
        (O.dart k).tail ∈ unboundedFrontierVertexSet C inputs :=
    rawFaceSuccOrbit_tail_mem_unboundedFrontierVertexSet
      O edge_openSegment_frontier
  let a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨(O.dart k).tail, tail_mem k⟩
  let rows := localSectorRows a
  rcases rows.exists_unit_neighbor_ne (O.dart pred).tail with
    ⟨x, hx, hx_ne_pred_tail⟩
  have hx_at_pred_head :
      (GraphBridge.unitDistanceSimpleGraph C).Adj (O.dart pred).head x := by
    simpa [a, hpred_head] using hx
  have hface_head_ne :
      (R.faceSucc (O.dart pred)).head ≠ (O.dart pred).tail :=
    geometricUnitDistanceRotationSystem_faceSucc_head_ne_tail_of_exists_other_neighbor
      (C := C) (O.dart pred) hx_at_pred_head hx_ne_pred_tail
  have hface_k := rawFaceSuccOrbit_faceSucc_eq_cyclicSucc O k
  have hk_head_succ_tail : (O.dart k).head = (O.dart succ).tail := by
    simpa [R, succ] using
      R.endpoint_chaining_of_faceSucc_eq_next hface_k
  exact hface_head_ne (by
    calc
      (R.faceSucc (O.dart pred)).head = (O.dart k).head := by
        rw [hface_pred]
      _ = (O.dart succ).tail := hk_head_succ_tail
      _ = (O.dart pred).tail := htail_eq.symm)

/-- Claim `S2-agent-raw-nonbacktracking-source`.

Selected geometric raw-orbit source for the predecessor/successor
nonbacktracking row consumed by `S2_agent_raw_tail_hit_source`.  The only
inputs are the actual dart-edge frontier row for the selected geometric raw
orbit and the pointwise local-sector rows; no cyclic carrier coverage, boundary
cycle, or final S2 rows are used. -/
theorem S2_agent_raw_nonbacktracking_source
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (dart_edge_openSegment_frontier :
      forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
          {start : UnitDistanceDart C},
        UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
        start.tail = e.1 ->
        start.head = e.2 ->
        forall O :
          UnitDistanceRotationSystem.RawFaceSuccOrbit
            (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
              C)
            start,
          forall k : Fin O.period,
            forall q : PlanarInterface.Point,
              PlanarInterface.InOpenSegment q
                ((canonicalGraph C).point (O.dart k).tail)
                ((canonicalGraph C).point (O.dart k).head) ->
              q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
        {start : UnitDistanceDart C},
      UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
      start.tail = e.1 ->
      start.head = e.2 ->
      forall O :
        UnitDistanceRotationSystem.RawFaceSuccOrbit
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
            C)
          start,
        forall k : Fin O.period,
          (O.dart (PlanarInterface.cyclicPred O.period_pos k)).tail ≠
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail := by
  intro e p start edgeRows htail hhead O
  let edge_openSegment_frontier :
      forall k : Fin O.period,
        forall q : PlanarInterface.Point,
          PlanarInterface.InOpenSegment q
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
    intro k q hq
    let next : Fin O.period := PlanarInterface.cyclicSucc O.period_pos k
    have hsucc := rawFaceSuccOrbit_faceSucc_eq_cyclicSucc O k
    have hhead_next : (O.dart k).head = (O.dart next).tail := by
      simpa [next] using
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C).endpoint_chaining_of_faceSucc_eq_next hsucc
    exact
      dart_edge_openSegment_frontier edgeRows htail hhead O k q
        (by simpa [next, hhead_next] using hq)
  exact
    rawFaceSuccOrbit_pred_succ_tail_ne_of_geometric_localSectorRows
      (C := C) (inputs := inputs) O edge_openSegment_frontier localSectorRows

/-- Following the raw face-successor orbit gives a carrier-graph path from the
initial raw tail to any later raw tail.

This is the graph-theoretic reachability core of the raw-root source: it uses
the actual whole-open-segment frontier row for consecutive raw tails, and does
not pass through cyclic coverage rows. -/
theorem rawFaceSuccOrbit_tail_reachable_from_zero_of_edge_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (k : Fin O.period) :
    (unboundedFrontierCarrierGraph C inputs).Reachable
      ⟨(O.dart ⟨0, O.period_pos⟩).tail,
        rawFaceSuccOrbit_tail_mem_unboundedFrontierVertexSet
          O edge_openSegment_frontier ⟨0, O.period_pos⟩⟩
      ⟨(O.dart k).tail,
        rawFaceSuccOrbit_tail_mem_unboundedFrontierVertexSet
          O edge_openSegment_frontier k⟩ := by
  classical
  let tail_mem :
      forall k : Fin O.period,
        (O.dart k).tail ∈ unboundedFrontierVertexSet C inputs :=
    rawFaceSuccOrbit_tail_mem_unboundedFrontierVertexSet
      O edge_openSegment_frontier
  let tailVertex
      (k : Fin O.period) :
      {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨(O.dart k).tail, tail_mem k⟩
  have step :
      forall i : Fin O.period,
        (unboundedFrontierCarrierGraph C inputs).Adj
          (tailVertex i)
          (tailVertex (PlanarInterface.cyclicSucc O.period_pos i)) := by
    intro i
    rcases
        rawFaceSuccOrbit_edge_mem_unboundedFrontierEdgeSet_or_symm
          O edge_openSegment_frontier i with
      hedge | hedge
    · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge hedge
    · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm hedge
  have reach_nat :
      forall m : Nat,
        forall hm : m < O.period,
          (unboundedFrontierCarrierGraph C inputs).Reachable
            (tailVertex ⟨0, O.period_pos⟩)
            (tailVertex ⟨m, hm⟩) := by
    intro m
    induction m with
    | zero =>
        intro hm
        exact SimpleGraph.Reachable.refl _
    | succ m ih =>
        intro hm
        have hm_prev : m < O.period := by omega
        have hsucc :
            PlanarInterface.cyclicSucc O.period_pos
                (⟨m, hm_prev⟩ : Fin O.period) =
              (⟨m + 1, hm⟩ : Fin O.period) := by
          exact Fin.ext (by
            simp [PlanarInterface.cyclicSucc, Nat.mod_eq_of_lt hm])
        have hstep :
            (unboundedFrontierCarrierGraph C inputs).Adj
              (tailVertex (⟨m, hm_prev⟩ : Fin O.period))
              (tailVertex (⟨m + 1, hm⟩ : Fin O.period)) := by
          simpa [tailVertex, hsucc] using
            step (⟨m, hm_prev⟩ : Fin O.period)
        exact
          (ih hm_prev).trans
            hstep.reachable
  simpa [tailVertex, tail_mem] using reach_nat k.val k.isLt

/-- Claim `S2-agent-raw-reachable-root-source`.

The selected raw face-successor orbit supplies the concrete carrier
reachability root once the exterior-orbit tracing row has shown that every
unbounded-frontier carrier vertex occurs as one of the raw tails.  The proof
walks along raw successor edges in the concrete `unboundedFrontierCarrierGraph`
and does not use cyclic carrier coverage. -/
theorem S2_agent_raw_reachable_root_source
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (frontier_vertex_tail_coverage :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        Exists fun k : Fin O.period => (O.dart k).tail = a.1) :
    (Exists fun root :
      {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} =>
        forall x :
          {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
            (unboundedFrontierCarrierGraph C inputs).Reachable root x) := by
  classical
  let tail_mem :
      forall k : Fin O.period,
        (O.dart k).tail ∈ unboundedFrontierVertexSet C inputs :=
    rawFaceSuccOrbit_tail_mem_unboundedFrontierVertexSet
      O edge_openSegment_frontier
  let root : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨(O.dart ⟨0, O.period_pos⟩).tail,
      tail_mem ⟨0, O.period_pos⟩⟩
  refine ⟨root, ?_⟩
  intro x
  rcases frontier_vertex_tail_coverage x with ⟨k, hk⟩
  have hreach :=
    rawFaceSuccOrbit_tail_reachable_from_zero_of_edge_openSegment_frontier
      (C := C) (inputs := inputs) O edge_openSegment_frontier k
  have hx :
      (⟨(O.dart k).tail, tail_mem k⟩ :
        {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) = x :=
    Subtype.ext hk
  simpa [root, tail_mem, hx] using hreach

/-- Local-sector rows close the raw-tail subset under all concrete carrier
neighbours once the raw orbit is known not to immediately reverse at any
frontier vertex.

The extra nonbacktracking row is deliberately explicit: without it, the raw
predecessor and successor tails may coincide, while a local-sector row still
supplies two distinct concrete frontier neighbours. -/
theorem rawFaceSuccOrbit_neighbor_tail_closed_of_localSectorRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (raw_pred_succ_tail_ne :
      forall k : Fin O.period,
        (O.dart (PlanarInterface.cyclicPred O.period_pos k)).tail ≠
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) :
    forall k : Fin O.period,
      forall hk :
        (O.dart k).tail ∈ unboundedFrontierVertexSet C inputs,
      forall b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        (unboundedFrontierCarrierGraph C inputs).Adj
          ⟨(O.dart k).tail, hk⟩ b ->
        Exists fun l : Fin O.period => (O.dart l).tail = b.1 := by
  classical
  let raw_edge_mem :
      forall k : Fin O.period,
        ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
            unboundedFrontierEdgeSet C inputs ∨
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
            (O.dart k).tail) ∈ unboundedFrontierEdgeSet C inputs :=
    rawFaceSuccOrbit_edge_mem_unboundedFrontierEdgeSet_or_symm
      O edge_openSegment_frontier
  let raw_tail_mem :
      forall k : Fin O.period,
        (O.dart k).tail ∈ unboundedFrontierVertexSet C inputs :=
    rawFaceSuccOrbit_tail_mem_unboundedFrontierVertexSet
      O edge_openSegment_frontier
  intro k hk b hab
  let a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨(O.dart k).tail, hk⟩
  let rows := localSectorRows a
  let pred : Fin O.period := PlanarInterface.cyclicPred O.period_pos k
  let succ : Fin O.period := PlanarInterface.cyclicSucc O.period_pos k
  let predVertex : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨(O.dart pred).tail, raw_tail_mem pred⟩
  let succVertex : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨(O.dart succ).tail, raw_tail_mem succ⟩
  have hpred_succ : PlanarInterface.cyclicSucc O.period_pos pred = k := by
    simpa [pred] using PlanarInterface.cyclicSucc_cyclicPred O.period_pos k
  have hpred_adj :
      (unboundedFrontierCarrierGraph C inputs).Adj a predVertex := by
    rcases raw_edge_mem pred with hedge | hedge
    · exact
        unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm
          (a := a) (b := predVertex)
          (by
            simpa [a, predVertex, pred, hpred_succ] using hedge)
    · exact
        unboundedFrontierCarrierGraph_adj_of_ordered_edge
          (a := a) (b := predVertex)
          (by
            simpa [a, predVertex, pred, hpred_succ] using hedge)
  have hsucc_adj :
      (unboundedFrontierCarrierGraph C inputs).Adj a succVertex := by
    rcases raw_edge_mem k with hedge | hedge
    · exact
        unboundedFrontierCarrierGraph_adj_of_ordered_edge
          (a := a) (b := succVertex)
          (by
            simpa [a, succVertex, succ] using hedge)
    · exact
        unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm
          (a := a) (b := succVertex)
          (by
            simpa [a, succVertex, succ] using hedge)
  have hpred_succ_ne : predVertex ≠ succVertex := by
    intro h
    have htail :
        (O.dart (PlanarInterface.cyclicPred O.period_pos k)).tail =
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail := by
      simpa [predVertex, succVertex, pred, succ] using congrArg Subtype.val h
    exact raw_pred_succ_tail_ne k htail
  have hpred_cases := (rows.neighbor_iff predVertex).1 hpred_adj
  have hsucc_cases := (rows.neighbor_iff succVertex).1 hsucc_adj
  have hb_cases := (rows.neighbor_iff b).1 (by simpa [a] using hab)
  have hb_raw : b = predVertex ∨ b = succVertex := by
    rcases hb_cases with hb_left | hb_right
    · rcases hpred_cases with hpred_left | hpred_right
      · exact Or.inl (hb_left.trans hpred_left.symm)
      · rcases hsucc_cases with hsucc_left | hsucc_right
        · exact Or.inr (hb_left.trans hsucc_left.symm)
        · exact False.elim
            (hpred_succ_ne (hpred_right.trans hsucc_right.symm))
    · rcases hpred_cases with hpred_left | hpred_right
      · rcases hsucc_cases with hsucc_left | hsucc_right
        · exact False.elim
            (hpred_succ_ne (hpred_left.trans hsucc_left.symm))
        · exact Or.inr (hb_right.trans hsucc_right.symm)
      · exact Or.inl (hb_right.trans hpred_right.symm)
  rcases hb_raw with hb_pred | hb_succ
  · exact ⟨pred, (congrArg Subtype.val hb_pred).symm⟩
  · exact ⟨succ, (congrArg Subtype.val hb_succ).symm⟩

/-- Raw-tail coverage plus the pointwise local-sector rows covers every
concrete unbounded-frontier carrier edge.

At an endpoint of a selected frontier edge, the local-sector row says every
carrier neighbour is one of the two raw predecessor/successor neighbours.
Thus a concrete frontier edge incident to that endpoint is exactly the raw
successor edge at the current raw tail or at the raw predecessor, up to the
stored orientation of `unboundedFrontierEdgeSet`. -/
theorem rawFaceSuccOrbit_edge_coverage_of_tail_coverage_localSectorRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (frontier_vertex_tail_coverage :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        Exists fun k : Fin O.period => (O.dart k).tail = a.1)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (raw_pred_succ_tail_ne :
      forall k : Fin O.period,
        (O.dart (PlanarInterface.cyclicPred O.period_pos k)).tail ≠
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) :
    forall e :
        {e : PlanarInterface.Edge n //
          e ∈ unboundedFrontierEdgeSet C inputs},
      Exists fun k : Fin O.period =>
        e.1 =
            ((O.dart k).tail,
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∨
          e.1 =
            ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
              (O.dart k).tail) := by
  classical
  let hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
    unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
  let raw_edge_mem :
      forall k : Fin O.period,
        ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
            unboundedFrontierEdgeSet C inputs ∨
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
              (O.dart k).tail) ∈ unboundedFrontierEdgeSet C inputs :=
    rawFaceSuccOrbit_edge_mem_unboundedFrontierEdgeSet_or_symm
      O edge_openSegment_frontier
  let raw_tail_mem :
      forall k : Fin O.period,
        (O.dart k).tail ∈ unboundedFrontierVertexSet C inputs :=
    rawFaceSuccOrbit_tail_mem_unboundedFrontierVertexSet
      O edge_openSegment_frontier
  intro e
  have hends :
      e.1.1 ∈ unboundedFrontierVertexSet C inputs ∧
        e.1.2 ∈ unboundedFrontierVertexSet C inputs :=
    endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
      hwhole e.2
  let a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨e.1.1, hends.1⟩
  let b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨e.1.2, hends.2⟩
  rcases frontier_vertex_tail_coverage a with ⟨k, hk⟩
  let rows := localSectorRows a
  let pred : Fin O.period := PlanarInterface.cyclicPred O.period_pos k
  let succ : Fin O.period := PlanarInterface.cyclicSucc O.period_pos k
  let predVertex : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨(O.dart pred).tail, raw_tail_mem pred⟩
  let succVertex : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨(O.dart succ).tail, raw_tail_mem succ⟩
  have hpred_succ : PlanarInterface.cyclicSucc O.period_pos pred = k := by
    simpa [pred] using PlanarInterface.cyclicSucc_cyclicPred O.period_pos k
  have hk_e : (O.dart k).tail = e.1.1 := by
    simpa [a] using hk
  have hpred_adj :
      (unboundedFrontierCarrierGraph C inputs).Adj a predVertex := by
    rcases raw_edge_mem pred with hedge | hedge
    · exact
        unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm
          (a := a) (b := predVertex)
          (by
            have hedge' :
                ((O.dart pred).tail, e.1.1) ∈
                    unboundedFrontierEdgeSet C inputs := by
              simpa [pred, hpred_succ, hk_e] using hedge
            simpa [a, predVertex, pred] using hedge')
    · exact
        unboundedFrontierCarrierGraph_adj_of_ordered_edge
          (a := a) (b := predVertex)
          (by
            have hedge' :
                (e.1.1, (O.dart pred).tail) ∈
                    unboundedFrontierEdgeSet C inputs := by
              simpa [pred, hpred_succ, hk_e] using hedge
            simpa [a, predVertex, pred] using hedge')
  have hsucc_adj :
      (unboundedFrontierCarrierGraph C inputs).Adj a succVertex := by
    rcases raw_edge_mem k with hedge | hedge
    · exact
        unboundedFrontierCarrierGraph_adj_of_ordered_edge
          (a := a) (b := succVertex)
          (by
            have hedge' :
                (e.1.1, (O.dart succ).tail) ∈
                    unboundedFrontierEdgeSet C inputs := by
              simpa [succ, hk_e] using hedge
            simpa [a, succVertex, succ] using hedge')
    · exact
        unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm
          (a := a) (b := succVertex)
          (by
            have hedge' :
                ((O.dart succ).tail, e.1.1) ∈
                    unboundedFrontierEdgeSet C inputs := by
              simpa [succ, hk_e] using hedge
            simpa [a, succVertex, succ] using hedge')
  have hpred_succ_ne : predVertex ≠ succVertex := by
    intro h
    have htail :
        (O.dart (PlanarInterface.cyclicPred O.period_pos k)).tail =
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail := by
      simpa [predVertex, succVertex, pred, succ] using congrArg Subtype.val h
    exact raw_pred_succ_tail_ne k htail
  have hb_adj :
      (unboundedFrontierCarrierGraph C inputs).Adj a b :=
    unboundedFrontierCarrierGraph_adj_of_ordered_edge e.2
  have hpred_cases := (rows.neighbor_iff predVertex).1 hpred_adj
  have hsucc_cases := (rows.neighbor_iff succVertex).1 hsucc_adj
  have hb_cases := (rows.neighbor_iff b).1 hb_adj
  have hb_raw : b = predVertex ∨ b = succVertex := by
    rcases hb_cases with hb_left | hb_right
    · rcases hpred_cases with hpred_left | hpred_right
      · exact Or.inl (hb_left.trans hpred_left.symm)
      · rcases hsucc_cases with hsucc_left | hsucc_right
        · exact Or.inr (hb_left.trans hsucc_left.symm)
        · exact False.elim
            (hpred_succ_ne (hpred_right.trans hsucc_right.symm))
    · rcases hpred_cases with hpred_left | hpred_right
      · rcases hsucc_cases with hsucc_left | hsucc_right
        · exact False.elim
            (hpred_succ_ne (hpred_left.trans hsucc_left.symm))
        · exact Or.inr (hb_right.trans hsucc_right.symm)
      · exact Or.inl (hb_right.trans hpred_right.symm)
  rcases hb_raw with hb_pred | hb_succ
  · refine ⟨pred, Or.inr ?_⟩
    apply Prod.ext
    · have htail :
          (O.dart (PlanarInterface.cyclicSucc O.period_pos pred)).tail =
            e.1.1 := by
        simpa [a, hpred_succ] using hk
      exact htail.symm
    · have htail : e.1.2 = (O.dart pred).tail := by
        simpa [b, predVertex] using congrArg Subtype.val hb_pred
      exact htail
  · refine ⟨k, Or.inl ?_⟩
    apply Prod.ext
    · exact hk.symm
    · have htail : e.1.2 = (O.dart succ).tail := by
        simpa [b, succVertex, succ] using congrArg Subtype.val hb_succ
      exact htail

/-- Tail injectivity plus period at least three gives the raw
predecessor/successor nonbacktracking row used by the local neighbour-closure
argument. -/
theorem rawFaceSuccOrbit_pred_succ_tail_ne_of_period_three_tail_injective
    {C : _root_.UDConfig n}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (period_ge_three : 3 <= O.period)
    (tail_injective :
      Function.Injective fun k : Fin O.period => (O.dart k).tail) :
    forall k : Fin O.period,
      (O.dart (PlanarInterface.cyclicPred O.period_pos k)).tail ≠
        (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail := by
  intro k htail
  exact
    (PlanarInterface.cyclicPred_ne_cyclicSucc_of_three_le
      O.period_pos period_ge_three k)
      (tail_injective htail)

/-- Closed-carrier source for raw-orbit tail coverage from independently
proved connectedness of the concrete carrier.

The raw edge-frontier row makes every raw tail a vertex of the concrete
unbounded-frontier carrier.  If the raw-tail subset is closed under all
carrier neighbours of its vertices, connectedness of that concrete carrier
forces every carrier vertex to occur as a raw tail.  This version takes
connectedness directly, so it does not need the cyclic coverage row that this
route is meant to source. -/
theorem rawFaceSuccOrbit_frontier_vertex_tail_coverage_of_carrier_connected_closed
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (hconn : (unboundedFrontierCarrierGraph C inputs).Connected)
    (neighbor_tail_closed :
      forall k : Fin O.period,
        forall hk :
          (O.dart k).tail ∈ unboundedFrontierVertexSet C inputs,
        forall b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
          (unboundedFrontierCarrierGraph C inputs).Adj
            ⟨(O.dart k).tail, hk⟩ b ->
            Exists fun l : Fin O.period => (O.dart l).tail = b.1) :
    forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      Exists fun k : Fin O.period => (O.dart k).tail = a.1 := by
  classical
  let G := unboundedFrontierCarrierGraph C inputs
  let covered
      (a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) :
      Prop :=
    Exists fun k : Fin O.period => (O.dart k).tail = a.1
  have raw_edge_mem :
      forall k : Fin O.period,
        ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
            unboundedFrontierEdgeSet C inputs ∨
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
            (O.dart k).tail) ∈ unboundedFrontierEdgeSet C inputs := by
    intro k
    have hadj :
        (canonicalGraph C).Adj
          (O.dart k).tail
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail := by
      exact
        ((canonicalGraph C).adj_iff_unitDistanceAdj
          (O.dart k).tail
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail).2
          ((GraphBridge.unitDistanceSimpleGraph_adj C
            (O.dart k).tail
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail).1
            (rawFaceSuccOrbit_tail_adj_cyclicSucc O k))
    exact
      unboundedFrontierEdgeSet_or_symm_of_adj_openSegment_frontier
        (C := C) (inputs := inputs) hadj (edge_openSegment_frontier k)
  have raw_tail_mem :
      forall k : Fin O.period,
        (O.dart k).tail ∈ unboundedFrontierVertexSet C inputs := by
    intro k
    let hwhole :
        UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
      unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
    rcases raw_edge_mem k with hedge | hedge
    · exact
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole hedge).1
    · exact
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole hedge).2
  have neighbor_closed :
      forall {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
        covered a ->
          (unboundedFrontierCarrierGraph C inputs).Adj a b ->
            covered b := by
    intro a b ha hab
    rcases ha with ⟨k, hk⟩
    have ha_eq :
        a = ⟨(O.dart k).tail, raw_tail_mem k⟩ := Subtype.ext hk.symm
    have hab_raw :
        (unboundedFrontierCarrierGraph C inputs).Adj
          ⟨(O.dart k).tail, raw_tail_mem k⟩ b := by
      simpa [G, ha_eq] using hab
    exact neighbor_tail_closed k (raw_tail_mem k) b hab_raw
  have walk_closed :
      forall {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
        (unboundedFrontierCarrierGraph C inputs).Walk a b ->
          covered a ->
            covered b := by
    intro a b walk
    induction walk with
    | nil =>
        intro ha
        exact ha
    | cons hab rest ih =>
        intro ha
        exact ih (neighbor_closed ha hab)
  let root : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨(O.dart ⟨0, O.period_pos⟩).tail, raw_tail_mem ⟨0, O.period_pos⟩⟩
  have hroot : covered root := ⟨⟨0, O.period_pos⟩, rfl⟩
  intro a
  exact (hconn root a).elim fun walk => walk_closed walk hroot

/-- Claim `S2-agent-tail-coverage-from-connected-carrier`.

For the selected geometric raw face-successor orbit, the dart-edge frontier row
coming from the exterior-sector proof is enough to build the consecutive
raw-tail open-segment frontier row.  With independent connectedness of the
