/-! ### No-cut bookkeeping for repeated exterior boundary vertices -/

/-- Generic Boolean side-separation rows around a proposed cut vertex.

The two sides are read as `side = true` and `side = false` after deleting
`cut`; the witness fields make both sides nonempty, and `anticomplete` is the
only graph row needed to assemble a `CutVertexInterface.CutVertexPartition`. -/
structure BoolSideSeparationRows
    (C : _root_.UDConfig n) where
  cut : Fin n
  side : Fin n -> Bool
  trueWitness : Fin n
  trueWitness_ne_cut : trueWitness ≠ cut
  trueWitness_side : side trueWitness = true
  falseWitness : Fin n
  falseWitness_ne_cut : falseWitness ≠ cut
  falseWitness_side : side falseWitness = false
  anticomplete :
    forall {a b : Fin n},
      a ≠ cut ->
      b ≠ cut ->
      side a = true ->
      side b = false ->
        ¬ (GraphBridge.unitDistanceSimpleGraph C).Adj a b

/-- Checked conversion from generic Boolean side-separation rows to the
project's concrete cut-vertex partition interface. -/
noncomputable def cutVertexPartitionOfBoolSideSeparationRows
    {C : _root_.UDConfig n}
    (R : BoolSideSeparationRows C) :
    CutVertexInterface.CutVertexPartition C where
  cut := R.cut
  left :=
    Finset.univ.filter
      (fun v : Fin n => v ≠ R.cut ∧ R.side v = true)
  right :=
    Finset.univ.filter
      (fun v : Fin n => v ≠ R.cut ∧ R.side v = false)
  left_nonempty := by
    refine ⟨R.trueWitness, ?_⟩
    simp [R.trueWitness_ne_cut, R.trueWitness_side]
  right_nonempty := by
    refine ⟨R.falseWitness, ?_⟩
    simp [R.falseWitness_ne_cut, R.falseWitness_side]
  left_cut_not_mem := by
    simp
  right_cut_not_mem := by
    simp
  disjoint := by
    rw [Finset.disjoint_left]
    intro x hx hy
    have hxside : R.side x = true := by
      simpa using (Finset.mem_filter.1 hx).2.2
    have hyside : R.side x = false := by
      simpa using (Finset.mem_filter.1 hy).2.2
    simp [hxside] at hyside
  cover_without_cut := by
    ext x
    by_cases hxcut : x = R.cut
    · subst x
      simp
    · cases hside : R.side x <;> simp [hxcut, hside]
  anticomplete := by
    intro a ha b hb
    have ha' : a ≠ R.cut ∧ R.side a = true := by
      simpa using (Finset.mem_filter.1 ha).2
    have hb' : b ≠ R.cut ∧ R.side b = false := by
      simpa using (Finset.mem_filter.1 hb).2
    exact R.anticomplete ha'.1 hb'.1 ha'.2 hb'.2

/-- A generic boundary labelling cannot repeat a graph vertex if each genuine
repeat supplies Boolean side-separation rows and `C` has no cut vertex. -/
theorem generic_repeated_boundary_vertex_impossible_of_noCutVertex
    {C : _root_.UDConfig n}
    {ι : Type u}
    (boundaryVertex : ι -> Fin n)
    (hno : CutVertexInterface.NoCutVertex C)
    (repeatRows :
      forall {a b : ι}, a ≠ b -> boundaryVertex a = boundaryVertex b ->
        BoolSideSeparationRows C) :
    ¬ Exists fun a : ι =>
      Exists fun b : ι => a ≠ b ∧ boundaryVertex a = boundaryVertex b := by
  rintro ⟨a, b, hab, hsame⟩
  exact hno
    ⟨cutVertexPartitionOfBoolSideSeparationRows
      (repeatRows hab hsame)⟩

/-- A graph disconnection after deleting one vertex gives the project's
concrete cut-vertex partition.  This is the graph-theoretic handoff used by
the S2 repeated-exterior-boundary argument once the planar separation proof has
shown two non-cut vertices are unreachable in `G - cut`. -/
noncomputable def cutVertexPartition_of_unreachable_after_delete
    (C : _root_.UDConfig n) (cut a b : Fin n)
    (ha : a ≠ cut) (hb : b ≠ cut)
    (hunreach :
      ¬ ((GraphBridge.unitDistanceSimpleGraph C).induce
          ({cut}ᶜ : Set (Fin n))).Reachable
          ⟨a, by simpa using ha⟩
          ⟨b, by simpa using hb⟩) :
    CutVertexInterface.CutVertexPartition C := by
  classical
  let G := GraphBridge.unitDistanceSimpleGraph C
  let s : Set (Fin n) := {cut}ᶜ
  let a' : s := ⟨a, by simpa [s] using ha⟩
  let b' : s := ⟨b, by simpa [s] using hb⟩
  let H := G.induce s
  let comp : H.ConnectedComponent := H.connectedComponentMk a'
  let side : Fin n -> Bool := fun v =>
    if hv : v ≠ cut then
      decide ((⟨v, by simpa [s] using hv⟩ : s) ∈ comp.supp)
    else
      false
  refine
    cutVertexPartitionOfBoolSideSeparationRows
      { cut := cut
        side := side
        trueWitness := a
        trueWitness_ne_cut := ha
        trueWitness_side := ?_
        falseWitness := b
        falseWitness_ne_cut := hb
        falseWitness_side := ?_
        anticomplete := ?_ }
  · dsimp [side, comp, H, a']
    rw [dif_pos ha]
    simp [SimpleGraph.ConnectedComponent.mem_supp_iff]
  · dsimp [side, comp, H, a', b']
    rw [dif_pos hb]
    rw [decide_eq_false_iff_not]
    intro hrev
    exact hunreach (SimpleGraph.ConnectedComponent.exact hrev.symm)
  · intro x y hx_cut hy_cut hx_side hy_side hxy
    dsimp [side] at hx_side hy_side
    rw [dif_pos hx_cut] at hx_side
    rw [dif_pos hy_cut] at hy_side
    let x' : s := ⟨x, by simpa [s] using hx_cut⟩
    let y' : s := ⟨y, by simpa [s] using hy_cut⟩
    have hxmem : x' ∈ comp.supp := by
      dsimp [x']
      exact of_decide_eq_true hx_side
    have hymem : y' ∉ comp.supp := by
      dsimp [y']
      exact of_decide_eq_false hy_side
    have hxyH : H.Adj x' y' := by
      simpa [H, x', y'] using hxy
    exact hymem
      (SimpleGraph.ConnectedComponent.mem_supp_of_adj_mem_supp
        comp hxmem hxyH)

/-! ### Finite cyclic-arc rows for repeated exterior boundary vertices -/

/-- The open cyclic arc from `i` to `j`, moving forward through the finite
index order and wrapping around at `m`.  The endpoints are not included. -/
def cyclicForwardOpenArc {m : Nat} (i j k : Fin m) : Prop :=
  if i.val < j.val then
    i.val < k.val ∧ k.val < j.val
  else
    i.val < k.val ∨ k.val < j.val

theorem cyclicForwardOpenArc_not_left_endpoint
    {m : Nat} {i j : Fin m} :
    ¬ cyclicForwardOpenArc i j i := by
  dsimp [cyclicForwardOpenArc]
  split_ifs <;> omega

theorem cyclicForwardOpenArc_not_right_endpoint
    {m : Nat} {i j : Fin m} :
    ¬ cyclicForwardOpenArc i j j := by
  dsimp [cyclicForwardOpenArc]
  split_ifs <;> omega

theorem cyclicForwardOpenArc_left_ne
    {m : Nat} {i j k : Fin m}
    (hk : cyclicForwardOpenArc i j k) :
    k ≠ i := by
  intro hki
  subst k
  exact cyclicForwardOpenArc_not_left_endpoint hk

theorem cyclicForwardOpenArc_right_ne
    {m : Nat} {i j k : Fin m}
    (hk : cyclicForwardOpenArc i j k) :
    k ≠ j := by
  intro hkj
  subst k
  exact cyclicForwardOpenArc_not_right_endpoint hk

/-- The two open arcs determined by distinct cyclic endpoints are disjoint as
index sets. -/
theorem cyclicForwardOpenArc_disjoint
    {m : Nat} {i j k : Fin m} (hij : i ≠ j)
    (hik : cyclicForwardOpenArc i j k)
    (hjk : cyclicForwardOpenArc j i k) :
    False := by
  dsimp [cyclicForwardOpenArc] at hik hjk
  by_cases hijval : i.val < j.val
  · simp [hijval] at hik
    have hnot_jlt_i : ¬ j.val < i.val := by omega
    simp [hnot_jlt_i] at hjk
    rcases hjk with hjk | hjk <;> omega
  · have hji : j.val < i.val := by
      have hval_ne : i.val ≠ j.val := by
        intro hval
        exact hij (Fin.ext hval)
      omega
    simp [hijval] at hik
    simp [hji] at hjk
    rcases hik with hik | hik <;> omega

/-- Every index different from two distinct cyclic endpoints lies on one of
the two open cyclic arcs between them. -/
theorem cyclicForwardOpenArc_or_reverse_of_ne_endpoints
    {m : Nat} {i j k : Fin m} (hij : i ≠ j)
    (hki : k ≠ i) (hkj : k ≠ j) :
    cyclicForwardOpenArc i j k ∨ cyclicForwardOpenArc j i k := by
  dsimp [cyclicForwardOpenArc]
  by_cases hijval : i.val < j.val
  · have hnot_jlt_i : ¬ j.val < i.val := by omega
    simp [hijval, hnot_jlt_i]
    have hki_val : k.val ≠ i.val := by
      intro hval
      exact hki (Fin.ext hval)
    have hkj_val : k.val ≠ j.val := by
      intro hval
      exact hkj (Fin.ext hval)
    by_cases hik : i.val < k.val
    · by_cases hkjlt : k.val < j.val
      · exact Or.inl ⟨hik, hkjlt⟩
      · have hjltk : j.val < k.val := by
          have hjk_le : j.val <= k.val := le_of_not_gt hkjlt
          omega
        exact Or.inr (Or.inl hjltk)
    · have hklti : k.val < i.val := by
        have hki_le : k.val <= i.val := le_of_not_gt hik
        omega
      exact Or.inr (Or.inr hklti)
  · have hji : j.val < i.val := by
      have hval_ne : i.val ≠ j.val := by
        intro hval
        exact hij (Fin.ext hval)
      omega
    simp [hijval, hji]
    have hki_val : k.val ≠ i.val := by
      intro hval
      exact hki (Fin.ext hval)
    have hkj_val : k.val ≠ j.val := by
      intro hval
      exact hkj (Fin.ext hval)
    by_cases hjk : j.val < k.val
    · by_cases hki_lt : k.val < i.val
      · exact Or.inr ⟨hjk, hki_lt⟩
      · exact Or.inl (Or.inl (by
          have hki_le : i.val <= k.val := le_of_not_gt hki_lt
          have hik_val : i.val ≠ k.val := by
            intro hval
            exact hki_val hval.symm
          omega))
    · exact Or.inl (Or.inr (by
        have hkj_le : k.val <= j.val := le_of_not_gt hjk
        omega))

/-- The graph-vertex image of an open cyclic boundary arc. -/
def repeatedBoundaryArcImage
    {m : Nat} (vertex : Fin m -> Fin n) (i j : Fin m) (v : Fin n) :
    Prop :=
  Exists fun k : Fin m => cyclicForwardOpenArc i j k ∧ vertex k = v

/-- Boolean side assignment obtained from the forward arc image.  Vertices in
the `i`-to-`j` arc are assigned `true`; all remaining vertices are assigned
`false`. -/
noncomputable def repeatedBoundaryArcSide
    {m : Nat} (vertex : Fin m -> Fin n) (i j : Fin m) :
    Fin n -> Bool := by
  classical
  exact fun v => decide (repeatedBoundaryArcImage vertex i j v)

theorem repeatedBoundaryArcSide_eq_true_iff
    {m : Nat} {vertex : Fin m -> Fin n} {i j : Fin m} {v : Fin n} :
    repeatedBoundaryArcSide vertex i j v = true ↔
      repeatedBoundaryArcImage vertex i j v := by
  classical
  simp [repeatedBoundaryArcSide]

theorem repeatedBoundaryArcSide_eq_false_iff
    {m : Nat} {vertex : Fin m -> Fin n} {i j : Fin m} {v : Fin n} :
    repeatedBoundaryArcSide vertex i j v = false ↔
      ¬ repeatedBoundaryArcImage vertex i j v := by
  classical
  by_cases hv : repeatedBoundaryArcImage vertex i j v <;>
    simp [repeatedBoundaryArcSide, hv]

/-- Finite rows saying that the two open arcs cut out by a repeated cyclic
boundary vertex separate the graph after deleting that repeated vertex.

The future exterior face-orbit proof is expected to provide these rows: both
arcs have a non-cut vertex, every non-cut graph vertex lies on one of the two
arc images, the reverse arc is disjoint from the forward image away from the
cut, and the two arc images are anticomplete. -/
structure RepeatedExteriorBoundaryArcSeparationRows
    {n m : Nat} (C : _root_.UDConfig n)
    (vertex : Fin m -> Fin n) (i j : Fin m) where
  repeat_eq : vertex i = vertex j
  index_ne : i ≠ j
  left_index : Fin m
  left_index_mem : cyclicForwardOpenArc i j left_index
  left_index_ne_cut : vertex left_index ≠ vertex i
  right_index : Fin m
  right_index_mem : cyclicForwardOpenArc j i right_index
  right_index_ne_cut : vertex right_index ≠ vertex i
  cover_noncut :
    forall v : Fin n, v ≠ vertex i ->
      repeatedBoundaryArcImage vertex i j v ∨
        repeatedBoundaryArcImage vertex j i v
  reverse_arc_not_forward_off_cut :
    forall {v : Fin n}, v ≠ vertex i ->
      repeatedBoundaryArcImage vertex j i v ->
        ¬ repeatedBoundaryArcImage vertex i j v
  arcs_anticomplete :
    forall {a b : Fin n},
      repeatedBoundaryArcImage vertex i j a ->
      repeatedBoundaryArcImage vertex j i b ->
      a ≠ vertex i ->
      b ≠ vertex i ->
        ¬ (GraphBridge.unitDistanceSimpleGraph C).Adj a b

namespace RepeatedExteriorBoundaryArcSeparationRows

variable {m : Nat} {C : _root_.UDConfig n}
variable {vertex : Fin m -> Fin n} {i j : Fin m}

theorem left_image
    (R : RepeatedExteriorBoundaryArcSeparationRows C vertex i j) :
    repeatedBoundaryArcImage vertex i j (vertex R.left_index) :=
  ⟨R.left_index, R.left_index_mem, rfl⟩

theorem right_image
    (R : RepeatedExteriorBoundaryArcSeparationRows C vertex i j) :
    repeatedBoundaryArcImage vertex j i (vertex R.right_index) :=
  ⟨R.right_index, R.right_index_mem, rfl⟩

theorem right_not_left
    (R : RepeatedExteriorBoundaryArcSeparationRows C vertex i j) :
    ¬ repeatedBoundaryArcImage vertex i j (vertex R.right_index) :=
  R.reverse_arc_not_forward_off_cut
    R.right_index_ne_cut R.right_image

/-- Arc separation rows produce the generic Boolean side rows used by the
checked cut-partition constructor. -/
noncomputable def toBoolSideSeparationRows
    (R : RepeatedExteriorBoundaryArcSeparationRows C vertex i j) :
    BoolSideSeparationRows C where
  cut := vertex i
  side := repeatedBoundaryArcSide vertex i j
  trueWitness := vertex R.left_index
  trueWitness_ne_cut := R.left_index_ne_cut
  trueWitness_side := by
    exact repeatedBoundaryArcSide_eq_true_iff.2 R.left_image
  falseWitness := vertex R.right_index
  falseWitness_ne_cut := R.right_index_ne_cut
  falseWitness_side := by
    exact repeatedBoundaryArcSide_eq_false_iff.2 R.right_not_left
  anticomplete := by
    intro a b ha_cut hb_cut ha_side hb_side
    have ha_left :
        repeatedBoundaryArcImage vertex i j a :=
      repeatedBoundaryArcSide_eq_true_iff.1 ha_side
    have hb_not_left :
        ¬ repeatedBoundaryArcImage vertex i j b :=
      repeatedBoundaryArcSide_eq_false_iff.1 hb_side
    have hb_right :
        repeatedBoundaryArcImage vertex j i b := by
      rcases R.cover_noncut b hb_cut with hb_left | hb_right
      · exact False.elim (hb_not_left hb_left)
      · exact hb_right
    exact R.arcs_anticomplete ha_left hb_right ha_cut hb_cut

end RepeatedExteriorBoundaryArcSeparationRows

/-- Separation rows sufficient to turn a repeated exterior boundary vertex
into the concrete cut-partition object used by the no-cut interface.  The
geometric part of S2 is responsible for producing `side` and `anticomplete`
from the two boundary arcs cut apart by the repeated vertex. -/
structure RepeatedExteriorBoundarySeparationRows
    {n m : Nat} (C : _root_.UDConfig n)
    (vertex : Fin m -> Fin n) (i j : Fin m) where
  repeat_eq : vertex i = vertex j
  index_ne : i ≠ j
  side : Fin n -> Bool
  left_witness : Fin n
  left_witness_ne_cut : left_witness ≠ vertex i
  left_witness_side : side left_witness = true
  right_witness : Fin n
  right_witness_ne_cut : right_witness ≠ vertex i
  right_witness_side : side right_witness = false
  anticomplete :
    forall {a b : Fin n},
      a ≠ vertex i ->
      b ≠ vertex i ->
      side a = true ->
      side b = false ->
        ¬ (GraphBridge.unitDistanceSimpleGraph C).Adj a b

/-- If the two sides cut out by a repeated boundary vertex contain two
non-cut vertices that are unreachable after deleting the repeated vertex, the
generic Boolean separation rows are available.  The planar part of S2 must
still provide the actual unreachable pair from the two exterior arcs; this
lemma packages the finite graph consequence. -/
noncomputable def repeatedExteriorBoundarySeparationRows_of_unreachable_after_delete
    {m : Nat} {C : _root_.UDConfig n}
    {vertex : Fin m -> Fin n} {i j : Fin m}
    (repeat_eq : vertex i = vertex j)
    (index_ne : i ≠ j)
    (left right : Fin n)
    (left_ne_cut : left ≠ vertex i)
    (right_ne_cut : right ≠ vertex i)
    (hunreach :
      ¬ ((GraphBridge.unitDistanceSimpleGraph C).induce
          ({vertex i}ᶜ : Set (Fin n))).Reachable
          ⟨left, by simpa using left_ne_cut⟩
          ⟨right, by simpa using right_ne_cut⟩) :
    RepeatedExteriorBoundarySeparationRows C vertex i j := by
  classical
  let G := GraphBridge.unitDistanceSimpleGraph C
  let cut := vertex i
  let s : Set (Fin n) := {cut}ᶜ
  let left' : s := ⟨left, by simpa [cut, s] using left_ne_cut⟩
  let right' : s := ⟨right, by simpa [cut, s] using right_ne_cut⟩
  let H := G.induce s
  let comp : H.ConnectedComponent := H.connectedComponentMk left'
  let side : Fin n -> Bool := fun v =>
    if hv : v ≠ cut then
      decide ((⟨v, by simpa [s] using hv⟩ : s) ∈ comp.supp)
    else
      false
  refine
    { repeat_eq := repeat_eq
      index_ne := index_ne
      side := side
      left_witness := left
      left_witness_ne_cut := left_ne_cut
      left_witness_side := ?_
      right_witness := right
      right_witness_ne_cut := right_ne_cut
      right_witness_side := ?_
      anticomplete := ?_ }
  · dsimp [side, comp, H, left', cut]
    rw [dif_pos left_ne_cut]
    simp [SimpleGraph.ConnectedComponent.mem_supp_iff]
  · dsimp [side, comp, H, left', right', cut]
    rw [dif_pos right_ne_cut]
    rw [decide_eq_false_iff_not]
    intro hrev
    exact hunreach (SimpleGraph.ConnectedComponent.exact hrev.symm)
  · intro x y hx_cut hy_cut hx_side hy_side hxy
    dsimp [side] at hx_side hy_side
    rw [dif_pos hx_cut] at hx_side
    rw [dif_pos hy_cut] at hy_side
    let x' : s := ⟨x, by simpa [cut, s] using hx_cut⟩
    let y' : s := ⟨y, by simpa [cut, s] using hy_cut⟩
    have hxmem : x' ∈ comp.supp := by
      dsimp [x']
      exact of_decide_eq_true hx_side
    have hymem : y' ∉ comp.supp := by
      dsimp [y']
      exact of_decide_eq_false hy_side
    have hxyH : H.Adj x' y' := by
      simpa [H, x', y', G] using hxy
    exact hymem
      (SimpleGraph.ConnectedComponent.mem_supp_of_adj_mem_supp
        comp hxmem hxyH)

namespace RepeatedExteriorBoundarySeparationRows

variable {m : Nat} {C : _root_.UDConfig n}
variable {vertex : Fin m -> Fin n} {i j : Fin m}

/-- Erase a Boolean separation of the two sides of a repeated exterior
boundary vertex to the project's concrete cut-vertex partition. -/
noncomputable def toCutVertexPartition
    (R : RepeatedExteriorBoundarySeparationRows C vertex i j) :
    CutVertexInterface.CutVertexPartition C where
  cut := vertex i
  left :=
    Finset.univ.filter
      (fun v : Fin n => v ≠ vertex i ∧ R.side v = true)
  right :=
    Finset.univ.filter
      (fun v : Fin n => v ≠ vertex i ∧ R.side v = false)
  left_nonempty := by
    refine ⟨R.left_witness, ?_⟩
    simp [R.left_witness_ne_cut, R.left_witness_side]
  right_nonempty := by
    refine ⟨R.right_witness, ?_⟩
    simp [R.right_witness_ne_cut, R.right_witness_side]
  left_cut_not_mem := by
    simp
  right_cut_not_mem := by
    simp
  disjoint := by
    rw [Finset.disjoint_left]
    intro x hx hy
    have hxside : R.side x = true := by
      simpa using (Finset.mem_filter.1 hx).2.2
    have hyside : R.side x = false := by
      simpa using (Finset.mem_filter.1 hy).2.2
    simp [hxside] at hyside
  cover_without_cut := by
    ext x
    by_cases hxcut : x = vertex i
    · subst x
      simp
    · cases hside : R.side x <;> simp [hxcut, hside]
  anticomplete := by
    intro a ha b hb
    have ha' : a ≠ vertex i ∧ R.side a = true := by
      simpa using (Finset.mem_filter.1 ha).2
    have hb' : b ≠ vertex i ∧ R.side b = false := by
      simpa using (Finset.mem_filter.1 hb).2
    exact R.anticomplete ha'.1 hb'.1 ha'.2 hb'.2

end RepeatedExteriorBoundarySeparationRows

namespace RepeatedExteriorBoundaryArcSeparationRows

variable {m : Nat} {C : _root_.UDConfig n}
variable {vertex : Fin m -> Fin n} {i j : Fin m}

/-- Arc separation rows produce the repeated-boundary separation target
consumed by `exterior_boundary_vertex_injective_of_noCutVertex`. -/
noncomputable def toRepeatedExteriorBoundarySeparationRows
    (R : RepeatedExteriorBoundaryArcSeparationRows C vertex i j) :
    RepeatedExteriorBoundarySeparationRows C vertex i j where
  repeat_eq := R.repeat_eq
  index_ne := R.index_ne
  side := repeatedBoundaryArcSide vertex i j
  left_witness := vertex R.left_index
  left_witness_ne_cut := R.left_index_ne_cut
  left_witness_side := by
    exact repeatedBoundaryArcSide_eq_true_iff.2 R.left_image
  right_witness := vertex R.right_index
  right_witness_ne_cut := R.right_index_ne_cut
  right_witness_side := by
    exact repeatedBoundaryArcSide_eq_false_iff.2 R.right_not_left
  anticomplete := by
    intro a b ha_cut hb_cut ha_side hb_side
    exact R.toBoolSideSeparationRows.anticomplete
      ha_cut hb_cut ha_side hb_side

end RepeatedExteriorBoundaryArcSeparationRows

/-- No-cut wrapper for boundary-cycle incident edge completeness using the
already-erased repeated-boundary separation rows.  This is the exact
repeated-boundary data needed when the geometric bad-incident-edge source does
not first package the two sides as cyclic arc images. -/
theorem boundaryCycleIncidentFrontierEdgeCompleteness_of_badIncidentEdge_repeatedBoundarySeparationRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (badIncidentEdge_repeatedRows :
      forall k : Fin B.length, forall x : Fin n,
        ((B.vertex k, x) ∈ unboundedFrontierEdgeSet C inputs ∨
          (x, B.vertex k) ∈ unboundedFrontierEdgeSet C inputs) ->
          x ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
            x ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
              Nonempty
                (Sigma fun i : Fin B.length =>
                  Sigma fun j : Fin B.length =>
                    RepeatedExteriorBoundarySeparationRows C B.vertex i j)) :
    BoundaryCycleIncidentFrontierEdgeCompleteness inputs B := by
  intro k x hedge
  by_contra hbad
  have hnot_pred :
      x ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) := by
    intro hx
    exact hbad (Or.inl hx)
  have hnot_succ :
      x ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) := by
    intro hx
    exact hbad (Or.inr hx)
  rcases badIncidentEdge_repeatedRows k x hedge hnot_pred hnot_succ with
    ⟨packedRows⟩
  rcases packedRows with ⟨i, packedRows'⟩
  rcases packedRows' with ⟨j, rows⟩
  exact inputs.noCutVertex ⟨rows.toCutVertexPartition⟩

/-- No-cut wrapper for boundary-cycle incident edge completeness.  If every
incident unbounded-frontier edge that is not one of the two boundary-cycle
neighbours produces the standard repeated-exterior-boundary arc separation
rows, then `inputs.noCutVertex` rules out all such bad incident edges. -/
theorem boundaryCycleIncidentFrontierEdgeCompleteness_of_badIncidentEdge_arcSeparationRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (badIncidentEdge_arcRows :
      forall k : Fin B.length, forall x : Fin n,
        ((B.vertex k, x) ∈ unboundedFrontierEdgeSet C inputs ∨
          (x, B.vertex k) ∈ unboundedFrontierEdgeSet C inputs) ->
          x ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
            x ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
              Nonempty
                (Sigma fun i : Fin B.length =>
                  Sigma fun j : Fin B.length =>
                    RepeatedExteriorBoundaryArcSeparationRows C B.vertex i j)) :
    BoundaryCycleIncidentFrontierEdgeCompleteness inputs B :=
  boundaryCycleIncidentFrontierEdgeCompleteness_of_badIncidentEdge_repeatedBoundarySeparationRows
    (fun k x hedge hnot_pred hnot_succ => by
      rcases badIncidentEdge_arcRows k x hedge hnot_pred hnot_succ with
        ⟨packedRows⟩
      rcases packedRows with ⟨i, packedRows'⟩
      rcases packedRows' with ⟨j, rows⟩
      exact
        ⟨⟨i, j, rows.toRepeatedExteriorBoundarySeparationRows⟩⟩)

/-- If every repeated pair in a boundary vertex sequence supplies the concrete
cut partition rows, `NoCutVertex` forces the sequence to be vertex-injective. -/
theorem exterior_boundary_vertex_injective_of_noCutVertex
    {m : Nat} {C : _root_.UDConfig n}
    (vertex : Fin m -> Fin n)
    (hno : CutVertexInterface.NoCutVertex C)
    (hrows :
      forall {i j : Fin m},
        i ≠ j ->
        vertex i = vertex j ->
          RepeatedExteriorBoundarySeparationRows C vertex i j) :
    Function.Injective vertex := by
  intro i j hij
  by_contra hne
  exact hno
    ⟨(hrows hne hij).toCutVertexPartition⟩

/-- Raw face-successor orbit specialization of the no-cut repeat handoff:
concrete separation rows for every repeated pair of orbit tails force the raw
orbit tail map to be injective. -/
theorem rawFaceSuccOrbit_tail_injective_of_noCutVertex
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (hrows :
      forall {i j : Fin O.period},
        i ≠ j ->
        (O.dart i).tail = (O.dart j).tail ->
          RepeatedExteriorBoundarySeparationRows C
            (fun k : Fin O.period => (O.dart k).tail) i j) :
    Function.Injective fun k : Fin O.period => (O.dart k).tail :=
  exterior_boundary_vertex_injective_of_noCutVertex
    (fun k : Fin O.period => (O.dart k).tail)
    inputs.noCutVertex
    hrows

/-- Raw face-successor orbit specialization of the no-cut repeat handoff:
arc-separation rows for every repeated pair of orbit tails force the raw
orbit tail map to be injective. -/
theorem rawFaceSuccOrbit_tail_injective_of_noCutVertex_arcRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (hrows :
      forall {i j : Fin O.period},
        i ≠ j ->
        (O.dart i).tail = (O.dart j).tail ->
          RepeatedExteriorBoundaryArcSeparationRows C
            (fun k : Fin O.period => (O.dart k).tail) i j) :
    Function.Injective fun k : Fin O.period => (O.dart k).tail :=
  rawFaceSuccOrbit_tail_injective_of_noCutVertex (inputs := inputs) O
    (fun hne heq => (hrows hne heq).toRepeatedExteriorBoundarySeparationRows)

/-- No-cut repeated-tail rows give the raw predecessor/successor
nonbacktracking row as soon as the raw orbit is known to have period at least
three. -/
theorem rawFaceSuccOrbit_pred_succ_tail_ne_of_period_three_noCutVertex
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (period_ge_three : 3 <= O.period)
    (repeated_tail_rows :
      forall {i j : Fin O.period},
        i ≠ j ->
        (O.dart i).tail = (O.dart j).tail ->
          RepeatedExteriorBoundarySeparationRows C
            (fun k : Fin O.period => (O.dart k).tail) i j) :
    forall k : Fin O.period,
      (O.dart (PlanarInterface.cyclicPred O.period_pos k)).tail ≠
        (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail :=
  rawFaceSuccOrbit_pred_succ_tail_ne_of_period_three_tail_injective
    O period_ge_three
    (rawFaceSuccOrbit_tail_injective_of_noCutVertex
      (inputs := inputs) O repeated_tail_rows)

/-- A hypothetical repeated raw tail is impossible once the actual exterior
source rows produce a cut-vertex partition for that repeated pair.

This is the no-cut handoff for the selected raw orbit: the geometric/topology
work should supply the cut partition from the two exterior boundary/frontier
sides cut apart by the repeated tail; `inputs.noCutVertex` then rules out the
repeat without using any completed cycle projection. -/
theorem rawFaceSuccOrbit_tail_ne_of_noCutVertex_cutPartitions
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (repeated_tail_cutPartitions :
      forall {i j : Fin O.period},
        i ≠ j ->
        (O.dart i).tail = (O.dart j).tail ->
          Nonempty (CutVertexInterface.CutVertexPartition C)) :
    forall {i j : Fin O.period},
      i ≠ j ->
      (O.dart i).tail ≠ (O.dart j).tail := by
  intro i j hij htail
  exact inputs.noCutVertex (repeated_tail_cutPartitions hij htail)

/-- Claim `S2-agent-no-cut-repeated-tail-source-from-inputs`.

Selected raw-orbit repeated-tail source from `inputs.noCutVertex`.  If the
actual exterior boundary/frontier analysis turns any hypothetical repeated raw
tail into a concrete cut-vertex partition, then no such repeat can occur.
Consequently the repeated-tail separation callback required by the current
raw-orbit wrappers is available by contradiction.

This is intentionally only a source row for the selected raw face-successor
orbit.  It does not project a final cycle, assume cyclic carrier coverage, or
use an induced frontier graph. -/
def S2_agent_no_cut_repeated_tail_source_from_inputs
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (repeated_tail_cutPartitions :
      forall {i j : Fin O.period},
        i ≠ j ->
        (O.dart i).tail = (O.dart j).tail ->
          Nonempty (CutVertexInterface.CutVertexPartition C)) :
    forall {i j : Fin O.period},
      i ≠ j ->
      (O.dart i).tail = (O.dart j).tail ->
        RepeatedExteriorBoundarySeparationRows C
          (fun k : Fin O.period => (O.dart k).tail) i j := by
  intro i j hij htail
  exact False.elim (inputs.noCutVertex (repeated_tail_cutPartitions hij htail))

/-- Boolean-side source variant of
`S2_agent_no_cut_repeated_tail_source_from_inputs`.

This matches the finite side-separation shape used by the repeated-boundary
bookkeeping: actual exterior boundary/frontier data supplies the two sides and
their anticompleteness for a hypothetical repeated tail, and the checked
cut-partition erasure plus `inputs.noCutVertex` makes the downstream
repeated-tail row vacuous. -/
def S2_agent_no_cut_repeated_tail_source_from_boolSideRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (repeated_tail_boolRows :
      forall {i j : Fin O.period},
        i ≠ j ->
        (O.dart i).tail = (O.dart j).tail ->
          BoolSideSeparationRows C) :
    forall {i j : Fin O.period},
      i ≠ j ->
      (O.dart i).tail = (O.dart j).tail ->
        RepeatedExteriorBoundarySeparationRows C
          (fun k : Fin O.period => (O.dart k).tail) i j :=
  S2_agent_no_cut_repeated_tail_source_from_inputs (inputs := inputs) O
    (fun {i} {j} hij htail =>
      ⟨cutVertexPartitionOfBoolSideSeparationRows
        (repeated_tail_boolRows (i := i) (j := j) hij htail)⟩)

/-- Pair-level residual rows for a hypothetical repeated selected raw tail.

The fields are exactly the finite exterior-arc facts needed to fill
`RepeatedExteriorBoundaryArcSeparationRows`: non-cut witnesses on both open
arcs, coverage of every non-cut graph vertex by one of the two raw-tail arc
images, disjointness of the reverse arc away from the cut vertex, and
anticompleteness across the two sides.  The actual edge-frontier carrier rows
are kept in the orbit-level source below. -/
structure RawFaceSuccOrbitRepeatedTailActualExteriorArcRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (i j : Fin O.period) where
  left_index : Fin O.period
  left_index_mem : cyclicForwardOpenArc i j left_index
  left_index_ne_cut : (O.dart left_index).tail ≠ (O.dart i).tail
  right_index : Fin O.period
  right_index_mem : cyclicForwardOpenArc j i right_index
  right_index_ne_cut : (O.dart right_index).tail ≠ (O.dart i).tail
  cover_noncut :
    forall v : Fin n, v ≠ (O.dart i).tail ->
      repeatedBoundaryArcImage
          (fun k : Fin O.period => (O.dart k).tail) i j v ∨
        repeatedBoundaryArcImage
          (fun k : Fin O.period => (O.dart k).tail) j i v
  reverse_arc_not_forward_off_cut :
    forall {v : Fin n}, v ≠ (O.dart i).tail ->
      repeatedBoundaryArcImage
          (fun k : Fin O.period => (O.dart k).tail) j i v ->
        ¬ repeatedBoundaryArcImage
          (fun k : Fin O.period => (O.dart k).tail) i j v
  arcs_anticomplete :
    forall {a b : Fin n},
      repeatedBoundaryArcImage
          (fun k : Fin O.period => (O.dart k).tail) i j a ->
      repeatedBoundaryArcImage
          (fun k : Fin O.period => (O.dart k).tail) j i b ->
      a ≠ (O.dart i).tail ->
      b ≠ (O.dart i).tail ->
        ¬ (GraphBridge.unitDistanceSimpleGraph C).Adj a b

namespace RawFaceSuccOrbitRepeatedTailActualExteriorArcRows

variable {C : _root_.UDConfig n}
variable {inputs : FinitePlanarOuterComponentInputs C}
variable {R : UnitDistanceRotationSystem C}
variable {start : UnitDistanceDart C}
variable {O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start}
variable {i j : Fin O.period}

/-- Fill the checked repeated-boundary arc-separation row from the
pair-level actual exterior arc residual. -/
def toRepeatedExteriorBoundaryArcSeparationRows
    (rows :
      RawFaceSuccOrbitRepeatedTailActualExteriorArcRows
        (inputs := inputs) O i j)
    (hij : i ≠ j)
    (htail : (O.dart i).tail = (O.dart j).tail) :
    RepeatedExteriorBoundaryArcSeparationRows C
      (fun k : Fin O.period => (O.dart k).tail) i j where
  repeat_eq := htail
  index_ne := hij
  left_index := rows.left_index
  left_index_mem := rows.left_index_mem
  left_index_ne_cut := rows.left_index_ne_cut
  right_index := rows.right_index
  right_index_mem := rows.right_index_mem
  right_index_ne_cut := rows.right_index_ne_cut
  cover_noncut := rows.cover_noncut
  reverse_arc_not_forward_off_cut :=
    rows.reverse_arc_not_forward_off_cut
  arcs_anticomplete := rows.arcs_anticomplete

end RawFaceSuccOrbitRepeatedTailActualExteriorArcRows

/-- Orbit-level residual rows for sourcing repeated selected raw-tail arc
separation from the actual unbounded exterior frontier.

The `edge_mem` field ties the selected raw face-successor orbit to the actual
`unboundedFrontierEdgeSet` carrier.  The `repeated_tail_arcRows` callback is
only invoked under a hypothetical repeated tail and supplies the two finite
exterior frontier arcs cut apart by that tail. -/
structure RawFaceSuccOrbitActualExteriorArcSeparationRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start) where
  edge_mem :
    forall k : Fin O.period,
      ((O.dart k).tail,
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
          unboundedFrontierEdgeSet C inputs ∨
        ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
            (O.dart k).tail) ∈
          unboundedFrontierEdgeSet C inputs
  repeated_tail_arcRows :
    forall {i j : Fin O.period},
      i ≠ j ->
      (O.dart i).tail = (O.dart j).tail ->
        RawFaceSuccOrbitRepeatedTailActualExteriorArcRows
          (inputs := inputs) O i j

/-- Actual exterior-frontier arc separation rows for hypothetical repeated
tails of the selected raw face-successor orbit.

The `edge_openSegment_frontier` field keeps the source tied to the actual
unbounded exterior frontier traced by the raw orbit.  The repeated-tail field
is the finite erasure of the two exterior frontier arcs cut apart by a
hypothetical repeated tail; it is deliberately stated on the selected raw
orbit tail sequence, not on a downstream cycle projection, arbitrary cycle,
induced frontier graph, or cyclic-coverage package. -/
structure RawFaceSuccOrbitExteriorFrontierArcSeparationSourceRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start) where
  edge_openSegment_frontier :
    forall k : Fin O.period,
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (O.dart k).tail)
          ((canonicalGraph C).point
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior
  repeated_tail_arcSeparation :
    forall {i j : Fin O.period},
      i ≠ j ->
      (O.dart i).tail = (O.dart j).tail ->
        RepeatedExteriorBoundaryArcSeparationRows C
          (fun k : Fin O.period => (O.dart k).tail) i j

namespace RawFaceSuccOrbitExteriorFrontierArcSeparationSourceRows

variable {C : _root_.UDConfig n}
variable {inputs : FinitePlanarOuterComponentInputs C}
variable {R : UnitDistanceRotationSystem C}
variable {start : UnitDistanceDart C}
variable {O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start}

/-- Erase an actual exterior-frontier repeated-tail arc separation row to the
Boolean side rows used by the checked cut-partition constructor. -/
noncomputable def toBoolSideSeparationRows
    (rows :
      RawFaceSuccOrbitExteriorFrontierArcSeparationSourceRows
        (inputs := inputs) O)
    {i j : Fin O.period}
    (hij : i ≠ j)
    (htail : (O.dart i).tail = (O.dart j).tail) :
    BoolSideSeparationRows C :=
  (rows.repeated_tail_arcSeparation hij htail).toBoolSideSeparationRows

/-- Erase an actual exterior-frontier repeated-tail arc separation row to the
concrete cut-vertex partition interface. -/
noncomputable def toCutVertexPartition
    (rows :
      RawFaceSuccOrbitExteriorFrontierArcSeparationSourceRows
        (inputs := inputs) O)
    {i j : Fin O.period}
    (hij : i ≠ j)
    (htail : (O.dart i).tail = (O.dart j).tail) :
    CutVertexInterface.CutVertexPartition C :=
  cutVertexPartitionOfBoolSideSeparationRows
    (rows.toBoolSideSeparationRows hij htail)

end RawFaceSuccOrbitExteriorFrontierArcSeparationSourceRows

