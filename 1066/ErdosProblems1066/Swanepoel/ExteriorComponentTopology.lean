variable {C : _root_.UDConfig n}
variable {inputs : FinitePlanarOuterComponentInputs C}

/-- Transport repeated-boundary separation rows from a face-orbit boundary
sequence to the matching raw face-successor orbit tail sequence.

This is the row needed by
`unboundedExteriorFrontierCycleRows_of_rawFaceSuccOrbit_sourceRows`: once the
actual raw orbit has been identified with the stored exterior face-orbit
boundary, any repeated-tail pair can use the existing repeated exterior
boundary separation row for the corresponding boundary indices. -/
def rawFaceSuccOrbit_repeated_tail_rows_of_boundary_rows
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit rows.rotation start)
    (hperiod : rows.orbit.boundary.length = O.period)
    (tail_eq :
      forall k : Fin rows.orbit.boundary.length,
        (O.dart (Fin.cast hperiod k)).tail =
          rows.orbit.boundary.vertex k)
    (boundary_rows :
      forall {i j : Fin rows.orbit.boundary.length},
        i ≠ j ->
        rows.orbit.boundary.vertex i = rows.orbit.boundary.vertex j ->
          RepeatedExteriorBoundarySeparationRows C
            rows.orbit.boundary.vertex i j) :
    forall {i j : Fin O.period},
      i ≠ j ->
      (O.dart i).tail = (O.dart j).tail ->
        RepeatedExteriorBoundarySeparationRows C
          (fun k : Fin O.period => (O.dart k).tail) i j := by
  intro i j hij htail
  let i' : Fin rows.orbit.boundary.length := Fin.cast hperiod.symm i
  let j' : Fin rows.orbit.boundary.length := Fin.cast hperiod.symm j
  have hcast_i : Fin.cast hperiod i' = i := by
    ext
    simp [i']
  have hcast_j : Fin.cast hperiod j' = j := by
    ext
    simp [j']
  have htail_i :
      (O.dart i).tail = rows.orbit.boundary.vertex i' := by
    simpa [hcast_i] using tail_eq i'
  have htail_j :
      (O.dart j).tail = rows.orbit.boundary.vertex j' := by
    simpa [hcast_j] using tail_eq j'
  have hij' : i' ≠ j' := by
    intro h
    exact hij (by
      have hcast := congrArg (Fin.cast hperiod) h
      simpa [hcast_i, hcast_j] using hcast)
  have hboundary :
      rows.orbit.boundary.vertex i' =
        rows.orbit.boundary.vertex j' :=
    htail_i.symm.trans (htail.trans htail_j)
  let R := boundary_rows hij' hboundary
  refine
    { repeat_eq := htail
      index_ne := hij
      side := R.side
      left_witness := R.left_witness
      left_witness_ne_cut := ?_
      left_witness_side := R.left_witness_side
      right_witness := R.right_witness
      right_witness_ne_cut := ?_
      right_witness_side := R.right_witness_side
      anticomplete := ?_ }
  · simpa [htail_i] using R.left_witness_ne_cut
  · simpa [htail_i] using R.right_witness_ne_cut
  · intro a b ha_cut hb_cut ha_side hb_side
    exact R.anticomplete
      (by simpa [htail_i] using ha_cut)
      (by simpa [htail_i] using hb_cut)
      ha_side hb_side

