                            Metric.ball z r /\
                        z ∈ closure
                          (connectedComponentIn
                            ((unboundedExteriorComponentRows C inputs).exterior ∩
                              Metric.ball z r) y)

/-- Sharper pointwise local component-selection source for an interior
canonical edge.

Once one relative-interior point of the edge lies on the unbounded exterior
frontier, every point of that open edge is accumulated, at every local scale,
by one connected component of the exterior cut down to the corresponding ball.
This removes the auxiliary same-edge closure point `q` and the neighborhood
bookkeeping from `InteriorEdgeLocalExteriorSideComponentSource`; the remaining
content is the genuine local component-selection theorem. -/
def InteriorEdgeOpenSegmentLocalExteriorSideComponentSource
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
    e ∈ (canonicalGraph C).edgeSet ->
    PlanarInterface.InOpenSegment p
      ((canonicalGraph C).point e.1)
      ((canonicalGraph C).point e.2) ->
    p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
      forall z : PlanarInterface.Point,
        PlanarInterface.InOpenSegment z
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
          forall r : Real,
            0 < r ->
              Exists fun y : PlanarInterface.Point =>
                y ∈
                    (unboundedExteriorComponentRows C inputs).exterior ∩
                      Metric.ball z r /\
                  z ∈ closure
                    (connectedComponentIn
                      ((unboundedExteriorComponentRows C inputs).exterior ∩
                        Metric.ball z r) y)

/-- Component-form eraser for the local open-edge exterior-side source.

The geometric content is the supplied local patch `S`: it lies inside the
selected exterior component cut down by `Metric.ball z r`, is preconnected, and
accumulates at `z`.  The conclusion follows by maximality of
`connectedComponentIn`, keeping the remaining S2 work focused on constructing
the local exterior-side patch rather than on component bookkeeping. -/
theorem interiorEdgeOpenSegmentLocalExteriorSideComponentSource_of_preconnected_patch
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (patch :
      forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
        e ∈ (canonicalGraph C).edgeSet ->
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
          forall z : PlanarInterface.Point,
            PlanarInterface.InOpenSegment z
              ((canonicalGraph C).point e.1)
              ((canonicalGraph C).point e.2) ->
            forall r : Real,
              0 < r ->
                Exists fun S : Set PlanarInterface.Point =>
                  Exists fun y : PlanarInterface.Point =>
                    IsPreconnected S ∧
                      y ∈ S ∧
                        S ⊆
                          (unboundedExteriorComponentRows C inputs).exterior ∩
                            Metric.ball z r ∧
                          z ∈ closure S) :
    InteriorEdgeOpenSegmentLocalExteriorSideComponentSource C inputs := by
  intro e p he hpEdge hpFrontier z hzEdge r hr
  rcases patch he hpEdge hpFrontier z hzEdge r hr with
    ⟨S, y, hSpre, hyS, hSsubset, hzClosure⟩
  refine ⟨y, hSsubset hyS, ?_⟩
  exact
    closure_mono
      (hSpre.subset_connectedComponentIn hyS hSsubset)
      hzClosure

/-- Drawing-complement version of
`interiorEdgeOpenSegmentLocalExteriorSideComponentSource_of_preconnected_patch`.

This is the form needed by the honest local side proof.  It is enough to
construct a preconnected same-side patch inside the local drawing complement
and ball, with one point already in the chosen unbounded exterior component;
component propagation then upgrades the whole patch to the selected exterior. -/
theorem interiorEdgeOpenSegmentLocalExteriorSideComponentSource_of_preconnected_drawingComplement_patch
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (patch :
      forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
        e ∈ (canonicalGraph C).edgeSet ->
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
          forall z : PlanarInterface.Point,
            PlanarInterface.InOpenSegment z
              ((canonicalGraph C).point e.1)
              ((canonicalGraph C).point e.2) ->
            forall r : Real,
              0 < r ->
                Exists fun S : Set PlanarInterface.Point =>
                  Exists fun y : PlanarInterface.Point =>
                    IsPreconnected S ∧
                      y ∈ S ∧
                        y ∈ (unboundedExteriorComponentRows C inputs).exterior ∧
                          S ⊆ drawingComplement C ∧
                            S ⊆ Metric.ball z r ∧
                              z ∈ closure S) :
    InteriorEdgeOpenSegmentLocalExteriorSideComponentSource C inputs := by
  apply
    interiorEdgeOpenSegmentLocalExteriorSideComponentSource_of_preconnected_patch
  intro e p he hpEdge hpFrontier z hzEdge r hr
  rcases patch he hpEdge hpFrontier z hzEdge r hr with
    ⟨S, y, hSpre, hyS, hyExterior, hSdraw, hSball, hzClosure⟩
  refine ⟨S, y, hSpre, hyS, ?_, hzClosure⟩
  exact
    preconnected_subset_unboundedExterior_inter_ball_of_subset_drawingComplement_inter_ball_of_mem
      (C := C) (inputs := inputs)
      hSpre hSdraw hSball hyS hyExterior

/-- The all-scale pointwise component-selection row supplies the accumulated
connected-component source used by the nearby-exterior-points reducer. -/
theorem interiorEdgeLocalExteriorSideComponentSource_of_openSegment_component_source
    {C : _root_.UDConfig n}
