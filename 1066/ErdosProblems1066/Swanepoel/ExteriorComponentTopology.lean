  ⟨rows.boundary,
    rows.frontier_iff_cycle_vertex,
    rows.cycle_edge_openSegment_frontier⟩

/-- Face-orbit specialization of
`S2_agent_actual_boundary_cycle_frontier_equivalence`. -/
theorem S2_agent_actual_boundary_cycle_frontier_equivalence_of_faceDartOrbit
    (rows : FaceDartOrbitExteriorCarrierRows C inputs) :
