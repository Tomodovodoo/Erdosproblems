/-- Seed-edge orientation form of
`S2_agent_actual_boundary_cycle_frontier_equivalence_of_faceDartOrbit_rawFaceSuccOrbitStartRows`.

The raw start identification is derived from the sharper selected-seed row:
the chosen local frontier edge starts at the first honest face-orbit boundary
vertex and points to its cyclic successor. -/
theorem S2_agent_actual_boundary_cycle_frontier_equivalence_of_faceDartOrbit_rawFaceSuccOrbitSeedEdgeRows
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    {e : PlanarInterface.Edge n}
    {p : PlanarInterface.Point}
    {start : UnitDistanceDart C}
    (edgeRows : UnboundedExteriorFrontierEdgeLocalRows C inputs e p)
    (htail : start.tail = e.1)
    (hhead : start.head = e.2)
    (hseed :
      e.1 =
          rows.orbit.boundary.vertex
            ⟨0, rows.orbit.boundary.length_pos⟩ ∧
        e.2 =
          rows.orbit.boundary.vertex
            (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos
              ⟨0, rows.orbit.boundary.length_pos⟩))
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit rows.rotation start) :
    Exists fun B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C =>
      (forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin B.length => B.vertex k = v) ∧
        (forall k : Fin B.length,
          forall p : PlanarInterface.Point,
            PlanarInterface.InOpenSegment p
              ((canonicalGraph C).point (B.vertex k))
              ((canonicalGraph C).point
                (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
            p ∈ frontier
              (unboundedExteriorComponentRows C inputs).exterior) := by
  exact
    S2_agent_actual_boundary_cycle_frontier_equivalence_of_faceDartOrbit_rawFaceSuccOrbitStartRows
      rows O
      (rows.raw_start_eq_orbit_zero_of_edgeLocalRows_orbit_zero_succ
        edgeRows htail hhead hseed)

/-- Seed-edge orientation form of the actual boundary edge-membership source. -/
theorem S2_agent_actual_boundary_edge_mem_source_of_faceDartOrbit_rawFaceSuccOrbitSeedEdgeRows
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    {e : PlanarInterface.Edge n}
    {p : PlanarInterface.Point}
    {start : UnitDistanceDart C}
    (edgeRows : UnboundedExteriorFrontierEdgeLocalRows C inputs e p)
    (htail : start.tail = e.1)
    (hhead : start.head = e.2)
    (hseed :
      e.1 =
          rows.orbit.boundary.vertex
            ⟨0, rows.orbit.boundary.length_pos⟩ ∧
        e.2 =
          rows.orbit.boundary.vertex
            (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos
              ⟨0, rows.orbit.boundary.length_pos⟩))
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit rows.rotation start) :
    BoundaryCycleEdgeMemSource C inputs :=
  S2_agent_actual_boundary_edge_mem_source_of_faceDartOrbit_rawFaceSuccOrbitStartRows
    rows O
    (rows.raw_start_eq_orbit_zero_of_edgeLocalRows_orbit_zero_succ
      edgeRows htail hhead hseed)

end ActualBoundaryCycleFrontierEquivalenceRows

/-- Claim `S2-agent-actual-boundary-cycle-frontier-equivalence`.

Top-level reducer exposing the exact minimal honest output rows for the
actual unbounded exterior boundary-cycle source: a concrete cycle boundary,
frontier-vertex equivalence, and consecutive open-segment frontier. -/
theorem S2_agent_actual_boundary_cycle_frontier_equivalence
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (rows : ActualBoundaryCycleFrontierEquivalenceRows C inputs) :
    Exists fun B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C =>
      (forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin B.length => B.vertex k = v) ∧
        (forall k : Fin B.length,
          forall p : PlanarInterface.Point,
            PlanarInterface.InOpenSegment p
              ((canonicalGraph C).point (B.vertex k))
              ((canonicalGraph C).point
                (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
          p ∈ frontier
              (unboundedExteriorComponentRows C inputs).exterior) :=
  rows.S2_agent_actual_boundary_cycle_frontier_equivalence

/-- Claim `S2-agent-explicit-B-raw-boundary-route`.

Same-boundary raw face-successor handoff.  When the selected raw orbit has
already been identified with a concrete cycle boundary `B`, this exposes the
two S2 consumer rows for that same `B`: graph-vertex frontier exactness and
actual unbounded-frontier membership of each consecutive boundary side. -/
theorem S2_agent_explicit_B_raw_boundary_route
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
    (hperiod : B.length = O.period)
    (tail_eq : forall k : Fin B.length,
      (O.dart (Fin.cast hperiod k)).tail = B.vertex k)
    (frontier_iff_tail :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin O.period => (O.dart k).tail = v)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    (forall v : Fin n,
      (canonicalGraph C).point v ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ↔
        Exists fun k : Fin B.length => B.vertex k = v) ∧
      (forall k : Fin B.length,
        (B.vertex k,
            B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
            unboundedFrontierEdgeSet C inputs ∨
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
            B.vertex k) ∈
            unboundedFrontierEdgeSet C inputs) := by
  let rows : ActualBoundaryCycleFrontierEquivalenceRows C inputs :=
    ActualBoundaryCycleFrontierEquivalenceRows.ofRawFaceSuccOrbitBoundaryRows
      O B hperiod tail_eq frontier_iff_tail edge_openSegment_frontier
  exact
    ⟨rows.frontier_iff_cycle_vertex,
      fun k => rows.cycle_edge_mem_unboundedFrontierEdgeSet_or_symm k⟩

/-! ### Honest exterior carrier row -/

/-- A proof-owning carrier for the real exterior boundary graph.

This is stronger than the current reducer needs: besides connectedness,
two-regularity, and the exact frontier-vertex image, it records that every
carrier edge is an actual open edge segment on the unbounded exterior frontier.
That honesty row prevents replacing the boundary carrier by an arbitrary
two-regular chord cycle through the same frontier vertices. -/
structure ExteriorFrontierCarrierRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) where
  V : Type u
  instFintype : Fintype V
  F : SimpleGraph V
  instDecidableAdj : DecidableRel F.Adj
  phi : SimpleGraph.Hom F (GraphBridge.unitDistanceSimpleGraph C)
  phi_injective : Function.Injective phi
  connected : F.Connected
  degree_two :
    forall v : V,
      @SimpleGraph.degree V F v (F.neighborSetFintype v) = 2
  vertex_image_iff_frontier :
    forall v : Fin n,
      (canonicalGraph C).point v ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ↔
        Exists fun x : V => phi x = v
  edge_openSegment_frontier :
    forall {x y : V},
      F.Adj x y ->
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (phi x))
            ((canonicalGraph C).point (phi y)) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior

/-! ### Raw face-successor orbit to honest carrier rows -/

theorem rawFaceSuccOrbit_faceSucc_eq_cyclicSucc
    {C : _root_.UDConfig n}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (k : Fin O.period) :
    R.faceSucc (O.dart k) =
      O.dart (PlanarInterface.cyclicSucc O.period_pos k) := by
  have hstep :
      R.faceSucc ((R.faceSuccPerm ^ k.val) start) =
        (R.faceSuccPerm ^ (k.val + 1)) start := by
    change
      R.faceSuccPerm ((R.faceSuccPerm ^ k.val) start) =
        (R.faceSuccPerm ^ (k.val + 1)) start
    rw [show k.val + 1 = Nat.succ k.val by omega]
    rw [pow_succ', Equiv.Perm.mul_apply]
  rw [O.dart_eq_iterate k]
  calc
    R.faceSucc ((R.faceSuccPerm ^ k.val) start) =
        (R.faceSuccPerm ^ (k.val + 1)) start := hstep
    _ = O.dart (PlanarInterface.cyclicSucc O.period_pos k) := by
      by_cases hnext : k.val + 1 < O.period
      · rw [O.dart_eq_iterate
          (PlanarInterface.cyclicSucc O.period_pos k)]
        simp [PlanarInterface.cyclicSucc, Nat.mod_eq_of_lt hnext]
      · have hlast : k.val + 1 = O.period :=
          eq_of_le_of_not_lt (Nat.succ_le_of_lt k.isLt) hnext
        rw [O.dart_eq_iterate
          (PlanarInterface.cyclicSucc O.period_pos k)]
        calc
          (R.faceSuccPerm ^ (k.val + 1)) start =
              (R.faceSuccPerm ^ O.period) start := by rw [hlast]
          _ = start := O.period_return
          _ = (R.faceSuccPerm ^
                (PlanarInterface.cyclicSucc O.period_pos k).val) start := by
            simp [PlanarInterface.cyclicSucc, hlast]

theorem rawFaceSuccOrbit_tail_adj_cyclicSucc
    {C : _root_.UDConfig n}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (k : Fin O.period) :
    (GraphBridge.unitDistanceSimpleGraph C).Adj
      (O.dart k).tail
      (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail := by
  have hsucc := rawFaceSuccOrbit_faceSucc_eq_cyclicSucc O k
  have hhead :
      (O.dart k).head =
        (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail :=
    R.endpoint_chaining_of_faceSucc_eq_next hsucc
  simpa [hhead] using (O.dart k).adj

namespace RawFaceSuccOrbitExplicitBoundary

private def ofChain {V : Type u} {G : SimpleGraph V} :
    (l : List V) -> (hne : l ≠ []) -> l.IsChain G.Adj ->
      G.Walk (l.head hne) (l.getLast hne)
  | [], hne, _ => False.elim (hne rfl)
  | [_x], _hne, _hchain => SimpleGraph.Walk.nil
  | x :: y :: xs, _hne, hchain => by
      have hxy : G.Adj x y := (List.isChain_cons_cons.mp hchain).1
      have htail : (y :: xs).IsChain G.Adj :=
        (List.isChain_cons_cons.mp hchain).2
      exact
        SimpleGraph.Walk.cons hxy
          (ofChain (y :: xs) (List.cons_ne_nil y xs) htail)

@[simp]
private theorem ofChain_support {V : Type u} {G : SimpleGraph V} :
    forall (l : List V) (hne : l ≠ []) (hchain : l.IsChain G.Adj),
      (ofChain l hne hchain).support = l
  | [], hne, _ => False.elim (hne rfl)
  | [_x], _hne, _hchain => rfl
  | x :: y :: xs, _hne, hchain => by
      have htail : (y :: xs).IsChain G.Adj :=
        (List.isChain_cons_cons.mp hchain).2
      change
        x :: (ofChain (y :: xs) (List.cons_ne_nil y xs) htail).support =
          x :: y :: xs
      rw [ofChain_support (y :: xs) (List.cons_ne_nil y xs) htail]

private def rotatedTailList
    {C : _root_.UDConfig n}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start) :
    List (Fin n) :=
  List.ofFn fun k : Fin O.period =>
    (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail

private theorem rotatedTailList_ne_nil
    {C : _root_.UDConfig n}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start) :
    rotatedTailList O ≠ [] := by
  simp [rotatedTailList, Nat.ne_of_gt O.period_pos]

private theorem rotatedTailList_head
    {C : _root_.UDConfig n}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start) :
    (rotatedTailList O).head (rotatedTailList_ne_nil O) =
      (O.dart
        (PlanarInterface.cyclicSucc O.period_pos
          ⟨0, O.period_pos⟩)).tail := by
  change
    (List.ofFn fun k : Fin O.period =>
      (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail).head
        (rotatedTailList_ne_nil O) =
      (O.dart
        (PlanarInterface.cyclicSucc O.period_pos
          ⟨0, O.period_pos⟩)).tail
  rw [List.head_ofFn]

private theorem cyclicSucc_pred_eq_zero
    {m : Nat} (hm : 0 < m) :
    PlanarInterface.cyclicSucc hm
        (⟨m - 1, Nat.sub_one_lt (Nat.ne_of_gt hm)⟩ : Fin m) =
      (⟨0, hm⟩ : Fin m) := by
  ext
  have hpred : m - 1 + 1 = m :=
    Nat.sub_add_cancel (Nat.succ_le_of_lt hm)
  simp [PlanarInterface.cyclicSucc, hpred]

private theorem rotatedTailList_getLast
    {C : _root_.UDConfig n}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start) :
    (rotatedTailList O).getLast (rotatedTailList_ne_nil O) =
      (O.dart ⟨0, O.period_pos⟩).tail := by
  change
    (List.ofFn fun k : Fin O.period =>
      (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail).getLast
        (rotatedTailList_ne_nil O) =
      (O.dart ⟨0, O.period_pos⟩).tail
  rw [List.getLast_ofFn]
  simp [cyclicSucc_pred_eq_zero O.period_pos]

private theorem rotatedTailList_chain
    {C : _root_.UDConfig n}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start) :
    (rotatedTailList O).IsChain
      (GraphBridge.unitDistanceSimpleGraph C).Adj := by
  rw [rotatedTailList, List.isChain_ofFn]
  intro i hi
  let k : Fin O.period := ⟨i, Nat.lt_of_succ_lt hi⟩
  let ksucc : Fin O.period := ⟨i + 1, hi⟩
  have hsucc :
      PlanarInterface.cyclicSucc O.period_pos k = ksucc := by
    ext
    simp [PlanarInterface.cyclicSucc, k, ksucc, Nat.mod_eq_of_lt hi]
  simpa [k, ksucc, hsucc] using
    rawFaceSuccOrbit_tail_adj_cyclicSucc O
      (PlanarInterface.cyclicSucc O.period_pos k)

private theorem rotatedTailList_nodup
    {C : _root_.UDConfig n}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (tail_injective :
      Function.Injective fun k : Fin O.period => (O.dart k).tail) :
    (rotatedTailList O).Nodup := by
  dsimp [rotatedTailList]
  exact
    List.nodup_ofFn_ofInjective
      (tail_injective.comp
        (PlanarInterface.cyclicSucc_injective O.period_pos))

end RawFaceSuccOrbitExplicitBoundary

/-- Claim `S2-worker-raw-orbit-explicit-boundary-constructor`.

Tail-injective raw face-successor orbits of period at least three give an
honest `UnitDistanceCycleBoundary` in the raw cyclic order.  The constructed
boundary has exactly the raw period length, and its displayed vertex at each
index is the tail of the corresponding raw dart. -/
theorem exists_unitDistanceCycleBoundary_of_rawFaceSuccOrbit_tail_injective
    {C : _root_.UDConfig n} {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (period_ge_three : 3 <= O.period)
    (tail_injective :
      Function.Injective fun k : Fin O.period => (O.dart k).tail) :
    Exists fun B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C =>
      Exists fun hperiod : B.length = O.period =>
        forall k : Fin B.length,
          (O.dart (Fin.cast hperiod k)).tail = B.vertex k := by
  let G := GraphBridge.unitDistanceSimpleGraph C
  let base : Fin n := (O.dart ⟨0, O.period_pos⟩).tail
  let L : List (Fin n) :=
    RawFaceSuccOrbitExplicitBoundary.rotatedTailList O
  have hLne : L ≠ [] := by
    simpa [L] using
      RawFaceSuccOrbitExplicitBoundary.rotatedTailList_ne_nil O
  have hchain : L.IsChain G.Adj := by
    simpa [G, L] using
      RawFaceSuccOrbitExplicitBoundary.rotatedTailList_chain O
  let tailWalk0 :=
    RawFaceSuccOrbitExplicitBoundary.ofChain L hLne hchain
  have htailWalk0_support : tailWalk0.support = L := by
    dsimp only [tailWalk0]
    exact
      RawFaceSuccOrbitExplicitBoundary.ofChain_support L hLne hchain
  have htailStart :
      L.head hLne =
        (O.dart
          (PlanarInterface.cyclicSucc O.period_pos
            ⟨0, O.period_pos⟩)).tail := by
    simpa [L] using
      RawFaceSuccOrbitExplicitBoundary.rotatedTailList_head O
  have htailEnd :
      L.getLast hLne = base := by
    simpa [L, base] using
      RawFaceSuccOrbitExplicitBoundary.rotatedTailList_getLast O
  let tailWalk := tailWalk0.copy htailStart htailEnd
  have htailWalk_support : tailWalk.support = L := by
    dsimp only [tailWalk]
    rw [SimpleGraph.Walk.support_copy]
    exact htailWalk0_support
  have htailWalk_path : tailWalk.IsPath := by
    rw [SimpleGraph.Walk.isPath_def]
    rw [htailWalk_support]
    simpa [L] using
      RawFaceSuccOrbitExplicitBoundary.rotatedTailList_nodup O
        tail_injective
  have hfirst :
      G.Adj base
        (O.dart
          (PlanarInterface.cyclicSucc O.period_pos
            ⟨0, O.period_pos⟩)).tail := by
    simpa [G, base] using
      rawFaceSuccOrbit_tail_adj_cyclicSucc O ⟨0, O.period_pos⟩
  let walk : G.Walk base base :=
    SimpleGraph.Walk.cons hfirst tailWalk
  have hwalk_tail_path : walk.tail.IsPath := by
    dsimp only [walk]
    rw [SimpleGraph.Walk.tail_cons, SimpleGraph.Walk.isPath_copy]
    exact htailWalk_path
  have htail_length : tailWalk.length + 1 = O.period := by
    have hsupp_len : tailWalk.support.length = tailWalk.length + 1 :=
      tailWalk.length_support
    rw [htailWalk_support] at hsupp_len
    have hLlength : L.length = O.period := by
      simp [L, RawFaceSuccOrbitExplicitBoundary.rotatedTailList]
    rw [hLlength] at hsupp_len
    exact hsupp_len.symm
  have hwalk_length : walk.length = O.period := by
    dsimp only [walk]
    rw [SimpleGraph.Walk.length_cons]
    exact htail_length
  have hcycle : walk.IsCycle := by
    rw [SimpleGraph.Walk.isCycle_iff_isPath_tail_and_le_length]
    exact ⟨hwalk_tail_path, by rw [hwalk_length]; exact period_ge_three⟩
  have hwalk_get_tail :
      forall j : Fin O.period, walk.getVert j.val = (O.dart j).tail := by
    intro j
    by_cases hj0 : j.val = 0
    · have hj_eq : j = ⟨0, O.period_pos⟩ := Fin.ext hj0
      simp [walk, base, hj_eq]
    · obtain ⟨i, hi_eq⟩ := Nat.exists_eq_succ_of_ne_zero hj0
      have hi_period : i + 1 < O.period := by
        simpa [hi_eq] using j.isLt
      let ki : Fin O.period := ⟨i, Nat.lt_of_succ_lt hi_period⟩
      have hsucc :
          PlanarInterface.cyclicSucc O.period_pos ki = j := by
        ext
        simp [PlanarInterface.cyclicSucc, ki, hi_eq,
          Nat.mod_eq_of_lt hi_period]
      have hi_le_tail : i <= tailWalk.length := by
        omega
      have htail_get :
          tailWalk.getVert i =
            (O.dart
              (PlanarInterface.cyclicSucc O.period_pos ki)).tail := by
        simpa [htailWalk_support, L,
          RawFaceSuccOrbitExplicitBoundary.rotatedTailList, ki] using
          tailWalk.getVert_eq_support_getElem hi_le_tail
      calc
        walk.getVert j.val = walk.getVert (i + 1) := by rw [hi_eq]
        _ = tailWalk.getVert i := rfl
        _ =
            (O.dart
              (PlanarInterface.cyclicSucc O.period_pos ki)).tail := htail_get
        _ = (O.dart j).tail := by rw [hsucc]
  let B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C := {
    base := base
    walk := walk
    isCycle := hcycle
  }
  have hperiod : B.length = O.period := by
    simpa [B, JordanBoundaryConcrete.UnitDistanceCycleBoundary.length] using
      hwalk_length
  refine ⟨B, hperiod, ?_⟩
  intro k
  let j : Fin O.period := Fin.cast hperiod k
  have hget := hwalk_get_tail j
  simpa [B, j, JordanBoundaryConcrete.UnitDistanceCycleBoundary.vertex] using
    hget.symm

/-- Same-boundary face-successor rows from a raw face-successor orbit.

When a raw orbit has already been identified with a concrete boundary cycle by
period and tail equality, the orbit's face-successor recurrence supplies
`UnitDistanceCycleFaceSuccRows` for that same explicit `B`. -/
theorem rawFaceSuccOrbit_unitDistanceCycleFaceSuccRows_of_tail_eq
    {C : _root_.UDConfig n}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
    (hperiod : B.length = O.period)
    (tail_eq : forall k : Fin B.length,
      (O.dart (Fin.cast hperiod k)).tail = B.vertex k) :
    UnitDistanceCycleFaceSuccRows C R B := by
  refine { faceSucc_eq_next := ?_ }
  have hdart_eq_ofBoundary :
      forall j : Fin B.length,
        O.dart (Fin.cast hperiod j) = UnitDistanceDart.ofBoundary B j := by
    intro j
    let oj : Fin O.period := Fin.cast hperiod j
    apply UnitDistanceDart.ext_endpoints
    · simpa [oj] using tail_eq j
    · have hsucc := rawFaceSuccOrbit_faceSucc_eq_cyclicSucc O oj
      have hhead :
          (O.dart oj).head =
            (O.dart (PlanarInterface.cyclicSucc O.period_pos oj)).tail :=
        R.endpoint_chaining_of_faceSucc_eq_next hsucc
      have hcast_succ :
          PlanarInterface.cyclicSucc O.period_pos oj =
            Fin.cast hperiod (PlanarInterface.cyclicSucc B.length_pos j) := by
        ext
        simp [oj, PlanarInterface.cyclicSucc, hperiod]
      calc
        (O.dart (Fin.cast hperiod j)).head = (O.dart oj).head := rfl
        _ = (O.dart (PlanarInterface.cyclicSucc O.period_pos oj)).tail := hhead
        _ =
            (O.dart
              (Fin.cast hperiod
                (PlanarInterface.cyclicSucc B.length_pos j))).tail := by
              rw [hcast_succ]
        _ = B.vertex (PlanarInterface.cyclicSucc B.length_pos j) :=
              tail_eq (PlanarInterface.cyclicSucc B.length_pos j)
  intro k
  let ok : Fin O.period := Fin.cast hperiod k
  have hsucc := rawFaceSuccOrbit_faceSucc_eq_cyclicSucc O ok
  have hcast_succ :
      PlanarInterface.cyclicSucc O.period_pos ok =
        Fin.cast hperiod (PlanarInterface.cyclicSucc B.length_pos k) := by
    ext
    simp [ok, PlanarInterface.cyclicSucc, hperiod]
  calc
    R.faceSucc (UnitDistanceDart.ofBoundary B k) =
        R.faceSucc (O.dart ok) := by
          rw [hdart_eq_ofBoundary k]
    _ = O.dart (PlanarInterface.cyclicSucc O.period_pos ok) := hsucc
    _ =
        O.dart
          (Fin.cast hperiod
            (PlanarInterface.cyclicSucc B.length_pos k)) := by
          rw [hcast_succ]
    _ =
        UnitDistanceDart.ofBoundary B
          (PlanarInterface.cyclicSucc B.length_pos k) :=
          hdart_eq_ofBoundary (PlanarInterface.cyclicSucc B.length_pos k)

/-- In the geometric rotation system, a face-successor step cannot immediately
reverse across a vertex that has another unit-distance outgoing direction.
The proof uses only the concrete sorted outgoing-dart list: its `formPerm`
successor has no fixed point once the list has at least two distinct entries. -/
theorem geometricUnitDistanceRotationSystem_faceSucc_head_ne_tail_of_exists_other_neighbor
    {C : _root_.UDConfig n}
    (d : UnitDistanceDart C)
    {x : Fin n}
    (hx : (GraphBridge.unitDistanceSimpleGraph C).Adj d.head x)
    (hx_ne : x ≠ d.tail) :
    ((_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
        C).faceSucc d).head ≠ d.tail := by
  classical
  let R :=
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
      C
  let L :=
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricOutgoingDartList
      C d.head
  let reverseOutgoing : OutgoingUnitDistanceDart C d.head :=
    ⟨d.reverse, by simp⟩
  let otherDart : UnitDistanceDart C :=
    { tail := d.head
      head := x
      adj := hx }
  let otherOutgoing : OutgoingUnitDistanceDart C d.head :=
    ⟨otherDart, rfl⟩
  have hreverse_mem : reverseOutgoing ∈ L := by
    exact
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.mem_geometricOutgoingDartList
        C d.head reverseOutgoing
  have hother_mem : otherOutgoing ∈ L := by
    exact
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.mem_geometricOutgoingDartList
        C d.head otherOutgoing
  have hother_ne : otherOutgoing ≠ reverseOutgoing := by
    intro h
    have hhead : x = d.tail := by
      have hhead' :=
        congrArg (fun od : OutgoingUnitDistanceDart C d.head => od.1.head) h
      simpa [otherOutgoing, otherDart, reverseOutgoing] using hhead'
    exact hx_ne hhead
  have hlen : 2 <= L.length := by
    rcases List.mem_iff_getElem.1 hreverse_mem with ⟨i, hi, hgeti⟩
    rcases List.mem_iff_getElem.1 hother_mem with ⟨j, hj, hgetj⟩
    have hij : i ≠ j := by
      intro hij
      have hfin : (⟨i, hi⟩ : Fin L.length) = ⟨j, hj⟩ := Fin.ext hij
      have hsame : L[i]'hi = L[j]'hj :=
        congrArg (fun t : Fin L.length => L.get t) hfin
      exact hother_ne (hgetj.symm.trans (hsame.symm.trans hgeti))
    omega
  have hnext_ne :
      L.formPerm reverseOutgoing ≠ reverseOutgoing := by
    exact
      (List.formPerm_apply_mem_ne_self_iff
        L
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricOutgoingDartList_nodup
          C d.head)
        reverseOutgoing hreverse_mem).2 hlen
  have hrotation_next_ne :
      (R.rotationAt d.head).next reverseOutgoing ≠ reverseOutgoing := by
    simpa [R, L,
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem_rotationAt,
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricVertexCyclicOrder]
      using hnext_ne
  intro hhead
  have hnext_eq : (R.rotationAt d.head).next reverseOutgoing = reverseOutgoing := by
    have hreverse_outgoing : d.reverse.outgoing = reverseOutgoing := by
      apply Subtype.ext
      rfl
    have hnext_head_raw :
        ((R.rotationAt d.reverse.tail).next d.reverse.outgoing).1.head =
          d.tail := by
      simpa [R, UnitDistanceRotationSystem.faceSucc,
        UnitDistanceRotationSystem.nextAround] using hhead
    have hnext_head :
        ((R.rotationAt d.head).next reverseOutgoing).1.head = d.tail := by
      simpa [hreverse_outgoing] using hnext_head_raw
    apply Subtype.ext
    apply UnitDistanceDart.ext_endpoints
    · exact ((R.rotationAt d.head).next reverseOutgoing).2.trans
        reverseOutgoing.2.symm
    · simpa [reverseOutgoing] using hnext_head
  exact hrotation_next_ne hnext_eq

/-- A raw face-successor orbit cannot have period one: a fixed face-successor
dart would have equal tail and head.  Ruling out the remaining two-dart bridge
case needs a separate geometric/exterior-boundary input. -/
theorem rawFaceSuccOrbit_period_two_le
    {C : _root_.UDConfig n}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start) :
    2 <= O.period := by
  by_contra hlt
  have hperiod_lt_two : O.period < 2 := Nat.lt_of_not_ge hlt
  have hperiod_pos : 0 < O.period := O.period_pos
  have hperiod_eq_one : O.period = 1 :=
    Nat.le_antisymm (Nat.lt_succ_iff.1 hperiod_lt_two)
      (Nat.succ_le_of_lt hperiod_pos)
  let k0 : Fin O.period := ⟨0, O.period_pos⟩
  have hsucc_index :
      PlanarInterface.cyclicSucc O.period_pos k0 = k0 := by
    apply Fin.ext
    simp [PlanarInterface.cyclicSucc, hperiod_eq_one, k0]
  have hfixed :
      R.faceSucc (O.dart k0) = O.dart k0 := by
    calc
      R.faceSucc (O.dart k0) =
          O.dart (PlanarInterface.cyclicSucc O.period_pos k0) :=
        rawFaceSuccOrbit_faceSucc_eq_cyclicSucc O k0
      _ = O.dart k0 := by rw [hsucc_index]
  have htail_head : (O.dart k0).tail = (O.dart k0).head := by
    have htail :
        (R.faceSucc (O.dart k0)).tail = (O.dart k0).tail :=
      congrArg UnitDistanceDart.tail hfixed
    have hhead :
        (R.faceSucc (O.dart k0)).tail = (O.dart k0).head :=
      R.faceSucc_tail_eq_head (O.dart k0)
    exact htail.symm.trans hhead
  exact (UnitDistanceDart.tail_ne_head (O.dart k0)) htail_head

/-- Actual local exterior-sector rows rule out the two-dart raw face-orbit
case.  If `O.period = 2`, the frontier equivalence says every selected
frontier carrier vertex is one of the two raw tails.  At the first tail, a
local-sector row supplies two distinct incident frontier neighbours, but both
neighbours must be the other raw tail, contradiction. -/
theorem rawFaceSuccOrbit_period_three_le_of_frontier_iff_tail_localSectorRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (frontier_iff_tail :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin O.period => (O.dart k).tail = v)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    3 <= O.period := by
  by_contra hnot_three
  have hperiod_two_le : 2 <= O.period :=
    rawFaceSuccOrbit_period_two_le O
  have hperiod_lt_three : O.period < 3 := Nat.lt_of_not_ge hnot_three
  have hperiod_eq_two : O.period = 2 := by omega
  let k0 : Fin O.period := ⟨0, O.period_pos⟩
  have hfront0 :
      (canonicalGraph C).point (O.dart k0).tail ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior :=
    (frontier_iff_tail (O.dart k0).tail).2 ⟨k0, rfl⟩
  let a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨(O.dart k0).tail, mem_unboundedFrontierVertexSet_iff.2 hfront0⟩
  let rows := localSectorRows a
  have hcarrier_loopless :
      ¬ (unboundedFrontierCarrierGraph C inputs).Adj a a := by
    intro hloop
    rcases (unboundedFrontierCarrierGraph_adj_iff).1 hloop with h | h
    · have hordered : a.1 < a.1 :=
        (canonicalGraph C).edge_mem_ordered
          (mem_unboundedFrontierEdgeSet_iff.1 h).1
      exact (lt_irrefl a.1) hordered
    · have hordered : a.1 < a.1 :=
        (canonicalGraph C).edge_mem_ordered
          (mem_unboundedFrontierEdgeSet_iff.1 h).1
      exact (lt_irrefl a.1) hordered
  have hfin_two_unique_nonzero :
      forall {i j : Fin O.period}, i ≠ k0 -> j ≠ k0 -> i = j := by
    intro i j hi hj
    apply Fin.ext
    have hi_ne_zero : i.val ≠ 0 := by
      intro hval
      exact hi (Fin.ext hval)
    have hj_ne_zero : j.val ≠ 0 := by
      intro hval
      exact hj (Fin.ext hval)
    have hi_lt_two : i.val < 2 := by
      simpa [hperiod_eq_two] using i.isLt
    have hj_lt_two : j.val < 2 := by
      simpa [hperiod_eq_two] using j.isLt
    omega
  have hleft_ne_a : rows.leftVertex ≠ a := by
    intro hleft_eq
    have hloop :
        (unboundedFrontierCarrierGraph C inputs).Adj a a := by
      simpa [rows, hleft_eq] using rows.left_adj
    exact hcarrier_loopless hloop
  have hright_ne_a : rows.rightVertex ≠ a := by
    intro hright_eq
    have hloop :
        (unboundedFrontierCarrierGraph C inputs).Adj a a := by
      simpa [rows, hright_eq] using rows.right_adj
    exact hcarrier_loopless hloop
  have hleft_ne_tail0 : rows.left ≠ (O.dart k0).tail := by
    intro hleft
    exact hleft_ne_a (Subtype.ext hleft)
  have hright_ne_tail0 : rows.right ≠ (O.dart k0).tail := by
    intro hright
    exact hright_ne_a (Subtype.ext hright)
  have hleft_frontier :
      (canonicalGraph C).point rows.left ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior :=
    mem_unboundedFrontierVertexSet_iff.1 rows.left_mem
  have hright_frontier :
      (canonicalGraph C).point rows.right ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior :=
    mem_unboundedFrontierVertexSet_iff.1 rows.right_mem
  rcases (frontier_iff_tail rows.left).1 hleft_frontier with
    ⟨kleft, hkleft_tail⟩
  rcases (frontier_iff_tail rows.right).1 hright_frontier with
    ⟨kright, hkright_tail⟩
  have hkleft_ne : kleft ≠ k0 := by
    intro hkleft
    exact hleft_ne_tail0 (by simpa [hkleft] using hkleft_tail.symm)
  have hkright_ne : kright ≠ k0 := by
    intro hkright
    exact hright_ne_tail0 (by simpa [hkright] using hkright_tail.symm)
  have hkleft_eq_kright : kleft = kright :=
    hfin_two_unique_nonzero hkleft_ne hkright_ne
  exact rows.heads_ne (by
    calc
      rows.left = (O.dart kleft).tail := hkleft_tail.symm
      _ = (O.dart kright).tail := by rw [hkleft_eq_kright]
      _ = rows.right := hkright_tail)

/-- Raw face-successor orbit version of the edge-local frontier propagation
row.  This is the exact row shape consumed by
`unboundedExteriorFrontierCycleRows_of_rawFaceSuccOrbit`: for each consecutive
raw orbit edge, one interior frontier point plus local nearby exterior points
forces the whole open segment to lie on the unbounded exterior frontier. -/
theorem rawFaceSuccOrbit_edge_openSegment_frontier_of_inOpenSegment_frontier_and_nearby_edge_point_exterior_points
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (edge_frontier_point :
      forall k : Fin O.period,
        Exists fun p : PlanarInterface.Point =>
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) /\
            p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (hnear :
      forall k : Fin O.period,
        forall q : PlanarInterface.Point,
          PlanarInterface.InOpenSegment q
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
            Exists fun r : Real =>
              0 < r /\
                forall z : PlanarInterface.Point,
                  z ∈ Metric.ball q r ->
                  PlanarInterface.InOpenSegment z
                    ((canonicalGraph C).point (O.dart k).tail)
                    ((canonicalGraph C).point
                      (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
                  forall eps : Real,
                    0 < eps ->
                      Exists fun y : PlanarInterface.Point =>
                        y ∈ (unboundedExteriorComponentRows C inputs).exterior /\
                          dist y z < eps) :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  intro k q hq
  let next : Fin O.period := PlanarInterface.cyclicSucc O.period_pos k
  rcases edge_frontier_point k with ⟨p, hpEdge, hpFrontier⟩
  have hsucc := rawFaceSuccOrbit_faceSucc_eq_cyclicSucc O k
  have hhead : (O.dart k).head = (O.dart next).tail := by
    simpa [next] using R.endpoint_chaining_of_faceSucc_eq_next hsucc
  have hadj :
      (canonicalGraph C).Adj (O.dart k).tail (O.dart next).tail := by
    simpa [next, hhead] using (O.dart k).canonicalAdj
  rcases hadj with he | he
  · have hnear_forward :
        forall q : PlanarInterface.Point,
          PlanarInterface.InOpenSegment q
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point (O.dart next).tail) ->
          q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
            Exists fun r : Real =>
              0 < r /\
                forall z : PlanarInterface.Point,
                  z ∈ Metric.ball q r ->
                  PlanarInterface.InOpenSegment z
                    ((canonicalGraph C).point (O.dart k).tail)
                    ((canonicalGraph C).point (O.dart next).tail) ->
                  forall eps : Real,
                    0 < eps ->
                      Exists fun y : PlanarInterface.Point =>
                        y ∈ (unboundedExteriorComponentRows C inputs).exterior /\
                          dist y z < eps := by
      simpa [next] using hnear k
    exact
      edge_openSegment_frontier_of_inOpenSegment_frontier_and_relative_ball_closure
        (C := C) (inputs := inputs)
        (e := ((O.dart k).tail, (O.dart next).tail))
        he (by simpa [next] using hpEdge) hpFrontier
        (relative_ball_closure_of_forall_nearby_edge_point_exterior_points
          (C := C) (inputs := inputs)
          (e := ((O.dart k).tail, (O.dart next).tail))
          hnear_forward)
        q (by simpa [next] using hq)
  · have hnear_rev :
        forall q : PlanarInterface.Point,
          PlanarInterface.InOpenSegment q
            ((canonicalGraph C).point (O.dart next).tail)
            ((canonicalGraph C).point (O.dart k).tail) ->
          q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
            Exists fun r : Real =>
              0 < r /\
                forall z : PlanarInterface.Point,
                  z ∈ Metric.ball q r ->
                  PlanarInterface.InOpenSegment z
                    ((canonicalGraph C).point (O.dart next).tail)
                    ((canonicalGraph C).point (O.dart k).tail) ->
                  forall eps : Real,
                    0 < eps ->
                      Exists fun y : PlanarInterface.Point =>
                        y ∈ (unboundedExteriorComponentRows C inputs).exterior /\
                          dist y z < eps := by
      intro x hx hxclosure
      rcases hnear k x (by simpa [next] using inOpenSegment_symm hx)
          hxclosure with
        ⟨r, hrpos, hr⟩
      refine ⟨r, hrpos, ?_⟩
      intro z hzball hzseg eps heps
      exact hr z hzball
        (by simpa [next] using inOpenSegment_symm hzseg) eps heps
    exact
      edge_openSegment_frontier_of_inOpenSegment_frontier_and_relative_ball_closure
        (C := C) (inputs := inputs)
        (e := ((O.dart next).tail, (O.dart k).tail))
        he (by simpa [next] using inOpenSegment_symm hpEdge) hpFrontier
        (relative_ball_closure_of_forall_nearby_edge_point_exterior_points
          (C := C) (inputs := inputs)
          (e := ((O.dart next).tail, (O.dart k).tail))
          hnear_rev)
        q (by simpa [next] using inOpenSegment_symm hq)

/-- A raw dart-edge frontier row supplies the two explicit local inputs used by
`unboundedExteriorFrontierCycleRows_of_rawFaceSuccOrbit_sourceRows`.

The raw face-successor endpoint row identifies the edge of `O.dart k` with the
consecutive-tail edge from `O.dart k` to the cyclic successor dart.  A midpoint
then gives the required frontier point, while frontier membership gives
arbitrarily close exterior points by the metric closure criterion. -/
theorem rawFaceSuccOrbit_source_inputs_of_dart_edge_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (dart_edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point (O.dart k).head) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    (forall k : Fin O.period,
      Exists fun p : PlanarInterface.Point =>
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (O.dart k).tail)
          ((canonicalGraph C).point
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) /\
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) /\
      (forall k : Fin O.period,
        forall q : PlanarInterface.Point,
          PlanarInterface.InOpenSegment q
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
            Exists fun r : Real =>
              0 < r /\
                forall z : PlanarInterface.Point,
                  z ∈ Metric.ball q r ->
                  PlanarInterface.InOpenSegment z
                    ((canonicalGraph C).point (O.dart k).tail)
                    ((canonicalGraph C).point
                      (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
                  forall eps : Real,
                    0 < eps ->
                      Exists fun y : PlanarInterface.Point =>
                        y ∈ (unboundedExteriorComponentRows C inputs).exterior /\
                          dist y z < eps) := by
  constructor
  · intro k
    let next : Fin O.period := PlanarInterface.cyclicSucc O.period_pos k
    have hsucc := rawFaceSuccOrbit_faceSucc_eq_cyclicSucc O k
    have hhead : (O.dart k).head = (O.dart next).tail :=
      R.endpoint_chaining_of_faceSucc_eq_next hsucc
    let p : PlanarInterface.Point :=
      PlanarInterface.segmentPoint
        ((canonicalGraph C).point (O.dart k).tail)
        ((canonicalGraph C).point (O.dart k).head) (1 / 2 : Real)
    have hp_dart :
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (O.dart k).tail)
          ((canonicalGraph C).point (O.dart k).head) := by
      simpa [p] using
        midpoint_inOpenSegment
          ((canonicalGraph C).point (O.dart k).tail)
          ((canonicalGraph C).point (O.dart k).head)
    have hp_next :
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (O.dart k).tail)
          ((canonicalGraph C).point
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) := by
      simpa [next, hhead] using hp_dart
    exact ⟨p, hp_next, dart_edge_openSegment_frontier k p hp_dart⟩
  · intro k q hq _hqclosure
    refine ⟨1, by norm_num, ?_⟩
    intro z _hzball hzedge eps heps
    let next : Fin O.period := PlanarInterface.cyclicSucc O.period_pos k
    have hsucc := rawFaceSuccOrbit_faceSucc_eq_cyclicSucc O k
    have hhead : (O.dart k).head = (O.dart next).tail :=
      R.endpoint_chaining_of_faceSucc_eq_next hsucc
    have hz_dart :
        PlanarInterface.InOpenSegment z
          ((canonicalGraph C).point (O.dart k).tail)
          ((canonicalGraph C).point (O.dart k).head) := by
      simpa [next, hhead] using hzedge
    have hzfrontier :
        z ∈ frontier (unboundedExteriorComponentRows C inputs).exterior :=
      dart_edge_openSegment_frontier k z hz_dart
    have hzclosure :
        z ∈ closure (unboundedExteriorComponentRows C inputs).exterior :=
      frontier_subset_closure hzfrontier
    rw [Metric.mem_closure_iff] at hzclosure
    rcases hzclosure eps heps with ⟨y, hyExterior, hydist⟩
    exact ⟨y, hyExterior, by simpa [dist_comm] using hydist⟩

/-- A dart-edge frontier row gives whole consecutive-edge frontier for the
same raw orbit, after rewriting the face-successor head as the cyclic
successor tail. -/
theorem rawFaceSuccOrbit_edge_openSegment_frontier_of_dart_edge_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (dart_edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point (O.dart k).head) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    forall k : Fin O.period,
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (O.dart k).tail)
          ((canonicalGraph C).point
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  intro k p hp
  let next : Fin O.period := PlanarInterface.cyclicSucc O.period_pos k
  have hsucc := rawFaceSuccOrbit_faceSucc_eq_cyclicSucc O k
  have hhead : (O.dart k).head = (O.dart next).tail :=
    R.endpoint_chaining_of_faceSucc_eq_next hsucc
  exact dart_edge_openSegment_frontier k p (by simpa [next, hhead] using hp)

/-- Raw face-successor orbit wrapper for the genuine nearby-exterior-points
source row.  If each consecutive raw orbit edge is already known to be a
selected unbounded-frontier edge, in either ordered orientation, then the
nearby-exterior-points input follows without using the separate
`edge_frontier_point` row. -/
theorem rawFaceSuccOrbit_nearby_edge_point_exterior_points_of_unboundedFrontierEdgeSet_edges
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (hedges :
      forall k : Fin O.period,
        ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
            unboundedFrontierEdgeSet C inputs ∨
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
              (O.dart k).tail) ∈
            unboundedFrontierEdgeSet C inputs) :
    forall k : Fin O.period,
      forall q : PlanarInterface.Point,
        PlanarInterface.InOpenSegment q
          ((canonicalGraph C).point (O.dart k).tail)
          ((canonicalGraph C).point
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
        q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun r : Real =>
            0 < r /\
              forall z : PlanarInterface.Point,
                z ∈ Metric.ball q r ->
                PlanarInterface.InOpenSegment z
                  ((canonicalGraph C).point (O.dart k).tail)
                  ((canonicalGraph C).point
                    (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
                forall eps : Real,
                  0 < eps ->
                    Exists fun y : PlanarInterface.Point =>
                      y ∈ (unboundedExteriorComponentRows C inputs).exterior /\
                        dist y z < eps := by
  intro k q hq hqclosure
  let next : Fin O.period := PlanarInterface.cyclicSucc O.period_pos k
  rcases hedges k with hforward | hreverse
  · have hq' :
        PlanarInterface.InOpenSegment q
          ((canonicalGraph C).point (O.dart k).tail)
          ((canonicalGraph C).point (O.dart next).tail) := by
      simpa [next] using hq
    exact
      unboundedFrontierEdgeSet_nearby_edge_point_exterior_points
        (C := C) (inputs := inputs)
        (e := ((O.dart k).tail, (O.dart next).tail))
        hforward q hq' hqclosure
  · rcases
      unboundedFrontierEdgeSet_nearby_edge_point_exterior_points
        (C := C) (inputs := inputs)
        (e := ((O.dart next).tail, (O.dart k).tail))
        hreverse q (by simpa [next] using inOpenSegment_symm hq)
        hqclosure with
    ⟨r, hrpos, hnear⟩
    refine ⟨r, hrpos, ?_⟩
    intro z hzball hzseg eps heps
    exact hnear z hzball
      (by simpa [next] using inOpenSegment_symm hzseg) eps heps

/-- Raw face-successor orbit wrapper for the interior-frontier-point source
row.  If each consecutive raw orbit edge is a selected unbounded-frontier
edge in either ordered orientation, the midpoint gives the required point. -/
theorem rawFaceSuccOrbit_edge_frontier_point_of_unboundedFrontierEdgeSet_edges
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (hedges :
      forall k : Fin O.period,
        ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
            unboundedFrontierEdgeSet C inputs ∨
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
              (O.dart k).tail) ∈
            unboundedFrontierEdgeSet C inputs) :
    forall k : Fin O.period,
      Exists fun p : PlanarInterface.Point =>
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (O.dart k).tail)
          ((canonicalGraph C).point
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) /\
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  intro k
  let next : Fin O.period := PlanarInterface.cyclicSucc O.period_pos k
  rcases hedges k with hforward | hreverse
  · rcases
      unboundedFrontierEdgeSet_has_frontier_interior_point
        (C := C) (inputs := inputs)
        (e := ((O.dart k).tail, (O.dart next).tail)) hforward with
      ⟨p, hpfrontier, hpseg⟩
    have hpseg' :
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (O.dart k).tail)
          ((canonicalGraph C).point
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) := by
      simpa [next] using hpseg
    exact ⟨p, hpseg', hpfrontier⟩
  · rcases
      unboundedFrontierEdgeSet_has_frontier_interior_point
        (C := C) (inputs := inputs)
        (e := ((O.dart next).tail, (O.dart k).tail)) hreverse with
      ⟨p, hpfrontier, hpseg⟩
    have hpseg' :
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (O.dart k).tail)
          ((canonicalGraph C).point
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) := by
      simpa [next] using inOpenSegment_symm hpseg
    exact ⟨p, hpseg', hpfrontier⟩

/-- Consecutive raw-orbit tail edges that have already been selected in the
actual unbounded-frontier edge carrier give the whole-open-segment frontier
row for the same raw orbit. -/
theorem rawFaceSuccOrbit_edge_openSegment_frontier_of_unboundedFrontierEdgeSet_edges
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (hedges :
      forall k : Fin O.period,
        ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
            unboundedFrontierEdgeSet C inputs ∨
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
              (O.dart k).tail) ∈
            unboundedFrontierEdgeSet C inputs) :
    forall k : Fin O.period,
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (O.dart k).tail)
          ((canonicalGraph C).point
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  intro k p hp
  let next : Fin O.period := PlanarInterface.cyclicSucc O.period_pos k
  rcases hedges k with hforward | hreverse
  · exact (mem_unboundedFrontierEdgeSet_iff.1 hforward).2 p
      (by simpa [next] using hp)
  · exact (mem_unboundedFrontierEdgeSet_iff.1 hreverse).2 p
      (by simpa [next] using inOpenSegment_symm hp)

/-- Consecutive raw face-successor tails whose whole open segment lies on the
unbounded exterior frontier determine a concrete frontier-carrier edge, in one
of the two ordered orientations. -/
theorem rawFaceSuccOrbit_edge_mem_unboundedFrontierEdgeSet_or_symm
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (k : Fin O.period) :
    ((O.dart k).tail,
        (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
        unboundedFrontierEdgeSet C inputs ∨
      ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
        (O.dart k).tail) ∈ unboundedFrontierEdgeSet C inputs := by
  have hadj :
      (canonicalGraph C).Adj
        (O.dart k).tail
        (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail := by
    exact
      ((canonicalGraph C).adj_iff_unitDistanceAdj
        (O.dart k).tail
        (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail).2
        ((GraphBridge.unitDistanceSimpleGraph_adj C
          (O.dart k).tail
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail).1
          (rawFaceSuccOrbit_tail_adj_cyclicSucc O k))
  exact
    unboundedFrontierEdgeSet_or_symm_of_adj_openSegment_frontier
      (C := C) (inputs := inputs) hadj (edge_openSegment_frontier k)

/-- Consecutive raw orbit tails form actual selected unbounded-frontier edges
