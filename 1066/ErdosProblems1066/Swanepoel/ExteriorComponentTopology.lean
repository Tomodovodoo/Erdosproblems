        (UnboundedFrontierCarrierCyclicCoverageRows C inputs ×
          (forall a :
            {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
              UnboundedFrontierCarrierLocalSectorRowsAt inputs a))) :
    UnboundedExteriorFrontierCycleRows C inputs := by
  letI : DecidableRel (unboundedFrontierCarrierGraph C inputs).Adj :=
    unboundedFrontierCarrierGraph_decidableAdj C inputs
  let data := Classical.choice rows
  exact
    unboundedExteriorFrontierCycleRows_of_frontierCarrierGraph_whole
      inputs
      (unboundedFrontierCarrierGraph_connected_of_cyclicCoverageRows data.1)
      (unboundedFrontierCarrierGraph_degree_two_of_dartPairRows
        inputs
        (unboundedFrontierCarrierDartPairRows_of_localSectorRows
          inputs data.2))
      unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition

/-- Direct S2 handoff from the strongest boundary-cycle carrier package to the
unbounded exterior frontier-cycle rows.  The source theorem still has to
construct the package; this definition only applies the existing cyclic
coverage/local-sector reducer. -/
noncomputable def unboundedExteriorFrontierCycleRows_of_exists_boundaryCycle_complete
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (exists_unboundedFrontierCarrierBoundaryCycle :
      Exists fun B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C =>
        (forall v : Fin n,
          (canonicalGraph C).point v ∈
              frontier (unboundedExteriorComponentRows C inputs).exterior ↔
            Exists fun k : Fin B.length => B.vertex k = v) ∧
        (forall k : Fin B.length,
          (B.vertex k,
              B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
              unboundedFrontierEdgeSet C inputs ∨
            (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
              B.vertex k) ∈
              unboundedFrontierEdgeSet C inputs) ∧
        BoundaryCycleIncidentFrontierEdgeCompleteness inputs B) :
    UnboundedExteriorFrontierCycleRows C inputs :=
  unboundedExteriorFrontierCycleRows_of_pointwise_cyclicCoverageLocalSectorRows
    inputs
    (cyclicCoverageLocalSectorRows_of_exists_boundaryCycle_complete
      exists_unboundedFrontierCarrierBoundaryCycle)

/-- An orbit-first exterior face-dart package with frontier and local
incidence rows erases to the compact concrete-carrier rows needed for the
unbounded exterior frontier cycle theorem. -/
noncomputable def unboundedExteriorFrontierCycleRows_of_faceDartOrbitExteriorCarrierRows
    (rows :
      forall {n : Nat} (C : _root_.UDConfig n)
        (inputs : FinitePlanarOuterComponentInputs C),
          FaceDartOrbitExteriorCarrierRows C inputs) :
    forall {n : Nat} (C : _root_.UDConfig n),
      (inputs : FinitePlanarOuterComponentInputs C) ->
        UnboundedExteriorFrontierCycleRows C inputs :=
  unboundedExteriorFrontierCycleRows_of_cyclicCoverageDartPairRows
    (fun C inputs => (rows C inputs).toCyclicCoverageRows)
    (fun C inputs => (rows C inputs).toDartPairRows)

/-- Erase an honest exterior-boundary carrier to the current cycle-row target.
The `edge_openSegment_frontier` field is deliberately consumed from the
supplied `ExteriorFrontierCarrierRows`; the older cycle-row target records only
the vertex cycle, but the handoff must still be sourced by an honest boundary
carrier rather than by manufacturing a replacement edge row. -/
noncomputable def unboundedExteriorFrontierCycleRows_of_carrier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (K : ExteriorFrontierCarrierRows C inputs) :
    UnboundedExteriorFrontierCycleRows C inputs := by
  classical
  letI : Fintype K.V := K.instFintype
  letI : DecidableRel K.F.Adj := K.instDecidableAdj
  let honestEdgeOpenSegmentFrontier :
      forall {x y : K.V},
        K.F.Adj x y ->
          forall p : PlanarInterface.Point,
            PlanarInterface.InOpenSegment p
              ((canonicalGraph C).point (K.phi x))
              ((canonicalGraph C).point (K.phi y)) ->
            p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior :=
    K.edge_openSegment_frontier
  let _honestCarrierRow :
      forall {x y : K.V},
        K.F.Adj x y ->
          forall p : PlanarInterface.Point,
            PlanarInterface.InOpenSegment p
              ((canonicalGraph C).point (K.phi x))
              ((canonicalGraph C).point (K.phi y)) ->
            p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior :=
    fun {x y} hxy => honestEdgeOpenSegmentFrontier hxy
  exact
    unboundedExteriorFrontierCycleRows_of_connected_two_regular_frontier_graph
      inputs K.F K.connected K.degree_two K.phi K.phi_injective
      K.vertex_image_iff_frontier

/-- Family form of the honest-carrier reducer.  This is the intended next S2
handoff: prove the carrier rows from `FinitePlanarOuterComponentInputs`, then
the existing W32 route can consume the resulting unbounded exterior cycle rows. -/
noncomputable def unboundedExteriorFrontierCycleRows_of_carrierRows
    (rows :
      forall {n : Nat} (C : _root_.UDConfig n),
        (inputs : FinitePlanarOuterComponentInputs C) ->
          Nonempty (ExteriorFrontierCarrierRows C inputs)) :
  forall {n : Nat} (C : _root_.UDConfig n),
      (inputs : FinitePlanarOuterComponentInputs C) ->
        UnboundedExteriorFrontierCycleRows C inputs := by
  intro n C inputs
  exact unboundedExteriorFrontierCycleRows_of_carrier
    (Classical.choice (rows C inputs))

/-- Raw face-successor orbit source for the unbounded exterior frontier cycle.

This is the narrow source handoff from an actual face-successor orbit: the raw
orbit supplies the honest carrier via
`exteriorFrontierCarrierRows_of_rawFaceSuccOrbit`, and the existing carrier
reducer then constructs the concrete `UnitDistanceCycleBoundary` whose vertices
are exactly the graph vertices on the unbounded exterior frontier. -/
noncomputable def unboundedExteriorFrontierCycleRows_of_rawFaceSuccOrbit
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (period_ge_three : 3 <= O.period)
    (tail_injective :
      Function.Injective fun k : Fin O.period => (O.dart k).tail)
    (frontier_iff_tail :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin O.period => (O.dart k).tail = v)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    UnboundedExteriorFrontierCycleRows C inputs :=
  unboundedExteriorFrontierCycleRows_of_carrier
    (exteriorFrontierCarrierRows_of_rawFaceSuccOrbit
      O period_ge_three tail_injective frontier_iff_tail
      edge_openSegment_frontier)

/-- Bundle the checked raw-orbit handoffs into the final unbounded exterior
frontier-cycle row.

The assumptions are deliberately the honest source rows: a concrete raw
face-successor orbit, the explicit period lower bound, repeated-pair rows that
the no-cut handoff turns into tail injectivity, a face-orbit carrier package
identified with the raw tail sequence, and the whole-open-segment frontier row
for each consecutive raw edge. -/
noncomputable def unboundedExteriorFrontierCycleRows_of_checkedRawFaceSuccOrbitHandoffs
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {start : UnitDistanceDart C}
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit rows.rotation start)
    (period_ge_three : 3 <= O.period)
    (repeated_tail_rows :
      forall {i j : Fin O.period},
        i ≠ j ->
        (O.dart i).tail = (O.dart j).tail ->
          RepeatedExteriorBoundarySeparationRows C
            (fun k : Fin O.period => (O.dart k).tail) i j)
    (hperiod : rows.orbit.boundary.length = O.period)
    (tail_eq :
      forall k : Fin rows.orbit.boundary.length,
        (O.dart (Fin.cast hperiod k)).tail =
          rows.orbit.boundary.vertex k)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    UnboundedExteriorFrontierCycleRows C inputs :=
  unboundedExteriorFrontierCycleRows_of_rawFaceSuccOrbit
    O period_ge_three
    (rawFaceSuccOrbit_tail_injective_of_noCutVertex
      (inputs := inputs) O repeated_tail_rows)
    (rows.frontier_iff_rawFaceSuccOrbit_tail O hperiod tail_eq)
    edge_openSegment_frontier

/-- Raw-orbit source assembled from the current geometric/topological handoff
rows.

This combines the checked local edge propagation, connected closed-carrier
coverage, period lower bound, and no-cut tail-injectivity reducers.  The
remaining source work is exactly the geometric production of these explicit
inputs for the raw orbit selected from the unbounded exterior component. -/
noncomputable def unboundedExteriorFrontierCycleRows_of_rawFaceSuccOrbit_sourceRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (edge_frontier_point :
      forall k : Fin O.period,
        Exists fun p : PlanarInterface.Point =>
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) /\
            p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (nearby_edge_point_exterior_points :
      forall k : Fin O.period,
        forall q : PlanarInterface.Point,
          PlanarInterface.InOpenSegment q
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
            Exists fun r : Real =>
              0 < r /\
                forall z : PlanarInterface.Point,
                  z ∈ Metric.ball q r ->
                  PlanarInterface.InOpenSegment z
                    ((canonicalGraph C).point (O.dart k).tail)
                    ((canonicalGraph C).point
                      (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
                  forall eps : Real,
                    0 < eps ->
                      Exists fun y : PlanarInterface.Point =>
                        y ∈ (unboundedExteriorComponentRows C inputs).exterior /\
                          dist y z < eps)
    (connectedRows : UnboundedFrontierCarrierCyclicCoverageRows C inputs)
    (raw_pred_succ_tail_ne :
      forall k : Fin O.period,
        (O.dart (PlanarInterface.cyclicPred O.period_pos k)).tail ≠
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (repeated_tail_rows :
      forall {i j : Fin O.period},
        i ≠ j ->
        (O.dart i).tail = (O.dart j).tail ->
          RepeatedExteriorBoundarySeparationRows C
            (fun k : Fin O.period => (O.dart k).tail) i j) :
    UnboundedExteriorFrontierCycleRows C inputs := by
  let edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior :=
    rawFaceSuccOrbit_edge_openSegment_frontier_of_inOpenSegment_frontier_and_nearby_edge_point_exterior_points
      O edge_frontier_point nearby_edge_point_exterior_points
  let frontier_vertex_tail_coverage :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        Exists fun k : Fin O.period => (O.dart k).tail = a.1 :=
    rawFaceSuccOrbit_frontier_vertex_tail_coverage_of_connected_closed_carrier
      O edge_openSegment_frontier connectedRows
      (rawFaceSuccOrbit_neighbor_tail_closed_of_localSectorRows
        O edge_openSegment_frontier localSectorRows raw_pred_succ_tail_ne)
  let frontier_iff_tail :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
