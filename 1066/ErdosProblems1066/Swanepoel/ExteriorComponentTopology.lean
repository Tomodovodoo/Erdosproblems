      q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
      q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
      (canonicalGraph C).Adj (B.vertex k) other ->
      q ∈ vertexIncidentGermW3 C (B.vertex k) other eps ->
