/-- Face-orbit exterior carrier rows erase to the local dart-pair rows for the
existing concrete carrier degree-two reducer. -/
noncomputable def toDartPairAt
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    (a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) :
    UnboundedFrontierCarrierDartPairAt inputs a := by
  classical
  have hfrontier :
      (canonicalGraph C).point a.1 ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior :=
    mem_unboundedFrontierVertexSet_iff.1 a.2
  let k : Fin rows.orbit.boundary.length :=
    Classical.choose ((rows.frontier_iff_orbit_vertex a.1).1 hfrontier)
  have hk : rows.orbit.boundary.vertex k = a.1 :=
    Classical.choose_spec ((rows.frontier_iff_orbit_vertex a.1).1 hfrontier)
  let pred := PlanarInterface.cyclicPred rows.orbit.boundary.length_pos k
  let succ := PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k
  have hsucc_pred :
      PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos pred = k := by
    dsimp [pred]
    exact PlanarInterface.cyclicSucc_cyclicPred
      rows.orbit.boundary.length_pos k
  have hleft_edge :
      (a.1, rows.orbit.boundary.vertex pred) ∈
          unboundedFrontierEdgeSet C inputs ∨
        (rows.orbit.boundary.vertex pred, a.1) ∈
          unboundedFrontierEdgeSet C inputs := by
    have hedge :
        (rows.orbit.boundary.vertex pred, rows.orbit.boundary.vertex k) ∈
            unboundedFrontierEdgeSet C inputs ∨
          (rows.orbit.boundary.vertex k, rows.orbit.boundary.vertex pred) ∈
            unboundedFrontierEdgeSet C inputs := by
      simpa [pred, hsucc_pred] using
        rows.orbit_edge_mem_unboundedFrontierEdgeSet pred
    rcases hedge with hedge | hedge
    · right
      simpa [hk] using hedge
    · left
      simpa [hk] using hedge
  have hright_edge :
      (a.1, rows.orbit.boundary.vertex succ) ∈
          unboundedFrontierEdgeSet C inputs ∨
        (rows.orbit.boundary.vertex succ, a.1) ∈
          unboundedFrontierEdgeSet C inputs := by
    have hedge :
        (rows.orbit.boundary.vertex k, rows.orbit.boundary.vertex succ) ∈
            unboundedFrontierEdgeSet C inputs ∨
          (rows.orbit.boundary.vertex succ, rows.orbit.boundary.vertex k) ∈
            unboundedFrontierEdgeSet C inputs := by
      simpa [succ] using rows.orbit_edge_mem_unboundedFrontierEdgeSet k
    rcases hedge with hedge | hedge
    · left
      simpa [hk] using hedge
    · right
      simpa [hk] using hedge
  have hpred_ne_succ :
      rows.orbit.boundary.vertex pred ≠ rows.orbit.boundary.vertex succ := by
    intro h
    have hidx : pred = succ := rows.orbit.boundary.simple h
    exact
      (PlanarInterface.cyclicPred_ne_cyclicSucc_of_three_le
        rows.orbit.boundary.length_pos rows.orbit.boundary.length_ge_three k)
        (by simpa [pred, succ] using hidx)
  refine
    unboundedFrontierCarrierDartPairAt_of_incident_unboundedFrontierEdges
      (a := a)
      (l := rows.orbit.boundary.vertex pred)
      (r := rows.orbit.boundary.vertex succ)
      hleft_edge hright_edge hpred_ne_succ ?_
  intro b hab
  have honly :=
    rows.incident_only_pred_succ k a b hk.symm hab
  simpa [pred, succ] using honly

