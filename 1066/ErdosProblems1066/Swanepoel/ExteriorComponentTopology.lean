    (succ_edge :
      (B.vertex k, B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
          unboundedFrontierEdgeSet C inputs ∨
        (B.vertex (PlanarInterface.cyclicSucc B.length_pos k), B.vertex k) ∈
          unboundedFrontierEdgeSet C inputs)
    (local_exterior_sector :
      forall (eps : Real) (q : PlanarInterface.Point) (x : Fin n),
        q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
          q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
            (canonicalGraph C).Adj (B.vertex k) x ->
              q ∈ vertexIncidentGermW3 C (B.vertex k) x eps ->
                q ≠ (canonicalGraph C).point (B.vertex k) ->
                x ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
                  x ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
                    BoundaryPredSuccPointAngularBetween C B k q)
    (no_between :
      forall x : Fin n,
        GraphBridge.UnitDistanceAdj C (B.vertex k) x ->
          x ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
            x ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
              ¬
                _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
                  C B k x) :
    UnboundedFrontierCarrierLocalSectorRowsAt inputs a :=
  unboundedFrontierCarrierLocalSectorRowsAt_of_boundary_vertex_local_frontier_germ_two
    ha pred_edge succ_edge
    (exists_local_frontier_germ_two_of_vertex_star_isolation_local_exterior_sector
      (C := C) (inputs := inputs) (B := B) k local_exterior_sector no_between)

namespace UnboundedFrontierCarrierLocalSectorRowsAt

variable {C : _root_.UDConfig n}
variable {inputs : FinitePlanarOuterComponentInputs C}
variable {a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}

theorem left_mem (rows : UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    rows.left ∈ unboundedFrontierVertexSet C inputs := by
  let hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
    unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
  rcases rows.left_edge with h | h
  · exact
      (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
        hwhole h).2
  · exact
      (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
        hwhole h).1

theorem right_mem (rows : UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    rows.right ∈ unboundedFrontierVertexSet C inputs := by
  let hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
    unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
  rcases rows.right_edge with h | h
  · exact
      (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
        hwhole h).2
  · exact
      (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
        hwhole h).1

def leftVertex (rows : UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
  ⟨rows.left, rows.left_mem⟩

def rightVertex (rows : UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
  ⟨rows.right, rows.right_mem⟩

theorem left_adj (rows : UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    (unboundedFrontierCarrierGraph C inputs).Adj a rows.leftVertex := by
  rcases rows.left_edge with h | h
  · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge h
  · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm h

theorem right_adj (rows : UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    (unboundedFrontierCarrierGraph C inputs).Adj a rows.rightVertex := by
  rcases rows.right_edge with h | h
  · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge h
  · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm h

/-- A local-sector row supplies a unit-distance neighbour different from any
prescribed incident direction: one of its two distinct selected carrier
neighbours must be different. -/
theorem exists_unit_neighbor_ne
    (rows : UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (x : Fin n) :
    Exists fun y : Fin n =>
      (GraphBridge.unitDistanceSimpleGraph C).Adj a.1 y ∧ y ≠ x := by
  have hleft_canonical : (canonicalGraph C).Adj a.1 rows.left := by
    simpa [leftVertex] using
      unboundedFrontierCarrierGraph_adj_canonicalAdj rows.left_adj
  have hright_canonical : (canonicalGraph C).Adj a.1 rows.right := by
    simpa [rightVertex] using
      unboundedFrontierCarrierGraph_adj_canonicalAdj rows.right_adj
  have hleft :
      (GraphBridge.unitDistanceSimpleGraph C).Adj a.1 rows.left :=
    (GraphBridge.unitDistanceSimpleGraph_adj C a.1 rows.left).2
      (((canonicalGraph C).adj_iff_unitDistanceAdj a.1 rows.left).1
        hleft_canonical)
  have hright :
      (GraphBridge.unitDistanceSimpleGraph C).Adj a.1 rows.right :=
    (GraphBridge.unitDistanceSimpleGraph_adj C a.1 rows.right).2
      (((canonicalGraph C).adj_iff_unitDistanceAdj a.1 rows.right).1
        hright_canonical)
  by_cases hleft_eq : rows.left = x
  · refine ⟨rows.right, hright, ?_⟩
    intro hright_eq
    exact rows.heads_ne (hleft_eq.trans hright_eq.symm)
  · exact ⟨rows.left, hleft, hleft_eq⟩

/-- The two carrier vertices selected by a local sector row are distinct. -/
theorem leftVertex_ne_rightVertex
    (rows : UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    rows.leftVertex ≠ rows.rightVertex := by
  intro h
  exact rows.heads_ne (congrArg Subtype.val h)

/-- The local-sector row identifies the full neighbour set at the selected
frontier vertex. -/
theorem neighbor_iff
    (rows : UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) :
    (unboundedFrontierCarrierGraph C inputs).Adj a b ↔
      b = rows.leftVertex ∨ b = rows.rightVertex := by
  constructor
  · intro hb
    rcases rows.only b hb with hb | hb
    · exact Or.inl (Subtype.ext hb)
    · exact Or.inr (Subtype.ext hb)
  · intro hb
    rcases hb with hb | hb
    · subst b
      exact rows.left_adj
    · subst b
      exact rows.right_adj

/-- Local-sector rows erase directly to the finite neighbour-pair row used by
the degree-two reducer. -/
def toNeighborPairAt
    (rows : UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    UnboundedFrontierCarrierNeighborPairAt inputs a where
  left := rows.leftVertex
  right := rows.rightVertex
  left_ne_right := rows.leftVertex_ne_rightVertex
  neighbor_iff := rows.neighbor_iff

/-- The two endpoints selected by a local sector row lie in the same connected
component of the concrete unbounded-frontier carrier. -/
theorem left_right_reachable
    (rows : UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    (unboundedFrontierCarrierGraph C inputs).Reachable
      rows.leftVertex rows.rightVertex := by
  exact (rows.left_adj.symm.reachable).trans rows.right_adj.reachable

/-- Connected-component form of `left_right_reachable`. -/
theorem left_connectedComponent_eq_right
    (rows : UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    (unboundedFrontierCarrierGraph C inputs).connectedComponentMk
        rows.leftVertex =
      (unboundedFrontierCarrierGraph C inputs).connectedComponentMk
        rows.rightVertex :=
  SimpleGraph.ConnectedComponent.sound rows.left_right_reachable

end UnboundedFrontierCarrierLocalSectorRowsAt

/-- A local-sector row gives a concrete selected frontier edge whose closed
segment contains the centre frontier vertex.  This is the endpoint case needed
for the full exterior-frontier edge-cover row. -/
theorem frontier_vertex_edge_cover_of_localSectorRowsAt
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (rows : UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    Exists fun e : PlanarInterface.Edge n =>
      e ∈ unboundedFrontierEdgeSet C inputs ∧
        (canonicalGraph C).point a.1 ∈
          closedSegment
            ((canonicalGraph C).point e.1)
            ((canonicalGraph C).point e.2) := by
  rcases rows.left_edge with hleft | hleft
  · refine ⟨(a.1, rows.left), hleft, ?_⟩
    exact left_mem_closedSegment _ _
  · refine ⟨(rows.left, a.1), hleft, ?_⟩
    exact right_mem_closedSegment _ _

/-- A concrete selected carrier edge incident to a graph-frontier vertex gives
the endpoint case of the exterior-frontier edge-cover row.  This is the small
carrier-only step used when a covered frontier point is exactly a graph
vertex, rather than an interior point of an edge. -/
theorem frontier_vertex_edge_cover_of_incident_unboundedFrontierEdgeSet
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {v w : Fin n}
    (hEdge :
      (v, w) ∈ unboundedFrontierEdgeSet C inputs ∨
        (w, v) ∈ unboundedFrontierEdgeSet C inputs) :
    Exists fun e : PlanarInterface.Edge n =>
      e ∈ unboundedFrontierEdgeSet C inputs ∧
        (canonicalGraph C).point v ∈
          closedSegment
            ((canonicalGraph C).point e.1)
            ((canonicalGraph C).point e.2) := by
  rcases hEdge with hEdge | hEdge
  · exact ⟨(v, w), hEdge, left_mem_closedSegment _ _⟩
  · exact ⟨(w, v), hEdge, right_mem_closedSegment _ _⟩

/-- Endpoint cover plus the underlying canonical incidence fact at a selected
unbounded-frontier carrier vertex.  The incidence comes from the embedded
drawing frontier, while the selected cover comes from the actual
`unboundedFrontierEdgeSet` carrier rows. -/
theorem frontier_vertex_incident_and_edge_cover_of_localSectorRowsAt
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (rows : UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    (Exists fun w : Fin n => (canonicalGraph C).Adj a.1 w) ∧
      Exists fun e : PlanarInterface.Edge n =>
        e ∈ unboundedFrontierEdgeSet C inputs ∧
          (canonicalGraph C).point a.1 ∈
            closedSegment
              ((canonicalGraph C).point e.1)
              ((canonicalGraph C).point e.2) := by
  constructor
  · exact
      unboundedExterior_frontier_vertex_incident C inputs
        (mem_unboundedFrontierVertexSet_iff.1 a.2)
  · exact
      frontier_vertex_edge_cover_of_incident_unboundedFrontierEdgeSet
        rows.left_edge

/-- Claim `S2-agent-frontier-edge-cover-endpoint-cases`.

If an arbitrary unbounded-exterior frontier point is exactly a graph vertex,
local carrier rows provide a selected unbounded-frontier edge whose closed
segment contains that point.  This closes the endpoint branches of the
frontier-edge cover reduction; the interior branch remains the separate
whole-open-segment propagation row. -/
theorem S2_agent_frontier_edge_cover_endpoint_cases
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    {p : PlanarInterface.Point}
    (hpfrontier :
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    {v : Fin n}
    (hpv : p = (canonicalGraph C).point v) :
    Exists fun e : PlanarInterface.Edge n =>
      e ∈ unboundedFrontierEdgeSet C inputs ∧
        p ∈ closedSegment
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) := by
  let a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨v, mem_unboundedFrontierVertexSet_iff.2 (by
      simpa [hpv] using hpfrontier)⟩
  rcases
      (frontier_vertex_incident_and_edge_cover_of_localSectorRowsAt
        (localSectorRows a)).2 with
    ⟨e, he, hpclosed⟩
  exact ⟨e, he, by simpa [a, hpv] using hpclosed⟩

/-- Claim `S2-agent-frontier-edge-cover-interior-cases`.

The open-edge branch of the frontier cover: if a frontier point lies in the
relative interior of a canonical adjacent pair, and the relative edge-closure
propagation row is available along that open segment, then one of the two
ordered versions of the edge is selected by `unboundedFrontierEdgeSet`. -/
theorem unboundedFrontierEdgeSet_or_symm_of_adj_inOpenSegment_frontier_and_relative_ball_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {i j : Fin n}
    {p : PlanarInterface.Point}
    (hij : (canonicalGraph C).Adj i j)
    (hpEdge :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point i)
        ((canonicalGraph C).point j))
    (hpFrontier :
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (hlocal :
      forall q : PlanarInterface.Point,
        PlanarInterface.InOpenSegment q
          ((canonicalGraph C).point i)
          ((canonicalGraph C).point j) ->
        q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun r : Real =>
            0 < r /\
              forall z : PlanarInterface.Point,
                z ∈ Metric.ball q r ->
                PlanarInterface.InOpenSegment z
                  ((canonicalGraph C).point i)
                  ((canonicalGraph C).point j) ->
                z ∈ closure (unboundedExteriorComponentRows C inputs).exterior) :
    (i, j) ∈ unboundedFrontierEdgeSet C inputs ∨
      (j, i) ∈ unboundedFrontierEdgeSet C inputs := by
  rcases hij with hij | hji
  · left
    let rows :
        UnboundedExteriorFrontierEdgeLocalRows C inputs (i, j) p :=
      unboundedExterior_frontierEdgeLocalRows_of_inOpenSegment_frontier
        hij hpEdge hpFrontier
    exact
      rows.mem_unboundedFrontierEdgeSet_of_local_closure_locus_isOpen
        (openSegment_closure_locus_isOpen_of_forall_relative_ball_closure
          (C := C) (inputs := inputs) (e := (i, j)) hlocal)
  · right
    have hpEdge_rev :
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point j)
          ((canonicalGraph C).point i) :=
      inOpenSegment_symm hpEdge
    have hlocal_rev :
        forall q : PlanarInterface.Point,
          PlanarInterface.InOpenSegment q
            ((canonicalGraph C).point j)
            ((canonicalGraph C).point i) ->
          q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
            Exists fun r : Real =>
              0 < r /\
                forall z : PlanarInterface.Point,
                  z ∈ Metric.ball q r ->
                  PlanarInterface.InOpenSegment z
                    ((canonicalGraph C).point j)
                    ((canonicalGraph C).point i) ->
                  z ∈ closure (unboundedExteriorComponentRows C inputs).exterior := by
      intro q hq hqclosure
      rcases hlocal q (inOpenSegment_symm hq) hqclosure with
        ⟨r, hrpos, hr⟩
      refine ⟨r, hrpos, ?_⟩
      intro z hzball hzseg
      exact hr z hzball (inOpenSegment_symm hzseg)
    let rows :
        UnboundedExteriorFrontierEdgeLocalRows C inputs (j, i) p :=
      unboundedExterior_frontierEdgeLocalRows_of_inOpenSegment_frontier
        hji hpEdge_rev hpFrontier
    exact
      rows.mem_unboundedFrontierEdgeSet_of_local_closure_locus_isOpen
        (openSegment_closure_locus_isOpen_of_forall_relative_ball_closure
          (C := C) (inputs := inputs) (e := (j, i)) hlocal_rev)

/-- Closed-segment witness form of the open-edge frontier-cover branch. -/
theorem frontier_edge_cover_interior_case_of_adj_inOpenSegment_frontier_and_relative_ball_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {i j : Fin n}
    {p : PlanarInterface.Point}
    (hij : (canonicalGraph C).Adj i j)
    (hpEdge :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point i)
        ((canonicalGraph C).point j))
    (hpFrontier :
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (hlocal :
      forall q : PlanarInterface.Point,
        PlanarInterface.InOpenSegment q
          ((canonicalGraph C).point i)
          ((canonicalGraph C).point j) ->
        q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun r : Real =>
            0 < r /\
              forall z : PlanarInterface.Point,
                z ∈ Metric.ball q r ->
                PlanarInterface.InOpenSegment z
                  ((canonicalGraph C).point i)
                  ((canonicalGraph C).point j) ->
                z ∈ closure (unboundedExteriorComponentRows C inputs).exterior) :
    Exists fun e : PlanarInterface.Edge n =>
      e ∈ unboundedFrontierEdgeSet C inputs ∧
        p ∈ closedSegment
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) := by
  rcases
      unboundedFrontierEdgeSet_or_symm_of_adj_inOpenSegment_frontier_and_relative_ball_closure
        (C := C) (inputs := inputs) hij hpEdge hpFrontier hlocal with
    he | he
  · exact ⟨(i, j), he, inOpenSegment_mem_closedSegment hpEdge⟩
  · exact
      ⟨(j, i), he,
        inOpenSegment_mem_closedSegment (inOpenSegment_symm hpEdge)⟩

/-- Exterior-frontier edge cover from two honest ingredients: local-sector rows
at graph frontier vertices, and a source which promotes any edge with an
interior frontier point into the concrete selected frontier-edge set.

The proof uses the existing embedded-edge carrier fact for frontier points, and
then splits the resulting closed segment into endpoint and open-edge cases. -/
theorem frontier_edge_cover_of_localSectorRows_and_interior_edge_mem
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (interior_edge_mem :
      forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
        e ∈ (canonicalGraph C).edgeSet ->
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
          e ∈ unboundedFrontierEdgeSet C inputs) :
    forall p : PlanarInterface.Point,
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
        Exists fun e : PlanarInterface.Edge n =>
          e ∈ unboundedFrontierEdgeSet C inputs ∧
            p ∈ closedSegment
              ((canonicalGraph C).point e.1)
              ((canonicalGraph C).point e.2) := by
  intro p hpfrontier
  rcases exists_edge_segment_of_mem_unboundedExterior_frontier
      C inputs hpfrontier with
    ⟨i, j, hij, hpseg⟩
  rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hpseg with
      hp_left | hp_right | hp_open
  · let a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
      ⟨i, mem_unboundedFrontierVertexSet_iff.2
        (by simpa [hp_left] using hpfrontier)⟩
    rcases frontier_vertex_edge_cover_of_localSectorRowsAt
        (localSectorRows a) with
      ⟨e, he, hclosed⟩
    exact ⟨e, he, by simpa [a, hp_left] using hclosed⟩
  · let a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
      ⟨j, mem_unboundedFrontierVertexSet_iff.2
        (by simpa [hp_right] using hpfrontier)⟩
    rcases frontier_vertex_edge_cover_of_localSectorRowsAt
        (localSectorRows a) with
      ⟨e, he, hclosed⟩
    exact ⟨e, he, by simpa [a, hp_right] using hclosed⟩
  · rcases hij with hij | hji
    · refine ⟨(i, j), interior_edge_mem hij hp_open hpfrontier, ?_⟩
      exact inOpenSegment_mem_closedSegment hp_open
    · refine ⟨(j, i), ?_, ?_⟩
      · exact interior_edge_mem hji (inOpenSegment_symm hp_open) hpfrontier
      · exact inOpenSegment_mem_closedSegment (inOpenSegment_symm hp_open)

/-- Claim `S2-agent-frontier-edge-cover-source`.

The full frontier-edge-cover row follows from local-sector rows at selected
frontier vertices and the existing relative-closure propagation principle for
edge interiors.  The remaining geometric work is precisely the relative
closure row along an edge once one of its interior points is known to lie on the
unbounded exterior frontier. -/
theorem S2_agent_frontier_edge_cover_source
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (interior_relative_ball_closure :
      forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
        e ∈ (canonicalGraph C).edgeSet ->
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
          forall q : PlanarInterface.Point,
            PlanarInterface.InOpenSegment q
              ((canonicalGraph C).point e.1)
              ((canonicalGraph C).point e.2) ->
            q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
              Exists fun r : Real =>
                0 < r ∧
                  forall z : PlanarInterface.Point,
                    z ∈ Metric.ball q r ->
                    PlanarInterface.InOpenSegment z
                      ((canonicalGraph C).point e.1)
                      ((canonicalGraph C).point e.2) ->
                    z ∈ closure
                      (unboundedExteriorComponentRows C inputs).exterior) :
    forall p : PlanarInterface.Point,
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
        Exists fun e : PlanarInterface.Edge n =>
          e ∈ unboundedFrontierEdgeSet C inputs ∧
            p ∈ closedSegment
              ((canonicalGraph C).point e.1)
              ((canonicalGraph C).point e.2) :=
  frontier_edge_cover_of_localSectorRows_and_interior_edge_mem
    inputs localSectorRows
    (fun {e} {p} he hpEdge hpFrontier =>
      mem_unboundedFrontierEdgeSet_of_inOpenSegment_frontier_and_relative_ball_closure
        (C := C) (inputs := inputs) (e := e) (p := p)
        he hpEdge hpFrontier
        (interior_relative_ball_closure he hpEdge hpFrontier))

/-- Claim `S2-agent-frontier-edge-cover-source`, with
`S2-agent-interior-relative-ball-closure-source` plugged in.

The remaining interior-edge assumption is now the nearby-exterior-points
source row, which is the local exterior-side/topology witness from which the
relative closure row follows by the metric closure criterion. -/
theorem S2_agent_frontier_edge_cover_source_of_nearby_edge_point_exterior_points
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (nearby_edge_point_exterior_points :
      InteriorEdgeNearbyExteriorPointSource C inputs) :
    forall p : PlanarInterface.Point,
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
        Exists fun e : PlanarInterface.Edge n =>
          e ∈ unboundedFrontierEdgeSet C inputs ∧
            p ∈ closedSegment
              ((canonicalGraph C).point e.1)
              ((canonicalGraph C).point e.2) :=
  S2_agent_frontier_edge_cover_source
    inputs localSectorRows
    (S2_agent_interior_relative_ball_closure_source
      nearby_edge_point_exterior_points)

/-- Sharper pointwise local-sector rows phrased directly in carrier vertices.
This is convenient when the geometric sector proof has already identified the
two carrier neighbours as graph vertices. -/
structure UnboundedFrontierCarrierSharpLocalSectorRowsAt
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) where
  left : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}
  right : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}
  left_ne_right : left ≠ right
  left_adj : (unboundedFrontierCarrierGraph C inputs).Adj a left
  right_adj : (unboundedFrontierCarrierGraph C inputs).Adj a right
  only :
    forall b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      (unboundedFrontierCarrierGraph C inputs).Adj a b ->
        b = left ∨ b = right

namespace UnboundedFrontierCarrierSharpLocalSectorRowsAt

variable {C : _root_.UDConfig n}
variable {inputs : FinitePlanarOuterComponentInputs C}
variable {a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}

/-- Sharp graph-neighbour sector rows erase to the ordered-edge local-sector
rows consumed by the current S2 concrete-carrier reducer. -/
def toLocalSectorRowsAt
    (rows : UnboundedFrontierCarrierSharpLocalSectorRowsAt inputs a) :
    UnboundedFrontierCarrierLocalSectorRowsAt inputs a where
  left := rows.left.1
  right := rows.right.1
  left_edge := by
    simpa using rows.left_adj
  right_edge := by
    simpa using rows.right_adj
  heads_ne := by
    intro h
    exact rows.left_ne_right (Subtype.ext h)
  only := by
    intro b hb
    rcases rows.only b hb with h | h
    · exact Or.inl (congrArg Subtype.val h)
    · exact Or.inr (congrArg Subtype.val h)

/-- A sharp local-sector row also immediately puts its two selected endpoints
in the same connected component of the concrete carrier graph. -/
theorem left_right_reachable
    (rows : UnboundedFrontierCarrierSharpLocalSectorRowsAt inputs a) :
    (unboundedFrontierCarrierGraph C inputs).Reachable
      rows.left rows.right := by
  exact rows.left_adj.symm.reachable.trans rows.right_adj.reachable

theorem left_connectedComponent_eq_right
    (rows : UnboundedFrontierCarrierSharpLocalSectorRowsAt inputs a) :
    (unboundedFrontierCarrierGraph C inputs).connectedComponentMk rows.left =
      (unboundedFrontierCarrierGraph C inputs).connectedComponentMk
        rows.right :=
  SimpleGraph.ConnectedComponent.sound rows.left_right_reachable

end UnboundedFrontierCarrierSharpLocalSectorRowsAt

/-- Local-sector rows erase to the dart-pair rows used by the two-regularity
reducer.  The remaining geometric proof must construct these rows from the two
exterior sectors adjacent to each frontier vertex. -/
noncomputable def unboundedFrontierCarrierDartPairAt_of_localSectorRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (rows : UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    UnboundedFrontierCarrierDartPairAt inputs a :=
  unboundedFrontierCarrierDartPairAt_of_incident_unboundedFrontierEdges
    (a := a) (l := rows.left) (r := rows.right)
    rows.left_edge rows.right_edge rows.heads_ne rows.only

/-- Family form of `unboundedFrontierCarrierDartPairAt_of_localSectorRows`. -/
noncomputable def unboundedFrontierCarrierDartPairRows_of_localSectorRows
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (rows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      UnboundedFrontierCarrierDartPairAt inputs a :=
  fun a => unboundedFrontierCarrierDartPairAt_of_localSectorRows (rows a)

/-- Local-sector rows also discharge degree two directly via the finite
neighbour-pair reducer.  This is the same local data as the dart-pair route,
without constructing the intermediate darts. -/
theorem unboundedFrontierCarrierGraph_degree_two_of_localSectorRows
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    [DecidableRel (unboundedFrontierCarrierGraph C inputs).Adj]
    (rows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      @SimpleGraph.degree _
        (unboundedFrontierCarrierGraph C inputs) a
        ((unboundedFrontierCarrierGraph C inputs).neighborSetFintype a) =
          2 :=
  unboundedFrontierCarrierGraph_degree_two_of_neighborPairRows
    inputs fun a => (rows a).toNeighborPairAt

/-- Claim `S2-agent-boundary-carrier-degree-two-from-local-sectors`, neighbour
form.

The pointwise local-sector row identifies the complete neighbour set of each
vertex in the concrete unbounded-frontier carrier: the only neighbours are the
two boundary endpoints selected by that local row. -/
theorem S2_agent_boundary_carrier_neighbors_from_local_sectors
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    forall a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      (unboundedFrontierCarrierGraph C inputs).Adj a b ↔
        b = (localSectorRows a).leftVertex ∨
          b = (localSectorRows a).rightVertex := by
  intro a b
  exact (localSectorRows a).neighbor_iff b

/-- Claim `S2-agent-boundary-carrier-degree-two-from-local-sectors`.

Local-sector rows supply exactly two boundary neighbours at every concrete
unbounded-frontier carrier vertex, so the actual carrier graph is two-regular.
This uses only the concrete carrier and the local-sector rows; it does not pass
through an arbitrary cycle, cyclic coverage, or any final S2 rows. -/
theorem S2_agent_boundary_carrier_degree_two_from_local_sectors
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    letI : DecidableRel (unboundedFrontierCarrierGraph C inputs).Adj :=
      unboundedFrontierCarrierGraph_decidableAdj C inputs
    forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      @SimpleGraph.degree _
        (unboundedFrontierCarrierGraph C inputs) a
        ((unboundedFrontierCarrierGraph C inputs).neighborSetFintype a) =
          2 := by
  letI : DecidableRel (unboundedFrontierCarrierGraph C inputs).Adj :=
    unboundedFrontierCarrierGraph_decidableAdj C inputs
  exact
    unboundedFrontierCarrierGraph_degree_two_of_localSectorRows
      inputs localSectorRows

/-- If a frontier vertex has an incident canonical edge whose whole relative
interior is in the closure of the unbounded exterior component, then that edge
is a selected unbounded-frontier carrier edge incident to the vertex. -/
theorem frontier_vertex_incident_unboundedFrontierEdgeSet_of_incident_openSegment_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (hprop :
      forall {v : Fin n},
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun e : PlanarInterface.Edge n =>
            e ∈ (canonicalGraph C).edgeSet ∧
              (e.1 = v ∨ e.2 = v) ∧
                forall p : PlanarInterface.Point,
                  PlanarInterface.InOpenSegment p
                    ((canonicalGraph C).point e.1)
                    ((canonicalGraph C).point e.2) ->
                  p ∈ closure
                    (unboundedExteriorComponentRows C inputs).exterior)
    {v : Fin n}
    (hv :
      (canonicalGraph C).point v ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior) :
    Exists fun e : PlanarInterface.Edge n =>
      e ∈ unboundedFrontierEdgeSet C inputs ∧ (e.1 = v ∨ e.2 = v) := by
  rcases hprop hv with ⟨e, he, hinc, hclosure⟩
  exact
    ⟨e,
      mem_unboundedFrontierEdgeSet_of_edge_openSegment_closure he hclosure,
      hinc⟩

/-- Vertex-seed form of the incident-edge closure handoff.  It converts a
frontier seed that is already known to be a graph vertex into an incident
selected frontier edge with an interior frontier point. -/
theorem seed_vertex_edgeInterior_frontier_point_of_incident_openSegment_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (seed : UnboundedExteriorFrontierSeed inputs)
    {v : Fin n}
    (hv : seed.point = (canonicalGraph C).point v)
    (hprop :
      forall {v : Fin n},
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun e : PlanarInterface.Edge n =>
            e ∈ (canonicalGraph C).edgeSet ∧
              (e.1 = v ∨ e.2 = v) ∧
                forall p : PlanarInterface.Point,
                  PlanarInterface.InOpenSegment p
                    ((canonicalGraph C).point e.1)
                    ((canonicalGraph C).point e.2) ->
                  p ∈ closure
                    (unboundedExteriorComponentRows C inputs).exterior) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        e ∈ unboundedFrontierEdgeSet C inputs ∧
          (e.1 = v ∨ e.2 = v) ∧
            p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
              PlanarInterface.InOpenSegment p
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2) := by
  have hvfront :
      (canonicalGraph C).point v ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior := by
    simpa [hv] using seed.point_mem_frontier
  rcases
      frontier_vertex_incident_unboundedFrontierEdgeSet_of_incident_openSegment_closure
        hprop hvfront with
    ⟨e, he, hinc⟩
  rcases unboundedFrontierEdgeSet_has_frontier_interior_point he with
    ⟨p, hpfrontier, hpseg⟩
  exact ⟨e, p, he, hinc, hpfrontier, hpseg⟩

/-- The first local exterior-frontier edge row follows once frontier vertices
can be assigned an incident canonical edge whose whole open segment lies in the
closure of the unbounded exterior component.  The edge-interior seed branch is
unconditional; the vertex seed branch is the supplied local sector-closure
row. -/
theorem exists_unboundedExteriorFrontierEdgeLocalRows_of_incident_openSegment_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (hprop :
      forall {v : Fin n},
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun e : PlanarInterface.Edge n =>
            e ∈ (canonicalGraph C).edgeSet ∧
              (e.1 = v ∨ e.2 = v) ∧
                forall p : PlanarInterface.Point,
                  PlanarInterface.InOpenSegment p
                    ((canonicalGraph C).point e.1)
                    ((canonicalGraph C).point e.2) ->
                  p ∈ closure
                    (unboundedExteriorComponentRows C inputs).exterior) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        UnboundedExteriorFrontierEdgeLocalRows C inputs e p := by
  rcases unboundedExteriorFrontierSeed_nonempty inputs with ⟨seed⟩
  rcases seed.vertex_or_edgeInterior with hvertex | hedge
  · rcases hvertex with ⟨v, hv⟩
    rcases
        seed_vertex_edgeInterior_frontier_point_of_incident_openSegment_closure
          seed hv hprop with
      ⟨e, p, he, _hinc, hpfrontier, hpseg⟩
    exact
      ⟨e, p,
        unboundedExterior_frontierEdgeLocalRows_of_inOpenSegment_frontier
          (mem_unboundedFrontierEdgeSet_iff.1 he).1 hpseg hpfrontier⟩
  · rcases hedge with ⟨i, j, hij, hpseg⟩
    rcases hij with hij | hji
    · exact
        ⟨(i, j), seed.point,
          unboundedExterior_frontierEdgeLocalRows_of_inOpenSegment_frontier
            hij hpseg seed.point_mem_frontier⟩
    · exact
        ⟨(j, i), seed.point,
          unboundedExterior_frontierEdgeLocalRows_of_inOpenSegment_frontier
            hji (inOpenSegment_symm hpseg) seed.point_mem_frontier⟩

/-- Local-sector rows make the elementary incident selected-edge consequence
available at the graph-vertex level. -/
theorem frontier_vertex_incident_unboundedFrontierEdgeSet_of_localSectorRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (rows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    {v : Fin n}
    (hv :
      (canonicalGraph C).point v ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior) :
    Exists fun w : Fin n =>
      (v, w) ∈ unboundedFrontierEdgeSet C inputs ∨
        (w, v) ∈ unboundedFrontierEdgeSet C inputs := by
  let a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨v, mem_unboundedFrontierVertexSet_iff.2 hv⟩
  exact ⟨(rows a).left, by simpa [a] using (rows a).left_edge⟩

/-- Local-sector rows close the vertex-side seed blocker: a graph vertex on
the unbounded exterior frontier has an incident canonical carrier edge, and
that selected edge has an interior point on the same actual frontier. -/
theorem frontier_vertex_incident_edgeInterior_frontier_point_of_localSectorRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (rows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    {v : Fin n}
    (hv :
      (canonicalGraph C).point v ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        e ∈ (canonicalGraph C).edgeSet ∧
          (e.1 = v ∨ e.2 = v) ∧
            p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
              PlanarInterface.InOpenSegment p
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2) := by
  rcases
      frontier_vertex_incident_unboundedFrontierEdgeSet_of_localSectorRows
        rows hv with
    ⟨w, hEdge | hEdge⟩
  · rcases unboundedFrontierEdgeSet_has_frontier_interior_point hEdge with
      ⟨p, hpfrontier, hpseg⟩
    exact
      ⟨(v, w), p, (mem_unboundedFrontierEdgeSet_iff.1 hEdge).1,
        Or.inl rfl, hpfrontier, hpseg⟩
  · rcases unboundedFrontierEdgeSet_has_frontier_interior_point hEdge with
      ⟨p, hpfrontier, hpseg⟩
    exact
      ⟨(w, v), p, (mem_unboundedFrontierEdgeSet_iff.1 hEdge).1,
        Or.inr rfl, hpfrontier, hpseg⟩

/-- Seed-shaped form of
`frontier_vertex_incident_edgeInterior_frontier_point_of_localSectorRows`.
This is the honest local-sector assumption needed by
`exists_geometricRawFaceSuccOrbitSeed_of_unboundedExteriorFrontierSeed` when
the chosen frontier seed is a graph vertex. -/
theorem seed_vertex_edgeInterior_frontier_point_of_localSectorRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (rows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (seed : UnboundedExteriorFrontierSeed inputs)
    {v : Fin n}
    (hv : seed.point = (canonicalGraph C).point v) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        e ∈ (canonicalGraph C).edgeSet ∧
          (e.1 = v ∨ e.2 = v) ∧
            p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
              PlanarInterface.InOpenSegment p
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2) := by
  have hvfront :
      (canonicalGraph C).point v ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior := by
    simpa [hv] using seed.point_mem_frontier
  exact
    frontier_vertex_incident_edgeInterior_frontier_point_of_localSectorRows
      rows hvfront

/-- Local-sector rows supply the incident open-segment closure row consumed by
the first local edge-row constructor. -/
theorem incident_openSegment_closure_of_localSectorRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (rows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    forall {v : Fin n},
      (canonicalGraph C).point v ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ->
        Exists fun e : PlanarInterface.Edge n =>
          e ∈ (canonicalGraph C).edgeSet ∧
            (e.1 = v ∨ e.2 = v) ∧
              forall p : PlanarInterface.Point,
                PlanarInterface.InOpenSegment p
                  ((canonicalGraph C).point e.1)
                  ((canonicalGraph C).point e.2) ->
                p ∈ closure
                  (unboundedExteriorComponentRows C inputs).exterior := by
  intro v hv
  rcases
      frontier_vertex_incident_unboundedFrontierEdgeSet_of_localSectorRows
        rows hv with
    ⟨w, hEdge | hEdge⟩
  · exact
      ⟨(v, w),
        (mem_unboundedFrontierEdgeSet_iff.1 hEdge).1,
        Or.inl rfl,
        fun p hp =>
          frontier_subset_closure
            ((mem_unboundedFrontierEdgeSet_iff.1 hEdge).2 p hp)⟩
  · exact
      ⟨(w, v),
        (mem_unboundedFrontierEdgeSet_iff.1 hEdge).1,
        Or.inr rfl,
        fun p hp =>
          frontier_subset_closure
            ((mem_unboundedFrontierEdgeSet_iff.1 hEdge).2 p hp)⟩

/-- Local-sector rows give a concrete local unbounded-frontier edge row. -/
theorem exists_unboundedExteriorFrontierEdgeLocalRows_of_localSectorRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (rows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        UnboundedExteriorFrontierEdgeLocalRows C inputs e p :=
  exists_unboundedExteriorFrontierEdgeLocalRows_of_incident_openSegment_closure
    (incident_openSegment_closure_of_localSectorRows rows)

/-- A selected local unbounded-frontier edge supplies an actual starting dart
for the geometric face-successor permutation, hence a raw finite face orbit.
This is only a seed for the orbit; it does not assume or synthesize an exterior
boundary cycle. -/
theorem exists_geometricRawFaceSuccOrbitSeed_of_unboundedExteriorFrontierEdgeLocalRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    {p : PlanarInterface.Point}
    (rows : UnboundedExteriorFrontierEdgeLocalRows C inputs e p) :
    Exists fun start : UnitDistanceDart C =>
      start.tail = e.1 ∧
        start.head = e.2 ∧
          Nonempty
            (UnitDistanceRotationSystem.RawFaceSuccOrbit
              (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
                C)
              start) := by
  let hcanonical : (canonicalGraph C).Adj e.1 e.2 := Or.inl rows.edge_mem
  let start : UnitDistanceDart C :=
    { tail := e.1
      head := e.2
      adj :=
        (GraphBridge.unitDistanceSimpleGraph_adj C e.1 e.2).2
          (((canonicalGraph C).adj_iff_unitDistanceAdj e.1 e.2).1
            hcanonical) }
  refine ⟨start, rfl, rfl, ?_⟩
  exact
    UnitDistanceRotationSystem.RawFaceSuccOrbit.nonempty
      (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
        C)
      start

/-- Orient a concrete unbounded-exterior frontier seed into the geometric raw
face-successor orbit seed.  The edge-interior branch is unconditional.  The
only extra input is the exact local-side theorem needed when the seed lands on
a graph vertex: an incident canonical edge must contain an interior point of
the same unbounded exterior frontier. -/
theorem exists_geometricRawFaceSuccOrbitSeed_of_unboundedExteriorFrontierSeed
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (seed : UnboundedExteriorFrontierSeed inputs)
    (hvertex_side :
      forall {v : Fin n},
        seed.point = (canonicalGraph C).point v ->
          Exists fun e : PlanarInterface.Edge n =>
            Exists fun p : PlanarInterface.Point =>
              e ∈ (canonicalGraph C).edgeSet ∧
                (e.1 = v ∨ e.2 = v) ∧
                  p ∈
                    frontier
                      (unboundedExteriorComponentRows C inputs).exterior ∧
                    PlanarInterface.InOpenSegment p
                      ((canonicalGraph C).point e.1)
                      ((canonicalGraph C).point e.2)) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        Exists fun start : UnitDistanceDart C =>
          UnboundedExteriorFrontierEdgeLocalRows C inputs e p ∧
            start.tail = e.1 ∧
              start.head = e.2 ∧
                Nonempty
                  (UnitDistanceRotationSystem.RawFaceSuccOrbit
                    (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
                      C)
                    start) := by
  rcases seed.vertex_or_edgeInterior with hvertex | hedge
  · rcases hvertex with ⟨v, hv⟩
    rcases hvertex_side hv with
      ⟨e, p, he, _hincident, hpfrontier, hpedge⟩
    let rows :
        UnboundedExteriorFrontierEdgeLocalRows C inputs e p :=
      unboundedExterior_frontierEdgeLocalRows_of_inOpenSegment_frontier
        he hpedge hpfrontier
    rcases
        exists_geometricRawFaceSuccOrbitSeed_of_unboundedExteriorFrontierEdgeLocalRows
          rows with
      ⟨start, htail, hhead, horbit⟩
    exact ⟨e, p, start, rows, htail, hhead, horbit⟩
  · rcases hedge with ⟨i, j, hij, hpedge⟩
    rcases hij with hij | hji
    · let rows :
          UnboundedExteriorFrontierEdgeLocalRows C inputs (i, j)
            seed.point :=
        unboundedExterior_frontierEdgeLocalRows_of_inOpenSegment_frontier
          hij hpedge seed.point_mem_frontier
      rcases
          exists_geometricRawFaceSuccOrbitSeed_of_unboundedExteriorFrontierEdgeLocalRows
            rows with
        ⟨start, htail, hhead, horbit⟩
      exact ⟨(i, j), seed.point, start, rows, htail, hhead, horbit⟩
    · let rows :
          UnboundedExteriorFrontierEdgeLocalRows C inputs (j, i)
            seed.point :=
        unboundedExterior_frontierEdgeLocalRows_of_inOpenSegment_frontier
          hji (inOpenSegment_symm hpedge) seed.point_mem_frontier
      rcases
          exists_geometricRawFaceSuccOrbitSeed_of_unboundedExteriorFrontierEdgeLocalRows
            rows with
        ⟨start, htail, hhead, horbit⟩
      exact ⟨(j, i), seed.point, start, rows, htail, hhead, horbit⟩

/-- Local-sector rows discharge the vertex-side premise in
`exists_geometricRawFaceSuccOrbitSeed_of_unboundedExteriorFrontierSeed`,
producing a geometric raw face-successor orbit seed from any unbounded exterior
frontier seed. -/
theorem exists_geometricRawFaceSuccOrbitSeed_of_unboundedExteriorFrontierSeed_localSectorRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (rows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (seed : UnboundedExteriorFrontierSeed inputs) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        Exists fun start : UnitDistanceDart C =>
          UnboundedExteriorFrontierEdgeLocalRows C inputs e p ∧
            start.tail = e.1 ∧
              start.head = e.2 ∧
                Nonempty
                  (UnitDistanceRotationSystem.RawFaceSuccOrbit
                    (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
                      C)
                    start) := by
  refine
    exists_geometricRawFaceSuccOrbitSeed_of_unboundedExteriorFrontierSeed
      seed ?_
  intro v hv
  exact seed_vertex_edgeInterior_frontier_point_of_localSectorRows rows seed hv

/-- Vertex-seed local-side reducer for the rightward/exterior seed blocker.

If the actual unbounded-frontier seed is a graph vertex, the only remaining
local-side input is the concrete incident-edge row saying that this vertex has
an incident canonical edge with an interior point on the same actual frontier.
This lemma turns precisely that row into the `UnboundedExteriorFrontierEdgeLocalRows`
needed to start the geometric raw face-successor orbit. -/
theorem exists_incident_unboundedExteriorFrontierEdgeLocalRows_of_vertex_seed_side
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (seed : UnboundedExteriorFrontierSeed inputs)
    {v : Fin n}
    (hv : seed.point = (canonicalGraph C).point v)
    (hvertex_side :
      Exists fun e : PlanarInterface.Edge n =>
        Exists fun p : PlanarInterface.Point =>
          e ∈ (canonicalGraph C).edgeSet ∧
            (e.1 = v ∨ e.2 = v) ∧
              p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
                PlanarInterface.InOpenSegment p
                  ((canonicalGraph C).point e.1)
                  ((canonicalGraph C).point e.2)) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        UnboundedExteriorFrontierEdgeLocalRows C inputs e p ∧
          (e.1 = v ∨ e.2 = v) := by
  have _hvfront :
      (canonicalGraph C).point v ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior := by
    simpa [hv] using seed.point_mem_frontier
  rcases hvertex_side with ⟨e, p, he, hincident, hpfrontier, hpedge⟩
  exact
    ⟨e, p,
      unboundedExterior_frontierEdgeLocalRows_of_inOpenSegment_frontier
        he hpedge hpfrontier,
      hincident⟩

/-- Finite vertex isolation upgrades the pointed accumulation residual.

To find a nearby exterior-frontier point which is not any graph vertex, it is
enough to find one which is merely different from the centre vertex.  Shrink
the requested ball by the finite drawing's vertex-isolation radius. -/
theorem nearby_nonvertex_unboundedExterior_frontier_of_punctured_vertex
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (v : Fin n)
    (hnear :
      forall ε : Real,
        0 < ε ->
          Exists fun q : PlanarInterface.Point =>
            q ∈ Metric.ball ((canonicalGraph C).point v) ε ∧
              q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
                q ≠ (canonicalGraph C).point v) :
    forall ε : Real,
      0 < ε ->
        Exists fun q : PlanarInterface.Point =>
          q ∈ Metric.ball ((canonicalGraph C).point v) ε ∧
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
              forall u : Fin n, q ≠ (canonicalGraph C).point u := by
  intro ε hεpos
  rcases
      _root_.ErdosProblems1066.Swanepoel.FinitePlaneDrawing.exists_ball_forall_graph_vertex_eq_of_mem_ball
        (C := C) v with
    ⟨η, hηpos, hvertex⟩
  have hδpos : 0 < min ε η := lt_min hεpos hηpos
  rcases hnear (min ε η) hδpos with
    ⟨q, hqball, hqfrontier, hq_ne_center⟩
  refine ⟨q, ?_, hqfrontier, ?_⟩
  · have hdist :
        dist q ((canonicalGraph C).point v) < min ε η := by
      simpa [Metric.mem_ball] using hqball
    exact (Metric.mem_ball).2 (lt_of_lt_of_le hdist (min_le_left ε η))
  · intro u hqu
    have hqballη :
        q ∈ Metric.ball ((canonicalGraph C).point v) η := by
      have hdist :
          dist q ((canonicalGraph C).point v) < min ε η := by
        simpa [Metric.mem_ball] using hqball
      exact (Metric.mem_ball).2
        (lt_of_lt_of_le hdist (min_le_right ε η))
    have huv : u = v := hvertex u (by simpa [hqu] using hqballη)
    exact hq_ne_center (by simpa [huv] using hqu)

/-- A sharper local-topology reducer for the vertex-seed side condition.

Near a graph-vertex seed, it is enough to find an actual unbounded-exterior
frontier point which is not any graph vertex.  The finite drawing's local
vertex-star isolation then supplies an incident canonical edge, and the
non-vertex condition upgrades closed-segment membership to open-segment
membership. -/
theorem vertex_seed_side_of_nearby_nonvertex_unboundedExterior_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (seed : UnboundedExteriorFrontierSeed inputs)
    {v : Fin n}
    (hv : seed.point = (canonicalGraph C).point v)
    (hnear :
      forall ε : Real,
        0 < ε ->
          Exists fun q : PlanarInterface.Point =>
            q ∈ Metric.ball ((canonicalGraph C).point v) ε ∧
              q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
                forall u : Fin n, q ≠ (canonicalGraph C).point u) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        e ∈ (canonicalGraph C).edgeSet ∧
          (e.1 = v ∨ e.2 = v) ∧
            p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
              PlanarInterface.InOpenSegment p
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2) := by
  have _hvfront :
      (canonicalGraph C).point v ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior := by
    simpa [hv] using seed.point_mem_frontier
  rcases
      exists_ball_forall_unboundedExterior_frontier_mem_incident_closedSegment_of_vertex
        C inputs v with
    ⟨ε, hεpos, hlocal⟩
  rcases hnear ε hεpos with ⟨q, hqball, hqfrontier, hq_nonvertex⟩
  rcases hlocal q hqball hqfrontier with ⟨w, hvw, hqseg⟩
  rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hqseg with
      hleft | hright | hinside
  · exact False.elim ((hq_nonvertex v) hleft)
  · exact False.elim ((hq_nonvertex w) hright)
  · rcases hvw with he | he
    · exact ⟨(v, w), q, he, Or.inl rfl, hqfrontier, hinside⟩
    · exact
        ⟨(w, v), q, he, Or.inr rfl, hqfrontier,
          inOpenSegment_symm hinside⟩

/-- Pointed accumulation version of
`vertex_seed_side_of_nearby_nonvertex_unboundedExterior_frontier`.

The remaining local topology is only that the actual unbounded exterior
frontier accumulates at the seed vertex by points different from that same
vertex.  Finite vertex isolation removes the need to mention all other graph
vertices in the residual. -/
theorem vertex_seed_side_of_punctured_vertex_unboundedExterior_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (seed : UnboundedExteriorFrontierSeed inputs)
    {v : Fin n}
    (hv : seed.point = (canonicalGraph C).point v)
    (hnear :
      forall ε : Real,
        0 < ε ->
          Exists fun q : PlanarInterface.Point =>
            q ∈ Metric.ball ((canonicalGraph C).point v) ε ∧
              q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
                q ≠ (canonicalGraph C).point v) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        e ∈ (canonicalGraph C).edgeSet ∧
          (e.1 = v ∨ e.2 = v) ∧
            p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
              PlanarInterface.InOpenSegment p
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2) := by
  exact
    vertex_seed_side_of_nearby_nonvertex_unboundedExterior_frontier
      seed hv
      (nearby_nonvertex_unboundedExterior_frontier_of_punctured_vertex
        (C := C) (inputs := inputs) v hnear)

/-- Incident open-segment closure from punctured vertex accumulation plus the
interior relative-ball closure row.

This is the non-circular graph-vertex seed handoff: punctured frontier
accumulation finds an incident canonical edge with one interior frontier
point, and the interior relative-ball closure row propagates that to closure
along the whole open segment. -/
theorem incident_openSegment_closure_of_punctured_vertex_and_relative_ball_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (hpunctured :
      forall {v : Fin n},
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ->
          forall eps : Real,
            0 < eps ->
              Exists fun q : PlanarInterface.Point =>
                q ∈ Metric.ball ((canonicalGraph C).point v) eps ∧
                  q ∈ frontier
                    (unboundedExteriorComponentRows C inputs).exterior ∧
                    q ≠ (canonicalGraph C).point v)
    (interior_relative_ball_closure :
      InteriorRelativeBallClosureRow C inputs) :
    forall {v : Fin n},
      (canonicalGraph C).point v ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ->
        Exists fun e : PlanarInterface.Edge n =>
          e ∈ (canonicalGraph C).edgeSet ∧
            (e.1 = v ∨ e.2 = v) ∧
              forall p : PlanarInterface.Point,
                PlanarInterface.InOpenSegment p
                  ((canonicalGraph C).point e.1)
                  ((canonicalGraph C).point e.2) ->
                p ∈ closure
                  (unboundedExteriorComponentRows C inputs).exterior := by
  intro v hvfront
  let seed : UnboundedExteriorFrontierSeed inputs :=
    { point := (canonicalGraph C).point v
      point_mem_frontier := hvfront
      vertex_or_edgeInterior := Or.inl ⟨v, rfl⟩ }
  rcases
      vertex_seed_side_of_punctured_vertex_unboundedExterior_frontier
        (C := C) (inputs := inputs) seed rfl (hpunctured hvfront) with
    ⟨e, p, he, hincident, hpfrontier, hpopen⟩
  refine ⟨e, he, hincident, ?_⟩
  intro q hqopen
  exact
    frontier_subset_closure
      (edge_openSegment_frontier_of_inOpenSegment_frontier_and_relative_ball_closure
        (C := C) (inputs := inputs) (e := e) (p := p)
        he hpopen hpfrontier
        (interior_relative_ball_closure he hpopen hpfrontier)
        q hqopen)

/-- Local edge-row existence from the same non-circular vertex-seed inputs:
punctured frontier accumulation at graph vertices plus the interior
relative-ball closure row. -/
theorem exists_unboundedExteriorFrontierEdgeLocalRows_of_punctured_vertex_and_relative_ball_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (hpunctured :
      forall {v : Fin n},
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ->
          forall eps : Real,
            0 < eps ->
              Exists fun q : PlanarInterface.Point =>
                q ∈ Metric.ball ((canonicalGraph C).point v) eps ∧
                  q ∈ frontier
                    (unboundedExteriorComponentRows C inputs).exterior ∧
                    q ≠ (canonicalGraph C).point v)
    (interior_relative_ball_closure :
      InteriorRelativeBallClosureRow C inputs) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        UnboundedExteriorFrontierEdgeLocalRows C inputs e p :=
  exists_unboundedExteriorFrontierEdgeLocalRows_of_incident_openSegment_closure
    (incident_openSegment_closure_of_punctured_vertex_and_relative_ball_closure
      (C := C) (inputs := inputs) hpunctured
      interior_relative_ball_closure)

/-- An incident open-frontier edge germ supplies the punctured same-vertex
accumulation row at a graph-vertex unbounded exterior frontier seed.

This isolates the local topology still needed for the vertex case: once one
incident canonical edge has its whole relative interior on the actual frontier,
points from that open segment approach the vertex from inside every ball. -/
theorem punctured_vertex_unboundedExterior_frontier_of_incident_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (seed : UnboundedExteriorFrontierSeed inputs)
    {v : Fin n}
    (_hv : seed.point = (canonicalGraph C).point v)
    (hincident :
      Exists fun e : PlanarInterface.Edge n =>
        e ∈ (canonicalGraph C).edgeSet ∧
          (e.1 = v ∨ e.2 = v) ∧
            forall p : PlanarInterface.Point,
              PlanarInterface.InOpenSegment p
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2) ->
              p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    forall eps : Real,
      0 < eps ->
        Exists fun q : PlanarInterface.Point =>
          q ∈ Metric.ball ((canonicalGraph C).point v) eps ∧
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
              q ≠ (canonicalGraph C).point v := by
  intro eps heps
  rcases hincident with ⟨e, he, hinc, hfrontier⟩
  have hAdj : (canonicalGraph C).Adj e.1 e.2 := Or.inl he
  rcases hinc with hleft | hright
  · have hclosure_left :
        (canonicalGraph C).point e.1 ∈
          closure
            ({p : PlanarInterface.Point |
              PlanarInterface.InOpenSegment p
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2)} :
              Set PlanarInterface.Point) :=
      left_mem_closure_inOpenSegment
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2)
    rw [Metric.mem_closure_iff] at hclosure_left
    rcases hclosure_left eps heps with ⟨q, hqopen, hqball_raw⟩
    refine ⟨q, ?_, hfrontier q hqopen, ?_⟩
    · have hqball_e1 :
          q ∈ Metric.ball ((canonicalGraph C).point e.1) eps := by
        simpa [Metric.mem_ball, dist_comm] using hqball_raw
      simpa [hleft] using hqball_e1
    · intro hqv
      exact
        (graph_vertex_not_inOpenSegment_of_adj (C := C) (v := v) hAdj)
          (by simpa [hqv] using hqopen)
  · have hclosure_right :
        (canonicalGraph C).point e.2 ∈
          closure
            ({p : PlanarInterface.Point |
              PlanarInterface.InOpenSegment p
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2)} :
              Set PlanarInterface.Point) :=
      right_mem_closure_inOpenSegment
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2)
    rw [Metric.mem_closure_iff] at hclosure_right
    rcases hclosure_right eps heps with ⟨q, hqopen, hqball_raw⟩
    refine ⟨q, ?_, hfrontier q hqopen, ?_⟩
    · have hqball_e2 :
          q ∈ Metric.ball ((canonicalGraph C).point e.2) eps := by
        simpa [Metric.mem_ball, dist_comm] using hqball_raw
      simpa [hright] using hqball_e2
    · intro hqv
      exact
        (graph_vertex_not_inOpenSegment_of_adj (C := C) (v := v) hAdj)
          (by simpa [hqv] using hqopen)

/-- Closure-form version of
`punctured_vertex_unboundedExterior_frontier_of_incident_openSegment_frontier`.

The remaining local residual is sharper than arbitrary punctured frontier
accumulation: find an incident canonical edge whose whole relative interior is
in the closure of the unbounded exterior component.  Since canonical edge
interiors are outside the exterior, this gives actual frontier points. -/
theorem punctured_vertex_unboundedExterior_frontier_of_incident_openSegment_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (seed : UnboundedExteriorFrontierSeed inputs)
    {v : Fin n}
    (hv : seed.point = (canonicalGraph C).point v)
    (hincident :
      Exists fun e : PlanarInterface.Edge n =>
        e ∈ (canonicalGraph C).edgeSet ∧
          (e.1 = v ∨ e.2 = v) ∧
            forall p : PlanarInterface.Point,
              PlanarInterface.InOpenSegment p
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2) ->
              p ∈ closure (unboundedExteriorComponentRows C inputs).exterior) :
    forall eps : Real,
      0 < eps ->
        Exists fun q : PlanarInterface.Point =>
          q ∈ Metric.ball ((canonicalGraph C).point v) eps ∧
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
              q ≠ (canonicalGraph C).point v := by
  apply
    punctured_vertex_unboundedExterior_frontier_of_incident_openSegment_frontier
      seed hv
  rcases hincident with ⟨e, he, hinc, hclosure⟩
  refine ⟨e, he, hinc, ?_⟩
  exact edge_openSegment_frontier_of_edge_openSegment_closure he hclosure

/-- The selected local edge row is enough for the raw orbit seed, before any
boundary-cycle identification is used.  The vertex branch is reduced exactly
to the concrete incident-edge/interior-frontier row. -/
theorem exists_unboundedExteriorFrontierEdgeLocalRows_of_unboundedExteriorFrontierSeed
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (seed : UnboundedExteriorFrontierSeed inputs)
    (hvertex_side :
      forall {v : Fin n},
        seed.point = (canonicalGraph C).point v ->
          Exists fun e : PlanarInterface.Edge n =>
            Exists fun p : PlanarInterface.Point =>
              e ∈ (canonicalGraph C).edgeSet ∧
                (e.1 = v ∨ e.2 = v) ∧
                  p ∈
                    frontier
                      (unboundedExteriorComponentRows C inputs).exterior ∧
                    PlanarInterface.InOpenSegment p
                      ((canonicalGraph C).point e.1)
                      ((canonicalGraph C).point e.2)) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        UnboundedExteriorFrontierEdgeLocalRows C inputs e p := by
  rcases
      exists_geometricRawFaceSuccOrbitSeed_of_unboundedExteriorFrontierSeed
        seed hvertex_side with
    ⟨e, p, _start, edgeRows, _htail, _hhead, _horbit⟩
  exact ⟨e, p, edgeRows⟩

/-- Version of
`exists_unboundedExteriorFrontierEdgeLocalRows_of_unboundedExteriorFrontierSeed`
whose vertex-seed residual is only a punctured, non-graph-vertex accumulation
row for the actual unbounded exterior frontier. -/
theorem exists_unboundedExteriorFrontierEdgeLocalRows_of_unboundedExteriorFrontierSeed_nearby_nonvertex
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (seed : UnboundedExteriorFrontierSeed inputs)
    (hnear :
      forall {v : Fin n},
        seed.point = (canonicalGraph C).point v ->
          forall ε : Real,
            0 < ε ->
              Exists fun q : PlanarInterface.Point =>
                q ∈ Metric.ball ((canonicalGraph C).point v) ε ∧
                  q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
                    forall u : Fin n, q ≠ (canonicalGraph C).point u) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        UnboundedExteriorFrontierEdgeLocalRows C inputs e p := by
  exact
    exists_unboundedExteriorFrontierEdgeLocalRows_of_unboundedExteriorFrontierSeed
      seed
      (fun {v} hv =>
        vertex_seed_side_of_nearby_nonvertex_unboundedExterior_frontier
          seed hv (hnear hv))

/-- Pointed-accumulation version of
`exists_unboundedExteriorFrontierEdgeLocalRows_of_unboundedExteriorFrontierSeed_nearby_nonvertex`.

This is the sharper reducer for the vertex-seed residual: for each graph
vertex seed on the actual unbounded exterior frontier, it remains only to find
arbitrarily close actual frontier points different from that same vertex. -/
theorem exists_unboundedExteriorFrontierEdgeLocalRows_of_unboundedExteriorFrontierSeed_punctured_vertex
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (seed : UnboundedExteriorFrontierSeed inputs)
    (hnear :
      forall {v : Fin n},
        seed.point = (canonicalGraph C).point v ->
          forall ε : Real,
            0 < ε ->
              Exists fun q : PlanarInterface.Point =>
                q ∈ Metric.ball ((canonicalGraph C).point v) ε ∧
                  q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
                    q ≠ (canonicalGraph C).point v) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        UnboundedExteriorFrontierEdgeLocalRows C inputs e p := by
  exact
    exists_unboundedExteriorFrontierEdgeLocalRows_of_unboundedExteriorFrontierSeed
      seed
      (fun {v} hv =>
        vertex_seed_side_of_punctured_vertex_unboundedExterior_frontier
          seed hv (hnear hv))

/-- Seed-local reducer for
`exists_unboundedExteriorFrontierEdgeLocalRows_of_unboundedExteriorFrontierSeed_punctured_vertex`.

Instead of assuming arbitrary punctured accumulation at the vertex seed, it is
enough to supply an incident open-segment exterior-closure row at that seed. -/
theorem exists_unboundedExteriorFrontierEdgeLocalRows_of_unboundedExteriorFrontierSeed_punctured_vertex_of_incident_openSegment_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (seed : UnboundedExteriorFrontierSeed inputs)
    (hincident :
      forall {v : Fin n},
        seed.point = (canonicalGraph C).point v ->
          Exists fun e : PlanarInterface.Edge n =>
            e ∈ (canonicalGraph C).edgeSet ∧
              (e.1 = v ∨ e.2 = v) ∧
                forall p : PlanarInterface.Point,
                  PlanarInterface.InOpenSegment p
                    ((canonicalGraph C).point e.1)
                    ((canonicalGraph C).point e.2) ->
                  p ∈ closure
                    (unboundedExteriorComponentRows C inputs).exterior) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        UnboundedExteriorFrontierEdgeLocalRows C inputs e p := by
  exact
    exists_unboundedExteriorFrontierEdgeLocalRows_of_unboundedExteriorFrontierSeed_punctured_vertex
      seed
      (fun {v} hv =>
        punctured_vertex_unboundedExterior_frontier_of_incident_openSegment_closure
          seed hv (hincident hv))

/-- Concrete replacement for the abstract `raw_start_on_boundary` callback.

It is enough to prove that every selected local unbounded-frontier edge row is
oriented as a forward edge of the actual boundary cycle.  Endpoint equality
then identifies any raw start dart with the corresponding `ofBoundary` dart. -/
theorem raw_start_on_boundary_of_edgeLocalRows_boundary_succ
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (edgeRows_boundary_succ :
      forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
        UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
          Exists fun j : Fin B.length =>
            e.1 = B.vertex j ∧
              e.2 =
                B.vertex (PlanarInterface.cyclicSucc B.length_pos j)) :
    forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
        {start : UnitDistanceDart C},
      UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
      start.tail = e.1 ->
      start.head = e.2 ->
      Exists fun j : Fin B.length =>
        start = UnitDistanceDart.ofBoundary B j := by
  intro e p start edgeRows htail hhead
  rcases edgeRows_boundary_succ edgeRows with ⟨j, htail_boundary, hhead_boundary⟩
  refine ⟨j, ?_⟩
  exact
    UnitDistanceDart.eq_ofBoundary_of_tail_head B j start
      (htail.trans htail_boundary)
      (hhead.trans hhead_boundary)

/-- Orientation-selected boundary raw start from endpoint data.

The selected local frontier edge may be stored in either canonical direction.
Instead of forcing the raw start dart to follow that stored orientation, choose
the actual boundary-cycle dart `j -> succ j` and remember that its unordered
endpoints agree with the selected local row. -/
theorem exists_boundary_raw_start_of_edgeLocalRows_boundary_succ_or_reverse
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (edgeRows_boundary_succ_or_reverse :
      forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
        UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
          Exists fun j : Fin B.length =>
            (e.1 = B.vertex j ∧
              e.2 =
                B.vertex (PlanarInterface.cyclicSucc B.length_pos j)) ∨
            (e.2 = B.vertex j ∧
              e.1 =
                B.vertex (PlanarInterface.cyclicSucc B.length_pos j))) :
    forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
      UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
        Exists fun start : UnitDistanceDart C =>
          Exists fun j : Fin B.length =>
            start = UnitDistanceDart.ofBoundary B j ∧
              Nonempty
                (UnitDistanceRotationSystem.RawFaceSuccOrbit
                  (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
                    C)
                  start) ∧
                ((start.tail = e.1 ∧ start.head = e.2) ∨
                  (start.tail = e.2 ∧ start.head = e.1)) := by
  intro e p edgeRows
  rcases edgeRows_boundary_succ_or_reverse edgeRows with
    ⟨j, hforward | hreverse⟩
  · let start : UnitDistanceDart C := UnitDistanceDart.ofBoundary B j
    refine ⟨start, j, rfl, ?_, Or.inl ?_⟩
    · exact
        UnitDistanceRotationSystem.RawFaceSuccOrbit.nonempty
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
            C)
          start
    · exact
        ⟨by simpa [start] using hforward.1.symm,
          by simpa [start] using hforward.2.symm⟩
  · let start : UnitDistanceDart C := UnitDistanceDart.ofBoundary B j
    refine ⟨start, j, rfl, ?_, Or.inr ?_⟩
    · exact
        UnitDistanceRotationSystem.RawFaceSuccOrbit.nonempty
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
            C)
          start
    · exact
        ⟨by simpa [start] using hreverse.1.symm,
          by simpa [start] using hreverse.2.symm⟩

/-- Boundary-start form of the geometric raw seed reducer.

The residual `edgeRows_boundary_succ` is the concrete local-side boundary
orientation row: every local unbounded-frontier edge chosen from the seed is a
forward edge of the actual boundary cycle.  This strictly refines the older
`raw_start_on_boundary` callback to endpoint data on the selected local row. -/
theorem exists_geometricRawFaceSuccOrbitBoundarySeed_of_unboundedExteriorFrontierSeed
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (seed : UnboundedExteriorFrontierSeed inputs)
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (hvertex_side :
      forall {v : Fin n},
        seed.point = (canonicalGraph C).point v ->
          Exists fun e : PlanarInterface.Edge n =>
            Exists fun p : PlanarInterface.Point =>
              e ∈ (canonicalGraph C).edgeSet ∧
                (e.1 = v ∨ e.2 = v) ∧
                  p ∈
                    frontier
                      (unboundedExteriorComponentRows C inputs).exterior ∧
                    PlanarInterface.InOpenSegment p
                      ((canonicalGraph C).point e.1)
                      ((canonicalGraph C).point e.2))
    (edgeRows_boundary_succ :
      forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
        UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
          Exists fun j : Fin B.length =>
            e.1 = B.vertex j ∧
              e.2 =
                B.vertex (PlanarInterface.cyclicSucc B.length_pos j)) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        Exists fun start : UnitDistanceDart C =>
          Exists fun j : Fin B.length =>
            UnboundedExteriorFrontierEdgeLocalRows C inputs e p ∧
              start.tail = e.1 ∧
                start.head = e.2 ∧
                  start = UnitDistanceDart.ofBoundary B j ∧
                    Nonempty
                      (UnitDistanceRotationSystem.RawFaceSuccOrbit
                        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
                          C)
                        start) := by
  rcases
      exists_geometricRawFaceSuccOrbitSeed_of_unboundedExteriorFrontierSeed
        seed hvertex_side with
    ⟨e, p, start, edgeRows, htail, hhead, horbit⟩
  rcases
      raw_start_on_boundary_of_edgeLocalRows_boundary_succ
        (C := C) (inputs := inputs) (B := B)
        edgeRows_boundary_succ edgeRows htail hhead with
    ⟨j, hstart_boundary⟩
  exact
    ⟨e, p, start, j, edgeRows, htail, hhead, hstart_boundary, horbit⟩

/-- Boundary-start form of the geometric raw seed reducer with orientation
selected from the actual boundary cycle.

The stored local edge orientation is used only to identify the unordered
endpoints of the selected boundary dart.  The raw orbit itself starts at
`UnitDistanceDart.ofBoundary B j`, so the reverse canonical storage case is
handled without any reverse-orientation exclusion hypothesis. -/
theorem exists_geometricRawFaceSuccOrbitBoundarySeed_of_unboundedExteriorFrontierSeed_orientationSelected
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (seed : UnboundedExteriorFrontierSeed inputs)
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (hvertex_side :
      forall {v : Fin n},
        seed.point = (canonicalGraph C).point v ->
          Exists fun e : PlanarInterface.Edge n =>
            Exists fun p : PlanarInterface.Point =>
              e ∈ (canonicalGraph C).edgeSet ∧
                (e.1 = v ∨ e.2 = v) ∧
                  p ∈
                    frontier
                      (unboundedExteriorComponentRows C inputs).exterior ∧
                    PlanarInterface.InOpenSegment p
                      ((canonicalGraph C).point e.1)
                      ((canonicalGraph C).point e.2))
    (edgeRows_boundary_succ_or_reverse :
      forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
        UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
          Exists fun j : Fin B.length =>
            (e.1 = B.vertex j ∧
              e.2 =
                B.vertex (PlanarInterface.cyclicSucc B.length_pos j)) ∨
            (e.2 = B.vertex j ∧
              e.1 =
                B.vertex (PlanarInterface.cyclicSucc B.length_pos j))) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        Exists fun start : UnitDistanceDart C =>
          Exists fun j : Fin B.length =>
            UnboundedExteriorFrontierEdgeLocalRows C inputs e p ∧
              start = UnitDistanceDart.ofBoundary B j ∧
                Nonempty
                  (UnitDistanceRotationSystem.RawFaceSuccOrbit
                    (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
                      C)
                    start) ∧
                  ((start.tail = e.1 ∧ start.head = e.2) ∨
                    (start.tail = e.2 ∧ start.head = e.1)) := by
  rcases
      exists_geometricRawFaceSuccOrbitSeed_of_unboundedExteriorFrontierSeed
        (C := C) (inputs := inputs) seed hvertex_side with
    ⟨e, p, _storedStart, edgeRows, _htail, _hhead, _horbit⟩
  rcases
      exists_boundary_raw_start_of_edgeLocalRows_boundary_succ_or_reverse
        (C := C) (inputs := inputs) (B := B)
        edgeRows_boundary_succ_or_reverse edgeRows with
    ⟨start, j, hstart, horbit, hendpoints⟩
  exact ⟨e, p, start, j, edgeRows, hstart, horbit, hendpoints⟩

namespace UnboundedFrontierCarrierDartPairAt

variable {C : _root_.UDConfig n}
variable {inputs : FinitePlanarOuterComponentInputs C}
variable {a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}

def toLocalSectorRowsAt
    (P : UnboundedFrontierCarrierDartPairAt inputs a) :
    UnboundedFrontierCarrierLocalSectorRowsAt inputs a where
  left := P.left.dart.head
  right := P.right.dart.head
  left_edge := P.left.carrier_edge
  right_edge := P.right.carrier_edge
  heads_ne := P.heads_ne
  only := P.only

def toNeighborPairAt
    (P : UnboundedFrontierCarrierDartPairAt inputs a) :
    UnboundedFrontierCarrierNeighborPairAt inputs a where
  left := P.left.headVertex
  right := P.right.headVertex
  left_ne_right := by
    intro h
    exact P.heads_ne (congrArg Subtype.val h)
  neighbor_iff := by
    intro b
    constructor
    · intro hb
      rcases P.only b hb with hb | hb
      · exact Or.inl (Subtype.ext hb)
      · exact Or.inr (Subtype.ext hb)
    · intro hb
      rcases hb with hb | hb
      · subst b
        exact P.left.adj
      · subst b
        exact P.right.adj

end UnboundedFrontierCarrierDartPairAt

/-- Dart-pair rows discharge the finite degree-two hypothesis for the concrete
unbounded-frontier carrier. -/
theorem unboundedFrontierCarrierGraph_degree_two_of_dartPairRows
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    [DecidableRel (unboundedFrontierCarrierGraph C inputs).Adj]
    (rows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierDartPairAt inputs a) :
    forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      @SimpleGraph.degree _
        (unboundedFrontierCarrierGraph C inputs) a
        ((unboundedFrontierCarrierGraph C inputs).neighborSetFintype a) =
          2 :=
  unboundedFrontierCarrierGraph_degree_two_of_neighborPairRows
    inputs fun a => (rows a).toNeighborPairAt

/-! ### Preconnected source for the unbounded exterior frontier -/

/-- Closed straight segments are preconnected. -/
theorem closedSegment_isPreconnected
    (a b : PlanarInterface.Point) :
    IsPreconnected (closedSegment a b) := by
  rw [closedSegment_eq_image_Icc]
  exact isPreconnected_Icc.image _
    (continuous_segmentPoint a b).continuousOn

/-- The closed frontier-carrier star at a selected unbounded-frontier vertex:
the vertex point together with all closed selected frontier-edge segments
incident to it in the concrete carrier graph. -/
def unboundedFrontierCarrierStar
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) :
    Set PlanarInterface.Point :=
  {p : PlanarInterface.Point |
    p = (canonicalGraph C).point a.1 ∨
      Exists fun b :
          {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} =>
        (unboundedFrontierCarrierGraph C inputs).Adj a b ∧
          p ∈ closedSegment
            ((canonicalGraph C).point a.1)
            ((canonicalGraph C).point b.1)}

theorem unboundedFrontierCarrierStar_vertex_mem
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) :
    (canonicalGraph C).point a.1 ∈
      unboundedFrontierCarrierStar inputs a :=
  Or.inl rfl

/-- Every closed star of the concrete selected frontier-edge carrier lies on
the actual unbounded exterior frontier.  The open edge pieces are on the
frontier by the definition of `unboundedFrontierEdgeSet`, while endpoints are
selected frontier vertices. -/
theorem unboundedFrontierCarrierStar_subset_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) :
    unboundedFrontierCarrierStar inputs a ⊆
      frontier (unboundedExteriorComponentRows C inputs).exterior := by
  intro p hp
  rcases hp with hvertex | hedge
  · rw [hvertex]
    exact mem_unboundedFrontierVertexSet_iff.1 a.2
  · rcases hedge with ⟨b, hab, hpseg⟩
    rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hpseg with
        hp_left | hp_right | hp_open
    · rw [hp_left]
      exact mem_unboundedFrontierVertexSet_iff.1 a.2
    · rw [hp_right]
      exact mem_unboundedFrontierVertexSet_iff.1 b.2
    · have hwhole :
          UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
        unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
      rcases hab with he | he
      · exact hwhole (a.1, b.1) he p hp_open
      · exact hwhole (b.1, a.1) he p (inOpenSegment_symm hp_open)

/-- Each closed star is preconnected: every point in the star lies on a
closed segment from the center vertex, or is the center itself. -/
theorem unboundedFrontierCarrierStar_preconnected
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) :
    IsPreconnected (unboundedFrontierCarrierStar inputs a) := by
  refine isPreconnected_of_forall ((canonicalGraph C).point a.1) ?_
  intro y hy
  rcases hy with hy | hy
  · refine
      ⟨{(canonicalGraph C).point a.1}, ?_, ?_, ?_,
        isPreconnected_singleton⟩
    · intro z hz
      exact Or.inl (by simpa using hz)
    · simp
    · simpa [hy]
  · rcases hy with ⟨b, hab, hyseg⟩
    refine
      ⟨closedSegment
          ((canonicalGraph C).point a.1)
          ((canonicalGraph C).point b.1),
        ?_, ?_, hyseg,
        closedSegment_isPreconnected _ _⟩
    · intro z hz
      exact Or.inr ⟨b, hab, hz⟩
    · exact left_mem_closedSegment _ _

/-- Adjacent carrier stars intersect, at the shared endpoint of the selected
frontier edge. -/
theorem unboundedFrontierCarrierStar_inter_nonempty_of_adj
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (hab : (unboundedFrontierCarrierGraph C inputs).Adj a b) :
    (unboundedFrontierCarrierStar inputs a ∩
      unboundedFrontierCarrierStar inputs b).Nonempty := by
  refine ⟨(canonicalGraph C).point a.1, ?_, ?_⟩
  · exact unboundedFrontierCarrierStar_vertex_mem a
  · exact Or.inr
      ⟨a, hab.symm,
        right_mem_closedSegment
          ((canonicalGraph C).point b.1)
          ((canonicalGraph C).point a.1)⟩

/-- The geometric carrier of the actual selected unbounded-frontier edges:
the union of the closed straight segments for edges in
`unboundedFrontierEdgeSet`. -/
def unboundedFrontierEdgeCarrierSet
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) :
    Set PlanarInterface.Point :=
  {p : PlanarInterface.Point |
    Exists fun e : PlanarInterface.Edge n =>
      e ∈ unboundedFrontierEdgeSet C inputs ∧
        p ∈ closedSegment
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2)}

/-- The closed segment contributed by one actual selected unbounded-frontier
edge. -/
def unboundedFrontierEdgeCarrierSegment
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (e : {e : PlanarInterface.Edge n // e ∈ unboundedFrontierEdgeSet C inputs}) :
    Set PlanarInterface.Point :=
  closedSegment
    ((canonicalGraph C).point e.1.1)
    ((canonicalGraph C).point e.1.2)

theorem unboundedFrontierEdgeCarrierSet_eq_iUnion_edgeSegments
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C} :
    unboundedFrontierEdgeCarrierSet inputs =
      ⋃ e : {e : PlanarInterface.Edge n //
          e ∈ unboundedFrontierEdgeSet C inputs},
        unboundedFrontierEdgeCarrierSegment inputs e := by
  ext p
  constructor
  · rintro ⟨e, he, hp⟩
    exact Set.mem_iUnion.2
      ⟨⟨e, he⟩, by
        simpa [unboundedFrontierEdgeCarrierSegment] using hp⟩
  · intro hp
    rcases Set.mem_iUnion.1 hp with ⟨e, hpseg⟩
    exact ⟨e.1, e.2, by
      simpa [unboundedFrontierEdgeCarrierSegment] using hpseg⟩

/-- Two actual selected edge-carrier segments meet as geometric subsets.  This
is the edge-level adjacency relation used by the carrier preconnectedness
source below. -/
def unboundedFrontierEdgeCarrierSegmentsMeet
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (e f :
      {e : PlanarInterface.Edge n // e ∈ unboundedFrontierEdgeSet C inputs}) :
    Prop :=
  (unboundedFrontierEdgeCarrierSegment inputs e ∩
    unboundedFrontierEdgeCarrierSegment inputs f).Nonempty

theorem unboundedFrontierEdgeCarrierSegmentsMeet_symm_apply
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e f :
      {e : PlanarInterface.Edge n // e ∈ unboundedFrontierEdgeSet C inputs}} :
    unboundedFrontierEdgeCarrierSegmentsMeet inputs e f ->
      unboundedFrontierEdgeCarrierSegmentsMeet inputs f e := by
  rintro ⟨p, hpe, hpf⟩
  exact ⟨p, hpf, hpe⟩

/-- A shared endpoint gives a genuine intersection of the corresponding closed
selected edge-carrier segments. -/
theorem unboundedFrontierEdgeCarrierSegmentsMeet_of_common_endpoint
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e f :
      {e : PlanarInterface.Edge n // e ∈ unboundedFrontierEdgeSet C inputs}}
    (hcommon :
      e.1.1 = f.1.1 ∨ e.1.1 = f.1.2 ∨
        e.1.2 = f.1.1 ∨ e.1.2 = f.1.2) :
    unboundedFrontierEdgeCarrierSegmentsMeet inputs e f := by
  rcases hcommon with h | h | h | h
  · refine ⟨(canonicalGraph C).point e.1.1, ?_, ?_⟩
    · simpa [unboundedFrontierEdgeCarrierSegment] using
        left_mem_closedSegment
          ((canonicalGraph C).point e.1.1)
          ((canonicalGraph C).point e.1.2)
    · simpa [unboundedFrontierEdgeCarrierSegment, h] using
        left_mem_closedSegment
          ((canonicalGraph C).point f.1.1)
          ((canonicalGraph C).point f.1.2)
  · refine ⟨(canonicalGraph C).point e.1.1, ?_, ?_⟩
    · simpa [unboundedFrontierEdgeCarrierSegment] using
        left_mem_closedSegment
          ((canonicalGraph C).point e.1.1)
          ((canonicalGraph C).point e.1.2)
    · simpa [unboundedFrontierEdgeCarrierSegment, h] using
        right_mem_closedSegment
          ((canonicalGraph C).point f.1.1)
          ((canonicalGraph C).point f.1.2)
  · refine ⟨(canonicalGraph C).point e.1.2, ?_, ?_⟩
    · simpa [unboundedFrontierEdgeCarrierSegment] using
        right_mem_closedSegment
          ((canonicalGraph C).point e.1.1)
          ((canonicalGraph C).point e.1.2)
    · simpa [unboundedFrontierEdgeCarrierSegment, h] using
        left_mem_closedSegment
          ((canonicalGraph C).point f.1.1)
          ((canonicalGraph C).point f.1.2)
  · refine ⟨(canonicalGraph C).point e.1.2, ?_, ?_⟩
    · simpa [unboundedFrontierEdgeCarrierSegment] using
        right_mem_closedSegment
          ((canonicalGraph C).point e.1.1)
          ((canonicalGraph C).point e.1.2)
    · simpa [unboundedFrontierEdgeCarrierSegment, h] using
        right_mem_closedSegment
          ((canonicalGraph C).point f.1.1)
          ((canonicalGraph C).point f.1.2)

/-- If two selected frontier edges are the same unordered edge, their closed
carrier segments meet. -/
theorem unboundedFrontierEdgeCarrierSegmentsMeet_of_eq_or_symm
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e f :
      {e : PlanarInterface.Edge n // e ∈ unboundedFrontierEdgeSet C inputs}}
    (h : e.1 = f.1 ∨ e.1 = (f.1.2, f.1.1)) :
    unboundedFrontierEdgeCarrierSegmentsMeet inputs e f := by
  rcases h with h | h
  · exact
      unboundedFrontierEdgeCarrierSegmentsMeet_of_common_endpoint
        (C := C) (inputs := inputs) (e := e) (f := f)
        (by left; exact congrArg Prod.fst h)
  · exact
      unboundedFrontierEdgeCarrierSegmentsMeet_of_common_endpoint
        (C := C) (inputs := inputs) (e := e) (f := f)
        (by
          right
          left
          simpa using congrArg Prod.fst h)

/-- A chosen actual selected edge for the consecutive tails of a raw
face-successor orbit.  The value is either the forward consecutive edge or its
reverse, according to the supplied membership row. -/
noncomputable def rawFaceSuccOrbitSelectedFrontierEdge
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (hedges :
      forall k : Fin O.period,
        ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
            unboundedFrontierEdgeSet C inputs ∨
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
            (O.dart k).tail) ∈ unboundedFrontierEdgeSet C inputs)
    (k : Fin O.period) :
    {e : PlanarInterface.Edge n // e ∈ unboundedFrontierEdgeSet C inputs} :=
  if h :
      ((O.dart k).tail,
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
          unboundedFrontierEdgeSet C inputs then
    ⟨((O.dart k).tail,
        (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail), h⟩
  else
    ⟨((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
        (O.dart k).tail),
      by
        rcases hedges k with hforward | hreverse
        · exact False.elim (h hforward)
        · exact hreverse⟩

theorem rawFaceSuccOrbitSelectedFrontierEdge_eq_or_symm
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (hedges :
      forall k : Fin O.period,
        ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
            unboundedFrontierEdgeSet C inputs ∨
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
            (O.dart k).tail) ∈ unboundedFrontierEdgeSet C inputs)
    (k : Fin O.period) :
    (rawFaceSuccOrbitSelectedFrontierEdge (inputs := inputs) O hedges k).1 =
        ((O.dart k).tail,
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∨
      (rawFaceSuccOrbitSelectedFrontierEdge (inputs := inputs) O hedges k).1 =
        ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
          (O.dart k).tail) := by
  unfold rawFaceSuccOrbitSelectedFrontierEdge
  by_cases h :
      ((O.dart k).tail,
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
          unboundedFrontierEdgeSet C inputs
  · left
    simp [h]
  · right
    simp [h]

theorem unboundedFrontierEdgeCarrierSegmentsMeet_rawOrbit_selected_of_eq_or_symm
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (hedges :
      forall k : Fin O.period,
        ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
            unboundedFrontierEdgeSet C inputs ∨
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
            (O.dart k).tail) ∈ unboundedFrontierEdgeSet C inputs)
    {e : {e : PlanarInterface.Edge n //
        e ∈ unboundedFrontierEdgeSet C inputs}}
    {k : Fin O.period}
    (he :
      e.1 =
          ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∨
        e.1 =
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
            (O.dart k).tail)) :
    unboundedFrontierEdgeCarrierSegmentsMeet inputs e
      (rawFaceSuccOrbitSelectedFrontierEdge (inputs := inputs) O hedges k) := by
  rcases rawFaceSuccOrbitSelectedFrontierEdge_eq_or_symm
      (inputs := inputs) O hedges k with hraw | hraw
  · rcases he with he | he
    · exact
        unboundedFrontierEdgeCarrierSegmentsMeet_of_eq_or_symm
          (C := C) (inputs := inputs) (e := e)
          (f := rawFaceSuccOrbitSelectedFrontierEdge
            (inputs := inputs) O hedges k)
          (Or.inl (he.trans hraw.symm))
    · exact
        unboundedFrontierEdgeCarrierSegmentsMeet_of_eq_or_symm
          (C := C) (inputs := inputs) (e := e)
          (f := rawFaceSuccOrbitSelectedFrontierEdge
            (inputs := inputs) O hedges k)
          (Or.inr (by
            rw [he, hraw]))
  · rcases he with he | he
    · exact
        unboundedFrontierEdgeCarrierSegmentsMeet_of_eq_or_symm
          (C := C) (inputs := inputs) (e := e)
          (f := rawFaceSuccOrbitSelectedFrontierEdge
            (inputs := inputs) O hedges k)
          (Or.inr (by
            rw [he, hraw]))
    · exact
        unboundedFrontierEdgeCarrierSegmentsMeet_of_eq_or_symm
          (C := C) (inputs := inputs) (e := e)
          (f := rawFaceSuccOrbitSelectedFrontierEdge
            (inputs := inputs) O hedges k)
          (Or.inl (he.trans hraw.symm))

theorem rawFaceSuccOrbitSelectedFrontierEdge_segmentsMeet_succ
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (hedges :
      forall k : Fin O.period,
        ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
            unboundedFrontierEdgeSet C inputs ∨
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
            (O.dart k).tail) ∈ unboundedFrontierEdgeSet C inputs)
    (k : Fin O.period) :
    unboundedFrontierEdgeCarrierSegmentsMeet inputs
      (rawFaceSuccOrbitSelectedFrontierEdge (inputs := inputs) O hedges k)
      (rawFaceSuccOrbitSelectedFrontierEdge (inputs := inputs) O hedges
        (PlanarInterface.cyclicSucc O.period_pos k)) := by
  let next := PlanarInterface.cyclicSucc O.period_pos k
  rcases rawFaceSuccOrbitSelectedFrontierEdge_eq_or_symm
      (inputs := inputs) O hedges k with h | h
  · rcases rawFaceSuccOrbitSelectedFrontierEdge_eq_or_symm
        (inputs := inputs) O hedges next with hnext | hnext
    · exact
        unboundedFrontierEdgeCarrierSegmentsMeet_of_common_endpoint
          (C := C) (inputs := inputs)
          (e := rawFaceSuccOrbitSelectedFrontierEdge
            (inputs := inputs) O hedges k)
          (f := rawFaceSuccOrbitSelectedFrontierEdge
            (inputs := inputs) O hedges next)
          (by
            right
            right
            left
            rw [h, hnext])
    · exact
        unboundedFrontierEdgeCarrierSegmentsMeet_of_common_endpoint
          (C := C) (inputs := inputs)
          (e := rawFaceSuccOrbitSelectedFrontierEdge
            (inputs := inputs) O hedges k)
          (f := rawFaceSuccOrbitSelectedFrontierEdge
            (inputs := inputs) O hedges next)
          (by
            right
            right
            right
            rw [h, hnext])
  · rcases rawFaceSuccOrbitSelectedFrontierEdge_eq_or_symm
        (inputs := inputs) O hedges next with hnext | hnext
    · exact
        unboundedFrontierEdgeCarrierSegmentsMeet_of_common_endpoint
          (C := C) (inputs := inputs)
          (e := rawFaceSuccOrbitSelectedFrontierEdge
            (inputs := inputs) O hedges k)
          (f := rawFaceSuccOrbitSelectedFrontierEdge
            (inputs := inputs) O hedges next)
          (by
            left
            rw [h, hnext])
    · exact
        unboundedFrontierEdgeCarrierSegmentsMeet_of_common_endpoint
          (C := C) (inputs := inputs)
          (e := rawFaceSuccOrbitSelectedFrontierEdge
            (inputs := inputs) O hedges k)
          (f := rawFaceSuccOrbitSelectedFrontierEdge
            (inputs := inputs) O hedges next)
          (by
            right
            left
            rw [h, hnext])

/-- Residual edge-adjacency source for the actual closed-segment carrier: any
two selected unbounded-frontier edges are linked by a chain of selected edge
segments with genuine geometric intersections. -/
def UnboundedFrontierEdgeCarrierSegmentChainConnected
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) :
    Prop :=
  forall e f :
      {e : PlanarInterface.Edge n // e ∈ unboundedFrontierEdgeSet C inputs},
    Relation.ReflTransGen
      (unboundedFrontierEdgeCarrierSegmentsMeet inputs) e f

/-- Raw-orbit selected-edge coverage proves the honest selected-edge segment
chain.  The source rows are exactly: consecutive raw tail edges are actual
selected frontier edges, and every actual selected frontier edge appears among
those consecutive raw tail edges up to orientation. -/
theorem unboundedFrontierEdgeCarrierSegmentChainConnected_of_rawFaceSuccOrbit_edges
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (hedges :
      forall k : Fin O.period,
        ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
            unboundedFrontierEdgeSet C inputs ∨
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
            (O.dart k).tail) ∈ unboundedFrontierEdgeSet C inputs)
    (edge_coverage :
      forall e :
          {e : PlanarInterface.Edge n //
            e ∈ unboundedFrontierEdgeSet C inputs},
        Exists fun k : Fin O.period =>
          e.1 =
              ((O.dart k).tail,
                (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∨
            e.1 =
              ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
                (O.dart k).tail)) :
    UnboundedFrontierEdgeCarrierSegmentChainConnected inputs := by
  intro e f
  let rawEdge :=
    rawFaceSuccOrbitSelectedFrontierEdge (inputs := inputs) O hedges
  let root : Fin O.period := ⟨0, O.period_pos⟩
  have raw_meet_succ :
      forall k : Fin O.period,
        unboundedFrontierEdgeCarrierSegmentsMeet inputs
          (rawEdge k)
          (rawEdge (PlanarInterface.cyclicSucc O.period_pos k)) := by
    intro k
    simpa [rawEdge] using
      rawFaceSuccOrbitSelectedFrontierEdge_segmentsMeet_succ
        (inputs := inputs) O hedges k
  have reach_nat :
      forall m : Nat,
        forall hm : m < O.period,
          Relation.ReflTransGen
            (unboundedFrontierEdgeCarrierSegmentsMeet inputs)
            (rawEdge root)
            (rawEdge ⟨m, hm⟩) := by
    intro m
    induction m with
    | zero =>
        intro hm
        have hidx : (⟨0, hm⟩ : Fin O.period) = root := Fin.ext rfl
        rw [hidx]
    | succ m ih =>
        intro hm
        have hm_prev : m < O.period := by omega
        have hsucc :
            PlanarInterface.cyclicSucc O.period_pos
                (⟨m, hm_prev⟩ : Fin O.period) =
              (⟨m + 1, hm⟩ : Fin O.period) := by
          exact Fin.ext (by
            simp [PlanarInterface.cyclicSucc, Nat.mod_eq_of_lt hm])
        exact
          (ih hm_prev).tail
            (by
              rw [← hsucc]
              exact raw_meet_succ ⟨m, hm_prev⟩)
  have edge_symm :
      Symmetric (unboundedFrontierEdgeCarrierSegmentsMeet inputs) := by
    intro a b h
    rcases h with ⟨p, hpa, hpb⟩
    exact ⟨p, hpb, hpa⟩
  have rtc_symm :
      Symmetric
        (Relation.ReflTransGen
          (unboundedFrontierEdgeCarrierSegmentsMeet inputs)) :=
    Relation.ReflTransGen.symmetric edge_symm
  rcases edge_coverage e with ⟨i, hei⟩
  rcases edge_coverage f with ⟨j, hfj⟩
  have hei_meet :
      unboundedFrontierEdgeCarrierSegmentsMeet inputs e (rawEdge i) := by
    simpa [rawEdge] using
      unboundedFrontierEdgeCarrierSegmentsMeet_rawOrbit_selected_of_eq_or_symm
        (inputs := inputs) O hedges (e := e) (k := i) hei
  have hfj_meet :
      unboundedFrontierEdgeCarrierSegmentsMeet inputs (rawEdge j) f :=
    edge_symm (by
      simpa [rawEdge] using
        unboundedFrontierEdgeCarrierSegmentsMeet_rawOrbit_selected_of_eq_or_symm
          (inputs := inputs) O hedges (e := f) (k := j) hfj)
  have h_i_root :
      Relation.ReflTransGen
        (unboundedFrontierEdgeCarrierSegmentsMeet inputs)
        (rawEdge i) (rawEdge root) :=
    rtc_symm (by
      simpa using reach_nat i.val i.isLt)
  have h_root_j :
      Relation.ReflTransGen
        (unboundedFrontierEdgeCarrierSegmentsMeet inputs)
        (rawEdge root) (rawEdge j) := by
    simpa using reach_nat j.val j.isLt
  exact
    (Relation.ReflTransGen.single hei_meet).trans
      (h_i_root.trans
        (h_root_j.trans (Relation.ReflTransGen.single hfj_meet)))

/-- Claim `S2-agent-edge-carrier-segment-chain-source` (raw-orbit reducer).

This is the sharp raw-orbit source form for the selected frontier-edge segment
chain: the only residual hypothesis is coverage of every actual selected
frontier edge by one of the actual consecutive raw orbit edges, up to
orientation. -/
theorem S2_agent_edge_carrier_segment_chain_source_rawFaceSuccOrbit
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (hedges :
      forall k : Fin O.period,
        ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
            unboundedFrontierEdgeSet C inputs ∨
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
            (O.dart k).tail) ∈ unboundedFrontierEdgeSet C inputs)
    (edge_coverage :
      forall e :
          {e : PlanarInterface.Edge n //
            e ∈ unboundedFrontierEdgeSet C inputs},
        Exists fun k : Fin O.period =>
          e.1 =
              ((O.dart k).tail,
                (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∨
            e.1 =
              ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
                (O.dart k).tail)) :
    UnboundedFrontierEdgeCarrierSegmentChainConnected inputs :=
  unboundedFrontierEdgeCarrierSegmentChainConnected_of_rawFaceSuccOrbit_edges
    (inputs := inputs) O hedges edge_coverage

/-- The actual selected unbounded-frontier edge carrier is preconnected once its
selected closed edge segments are connected by genuine segment-intersection
chains.  This uses local connectedness of each straight edge segment and avoids
carrier-graph connectedness, cyclic coverage, arbitrary cycles, induced
frontier graphs, and downstream S2 rows. -/
theorem unboundedFrontierEdgeCarrierSet_preconnected_of_edgeSegmentChain
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (edge_segment_chain :
      UnboundedFrontierEdgeCarrierSegmentChainConnected inputs) :
    IsPreconnected (unboundedFrontierEdgeCarrierSet inputs) := by
  have hpre :
      IsPreconnected
        (⋃ e : {e : PlanarInterface.Edge n //
            e ∈ unboundedFrontierEdgeSet C inputs},
          unboundedFrontierEdgeCarrierSegment inputs e) := by
    refine
      IsPreconnected.iUnion_of_reflTransGen
        (fun e => ?_) ?_
    · simpa [unboundedFrontierEdgeCarrierSegment] using
        closedSegment_isPreconnected
          ((canonicalGraph C).point e.1.1)
          ((canonicalGraph C).point e.1.2)
    · intro e f
      exact edge_segment_chain e f
  rw [unboundedFrontierEdgeCarrierSet_eq_iUnion_edgeSegments]
  exact hpre

/-- Claim `S2-agent-edge-carrier-preconnected-source`: the closed geometric
carrier of the actual `unboundedFrontierEdgeSet` is preconnected from an honest
edge-intersection chain source. -/
theorem S2_agent_edge_carrier_preconnected_source
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (edge_segment_chain :
      UnboundedFrontierEdgeCarrierSegmentChainConnected inputs) :
    IsPreconnected (unboundedFrontierEdgeCarrierSet inputs) :=
  unboundedFrontierEdgeCarrierSet_preconnected_of_edgeSegmentChain
    (C := C) (inputs := inputs) edge_segment_chain

/-- The concrete edge carrier is contained in the actual unbounded exterior
frontier.  Edge interiors are frontier by the carrier definition; endpoints
are obtained by closing those whole open frontier segments. -/
theorem unboundedFrontierEdgeCarrierSet_subset_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C} :
    unboundedFrontierEdgeCarrierSet inputs ⊆
      frontier (unboundedExteriorComponentRows C inputs).exterior := by
  intro p hp
  rcases hp with ⟨e, he, hpseg⟩
  rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hpseg with
    hp_left | hp_right | hp_open
  · have hend :
        e.1 ∈ unboundedFrontierVertexSet C inputs ∧
          e.2 ∈ unboundedFrontierVertexSet C inputs :=
      endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
        (C := C) (inputs := inputs)
        unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition he
    simpa [hp_left] using mem_unboundedFrontierVertexSet_iff.1 hend.1
  · have hend :
        e.1 ∈ unboundedFrontierVertexSet C inputs ∧
          e.2 ∈ unboundedFrontierVertexSet C inputs :=
      endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
        (C := C) (inputs := inputs)
        unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition he
    simpa [hp_right] using mem_unboundedFrontierVertexSet_iff.1 hend.2
  · exact (mem_unboundedFrontierEdgeSet_iff.1 he).2 p hp_open

/-- A frontier-edge cover identifies the actual frontier with the concrete
closed-segment carrier of `unboundedFrontierEdgeSet`. -/
theorem unboundedFrontierEdgeCarrierSet_eq_frontier_of_frontier_edge_cover
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (frontier_edge_cover :
      forall p : PlanarInterface.Point,
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun e : PlanarInterface.Edge n =>
            e ∈ unboundedFrontierEdgeSet C inputs ∧
              p ∈ closedSegment
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2)) :
    unboundedFrontierEdgeCarrierSet inputs =
      frontier (unboundedExteriorComponentRows C inputs).exterior := by
  exact
    subset_antisymm
      unboundedFrontierEdgeCarrierSet_subset_frontier
      (by
        intro p hp
        exact frontier_edge_cover p hp)

/-- Frontier preconnectedness from the concrete frontier-edge cover and the
single remaining topological row: preconnectedness of the closed-segment
carrier itself.  This avoids assuming connectedness of the finite carrier
graph, cyclic coverage, or any downstream boundary-cycle rows. -/
theorem unboundedExterior_frontier_preconnected_of_frontier_edge_cover_and_edgeCarrier_preconnected
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (frontier_edge_cover :
      forall p : PlanarInterface.Point,
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun e : PlanarInterface.Edge n =>
            e ∈ unboundedFrontierEdgeSet C inputs ∧
              p ∈ closedSegment
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2))
    (edgeCarrier_preconnected :
      IsPreconnected (unboundedFrontierEdgeCarrierSet inputs)) :
    IsPreconnected
      (frontier (unboundedExteriorComponentRows C inputs).exterior) := by
  have hcarrier_eq :
      unboundedFrontierEdgeCarrierSet inputs =
        frontier (unboundedExteriorComponentRows C inputs).exterior :=
    unboundedFrontierEdgeCarrierSet_eq_frontier_of_frontier_edge_cover
      (C := C) (inputs := inputs) frontier_edge_cover
  simpa [hcarrier_eq] using edgeCarrier_preconnected

/-- Claim `S2-agent-frontier-preconnected-from-frontier-edge-cover`.

The frontier-edge cover plus preconnectedness of its concrete closed-segment
carrier source the actual exterior-frontier preconnectedness row. -/
theorem S2_agent_frontier_preconnected_from_frontier_edge_cover
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (frontier_edge_cover :
      forall p : PlanarInterface.Point,
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun e : PlanarInterface.Edge n =>
            e ∈ unboundedFrontierEdgeSet C inputs ∧
              p ∈ closedSegment
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2))
    (edgeCarrier_preconnected :
      IsPreconnected (unboundedFrontierEdgeCarrierSet inputs)) :
    IsPreconnected
      (frontier (unboundedExteriorComponentRows C inputs).exterior) :=
  unboundedExterior_frontier_preconnected_of_frontier_edge_cover_and_edgeCarrier_preconnected
    (C := C) (inputs := inputs) frontier_edge_cover edgeCarrier_preconnected

/-- Claim `S2-agent-frontier-preconnected-source-route`.

The selected-edge segment-chain source proves preconnectedness of the concrete
closed edge carrier; a genuine frontier-edge cover then identifies that carrier
with the actual unbounded exterior frontier.  This route does not use carrier
graph connectedness, a spanning cycle, an induced frontier graph, or any final
S2 wrapper. -/
theorem S2_agent_frontier_preconnected_source_route
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (edge_segment_chain :
      UnboundedFrontierEdgeCarrierSegmentChainConnected inputs)
    (frontier_edge_cover :
      forall p : PlanarInterface.Point,
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun e : PlanarInterface.Edge n =>
            e ∈ unboundedFrontierEdgeSet C inputs ∧
              p ∈ closedSegment
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2)) :
    IsPreconnected
      (frontier (unboundedExteriorComponentRows C inputs).exterior) :=
  S2_agent_frontier_preconnected_from_frontier_edge_cover
    inputs frontier_edge_cover
    (S2_agent_edge_carrier_preconnected_source
      inputs edge_segment_chain)

/-- Compact source rows for the frontier-preconnectedness lane.

The first field connects the selected frontier-edge carrier by overlapping
closed edge segments.  The second identifies every point of the actual
unbounded exterior frontier with one of those selected closed segments. -/
structure UnboundedExteriorFrontierPreconnectedSourceRows
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) : Prop where
  edge_segment_chain :
    UnboundedFrontierEdgeCarrierSegmentChainConnected inputs
  frontier_edge_cover :
    forall p : PlanarInterface.Point,
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
        Exists fun e : PlanarInterface.Edge n =>
          e ∈ unboundedFrontierEdgeSet C inputs ∧
            p ∈ closedSegment
              ((canonicalGraph C).point e.1)
              ((canonicalGraph C).point e.2)

/-- The compact preconnectedness source rows feed the checked S2 local route. -/
theorem unboundedExterior_frontier_preconnected_of_sourceRows
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (rows : UnboundedExteriorFrontierPreconnectedSourceRows inputs) :
    IsPreconnected
      (frontier (unboundedExteriorComponentRows C inputs).exterior) :=
  S2_agent_frontier_preconnected_source_route
    inputs rows.edge_segment_chain rows.frontier_edge_cover

/-- Raw-face-orbit form of
`S2_agent_frontier_preconnected_source_route`: consecutive selected raw orbit
edges and coverage of all selected frontier edges supply the segment-chain row
used to make the frontier preconnected. -/
theorem S2_agent_frontier_preconnected_source_route_rawFaceSuccOrbit
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (hedges :
      forall k : Fin O.period,
        ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
            unboundedFrontierEdgeSet C inputs ∨
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
            (O.dart k).tail) ∈ unboundedFrontierEdgeSet C inputs)
    (edge_coverage :
      forall e :
          {e : PlanarInterface.Edge n //
            e ∈ unboundedFrontierEdgeSet C inputs},
        Exists fun k : Fin O.period =>
          e.1 =
              ((O.dart k).tail,
                (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∨
            e.1 =
              ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
                (O.dart k).tail))
    (frontier_edge_cover :
      forall p : PlanarInterface.Point,
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun e : PlanarInterface.Edge n =>
            e ∈ unboundedFrontierEdgeSet C inputs ∧
              p ∈ closedSegment
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2)) :
    IsPreconnected
      (frontier (unboundedExteriorComponentRows C inputs).exterior) :=
  S2_agent_frontier_preconnected_source_route
    inputs
    (S2_agent_edge_carrier_segment_chain_source_rawFaceSuccOrbit
      (inputs := inputs) O hedges edge_coverage)
    frontier_edge_cover

/-- Frontier-preconnectedness from the selected-edge segment chain plus the
existing frontier-edge-cover reducer whose residual input is the local
nearby-exterior-points row for edge interiors. -/
theorem S2_agent_frontier_preconnected_source_route_of_nearby_edge_point_exterior_points
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (edge_segment_chain :
      UnboundedFrontierEdgeCarrierSegmentChainConnected inputs)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (nearby_edge_point_exterior_points :
      InteriorEdgeNearbyExteriorPointSource C inputs) :
    IsPreconnected
      (frontier (unboundedExteriorComponentRows C inputs).exterior) :=
  S2_agent_frontier_preconnected_source_route
    inputs edge_segment_chain
    (S2_agent_frontier_edge_cover_source_of_nearby_edge_point_exterior_points
      inputs localSectorRows nearby_edge_point_exterior_points)

/-- Fully raw-face-orbit version of the frontier-preconnectedness route, with
the existing frontier-edge-cover reducer plugged in.  The residual rows are
exactly selected consecutive raw orbit edges, selected-edge coverage of the
carrier, local sectors at selected frontier vertices, and the local
nearby-exterior-points source for edge interiors. -/
theorem S2_agent_frontier_preconnected_source_route_rawFaceSuccOrbit_of_nearby_edge_point_exterior_points
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (hedges :
      forall k : Fin O.period,
        ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
            unboundedFrontierEdgeSet C inputs ∨
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
            (O.dart k).tail) ∈ unboundedFrontierEdgeSet C inputs)
    (edge_coverage :
      forall e :
          {e : PlanarInterface.Edge n //
            e ∈ unboundedFrontierEdgeSet C inputs},
        Exists fun k : Fin O.period =>
          e.1 =
              ((O.dart k).tail,
                (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∨
            e.1 =
              ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
                (O.dart k).tail))
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (nearby_edge_point_exterior_points :
      InteriorEdgeNearbyExteriorPointSource C inputs) :
    IsPreconnected
      (frontier (unboundedExteriorComponentRows C inputs).exterior) :=
  S2_agent_frontier_preconnected_source_route_rawFaceSuccOrbit
    O hedges edge_coverage
    (S2_agent_frontier_edge_cover_source_of_nearby_edge_point_exterior_points
      inputs localSectorRows nearby_edge_point_exterior_points)

/-- If the concrete selected frontier-edge carrier is connected and its stars
cover the whole unbounded exterior frontier, then that frontier is
preconnected.  This is the frontier-preconnected row for the
adjacency-closed topology package, reduced to an actual carrier cover rather
than an arbitrary cycle. -/
theorem unboundedExterior_frontier_preconnected_of_carrier_connected_starCover
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (hconn : (unboundedFrontierCarrierGraph C inputs).Connected)
    (hcover :
      frontier (unboundedExteriorComponentRows C inputs).exterior ⊆
        ⋃ a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
          unboundedFrontierCarrierStar inputs a) :
    IsPreconnected
      (frontier (unboundedExteriorComponentRows C inputs).exterior) := by
  let U : Set PlanarInterface.Point :=
    ⋃ a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      unboundedFrontierCarrierStar inputs a
  have hpreU : IsPreconnected U := by
    dsimp [U]
    refine
      IsPreconnected.iUnion_of_reflTransGen
        (fun a => unboundedFrontierCarrierStar_preconnected a) ?_
    intro a b
    have hreach :
        (unboundedFrontierCarrierGraph C inputs).Reachable a b :=
      hconn.preconnected a b
    have hrtg :
        Relation.ReflTransGen
          (unboundedFrontierCarrierGraph C inputs).Adj a b :=
      (SimpleGraph.reachable_iff_reflTransGen
        (G := unboundedFrontierCarrierGraph C inputs) a b).1 hreach
    exact
      Relation.ReflTransGen.mono
        (fun x y hxy =>
          unboundedFrontierCarrierStar_inter_nonempty_of_adj
            (C := C) (inputs := inputs) (a := x) (b := y) hxy)
        hrtg
  have hU_subset :
      U ⊆ frontier (unboundedExteriorComponentRows C inputs).exterior := by
    intro p hp
    rcases Set.mem_iUnion.1 hp with ⟨a, hpa⟩
    exact unboundedFrontierCarrierStar_subset_frontier a hpa
  have hU_eq :
      U = frontier (unboundedExteriorComponentRows C inputs).exterior :=
    subset_antisymm hU_subset hcover
  simpa [hU_eq] using hpreU

/-- Claim `S2-agent-frontier-preconnected-source`: an input-facing source for
the `frontier_preconnected` field.  The remaining honest gap is the stated
`frontier_edge_cover`: every point of the unbounded exterior frontier must lie
on a closed segment of an actual selected unbounded-frontier edge. -/
theorem S2_agent_frontier_preconnected_source
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (hconn : (unboundedFrontierCarrierGraph C inputs).Connected)
    (frontier_edge_cover :
      forall p : PlanarInterface.Point,
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun e : PlanarInterface.Edge n =>
            e ∈ unboundedFrontierEdgeSet C inputs ∧
              p ∈ closedSegment
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2)) :
    IsPreconnected
      (frontier (unboundedExteriorComponentRows C inputs).exterior) := by
  refine
    unboundedExterior_frontier_preconnected_of_carrier_connected_starCover
      (C := C) (inputs := inputs) hconn ?_
  intro p hp
  rcases frontier_edge_cover p hp with ⟨e, he, hpseg⟩
  have hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
    unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
  have hend :
      e.1 ∈ unboundedFrontierVertexSet C inputs ∧
        e.2 ∈ unboundedFrontierVertexSet C inputs :=
    endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
      hwhole he
  let a :
      {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨e.1, hend.1⟩
  let b :
      {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨e.2, hend.2⟩
  refine Set.mem_iUnion.2 ⟨a, ?_⟩
  exact Or.inr
    ⟨b, unboundedFrontierCarrierGraph_adj_of_ordered_edge he, hpseg⟩

/-! ### Topological source for adjacency-closed carrier connectedness -/

/-- The geometric realization of a subset of the concrete unbounded-frontier
carrier: selected frontier vertices, together with relative interiors of
selected frontier edges incident to one of those selected vertices.  For
adjacency-closed subsets, incidence to one selected endpoint forces the other
endpoint to be selected as well. -/
def unboundedFrontierCarrierSubsetRealization
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) :
    Set PlanarInterface.Point :=
  {p : PlanarInterface.Point |
    (Exists fun a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} =>
      a ∈ s ∧ p = (canonicalGraph C).point a.1) ∨
      Exists fun e : PlanarInterface.Edge n =>
        e ∈ unboundedFrontierEdgeSet C inputs ∧
          ((Exists fun a :
              {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} =>
              a ∈ s ∧ a.1 = e.1) ∨
            (Exists fun a :
              {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} =>
              a ∈ s ∧ a.1 = e.2)) ∧
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point e.1)
            ((canonicalGraph C).point e.2)}

/-- A carrier vertex belongs to the geometric realization of an
adjacency-closed carrier subset exactly when it belongs to the subset.  The
edge-interior branch cannot contain a graph vertex. -/
theorem unboundedFrontierCarrierSubsetRealization_vertex_iff
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (_hclosed :
      forall
        {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
        a ∈ s ->
          (unboundedFrontierCarrierGraph C inputs).Adj a b ->
            b ∈ s)
    (a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) :
    (canonicalGraph C).point a.1 ∈
        unboundedFrontierCarrierSubsetRealization inputs s ↔
      a ∈ s := by
  constructor
  · intro hmem
    rcases hmem with hvertex | hedge
    · rcases hvertex with ⟨b, hb, hpoint⟩
      have hval : b.1 = a.1 := by
        exact canonical_point_injective C (Eq.symm hpoint)
      have hba : b = a := Subtype.ext hval
      simpa [hba] using hb
    · rcases hedge with ⟨e, he, _hincident, hpseg⟩
      exact False.elim
        (graph_vertex_inOpenSegment_false_of_adj
          (C := C) (v := a.1) (i := e.1) (j := e.2)
          (unboundedFrontierEdgeSet_adj he) hpseg)
  · intro ha
    exact Or.inl ⟨a, ha, rfl⟩

/-- On the relative interior of one selected frontier edge, membership in an
adjacency-closed carrier-subset realization is equivalent to membership of the
left endpoint of that selected edge. -/
theorem unboundedFrontierCarrierSubsetRealization_inOpenSegment_iff_left_endpoint_mem
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (hclosed :
      forall
        {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
        a ∈ s ->
          (unboundedFrontierCarrierGraph C inputs).Adj a b ->
            b ∈ s)
    {e : PlanarInterface.Edge n} {q : PlanarInterface.Point}
    (he : e ∈ unboundedFrontierEdgeSet C inputs)
    (hq :
      PlanarInterface.InOpenSegment q
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2)) :
    let left :
        {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
      ⟨e.1,
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          (C := C) (inputs := inputs)
          unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition he).1⟩
    q ∈ unboundedFrontierCarrierSubsetRealization inputs s ↔
      left ∈ s := by
  classical
  let hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
    unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
  let endpoints :=
    endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
      (C := C) (inputs := inputs) hwhole he
  let left :
      {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨e.1, endpoints.1⟩
  let right :
      {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨e.2, endpoints.2⟩
  have hleft_right :
      (unboundedFrontierCarrierGraph C inputs).Adj left right :=
    unboundedFrontierCarrierGraph_adj_of_ordered_edge he
  change
    q ∈ unboundedFrontierCarrierSubsetRealization inputs s ↔
      left ∈ s
  constructor
  · intro hmem
    rcases hmem with hvertex | hedge
    · rcases hvertex with ⟨a, _ha, hpoint⟩
      exact False.elim
        (graph_vertex_inOpenSegment_false_of_adj
          (C := C) (v := a.1) (i := e.1) (j := e.2)
          (unboundedFrontierEdgeSet_adj he)
          (by simpa [← hpoint] using hq))
    · rcases hedge with ⟨f, hf, hincident, hqf⟩
      have hfe : f = e :=
        unboundedFrontierEdgeSet_eq_of_common_interior_point
          (e := f) (f := e) hf he hqf hq
      subst f
      rcases hincident with hleft | hright
      · rcases hleft with ⟨a, ha, ha_left⟩
        have h : a = left := Subtype.ext ha_left
        simpa [h] using ha
      · rcases hright with ⟨a, ha, ha_right⟩
        have h : a = right := Subtype.ext ha_right
        have hright_mem : right ∈ s := by simpa [h] using ha
        exact hclosed hright_mem hleft_right.symm
  · intro hleft_mem
    exact Or.inr
      ⟨e, he, Or.inl ⟨left, hleft_mem, rfl⟩, hq⟩

/-- Claim `S2-agent-local-constancy-edge-interior`: at an interior point of a
selected frontier edge, every sufficiently nearby exterior-frontier point has
the same carrier-subset realization membership.  This is the edge-interior
local-constancy row needed by the adjacency-closed topology package, and it
uses only local edge isolation for the actual unbounded exterior frontier. -/
theorem S2_agent_local_constancy_edge_interior
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (hclosed :
      forall
        {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
        a ∈ s ->
          (unboundedFrontierCarrierGraph C inputs).Adj a b ->
            b ∈ s)
    {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
    (he : e ∈ unboundedFrontierEdgeSet C inputs)
    (hp :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2)) :
    Exists fun ε : Real =>
      0 < ε ∧
        forall q : PlanarInterface.Point,
          q ∈ Metric.ball p ε ->
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
              (q ∈ unboundedFrontierCarrierSubsetRealization inputs s ↔
                p ∈ unboundedFrontierCarrierSubsetRealization inputs s) := by
  rcases
      exists_ball_forall_mem_inOpenSegment_of_inOpenSegment
        (C := C) (p := p) (e := e)
        (mem_unboundedFrontierEdgeSet_iff.1 he).1 hp with
    ⟨ε, hεpos, hlocal⟩
  refine ⟨ε, hεpos, ?_⟩
  intro q hqball hqfrontier
  have hqdraw :
      q ∈ embeddedEdgeSet C :=
    (unboundedExteriorComponentRows C inputs).frontier_subset_embeddedEdgeSet
      hqfrontier
  have hqseg :
      PlanarInterface.InOpenSegment q
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2) :=
    hlocal q hqball hqdraw
  exact
    (unboundedFrontierCarrierSubsetRealization_inOpenSegment_iff_left_endpoint_mem
      (C := C) (inputs := inputs) (s := s) hclosed he hqseg).trans
      (unboundedFrontierCarrierSubsetRealization_inOpenSegment_iff_left_endpoint_mem
        (C := C) (inputs := inputs) (s := s) hclosed he hp).symm

/-- Local constancy at a graph-vertex frontier point.

The explicit `frontier_edge_cover` row supplies the honest selected
unbounded-frontier edge through every nearby frontier point.  Vertex-star
isolation then makes that selected edge incident to the centre vertex, and
adjacency-closedness of `s` propagates realization membership across that
single carrier edge. -/
theorem unboundedFrontierCarrierSubsetRealization_local_const_of_vertex_star_frontier_edge_cover
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (frontier_edge_cover :
      forall p : PlanarInterface.Point,
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun e : PlanarInterface.Edge n =>
            e ∈ unboundedFrontierEdgeSet C inputs ∧
              p ∈ closedSegment
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2))
    (s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs})
    (hclosed :
      forall
        {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
        a ∈ s ->
          (unboundedFrontierCarrierGraph C inputs).Adj a b ->
            b ∈ s)
    (a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) :
    Exists fun ε : Real =>
      0 < ε ∧
        forall q : PlanarInterface.Point,
          q ∈ Metric.ball ((canonicalGraph C).point a.1) ε ->
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
              (q ∈ unboundedFrontierCarrierSubsetRealization inputs s ↔
                (canonicalGraph C).point a.1 ∈
                  unboundedFrontierCarrierSubsetRealization inputs s) := by
  rcases
      exists_ball_forall_unboundedExterior_frontier_mem_incident_inOpenSegment_of_vertex_ne
        C inputs a.1 with
    ⟨ε, hεpos, hstar⟩
  refine ⟨ε, hεpos, ?_⟩
  intro q hqball hqfrontier
  by_cases hq_center : q = (canonicalGraph C).point a.1
  · subst q
    rfl
  rcases hstar q hqball hq_center hqfrontier with
    ⟨w, haw, hqaw⟩
  rcases frontier_edge_cover q hqfrontier with ⟨e, he, hqe_closed⟩
  have hqe_open :
      PlanarInterface.InOpenSegment q
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2) := by
    rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hqe_closed with
      hleft | hright | hinside
    · exact False.elim
        (graph_vertex_inOpenSegment_false_of_adj
          (C := C) (v := e.1) (i := a.1) (j := w) haw
          (by simpa [hleft] using hqaw))
    · exact False.elim
        (graph_vertex_inOpenSegment_false_of_adj
          (C := C) (v := e.2) (i := a.1) (j := w) haw
          (by simpa [hright] using hqaw))
    · exact hinside
  have he_same :
      (e.1 = a.1 ∧ e.2 = w) ∨
        (e.1 = w ∧ e.2 = a.1) :=
    unboundedFrontierEdgeSet_same_unordered_of_common_interior_closed_adj
      (C := C) (inputs := inputs) (e := e) (i := a.1) (j := w)
      he haw hqe_open (inOpenSegment_mem_closedSegment hqaw)
  have center_iff :
      (canonicalGraph C).point a.1 ∈
          unboundedFrontierCarrierSubsetRealization inputs s ↔
        a ∈ s :=
    unboundedFrontierCarrierSubsetRealization_vertex_iff
      (C := C) (inputs := inputs) (s := s) hclosed a
  have hq_iff_a :
      q ∈ unboundedFrontierCarrierSubsetRealization inputs s ↔
        a ∈ s := by
    rcases he_same with he_aw | he_wa
    · have heq : e = (a.1, w) := Prod.ext he_aw.1 he_aw.2
      have he_aw_mem :
          (a.1, w) ∈ unboundedFrontierEdgeSet C inputs := by
        simpa [heq] using he
      let endpoints :=
        endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          (C := C) (inputs := inputs)
          unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
          he_aw_mem
      let left :
          {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
        ⟨a.1, endpoints.1⟩
      have hleft_eq : left = a := Subtype.ext rfl
      have hq_left :
          q ∈ unboundedFrontierCarrierSubsetRealization inputs s ↔
            left ∈ s := by
        simpa [left] using
          (unboundedFrontierCarrierSubsetRealization_inOpenSegment_iff_left_endpoint_mem
            (C := C) (inputs := inputs) (s := s) hclosed he_aw_mem hqaw)
      simpa [hleft_eq] using hq_left
    · have heq : e = (w, a.1) := Prod.ext he_wa.1 he_wa.2
      have he_wa_mem :
          (w, a.1) ∈ unboundedFrontierEdgeSet C inputs := by
        simpa [heq] using he
      let endpoints :=
        endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          (C := C) (inputs := inputs)
          unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
          he_wa_mem
      let left :
          {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
        ⟨w, endpoints.1⟩
      have hq_left :
          q ∈ unboundedFrontierCarrierSubsetRealization inputs s ↔
            left ∈ s := by
        simpa [left] using
          (unboundedFrontierCarrierSubsetRealization_inOpenSegment_iff_left_endpoint_mem
            (C := C) (inputs := inputs) (s := s) hclosed he_wa_mem
            (inOpenSegment_symm hqaw))
      have hleft_a :
          (unboundedFrontierCarrierGraph C inputs).Adj left a := by
        exact
          unboundedFrontierCarrierGraph_adj_of_ordered_edge
            (C := C) (inputs := inputs) (a := left) (b := a)
            he_wa_mem
      have ha_left :
          (unboundedFrontierCarrierGraph C inputs).Adj a left := hleft_a.symm
      have hleft_iff_a : left ∈ s ↔ a ∈ s :=
        ⟨fun hleft_mem => hclosed hleft_mem hleft_a,
          fun ha => hclosed ha ha_left⟩
      exact hq_left.trans hleft_iff_a
  exact hq_iff_a.trans center_iff.symm

/-- Claim `S2-agent-local-constancy-vertex-star`: endpoint local constancy for
the adjacency-closed topology route, with the selected frontier-edge cover kept
as an explicit honest input. -/
theorem S2_agent_local_constancy_vertex_star
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (frontier_edge_cover :
      forall p : PlanarInterface.Point,
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun e : PlanarInterface.Edge n =>
            e ∈ unboundedFrontierEdgeSet C inputs ∧
              p ∈ closedSegment
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2))
    (s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs})
    (hclosed :
      forall
        {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
        a ∈ s ->
          (unboundedFrontierCarrierGraph C inputs).Adj a b ->
            b ∈ s)
    (a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) :
    Exists fun ε : Real =>
      0 < ε ∧
        forall q : PlanarInterface.Point,
          q ∈ Metric.ball ((canonicalGraph C).point a.1) ε ->
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
              (q ∈ unboundedFrontierCarrierSubsetRealization inputs s ↔
                (canonicalGraph C).point a.1 ∈
                  unboundedFrontierCarrierSubsetRealization inputs s) :=
  unboundedFrontierCarrierSubsetRealization_local_const_of_vertex_star_frontier_edge_cover
    (C := C) (inputs := inputs) frontier_edge_cover s hclosed a

/-- The precise topology row needed to source the adjacency-closed connectedness
hypothesis for the concrete unbounded-frontier carrier.

It asks for the actual unbounded exterior frontier to be preconnected, and for
every adjacency-closed carrier subset, its concrete geometric realization to be
closed and open relative to that same frontier.  The theorem below then turns
those topology facts into the finite graph `hclosed_all` row. -/
structure UnboundedFrontierCarrierAdjClosedTopologySourceRows
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) : Prop where
  frontier_preconnected :
    IsPreconnected
      (frontier (unboundedExteriorComponentRows C inputs).exterior)
  realization_isClosed :
    forall
      (s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}),
      (forall
        {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
        a ∈ s ->
          (unboundedFrontierCarrierGraph C inputs).Adj a b ->
            b ∈ s) ->
        IsClosed
          ({p :
              {p : PlanarInterface.Point //
                p ∈ frontier
                  (unboundedExteriorComponentRows C inputs).exterior} |
            (p : PlanarInterface.Point) ∈
              unboundedFrontierCarrierSubsetRealization inputs s})
  realization_isOpen :
    forall
      (s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}),
      (forall
        {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
        a ∈ s ->
          (unboundedFrontierCarrierGraph C inputs).Adj a b ->
            b ∈ s) ->
        IsOpen
          ({p :
              {p : PlanarInterface.Point //
                p ∈ frontier
                  (unboundedExteriorComponentRows C inputs).exterior} |
            (p : PlanarInterface.Point) ∈
              unboundedFrontierCarrierSubsetRealization inputs s})

/-- The concrete realization of any selected carrier subset is carried by the
actual unbounded exterior frontier.  Vertex points are on the frontier by the
carrier subtype, while edge-interior points are on the frontier by the
definition of `unboundedFrontierEdgeSet`. -/
theorem unboundedFrontierCarrierSubsetRealization_subset_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}} :
    unboundedFrontierCarrierSubsetRealization inputs s ⊆
      frontier (unboundedExteriorComponentRows C inputs).exterior := by
  intro p hp
  rcases hp with hvertex | hedge
  · rcases hvertex with ⟨a, _ha, rfl⟩
    exact mem_unboundedFrontierVertexSet_iff.1 a.2
  · rcases hedge with ⟨e, he, _hincident, hpseg⟩
    exact (mem_unboundedFrontierEdgeSet_iff.1 he).2 p hpseg

/-- Relative openness source for a carrier-subset realization: it is enough to
prove pointwise that every realized point has an ambient ball whose
intersection with the actual unbounded frontier stays realized. -/
theorem unboundedFrontierCarrierSubsetRealization_relative_isOpen_of_local
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (hlocal :
      forall p :
          {p : PlanarInterface.Point //
            p ∈ frontier
              (unboundedExteriorComponentRows C inputs).exterior},
        (p : PlanarInterface.Point) ∈
            unboundedFrontierCarrierSubsetRealization inputs s ->
          Exists fun ε : Real =>
            0 < ε ∧
              forall q : PlanarInterface.Point,
                q ∈ Metric.ball (p : PlanarInterface.Point) ε ->
                  q ∈ frontier
                    (unboundedExteriorComponentRows C inputs).exterior ->
                    q ∈ unboundedFrontierCarrierSubsetRealization inputs s) :
    IsOpen
      ({p :
          {p : PlanarInterface.Point //
            p ∈ frontier
              (unboundedExteriorComponentRows C inputs).exterior} |
        (p : PlanarInterface.Point) ∈
          unboundedFrontierCarrierSubsetRealization inputs s}) := by
  rw [Metric.isOpen_iff]
  intro p hp
  rcases hlocal p hp with ⟨ε, hεpos, hε⟩
  refine ⟨ε, hεpos, ?_⟩
  intro q hqball
  have hqball' :
      (q : PlanarInterface.Point) ∈
        Metric.ball (p : PlanarInterface.Point) ε := by
    simpa [Metric.mem_ball] using hqball
  exact hε (q : PlanarInterface.Point) hqball' q.2

/-- Relative closedness source for a carrier-subset realization: it is enough
to prove pointwise that every frontier point outside the realization has an
ambient ball whose intersection with the actual unbounded frontier stays
outside the realization. -/
theorem unboundedFrontierCarrierSubsetRealization_relative_isClosed_of_local_compl
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (hlocal :
      forall p :
          {p : PlanarInterface.Point //
            p ∈ frontier
              (unboundedExteriorComponentRows C inputs).exterior},
        (p : PlanarInterface.Point) ∉
            unboundedFrontierCarrierSubsetRealization inputs s ->
          Exists fun ε : Real =>
            0 < ε ∧
              forall q : PlanarInterface.Point,
                q ∈ Metric.ball (p : PlanarInterface.Point) ε ->
                  q ∈ frontier
                    (unboundedExteriorComponentRows C inputs).exterior ->
                    q ∉ unboundedFrontierCarrierSubsetRealization inputs s) :
    IsClosed
      ({p :
          {p : PlanarInterface.Point //
            p ∈ frontier
              (unboundedExteriorComponentRows C inputs).exterior} |
        (p : PlanarInterface.Point) ∈
          unboundedFrontierCarrierSubsetRealization inputs s}) := by
  rw [← isOpen_compl_iff]
  rw [Metric.isOpen_iff]
  intro p hp
  change
    (p : PlanarInterface.Point) ∉
      unboundedFrontierCarrierSubsetRealization inputs s at hp
  rcases hlocal p hp with ⟨ε, hεpos, hε⟩
  refine ⟨ε, hεpos, ?_⟩
  intro q hqball
  change
    (q : PlanarInterface.Point) ∉
      unboundedFrontierCarrierSubsetRealization inputs s
  have hqball' :
      (q : PlanarInterface.Point) ∈
        Metric.ball (p : PlanarInterface.Point) ε := by
    simpa [Metric.mem_ball] using hqball
  exact hε (q : PlanarInterface.Point) hqball' q.2

/-- Assemble the adjacency-closed topology rows from the real source
obligations: connectedness of the actual unbounded frontier, local complement
stability for relative closedness, and local realization stability for
relative openness. -/
theorem unboundedFrontierCarrierAdjClosedTopologyRows_of_local_stability
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (frontier_preconnected :
      IsPreconnected
        (frontier (unboundedExteriorComponentRows C inputs).exterior))
    (closed_local :
      forall
        (s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}),
        (forall
          {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
          a ∈ s ->
            (unboundedFrontierCarrierGraph C inputs).Adj a b ->
              b ∈ s) ->
          forall p :
              {p : PlanarInterface.Point //
                p ∈ frontier
                  (unboundedExteriorComponentRows C inputs).exterior},
            (p : PlanarInterface.Point) ∉
                unboundedFrontierCarrierSubsetRealization inputs s ->
              Exists fun ε : Real =>
                0 < ε ∧
                  forall q : PlanarInterface.Point,
                    q ∈ Metric.ball (p : PlanarInterface.Point) ε ->
                      q ∈ frontier
                        (unboundedExteriorComponentRows C inputs).exterior ->
                        q ∉
                          unboundedFrontierCarrierSubsetRealization inputs s)
    (open_local :
      forall
        (s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}),
        (forall
          {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
          a ∈ s ->
            (unboundedFrontierCarrierGraph C inputs).Adj a b ->
              b ∈ s) ->
          forall p :
              {p : PlanarInterface.Point //
                p ∈ frontier
                  (unboundedExteriorComponentRows C inputs).exterior},
            (p : PlanarInterface.Point) ∈
                unboundedFrontierCarrierSubsetRealization inputs s ->
              Exists fun ε : Real =>
                0 < ε ∧
                  forall q : PlanarInterface.Point,
                    q ∈ Metric.ball (p : PlanarInterface.Point) ε ->
                      q ∈ frontier
                        (unboundedExteriorComponentRows C inputs).exterior ->
                        q ∈
                          unboundedFrontierCarrierSubsetRealization inputs s) :
    UnboundedFrontierCarrierAdjClosedTopologySourceRows inputs := by
  refine
    { frontier_preconnected := frontier_preconnected
      realization_isClosed := ?_
      realization_isOpen := ?_ }
  · intro s hclosed
    exact
      unboundedFrontierCarrierSubsetRealization_relative_isClosed_of_local_compl
        (C := C) (inputs := inputs) (s := s)
        (closed_local s hclosed)
  · intro s hclosed
    exact
      unboundedFrontierCarrierSubsetRealization_relative_isOpen_of_local
        (C := C) (inputs := inputs) (s := s)
        (open_local s hclosed)

/-- A single local constancy row for the carrier-subset realization supplies
both relative closedness and relative openness in the adjacency-closed topology
package.  This keeps the remaining geometric work focused on proving that the
actual exterior frontier is locally one selected carrier edge or vertex star. -/
theorem unboundedFrontierCarrierAdjClosedTopologyRows_of_frontier_preconnected_local_const
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (frontier_preconnected :
      IsPreconnected
        (frontier (unboundedExteriorComponentRows C inputs).exterior))
    (local_const :
      forall
        (s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}),
        (forall
          {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
          a ∈ s ->
            (unboundedFrontierCarrierGraph C inputs).Adj a b ->
              b ∈ s) ->
          forall p :
              {p : PlanarInterface.Point //
                p ∈ frontier
                  (unboundedExteriorComponentRows C inputs).exterior},
            Exists fun ε : Real =>
              0 < ε ∧
                forall q : PlanarInterface.Point,
                  q ∈ Metric.ball (p : PlanarInterface.Point) ε ->
                    q ∈ frontier
                      (unboundedExteriorComponentRows C inputs).exterior ->
                      (q ∈
                          unboundedFrontierCarrierSubsetRealization inputs s ↔
                        (p : PlanarInterface.Point) ∈
                          unboundedFrontierCarrierSubsetRealization inputs s)) :
    UnboundedFrontierCarrierAdjClosedTopologySourceRows inputs := by
  refine
    unboundedFrontierCarrierAdjClosedTopologyRows_of_local_stability
      (C := C) (inputs := inputs)
      frontier_preconnected ?_ ?_
  · intro s hclosed p hpnot
    rcases local_const s hclosed p with ⟨ε, hεpos, hε⟩
    refine ⟨ε, hεpos, ?_⟩
    intro q hqball hqfrontier hqmem
    exact hpnot ((hε q hqball hqfrontier).1 hqmem)
  · intro s hclosed p hpmem
    rcases local_const s hclosed p with ⟨ε, hεpos, hε⟩
    refine ⟨ε, hεpos, ?_⟩
    intro q hqball hqfrontier
    exact (hε q hqball hqfrontier).2 hpmem

/-- On a selected concrete frontier edge, membership in an adjacency-closed
carrier-subset realization agrees along the whole closed edge segment.
The reference value is membership of the left endpoint in the subset. -/
theorem unboundedFrontierCarrierSubsetRealization_mem_closedSegment_edge_iff_left
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (hclosed :
      forall
        {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
        a ∈ s ->
          (unboundedFrontierCarrierGraph C inputs).Adj a b ->
            b ∈ s)
    {e : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs)
    {p : PlanarInterface.Point}
    (hp :
      p ∈ closedSegment
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2)) :
    p ∈ unboundedFrontierCarrierSubsetRealization inputs s ↔
      (⟨e.1,
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
          he).1⟩ :
        {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) ∈ s := by
  let hwhole : UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
    unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
  let hend := endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
    hwhole he
  let a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨e.1, hend.1⟩
  let b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨e.2, hend.2⟩
  have hab : (unboundedFrontierCarrierGraph C inputs).Adj a b :=
    unboundedFrontierCarrierGraph_adj_of_ordered_edge he
  change
    p ∈ unboundedFrontierCarrierSubsetRealization inputs s ↔ a ∈ s
  constructor
  · intro hmem
    rcases hmem with hvertex | hedge
    · rcases hvertex with ⟨c, hc, hpc⟩
      have hcseg :
          (canonicalGraph C).point c.1 ∈ closedSegment
            ((canonicalGraph C).point e.1)
            ((canonicalGraph C).point e.2) := by
        simpa [hpc] using hp
      rcases
          graph_vertex_on_unit_edge_segment_is_endpoint
            (C := C) (v := c.1) (i := e.1) (j := e.2)
            (unboundedFrontierEdgeSet_adj he) hcseg with
        hc_left | hc_right
      · have hca : c = a := Subtype.ext hc_left
        simpa [hca] using hc
      · have hcb : c = b := Subtype.ext hc_right
        have hb : b ∈ s := by
          simpa [hcb] using hc
        exact hclosed hb hab.symm
    · rcases hedge with ⟨f, hf, hincident, hfopen⟩
      have hfeq : f = e :=
        unboundedFrontierEdgeSet_eq_of_common_interior_closed_point
          hf (mem_unboundedFrontierEdgeSet_iff.1 he).1 hfopen hp
      subst f
      rcases hincident with hleft | hright
      · rcases hleft with ⟨c, hc, hc_eq⟩
        have hca : c = a := Subtype.ext hc_eq
        simpa [hca] using hc
      · rcases hright with ⟨c, hc, hc_eq⟩
        have hcb : c = b := Subtype.ext hc_eq
        have hb : b ∈ s := by
          simpa [hcb] using hc
        exact hclosed hb hab.symm
  · intro ha
    rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hp with
      hp_left | hp_right | hp_open
    · have hp_a : p = (canonicalGraph C).point a.1 := by
        change p = (canonicalGraph C).point e.1
        exact hp_left
      exact Or.inl ⟨a, ha, hp_a⟩
    · have hb : b ∈ s := hclosed ha hab
      have hp_b : p = (canonicalGraph C).point b.1 := by
        change p = (canonicalGraph C).point e.2
        exact hp_right
      exact Or.inl ⟨b, hb, hp_b⟩
    · exact Or.inr ⟨e, he, Or.inl ⟨a, ha, rfl⟩, hp_open⟩

/-- Edge-interior local constancy for adjacency-closed carrier-subset
realizations.  Near an interior point of a selected concrete frontier edge,
the exterior frontier is carried by that same closed edge segment, so the
previous edge-constancy lemma applies. -/
theorem unboundedFrontierCarrierSubsetRealization_local_const_of_edgeInterior
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (hclosed :
      forall
        {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
        a ∈ s ->
          (unboundedFrontierCarrierGraph C inputs).Adj a b ->
            b ∈ s)
    {e : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs)
    {p : PlanarInterface.Point}
    (hp :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2)) :
    Exists fun ε : Real =>
      0 < ε ∧
        forall q : PlanarInterface.Point,
          q ∈ Metric.ball p ε ->
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
              (q ∈ unboundedFrontierCarrierSubsetRealization inputs s ↔
                p ∈ unboundedFrontierCarrierSubsetRealization inputs s) := by
  let rows : UnboundedExteriorFrontierEdgeLocalRows C inputs e p :=
    unboundedExterior_frontierEdgeLocalRows_of_inOpenSegment_frontier
      (mem_unboundedFrontierEdgeSet_iff.1 he).1 hp
      ((mem_unboundedFrontierEdgeSet_iff.1 he).2 p hp)
  rcases rows.exists_local_radius with ⟨ε, hεpos, _hdraw, hfrontier_closed⟩
  refine ⟨ε, hεpos, ?_⟩
  intro q hqball hqfrontier
  have hp_closed :
      p ∈ closedSegment
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2) :=
    inOpenSegment_mem_closedSegment hp
  have hq_closed :
      q ∈ closedSegment
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2) :=
    hfrontier_closed q hqball hqfrontier
  let hqiff :=
    unboundedFrontierCarrierSubsetRealization_mem_closedSegment_edge_iff_left
      (C := C) (inputs := inputs) (s := s) hclosed he hq_closed
  let hpiff :=
    unboundedFrontierCarrierSubsetRealization_mem_closedSegment_edge_iff_left
      (C := C) (inputs := inputs) (s := s) hclosed he hp_closed
  constructor
  · intro hqmem
    exact hpiff.2 (hqiff.1 hqmem)
  · intro hpmem
    exact hqiff.2 (hpiff.1 hpmem)

/-- Vertex local constancy from a real frontier-edge cover.  After shrinking
around the vertex, noncenter frontier points lie in the relative interior of
some incident canonical edge.  The frontier-edge cover then identifies that
incident edge with an actual selected carrier edge, so adjacency-closedness
propagates membership exactly across the local star. -/
theorem unboundedFrontierCarrierSubsetRealization_local_const_of_vertex_frontier_edge_cover
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (frontier_edge_cover :
      forall p : PlanarInterface.Point,
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun e : PlanarInterface.Edge n =>
            e ∈ unboundedFrontierEdgeSet C inputs ∧
              p ∈ closedSegment
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2))
    {s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (hclosed :
      forall
        {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
        a ∈ s ->
          (unboundedFrontierCarrierGraph C inputs).Adj a b ->
            b ∈ s)
    {v : Fin n}
    (hvfrontier :
      (canonicalGraph C).point v ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior) :
    Exists fun ε : Real =>
      0 < ε ∧
        forall q : PlanarInterface.Point,
          q ∈ Metric.ball ((canonicalGraph C).point v) ε ->
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
              (q ∈ unboundedFrontierCarrierSubsetRealization inputs s ↔
                (canonicalGraph C).point v ∈
                  unboundedFrontierCarrierSubsetRealization inputs s) := by
  rcases
      exists_ball_forall_unboundedExterior_frontier_mem_incident_inOpenSegment_of_vertex_ne
        C inputs v with
    ⟨ε, hεpos, hlocal⟩
  refine ⟨ε, hεpos, ?_⟩
  intro q hqball hqfrontier
  let a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨v, mem_unboundedFrontierVertexSet_iff.2 hvfrontier⟩
  by_cases hqv : q = (canonicalGraph C).point v
  · subst q
    exact Iff.rfl
  · rcases hlocal q hqball hqv hqfrontier with ⟨w, hvw, hqopen⟩
    rcases frontier_edge_cover q hqfrontier with ⟨f, hf, hqfseg⟩
    have hqfopen :
        PlanarInterface.InOpenSegment q
          ((canonicalGraph C).point f.1)
          ((canonicalGraph C).point f.2) := by
      rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hqfseg with
        hf_left | hf_right | hf_open
      · exact False.elim
          ((graph_vertex_not_inOpenSegment_of_adj
            (C := C) (v := f.1) hvw) (by simpa [hf_left] using hqopen))
      · exact False.elim
          ((graph_vertex_not_inOpenSegment_of_adj
            (C := C) (v := f.2) hvw) (by simpa [hf_right] using hqopen))
      · exact hf_open
    have hsame :
        (f.1 = v ∧ f.2 = w) ∨ (f.1 = w ∧ f.2 = v) :=
      unboundedFrontierEdgeSet_same_unordered_of_common_interior_closed_adj
        (C := C) (inputs := inputs) (e := f) (i := v) (j := w)
        hf hvw hqfopen (inOpenSegment_mem_closedSegment hqopen)
    let hwhole : UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
      unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
    let hend :=
      endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
        hwhole hf
    let left : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
      ⟨f.1, hend.1⟩
    let right : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
      ⟨f.2, hend.2⟩
    have hq_iff_left :
        q ∈ unboundedFrontierCarrierSubsetRealization inputs s ↔
          left ∈ s :=
      unboundedFrontierCarrierSubsetRealization_mem_closedSegment_edge_iff_left
        (C := C) (inputs := inputs) (s := s) hclosed hf hqfseg
    have hv_iff_a :
        (canonicalGraph C).point v ∈
            unboundedFrontierCarrierSubsetRealization inputs s ↔
          a ∈ s :=
      unboundedFrontierCarrierSubsetRealization_vertex_iff
        (C := C) (inputs := inputs) (s := s) hclosed a
    have hleft_iff_a : left ∈ s ↔ a ∈ s := by
      rcases hsame with hsame | hsame
      · have hleft_eq : left = a := Subtype.ext hsame.1
        simp [hleft_eq]
      · have hright_eq : right = a := Subtype.ext hsame.2
        have hlr : (unboundedFrontierCarrierGraph C inputs).Adj left right :=
          unboundedFrontierCarrierGraph_adj_of_ordered_edge hf
        constructor
        · intro hleft
          have hright : right ∈ s := hclosed hleft hlr
          simpa [hright_eq] using hright
        · intro ha
          have hright : right ∈ s := by
            simpa [hright_eq] using ha
          exact hclosed hright hlr.symm
    constructor
    · intro hqmem
      exact hv_iff_a.2 (hleft_iff_a.1 (hq_iff_left.1 hqmem))
    · intro hvmem
      exact hq_iff_left.2 (hleft_iff_a.2 (hv_iff_a.1 hvmem))

/-- Claim `S2-agent-local-constancy-frontier-edge-cover`: non-circular
adjacency-closed topology source from an actual frontier preconnectedness row
and a genuine frontier-edge cover.  The proof uses edge-interior isolation for
interior cover points and vertex-star isolation plus the same cover for
endpoint cases; no carrier connectedness, cyclic coverage, or downstream S2
cycle rows enter. -/
theorem unboundedFrontierCarrierAdjClosedTopologyRows_of_frontier_preconnected_and_frontier_edge_cover
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (frontier_preconnected :
      IsPreconnected
        (frontier (unboundedExteriorComponentRows C inputs).exterior))
    (frontier_edge_cover :
      forall p : PlanarInterface.Point,
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun e : PlanarInterface.Edge n =>
            e ∈ unboundedFrontierEdgeSet C inputs ∧
              p ∈ closedSegment
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2)) :
    UnboundedFrontierCarrierAdjClosedTopologySourceRows inputs := by
  refine
    unboundedFrontierCarrierAdjClosedTopologyRows_of_frontier_preconnected_local_const
      (C := C) (inputs := inputs) frontier_preconnected ?_
  intro s hclosed p
  rcases frontier_edge_cover (p : PlanarInterface.Point) p.2 with
    ⟨e, he, hpseg⟩
  rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hpseg with
    hp_left | hp_right | hp_open
  · have hvfrontier :
        (canonicalGraph C).point e.1 ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior := by
      simpa [hp_left] using p.2
    rcases
        unboundedFrontierCarrierSubsetRealization_local_const_of_vertex_frontier_edge_cover
          (C := C) (inputs := inputs) frontier_edge_cover hclosed
          (v := e.1) hvfrontier with
      ⟨ε, hεpos, hε⟩
    refine ⟨ε, hεpos, ?_⟩
    intro q hqball hqfrontier
    have hqball' :
        q ∈ Metric.ball ((canonicalGraph C).point e.1) ε := by
      simpa [hp_left] using hqball
    simpa [hp_left] using hε q hqball' hqfrontier
  · have hvfrontier :
        (canonicalGraph C).point e.2 ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior := by
      simpa [hp_right] using p.2
    rcases
        unboundedFrontierCarrierSubsetRealization_local_const_of_vertex_frontier_edge_cover
          (C := C) (inputs := inputs) frontier_edge_cover hclosed
          (v := e.2) hvfrontier with
      ⟨ε, hεpos, hε⟩
    refine ⟨ε, hεpos, ?_⟩
    intro q hqball hqfrontier
    have hqball' :
        q ∈ Metric.ball ((canonicalGraph C).point e.2) ε := by
      simpa [hp_right] using hqball
    simpa [hp_right] using hε q hqball' hqfrontier
  · exact
      unboundedFrontierCarrierSubsetRealization_local_const_of_edgeInterior
        (C := C) (inputs := inputs) (s := s) hclosed he hp_open

/-- Claim `S2-agent-carrier-realization-clopen-source`: the relative
closed/open realization fields for adjacency-closed carrier subsets, packaged
in the exact shape consumed by
`unboundedFrontierCarrierGraph_nonempty_adjClosed_all_of_topologyRows`.

The proof is deliberately local: `closed_local` and `open_local` are the
pointwise frontier-neighborhood rows produced by the edge/vertex isolation
arguments, and no cyclic coverage or downstream boundary-cycle rows enter. -/
theorem S2_agent_carrier_realization_clopen_source
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (closed_local :
      forall
        (s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}),
        (forall
          {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
          a ∈ s ->
            (unboundedFrontierCarrierGraph C inputs).Adj a b ->
              b ∈ s) ->
          forall p :
              {p : PlanarInterface.Point //
                p ∈ frontier
                  (unboundedExteriorComponentRows C inputs).exterior},
            (p : PlanarInterface.Point) ∉
                unboundedFrontierCarrierSubsetRealization inputs s ->
              Exists fun ε : Real =>
                0 < ε ∧
                  forall q : PlanarInterface.Point,
                    q ∈ Metric.ball (p : PlanarInterface.Point) ε ->
                      q ∈ frontier
                        (unboundedExteriorComponentRows C inputs).exterior ->
                        q ∉
                          unboundedFrontierCarrierSubsetRealization inputs s)
    (open_local :
      forall
        (s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}),
        (forall
          {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
          a ∈ s ->
            (unboundedFrontierCarrierGraph C inputs).Adj a b ->
              b ∈ s) ->
          forall p :
              {p : PlanarInterface.Point //
                p ∈ frontier
                  (unboundedExteriorComponentRows C inputs).exterior},
            (p : PlanarInterface.Point) ∈
                unboundedFrontierCarrierSubsetRealization inputs s ->
              Exists fun ε : Real =>
                0 < ε ∧
                  forall q : PlanarInterface.Point,
                    q ∈ Metric.ball (p : PlanarInterface.Point) ε ->
                      q ∈ frontier
                        (unboundedExteriorComponentRows C inputs).exterior ->
                        q ∈
                          unboundedFrontierCarrierSubsetRealization inputs s) :
    forall
      (s : Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}),
      (forall
        {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
        a ∈ s ->
          (unboundedFrontierCarrierGraph C inputs).Adj a b ->
            b ∈ s) ->
        IsClosed
            ({p :
                {p : PlanarInterface.Point //
                  p ∈ frontier
                    (unboundedExteriorComponentRows C inputs).exterior} |
              (p : PlanarInterface.Point) ∈
                unboundedFrontierCarrierSubsetRealization inputs s}) ∧
          IsOpen
            ({p :
                {p : PlanarInterface.Point //
                  p ∈ frontier
                    (unboundedExteriorComponentRows C inputs).exterior} |
              (p : PlanarInterface.Point) ∈
                unboundedFrontierCarrierSubsetRealization inputs s}) := by
  intro s hclosed
  exact
    ⟨unboundedFrontierCarrierSubsetRealization_relative_isClosed_of_local_compl
        (C := C) (inputs := inputs) (s := s) (closed_local s hclosed),
      unboundedFrontierCarrierSubsetRealization_relative_isOpen_of_local
        (C := C) (inputs := inputs) (s := s) (open_local s hclosed)⟩

/-- Actual-topology source for the `hclosed_all` hypothesis of
`unboundedFrontierCarrierGraph_connected_of_nonempty_adjClosed_all`: in a
preconnected unbounded exterior frontier, a nonempty adjacency-closed carrier
realization that is relatively clopen must contain every frontier carrier
vertex. -/
theorem unboundedFrontierCarrierGraph_nonempty_adjClosed_all_of_topologyRows
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (rows : UnboundedFrontierCarrierAdjClosedTopologySourceRows inputs) :
    forall s :
        Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      s.Nonempty ->
        (forall
          {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
          a ∈ s ->
            (unboundedFrontierCarrierGraph C inputs).Adj a b ->
              b ∈ s) ->
          forall v :
            {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
            v ∈ s := by
  intro s hs hclosed v
  let frontierSubtype : Set PlanarInterface.Point :=
    frontier (unboundedExteriorComponentRows C inputs).exterior
  let realizationOnFrontier : Set frontierSubtype :=
    {p : frontierSubtype |
      (p : PlanarInterface.Point) ∈
        unboundedFrontierCarrierSubsetRealization inputs s}
  have hpre :
      IsPreconnected (Set.univ : Set frontierSubtype) := by
    haveI : PreconnectedSpace frontierSubtype :=
      Subtype.preconnectedSpace (by
        simpa [frontierSubtype] using rows.frontier_preconnected)
    exact preconnectedSpace_iff_univ.mp inferInstance
  have hclosed_realization : IsClosed realizationOnFrontier := by
    simpa [realizationOnFrontier, frontierSubtype] using
      rows.realization_isClosed s hclosed
  have hopen_realization : IsOpen realizationOnFrontier := by
    simpa [realizationOnFrontier, frontierSubtype] using
      rows.realization_isOpen s hclosed
  have hnonempty : (Set.univ ∩ realizationOnFrontier).Nonempty := by
    rcases hs with ⟨root, hroot⟩
    refine ⟨⟨(canonicalGraph C).point root.1, ?_⟩, ?_⟩
    · exact mem_unboundedFrontierVertexSet_iff.1 root.2
    · exact
        ⟨Set.mem_univ _,
          (unboundedFrontierCarrierSubsetRealization_vertex_iff
            (C := C) (inputs := inputs) (s := s) hclosed root).2 hroot⟩
  have hsubset :
      (Set.univ : Set frontierSubtype) ⊆ realizationOnFrontier :=
    hpre.subset_isClopen
      ⟨hclosed_realization, hopen_realization⟩ hnonempty
  have hvfrontier :
      (canonicalGraph C).point v.1 ∈ frontierSubtype := by
    exact mem_unboundedFrontierVertexSet_iff.1 v.2
  have hvrealization :
      (⟨(canonicalGraph C).point v.1, hvfrontier⟩ :
        frontierSubtype) ∈ realizationOnFrontier :=
    hsubset (Set.mem_univ _)
  exact
    (unboundedFrontierCarrierSubsetRealization_vertex_iff
      (C := C) (inputs := inputs) (s := s) hclosed v).1 hvrealization

/-! ### Connectedness bookkeeping for a cyclic exterior boundary carrier -/

section ConnectedClosedSubsetGraph

variable {V : Type u}

/-- In a connected simple graph, any nonempty vertex set closed under
adjacency is all vertices. -/
theorem simpleGraph_forall_mem_of_connected_nonempty_adjClosed
    {G : SimpleGraph V} {s : Set V}
    (hconn : G.Connected)
    (hs : s.Nonempty)
    (hclosed : forall {a b : V}, a ∈ s -> G.Adj a b -> b ∈ s) :
    forall v : V, v ∈ s := by
  rcases hs with ⟨root, hroot⟩
  have hwalk :
      forall {a b : V}, G.Walk a b -> a ∈ s -> b ∈ s := by
    intro a b p
    induction p with
    | nil =>
        intro ha
        simpa using ha
    | cons h p ih =>
        intro ha
        exact ih (hclosed ha h)
  intro v
  rcases hconn.preconnected root v with ⟨p⟩
  exact hwalk p hroot

/-- Conversely, a nonempty simple graph is connected if every nonempty vertex
set closed under adjacency is all vertices.  This is the finite-carrier
closure shape needed by a direct topology route: topology may prove that a
proper carrier component cannot be both nonempty and adjacency-closed, and
this lemma turns that into graph connectedness without manufacturing a cycle. -/
theorem simpleGraph_connected_of_nonempty_forall_nonempty_adjClosed
    {G : SimpleGraph V}
    (hV : Nonempty V)
    (hclosed_all :
      forall s : Set V,
        s.Nonempty ->
          (forall {a b : V}, a ∈ s -> G.Adj a b -> b ∈ s) ->
            forall v : V, v ∈ s) :
    G.Connected := by
  rw [SimpleGraph.connected_iff]
  constructor
  · intro u v
    let s : Set V := {w : V | G.Reachable u w}
    have hs : s.Nonempty := by
      exact ⟨u, ⟨SimpleGraph.Walk.nil⟩⟩
    have hclosed : forall {a b : V}, a ∈ s -> G.Adj a b -> b ∈ s := by
      intro a b ha hab
      exact ha.trans hab.reachable
    exact hclosed_all s hs hclosed v
  · exact hV

end ConnectedClosedSubsetGraph

/-- A root-reachability row is enough to prove connectedness of the concrete
unbounded-frontier carrier.  The exterior face-orbit proof should provide the
root and reachability of all carrier vertices along successive frontier edges. -/
theorem unboundedFrontierCarrierGraph_connected_of_exists_reachable_root
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (hroot :
      Exists fun root :
        {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} =>
          forall x :
            {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
              (unboundedFrontierCarrierGraph C inputs).Reachable root x) :
    (unboundedFrontierCarrierGraph C inputs).Connected :=
  (SimpleGraph.connected_iff_exists_forall_reachable
    (G := unboundedFrontierCarrierGraph C inputs)).2 hroot

/-- Direct finite-carrier closure criterion for the concrete unbounded-frontier
carrier.  A topology proof can use this by proving that any nonempty selected
carrier subset closed under all selected frontier edges already contains every
selected frontier vertex. -/
theorem unboundedFrontierCarrierGraph_connected_of_nonempty_adjClosed_all
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (hV :
      Nonempty
        {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs})
    (hclosed_all :
      forall s :
          Set {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        s.Nonempty ->
          (forall
            {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
            a ∈ s ->
              (unboundedFrontierCarrierGraph C inputs).Adj a b ->
                b ∈ s) ->
            forall v :
              {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
              v ∈ s) :
    (unboundedFrontierCarrierGraph C inputs).Connected :=
  simpleGraph_connected_of_nonempty_forall_nonempty_adjClosed
    (G := unboundedFrontierCarrierGraph C inputs) hV hclosed_all

/-- Connectedness of the concrete carrier from the exact connected-frontier
topology rows.  This is the direct connectedness route: no cyclic coverage or
Jordan facade is used here. -/
theorem unboundedFrontierCarrierGraph_connected_of_adjClosed_topologyRows
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (hV :
      Nonempty
        {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs})
    (rows : UnboundedFrontierCarrierAdjClosedTopologySourceRows inputs) :
    (unboundedFrontierCarrierGraph C inputs).Connected :=
  unboundedFrontierCarrierGraph_connected_of_nonempty_adjClosed_all
    inputs hV
    (unboundedFrontierCarrierGraph_nonempty_adjClosed_all_of_topologyRows
      inputs rows)

/-- A genuine frontier-edge cover makes the concrete carrier vertex type
nonempty.  This removes the auxiliary nonemptiness row from the source-facing
connectedness handoff below. -/
theorem unboundedFrontierCarrier_nonempty_of_frontier_edge_cover
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (frontier_edge_cover :
      forall p : PlanarInterface.Point,
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun e : PlanarInterface.Edge n =>
            e ∈ unboundedFrontierEdgeSet C inputs ∧
              p ∈ closedSegment
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2)) :
    Nonempty {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} := by
  rcases unboundedExterior_frontier_nonempty C inputs with ⟨p, hp⟩
  rcases frontier_edge_cover p hp with ⟨e, he, _hpseg⟩
  let hend :=
    endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
      unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition he
  exact ⟨⟨e.1, hend.1⟩⟩

/-- Claim `S2-agent-frontier-cover-to-connected-carrier-integration`.

Honest source rows for the actual unbounded exterior frontier produce
connectedness of the concrete carrier.  The proof first builds the selected
frontier-edge cover from local-sector rows and the interior relative-closure
row, then feeds that cover and frontier preconnectedness through the checked
adjacency-closed topology reducer.  It assumes no cyclic coverage, arbitrary
cycle, induced frontier graph, or downstream S2 cycle row. -/
theorem S2_agent_frontier_cover_to_connected_carrier_integration
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (frontier_preconnected :
      IsPreconnected
        (frontier (unboundedExteriorComponentRows C inputs).exterior))
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (interior_relative_ball_closure :
      forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
        e ∈ (canonicalGraph C).edgeSet ->
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
          forall q : PlanarInterface.Point,
            PlanarInterface.InOpenSegment q
              ((canonicalGraph C).point e.1)
              ((canonicalGraph C).point e.2) ->
            q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
              Exists fun r : Real =>
                0 < r ∧
                  forall z : PlanarInterface.Point,
                    z ∈ Metric.ball q r ->
                    PlanarInterface.InOpenSegment z
                      ((canonicalGraph C).point e.1)
                      ((canonicalGraph C).point e.2) ->
                    z ∈ closure
                      (unboundedExteriorComponentRows C inputs).exterior) :
    (unboundedFrontierCarrierGraph C inputs).Connected := by
  let frontier_edge_cover :=
    S2_agent_frontier_edge_cover_source
      inputs localSectorRows interior_relative_ball_closure
  let topologyRows :=
    unboundedFrontierCarrierAdjClosedTopologyRows_of_frontier_preconnected_and_frontier_edge_cover
      (C := C) (inputs := inputs) frontier_preconnected frontier_edge_cover
  let frontier_vertices_nonempty :
      Nonempty {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    unboundedFrontierCarrier_nonempty_of_frontier_edge_cover
      inputs frontier_edge_cover
  exact
    unboundedFrontierCarrierGraph_connected_of_adjClosed_topologyRows
      inputs frontier_vertices_nonempty topologyRows

/-- Connected-carrier integration with
`S2-agent-interior-relative-ball-closure-source` plugged in.  The proof path is
the same frontier-cover/topology reducer; the residual local row is the
nearby-exterior-points source rather than the already-converted relative
closure row. -/
theorem S2_agent_frontier_cover_to_connected_carrier_integration_of_nearby_edge_point_exterior_points
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (frontier_preconnected :
      IsPreconnected
        (frontier (unboundedExteriorComponentRows C inputs).exterior))
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (nearby_edge_point_exterior_points :
      InteriorEdgeNearbyExteriorPointSource C inputs) :
    (unboundedFrontierCarrierGraph C inputs).Connected :=
  S2_agent_frontier_cover_to_connected_carrier_integration
    inputs frontier_preconnected localSectorRows
    (S2_agent_interior_relative_ball_closure_source
      nearby_edge_point_exterior_points)

/-- Connected-carrier integration with the interior-edge source reduced to the
exact local statement that an edge with a relative-interior frontier point is
already a selected unbounded-frontier carrier edge. -/
theorem S2_agent_frontier_cover_to_connected_carrier_integration_of_interior_frontier_edge_carrier_membership
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (frontier_preconnected :
      IsPreconnected
        (frontier (unboundedExteriorComponentRows C inputs).exterior))
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (interior_edge_mem :
      InteriorFrontierEdgeCarrierMembershipSource C inputs) :
    (unboundedFrontierCarrierGraph C inputs).Connected :=
  S2_agent_frontier_cover_to_connected_carrier_integration_of_nearby_edge_point_exterior_points
    inputs frontier_preconnected localSectorRows
    (interiorEdgeNearbyExteriorPointSource_of_interior_frontier_edge_carrier_membership
      interior_edge_mem)

/-- Cyclic coverage rows for the concrete unbounded-frontier carrier.  This is
the finite graph output expected from the exterior face-orbit proof: a cyclic
list of frontier vertices, carrier adjacencies along the cycle graph, and
coverage of every carrier vertex. -/
structure UnboundedFrontierCarrierCyclicCoverageRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) where
  length : Nat
  length_pos : 0 < length
  vertex :
    Fin length -> {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}
  cycle_adj :
    forall {i j : Fin length},
      (SimpleGraph.cycleGraph length).Adj i j ->
        (unboundedFrontierCarrierGraph C inputs).Adj (vertex i) (vertex j)
  coverage :
    forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      Exists fun k : Fin length => vertex k = a

/-- Cyclic coverage rows prove connectedness of the concrete carrier. -/
theorem unboundedFrontierCarrierGraph_connected_of_cyclicCoverageRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (rows : UnboundedFrontierCarrierCyclicCoverageRows C inputs) :
    (unboundedFrontierCarrierGraph C inputs).Connected :=
  simpleGraph_connected_of_cycleGraph_surjective_hom
    (G := unboundedFrontierCarrierGraph C inputs)
    rows.length_pos rows.vertex
    (by
      intro i j hij
      exact rows.cycle_adj hij)
    rows.coverage

/-- Boundary-cycle projection of concrete carrier cyclic coverage.

If a proposed genuine boundary cycle is pointwise the same cyclic list as a
coverage row for the actual unbounded-frontier carrier, then its vertices are
exactly the graph vertices on the selected unbounded exterior frontier.  This
is only a projection lemma: the source work remains the honest construction of
the cyclic coverage rows and their identification with the chosen boundary. -/
theorem frontier_iff_boundaryCycle_vertex_of_cyclicCoverageRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
    (rows : UnboundedFrontierCarrierCyclicCoverageRows C inputs)
    (hlength : rows.length = B.length)
    (vertex_eq_boundary :
      forall k : Fin rows.length,
        (rows.vertex k).1 = B.vertex (Fin.cast hlength k)) :
    forall v : Fin n,
      (canonicalGraph C).point v ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ↔
        Exists fun k : Fin B.length => B.vertex k = v := by
  intro v
  constructor
  · intro hv
    rcases
        (unboundedFrontierCarrierGraph_vertex_image_iff_frontier
          C inputs v).1 hv with
      ⟨a, ha⟩
    rcases rows.coverage a with ⟨k, hk⟩
    refine ⟨Fin.cast hlength k, ?_⟩
    have hval : (rows.vertex k).1 = a.1 := congrArg Subtype.val hk
    exact (vertex_eq_boundary k).symm.trans (hval.trans ha)
  · rintro ⟨k, hk⟩
    let j : Fin rows.length := Fin.cast hlength.symm k
    have hcast : Fin.cast hlength j = k := by
      ext
      simp [j]
    have hval : (rows.vertex j).1 = v := by
      exact (vertex_eq_boundary j).trans (by simpa [hcast] using hk)
    exact
      (unboundedFrontierCarrierGraph_vertex_image_iff_frontier
        C inputs v).2
        ⟨rows.vertex j, hval⟩

theorem fin_add_one_eq_cyclicSucc_add_two
    {m : Nat} (i : Fin (m + 2)) :
    (i + 1 : Fin (m + 2)) =
      PlanarInterface.cyclicSucc (by omega : 0 < m + 2) i := by
  ext
  simp [PlanarInterface.cyclicSucc, Fin.val_add, Nat.add_mod]

/-- In a cycle graph of length at least three, adjacency means exactly the
successor/predecessor relation for the repository cyclic indexing convention. -/
theorem cycleGraph_adj_eq_cyclicSucc_or_eq_cyclicPred
    {m : Nat} (hm : 0 < m) (hm3 : 3 <= m) {i j : Fin m}
    (hij : (SimpleGraph.cycleGraph m).Adj i j) :
    j = PlanarInterface.cyclicSucc hm i ∨
      j = PlanarInterface.cyclicPred hm i := by
  cases m with
  | zero => omega
  | succ m1 =>
    cases m1 with
    | zero => omega
    | succ t =>
      change (SimpleGraph.cycleGraph (t + 2)).Adj i j at hij
      rw [SimpleGraph.cycleGraph_adj] at hij
      rcases hij with hij | hij
      · right
        have hi : i = j + 1 := (sub_eq_iff_eq_add').1 hij
        have hsucc :
            i =
              PlanarInterface.cyclicSucc (by omega : 0 < t + 2) j := by
          simpa [fin_add_one_eq_cyclicSucc_add_two j] using hi
        calc
          j =
              PlanarInterface.cyclicPred (by omega : 0 < t + 2)
                (PlanarInterface.cyclicSucc (by omega : 0 < t + 2) j) := by
            exact
              (PlanarInterface.cyclicPred_cyclicSucc
                (by omega : 0 < t + 2) j).symm
          _ = PlanarInterface.cyclicPred (by omega : 0 < t + 2) i := by
            rw [hsucc]
      · left
        have hj : j = i + 1 := (sub_eq_iff_eq_add').1 hij
        simpa [fin_add_one_eq_cyclicSucc_add_two i] using hj

/-- A cycle graph of length at least three is two-regular. -/
theorem cycleGraph_degree_two_of_three_le
    {m : Nat} (hm3 : 3 <= m) (v : Fin m) :
    (SimpleGraph.cycleGraph m).degree v = 2 := by
  cases m with
  | zero => omega
  | succ m1 =>
    cases m1 with
    | zero => omega
    | succ m2 =>
      cases m2 with
      | zero => omega
      | succ t =>
        change (SimpleGraph.cycleGraph (t + 3)).degree v = 2
        exact SimpleGraph.cycleGraph_degree_three_le (n := t) (v := v)

/-- Successor adjacencies around a cyclic list, together with coverage of all
concrete carrier vertices, fill the cyclic coverage rows for the concrete
unbounded-frontier carrier. -/
def unboundedFrontierCarrierCyclicCoverageRows_of_succAdj_coverage
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {m : Nat} (hm : 0 < m) (hm3 : 3 <= m)
    (vertex :
      Fin m -> {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs})
    (succ_adj :
      forall k : Fin m,
        (unboundedFrontierCarrierGraph C inputs).Adj
          (vertex k)
          (vertex (PlanarInterface.cyclicSucc hm k)))
    (coverage :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        Exists fun k : Fin m => vertex k = a) :
    UnboundedFrontierCarrierCyclicCoverageRows C inputs where
  length := m
  length_pos := hm
  vertex := vertex
  cycle_adj := by
    intro i j hij
    rcases cycleGraph_adj_eq_cyclicSucc_or_eq_cyclicPred hm hm3 hij with
      hsucc | hpred
    · subst j
      exact succ_adj i
    · subst j
      have hpred_succ : PlanarInterface.cyclicSucc hm
          (PlanarInterface.cyclicPred hm i) = i :=
        PlanarInterface.cyclicSucc_cyclicPred hm i
      exact (unboundedFrontierCarrierGraph C inputs).symm (by
        simpa [hpred_succ] using
          succ_adj (PlanarInterface.cyclicPred hm i))
  coverage := coverage

/-- Connectedness of the concrete unbounded-frontier carrier, together with
the local sector rows at each carrier vertex, gives the cyclic coverage rows
for that same concrete carrier.  The finite graph cycle is supplied by
`connected_two_regular_spanning_cycle`; this helper only reindexes its closed
walk into the repository's cyclic-successor row format. -/
noncomputable def unboundedFrontierCarrierCyclicCoverageRows_of_connected_localSectorRows
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    [DecidableRel (unboundedFrontierCarrierGraph C inputs).Adj]
    (hconn : (unboundedFrontierCarrierGraph C inputs).Connected)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a) :
    UnboundedFrontierCarrierCyclicCoverageRows C inputs := by
  classical
  let G := unboundedFrontierCarrierGraph C inputs
  have hdegree_two :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        @SimpleGraph.degree _ G a (G.neighborSetFintype a) = 2 := by
    simpa [G] using
      unboundedFrontierCarrierGraph_degree_two_of_localSectorRows
        inputs localSectorRows
  let hspan := connected_two_regular_spanning_cycle G hconn hdegree_two
  let base := Classical.choose hspan
  let hw_exists := Classical.choose_spec hspan
  let w := Classical.choose hw_exists
  have hw : w.IsCycle ∧
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        Set.Mem w.toSubgraph.verts a :=
    Classical.choose_spec hw_exists
  have hwcycle : w.IsCycle := hw.1
  have hwspan :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        Set.Mem w.toSubgraph.verts a := hw.2
  have hlen_pos : 0 < w.length := by
    have hthree : 3 <= w.length := hwcycle.three_le_length
    omega
  have hlen_three : 3 <= w.length := hwcycle.three_le_length
  refine
    unboundedFrontierCarrierCyclicCoverageRows_of_succAdj_coverage
      (C := C) (inputs := inputs)
      hlen_pos hlen_three
      (fun k => w.getVert k.val)
      ?succ_adj
      ?coverage
  · intro k
    have hklt : k.val < w.length := k.isLt
    have hstep :
        G.Adj (w.getVert k.val) (w.getVert (k.val + 1)) :=
      w.adj_getVert_succ hklt
    by_cases hwrap : k.val + 1 = w.length
    · simpa [G, PlanarInterface.cyclicSucc, hwrap,
        SimpleGraph.Walk.getVert_length, SimpleGraph.Walk.getVert_zero] using
        hstep
    · have hlt : k.val + 1 < w.length := by omega
      simpa [G, PlanarInterface.cyclicSucc, Nat.mod_eq_of_lt hlt] using
        hstep
  · intro a
    have hvset : Set.Mem w.toSubgraph.verts a := hwspan a
    have hvlist : List.Mem a w.support :=
      (w.mem_verts_toSubgraph).1 hvset
    rcases (SimpleGraph.Walk.mem_support_iff_exists_getVert).1 hvlist with
      ⟨m, hm_eq, hm_le⟩
    by_cases hmlt : m < w.length
    · exact ⟨⟨m, hmlt⟩, by simpa using hm_eq⟩
    · have hm_eq_len : m = w.length := by omega
      exact ⟨⟨0, hlen_pos⟩, by
        change w.getVert 0 = a
        simpa [hm_eq_len, SimpleGraph.Walk.getVert_length,
          SimpleGraph.Walk.getVert_zero] using hm_eq⟩

/-- A genuine boundary cycle whose vertices are exactly the unbounded exterior
frontier vertices and whose consecutive edges are selected frontier-carrier
edges supplies cyclic coverage of the concrete carrier. -/
def unboundedFrontierCarrierCyclicCoverageRows_of_boundaryCycle
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
    (frontier_iff_cycle_vertex :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin B.length => B.vertex k = v)
    (cycle_edge_mem :
      forall k : Fin B.length,
        (B.vertex k,
            B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
            unboundedFrontierEdgeSet C inputs ∨
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
            B.vertex k) ∈
            unboundedFrontierEdgeSet C inputs) :
    UnboundedFrontierCarrierCyclicCoverageRows C inputs :=
  unboundedFrontierCarrierCyclicCoverageRows_of_succAdj_coverage
    (C := C) (inputs := inputs)
    B.length_pos B.length_ge_three
    (fun k =>
      ⟨B.vertex k,
        mem_unboundedFrontierVertexSet_iff.2
          ((frontier_iff_cycle_vertex (B.vertex k)).2 ⟨k, rfl⟩)⟩)
    (by
      intro k
      rcases cycle_edge_mem k with h | h
      · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge h
      · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm h)
    (by
      intro a
      have hfrontier :
          (canonicalGraph C).point a.1 ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior :=
        mem_unboundedFrontierVertexSet_iff.1 a.2
      rcases (frontier_iff_cycle_vertex a.1).1 hfrontier with ⟨k, hk⟩
      exact ⟨k, Subtype.ext hk⟩)

def unboundedFrontierCarrierCyclicCoverageRows_of_boundaryCycle_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
    (frontier_iff_cycle_vertex :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin B.length => B.vertex k = v)
    (cycle_edge_openSegment_frontier :
      forall k : Fin B.length,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (B.vertex k))
            ((canonicalGraph C).point
              (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    UnboundedFrontierCarrierCyclicCoverageRows C inputs :=
  unboundedFrontierCarrierCyclicCoverageRows_of_boundaryCycle
    B frontier_iff_cycle_vertex
    (cycle_edge_mem_unboundedFrontierEdgeSet_or_symm_of_openSegment_frontier
      cycle_edge_openSegment_frontier)

/-- A raw face-successor orbit that traces exactly the unbounded exterior
frontier supplies cyclic coverage of the concrete frontier carrier.  This is
the connectedness half of the orbit route; injectivity and local sector
exclusion are handled by separate rows. -/
def unboundedFrontierCarrierCyclicCoverageRows_of_rawFaceSuccOrbit
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (period_ge_three : 3 <= O.period)
    (frontier_iff_tail :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin O.period => (O.dart k).tail = v)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    UnboundedFrontierCarrierCyclicCoverageRows C inputs :=
  unboundedFrontierCarrierCyclicCoverageRows_of_succAdj_coverage
    (C := C) (inputs := inputs)
    O.period_pos period_ge_three
    (fun k =>
      ⟨(O.dart k).tail,
        mem_unboundedFrontierVertexSet_iff.2
          ((frontier_iff_tail (O.dart k).tail).2 ⟨k, rfl⟩)⟩)
    (by
      intro k
      have hhead :
          (O.dart k).head =
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail :=
        R.endpoint_chaining_of_faceSucc_eq_next
          (O.faceSucc_dart_eq_cyclicSucc k)
      have hadj :
          (canonicalGraph C).Adj
            (O.dart k).tail
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail := by
        simpa [hhead] using (O.dart k).canonicalAdj
      have hfront :=
        edge_openSegment_frontier k
      have hedge :
          ((O.dart k).tail,
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
              unboundedFrontierEdgeSet C inputs ∨
            ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
              (O.dart k).tail) ∈
              unboundedFrontierEdgeSet C inputs :=
        unboundedFrontierEdgeSet_or_symm_of_adj_openSegment_frontier
          (C := C) (inputs := inputs) hadj hfront
      rcases hedge with hedge | hedge
      · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge hedge
      · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm hedge)
    (by
      intro a
      have hfrontier :
          (canonicalGraph C).point a.1 ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior :=
        mem_unboundedFrontierVertexSet_iff.1 a.2
      rcases (frontier_iff_tail a.1).1 hfrontier with ⟨k, hk⟩
      exact ⟨k, Subtype.ext hk⟩)

/-- Connectedness corollary for a raw face-successor orbit that traces the
unbounded exterior frontier. -/
theorem unboundedFrontierCarrierGraph_connected_of_rawFaceSuccOrbit
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (period_ge_three : 3 <= O.period)
    (frontier_iff_tail :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin O.period => (O.dart k).tail = v)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    (unboundedFrontierCarrierGraph C inputs).Connected :=
  unboundedFrontierCarrierGraph_connected_of_cyclicCoverageRows
    (unboundedFrontierCarrierCyclicCoverageRows_of_rawFaceSuccOrbit
      O period_ge_three frontier_iff_tail edge_openSegment_frontier)

/-! ### Face-orbit rows for the concrete carrier reducers -/

/-- Local rows turning a genuine exterior face-dart orbit into the concrete
unbounded-frontier carrier interface.

The fields are intentionally combinatorial at the carrier boundary: the orbit
vertices are exactly the unbounded-frontier graph vertices, every orbit edge
has its open segment on the exterior frontier, and carrier neighbours incident
to an orbit vertex are only the predecessor and successor orbit vertices. -/
structure FaceDartOrbitExteriorCarrierRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) where
  rotation : UnitDistanceRotationSystem C
  orbit : FaceDartOrbit C rotation
  frontier_iff_orbit_vertex :
    forall v : Fin n,
      (canonicalGraph C).point v ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ↔
        Exists fun k : Fin orbit.boundary.length =>
          orbit.boundary.vertex k = v
  orbit_edge_openSegment_frontier :
    forall k : Fin orbit.boundary.length,
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (orbit.boundary.vertex k))
          ((canonicalGraph C).point
            (orbit.boundary.vertex
              (PlanarInterface.cyclicSucc orbit.boundary.length_pos k))) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior
  incident_only_pred_succ :
    forall k : Fin orbit.boundary.length,
      forall a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        a.1 = orbit.boundary.vertex k ->
          (unboundedFrontierCarrierGraph C inputs).Adj a b ->
            b.1 =
                orbit.boundary.vertex
                  (PlanarInterface.cyclicPred orbit.boundary.length_pos k) ∨
              b.1 =
                orbit.boundary.vertex
                  (PlanarInterface.cyclicSucc orbit.boundary.length_pos k)

namespace FaceDartOrbitExteriorCarrierRows

variable {C : _root_.UDConfig n}
variable {inputs : FinitePlanarOuterComponentInputs C}

def carrierVertex (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    (k : Fin rows.orbit.boundary.length) :
    {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
  ⟨rows.orbit.boundary.vertex k,
    mem_unboundedFrontierVertexSet_iff.2
      ((rows.frontier_iff_orbit_vertex (rows.orbit.boundary.vertex k)).2
        ⟨k, rfl⟩)⟩

theorem orbit_edge_mem_unboundedFrontierEdgeSet
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    (k : Fin rows.orbit.boundary.length) :
    (rows.orbit.boundary.vertex k,
        rows.orbit.boundary.vertex
          (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k)) ∈
        unboundedFrontierEdgeSet C inputs ∨
      (rows.orbit.boundary.vertex
          (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k),
        rows.orbit.boundary.vertex k) ∈
        unboundedFrontierEdgeSet C inputs := by
  exact
    cycle_edge_mem_unboundedFrontierEdgeSet_or_symm_of_openSegment_frontier
      rows.orbit_edge_openSegment_frontier k

/-- A selected ordered edge for the `k`-th geometric orbit side, packaged with
the fact that its endpoints are exactly the two consecutive orbit vertices. -/
noncomputable def orbitCarrierEdgeWithEndpoints
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    (k : Fin rows.orbit.boundary.length) :
    {e : PlanarInterface.Edge n //
      e ∈ unboundedFrontierEdgeSet C inputs ∧
        ((e.1 = rows.orbit.boundary.vertex k ∧
            e.2 =
              rows.orbit.boundary.vertex
                (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k)) ∨
          (e.1 =
              rows.orbit.boundary.vertex
                (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k) ∧
            e.2 = rows.orbit.boundary.vertex k))} := by
  classical
  refine Classical.choice ?_
  rcases rows.orbit_edge_mem_unboundedFrontierEdgeSet k with h | h
  · exact
      ⟨(rows.orbit.boundary.vertex k,
          rows.orbit.boundary.vertex
            (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k)),
        h, Or.inl ⟨rfl, rfl⟩⟩
  · exact
      ⟨(rows.orbit.boundary.vertex
            (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k),
          rows.orbit.boundary.vertex k),
        h, Or.inr ⟨rfl, rfl⟩⟩

/-- The selected carrier edge underlying the `k`-th geometric orbit side. -/
noncomputable def orbitCarrierEdge
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    (k : Fin rows.orbit.boundary.length) :
    {e : PlanarInterface.Edge n // e ∈ unboundedFrontierEdgeSet C inputs} :=
  ⟨(rows.orbitCarrierEdgeWithEndpoints k).1,
    (rows.orbitCarrierEdgeWithEndpoints k).2.1⟩

theorem orbitCarrierEdge_endpoint_or
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    (k : Fin rows.orbit.boundary.length) :
    (((rows.orbitCarrierEdge k).1.1 = rows.orbit.boundary.vertex k ∧
        (rows.orbitCarrierEdge k).1.2 =
          rows.orbit.boundary.vertex
            (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k)) ∨
      ((rows.orbitCarrierEdge k).1.1 =
          rows.orbit.boundary.vertex
            (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k) ∧
        (rows.orbitCarrierEdge k).1.2 = rows.orbit.boundary.vertex k)) := by
  simpa [orbitCarrierEdge] using
    (rows.orbitCarrierEdgeWithEndpoints k).2.2

theorem orbitCarrierEdge_has_vertex_endpoint
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    (k : Fin rows.orbit.boundary.length) :
    (rows.orbitCarrierEdge k).1.1 = rows.orbit.boundary.vertex k ∨
      (rows.orbitCarrierEdge k).1.2 = rows.orbit.boundary.vertex k := by
  rcases rows.orbitCarrierEdge_endpoint_or k with h | h
  · exact Or.inl h.1
  · exact Or.inr h.2

theorem orbitCarrierEdge_has_succ_endpoint
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    (k : Fin rows.orbit.boundary.length) :
    (rows.orbitCarrierEdge k).1.1 =
        rows.orbit.boundary.vertex
          (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k) ∨
      (rows.orbitCarrierEdge k).1.2 =
        rows.orbit.boundary.vertex
          (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k) := by
  rcases rows.orbitCarrierEdge_endpoint_or k with h | h
  · exact Or.inr h.2
  · exact Or.inl h.1

/-- Consecutive selected orbit sides have a genuine closed-segment
intersection at their common orbit vertex. -/
theorem orbitCarrierEdge_segmentsMeet_succ
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    (k : Fin rows.orbit.boundary.length) :
    unboundedFrontierEdgeCarrierSegmentsMeet inputs
      (rows.orbitCarrierEdge k)
      (rows.orbitCarrierEdge
        (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k)) := by
  have hleft := rows.orbitCarrierEdge_has_succ_endpoint k
  have hright :=
    rows.orbitCarrierEdge_has_vertex_endpoint
      (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k)
  rcases hleft with hleft | hleft <;> rcases hright with hright | hright
  · exact
      unboundedFrontierEdgeCarrierSegmentsMeet_of_common_endpoint
        (C := C) (inputs := inputs)
        (e := rows.orbitCarrierEdge k)
        (f := rows.orbitCarrierEdge
          (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k))
        (Or.inl (hleft.trans hright.symm))
  · exact
      unboundedFrontierEdgeCarrierSegmentsMeet_of_common_endpoint
        (C := C) (inputs := inputs)
        (e := rows.orbitCarrierEdge k)
        (f := rows.orbitCarrierEdge
          (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k))
        (Or.inr (Or.inl (hleft.trans hright.symm)))
  · exact
      unboundedFrontierEdgeCarrierSegmentsMeet_of_common_endpoint
        (C := C) (inputs := inputs)
        (e := rows.orbitCarrierEdge k)
        (f := rows.orbitCarrierEdge
          (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k))
        (Or.inr (Or.inr (Or.inl (hleft.trans hright.symm))))
  · exact
      unboundedFrontierEdgeCarrierSegmentsMeet_of_common_endpoint
        (C := C) (inputs := inputs)
        (e := rows.orbitCarrierEdge k)
        (f := rows.orbitCarrierEdge
          (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k))
        (Or.inr (Or.inr (Or.inr (hleft.trans hright.symm))))

/-- Every selected unbounded-frontier edge touches one of the actual geometric
face-orbit carrier edges. -/
theorem selectedEdge_segmentsMeet_orbitCarrierEdge
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    (e : {e : PlanarInterface.Edge n //
      e ∈ unboundedFrontierEdgeSet C inputs}) :
    Exists fun k : Fin rows.orbit.boundary.length =>
      unboundedFrontierEdgeCarrierSegmentsMeet inputs e
        (rows.orbitCarrierEdge k) := by
  classical
  let hwhole : UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
    unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
  let hend :=
    endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
      hwhole e.2
  let a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨e.1.1, hend.1⟩
  let b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨e.1.2, hend.2⟩
  have hab : (unboundedFrontierCarrierGraph C inputs).Adj a b :=
    unboundedFrontierCarrierGraph_adj_of_ordered_edge e.2
  have hfrontier :
      (canonicalGraph C).point a.1 ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior :=
    mem_unboundedFrontierVertexSet_iff.1 a.2
  let k : Fin rows.orbit.boundary.length :=
    Classical.choose ((rows.frontier_iff_orbit_vertex a.1).1 hfrontier)
  have hk : rows.orbit.boundary.vertex k = a.1 :=
    Classical.choose_spec ((rows.frontier_iff_orbit_vertex a.1).1 hfrontier)
  rcases rows.incident_only_pred_succ k a b hk.symm hab with hpred | hsucc
  · let pred := PlanarInterface.cyclicPred rows.orbit.boundary.length_pos k
    refine ⟨pred, ?_⟩
    have hsucc_pred :
        PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos pred = k := by
      dsimp [pred]
      exact PlanarInterface.cyclicSucc_cyclicPred
        rows.orbit.boundary.length_pos k
    have hendpoint :
        (rows.orbitCarrierEdge pred).1.1 = a.1 ∨
          (rows.orbitCarrierEdge pred).1.2 = a.1 := by
      simpa [pred, hsucc_pred, hk] using
        rows.orbitCarrierEdge_has_succ_endpoint pred
    rcases hendpoint with hendpoint | hendpoint
    · exact
        unboundedFrontierEdgeCarrierSegmentsMeet_of_common_endpoint
          (C := C) (inputs := inputs) (e := e)
          (f := rows.orbitCarrierEdge pred)
          (Or.inl (show e.1.1 = (rows.orbitCarrierEdge pred).1.1 by
            simpa [a] using hendpoint.symm))
    · exact
        unboundedFrontierEdgeCarrierSegmentsMeet_of_common_endpoint
          (C := C) (inputs := inputs) (e := e)
          (f := rows.orbitCarrierEdge pred)
          (Or.inr (Or.inl
            (show e.1.1 = (rows.orbitCarrierEdge pred).1.2 by
              simpa [a] using hendpoint.symm)))
  · refine ⟨k, ?_⟩
    have hendpoint :
        (rows.orbitCarrierEdge k).1.1 = a.1 ∨
          (rows.orbitCarrierEdge k).1.2 = a.1 := by
      simpa [hk] using rows.orbitCarrierEdge_has_vertex_endpoint k
    rcases hendpoint with hendpoint | hendpoint
    · exact
        unboundedFrontierEdgeCarrierSegmentsMeet_of_common_endpoint
          (C := C) (inputs := inputs) (e := e)
          (f := rows.orbitCarrierEdge k)
          (Or.inl (show e.1.1 = (rows.orbitCarrierEdge k).1.1 by
            simpa [a] using hendpoint.symm))
    · exact
        unboundedFrontierEdgeCarrierSegmentsMeet_of_common_endpoint
          (C := C) (inputs := inputs) (e := e)
          (f := rows.orbitCarrierEdge k)
          (Or.inr (Or.inl
            (show e.1.1 = (rows.orbitCarrierEdge k).1.2 by
              simpa [a] using hendpoint.symm)))

/-- Following the actual geometric face orbit gives a segment-intersection
chain from the first selected orbit edge to any later selected orbit edge. -/
theorem orbitCarrierEdge_reflTransGen_from_zero
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    (k : Fin rows.orbit.boundary.length) :
    Relation.ReflTransGen
      (unboundedFrontierEdgeCarrierSegmentsMeet inputs)
      (rows.orbitCarrierEdge ⟨0, rows.orbit.boundary.length_pos⟩)
      (rows.orbitCarrierEdge k) := by
  classical
  let root : Fin rows.orbit.boundary.length :=
    ⟨0, rows.orbit.boundary.length_pos⟩
  have reach_nat :
      forall m : Nat,
        forall hm : m < rows.orbit.boundary.length,
          Relation.ReflTransGen
            (unboundedFrontierEdgeCarrierSegmentsMeet inputs)
            (rows.orbitCarrierEdge root)
            (rows.orbitCarrierEdge ⟨m, hm⟩) := by
    intro m
    induction m with
    | zero =>
        intro hm
        have hidx :
            (⟨0, hm⟩ : Fin rows.orbit.boundary.length) = root :=
          Fin.ext rfl
        rw [hidx]
    | succ m ih =>
        intro hm
        have hm_prev : m < rows.orbit.boundary.length := by omega
        have hsucc :
            PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos
                (⟨m, hm_prev⟩ : Fin rows.orbit.boundary.length) =
              (⟨m + 1, hm⟩ : Fin rows.orbit.boundary.length) := by
          exact Fin.ext (by
            simp [PlanarInterface.cyclicSucc, Nat.mod_eq_of_lt hm])
        exact
          (ih hm_prev).tail
            (by
              rw [← hsucc]
              exact
                rows.orbitCarrierEdge_segmentsMeet_succ
                  (⟨m, hm_prev⟩ : Fin rows.orbit.boundary.length))
  simpa [root] using reach_nat k.val k.isLt

/-- Face-orbit exterior carrier rows prove the honest selected-edge
closed-segment chain required by the edge-carrier preconnectedness source. -/
theorem edgeCarrierSegmentChainConnected
    (rows : FaceDartOrbitExteriorCarrierRows C inputs) :
    UnboundedFrontierEdgeCarrierSegmentChainConnected inputs := by
  intro e f
  rcases rows.selectedEdge_segmentsMeet_orbitCarrierEdge e with ⟨i, hei⟩
  rcases rows.selectedEdge_segmentsMeet_orbitCarrierEdge f with ⟨j, hfj⟩
  have hsymm :
      Symmetric
        (Relation.ReflTransGen
          (unboundedFrontierEdgeCarrierSegmentsMeet inputs)) :=
    Relation.ReflTransGen.symmetric
      (fun _ _ h => by
        rcases h with ⟨p, hleft, hright⟩
        exact ⟨p, hright, hleft⟩)
  have h_i_root :
      Relation.ReflTransGen
        (unboundedFrontierEdgeCarrierSegmentsMeet inputs)
        (rows.orbitCarrierEdge i)
        (rows.orbitCarrierEdge ⟨0, rows.orbit.boundary.length_pos⟩) :=
    hsymm (rows.orbitCarrierEdge_reflTransGen_from_zero i)
  have h_root_j :
      Relation.ReflTransGen
        (unboundedFrontierEdgeCarrierSegmentsMeet inputs)
        (rows.orbitCarrierEdge ⟨0, rows.orbit.boundary.length_pos⟩)
        (rows.orbitCarrierEdge j) :=
    rows.orbitCarrierEdge_reflTransGen_from_zero j
  exact
    (Relation.ReflTransGen.single hei).trans
      (h_i_root.trans
        (h_root_j.trans
          (Relation.ReflTransGen.single
            (by
              rcases hfj with ⟨p, hleft, hright⟩
              exact ⟨p, hright, hleft⟩))))

/-- Claim `S2-agent-edge-carrier-segment-chain-source`.

The actual exterior face-dart carrier rows source the selected-edge
closed-segment chain directly from the face orbit: arbitrary selected frontier
edges attach to orbit sides at their endpoints, and consecutive orbit sides
intersect at their shared orbit vertex. -/
theorem S2_agent_edge_carrier_segment_chain_source
    (rows : FaceDartOrbitExteriorCarrierRows C inputs) :
    UnboundedFrontierEdgeCarrierSegmentChainConnected inputs :=
  rows.edgeCarrierSegmentChainConnected

theorem carrier_adj_succ
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    (k : Fin rows.orbit.boundary.length) :
    (unboundedFrontierCarrierGraph C inputs).Adj
      (rows.carrierVertex k)
      (rows.carrierVertex
        (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k)) := by
  simpa [carrierVertex] using
    unboundedFrontierCarrierGraph_adj_of_cycle_edge_openSegment_frontier
      rows.frontier_iff_orbit_vertex rows.orbit_edge_openSegment_frontier k

theorem carrier_adj_pred
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    (k : Fin rows.orbit.boundary.length) :
    (unboundedFrontierCarrierGraph C inputs).Adj
      (rows.carrierVertex k)
      (rows.carrierVertex
        (PlanarInterface.cyclicPred rows.orbit.boundary.length_pos k)) := by
  have hsucc :
      PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos
          (PlanarInterface.cyclicPred rows.orbit.boundary.length_pos k) =
        k := by
    exact PlanarInterface.cyclicSucc_cyclicPred
      rows.orbit.boundary.length_pos k
  have hedge :
      (rows.orbit.boundary.vertex
          (PlanarInterface.cyclicPred rows.orbit.boundary.length_pos k),
        rows.orbit.boundary.vertex k) ∈
          unboundedFrontierEdgeSet C inputs ∨
      (rows.orbit.boundary.vertex k,
        rows.orbit.boundary.vertex
          (PlanarInterface.cyclicPred rows.orbit.boundary.length_pos k)) ∈
          unboundedFrontierEdgeSet C inputs := by
    simpa [hsucc] using
      rows.orbit_edge_mem_unboundedFrontierEdgeSet
        (PlanarInterface.cyclicPred rows.orbit.boundary.length_pos k)
  rcases hedge with h | h
  · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm h
  · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge h

theorem carrier_adj_of_cycleGraph_adj
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    {i j : Fin rows.orbit.boundary.length}
    (hij : (SimpleGraph.cycleGraph rows.orbit.boundary.length).Adj i j) :
    (unboundedFrontierCarrierGraph C inputs).Adj
      (rows.carrierVertex i) (rows.carrierVertex j) := by
  rcases
      cycleGraph_adj_eq_cyclicSucc_or_eq_cyclicPred
        rows.orbit.boundary.length_pos rows.orbit.boundary.length_ge_three hij with
    hsucc | hpred
  · subst j
    exact rows.carrier_adj_succ i
  · subst j
    exact rows.carrier_adj_pred i

/-- Face-orbit exterior carrier rows erase to cyclic coverage rows for the
existing concrete carrier connectedness reducer. -/
