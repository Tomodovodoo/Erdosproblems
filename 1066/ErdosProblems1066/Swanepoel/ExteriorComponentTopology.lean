          C B k other := by
  intro k
  exact
    boundary_frontier_third_germ_between_of_local_exterior_sector
      (C := C) (inputs := inputs) (B := B) k
      (boundary_frontier_local_exterior_sector k)

/-- Stronger local-side residual with the W3 bookkeeping removed.

For each boundary vertex, any noncenter actual unbounded-frontier point that
lies on a third incident closed segment and is sufficiently close to the vertex
already has its point-ray in the open predecessor/successor exterior sector.
This is a purely closed-segment local exterior-side statement; the W3 germ
condition is recovered from it by projection. -/
abbrev BoundaryFrontierClosedSegmentLocalExteriorSector
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall (k : Fin B.length) (eps : Real) (q : PlanarInterface.Point)
      (other : Fin n),
    q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
    q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
    (canonicalGraph C).Adj (B.vertex k) other ->
    q ∈ closedSegment
      ((canonicalGraph C).point (B.vertex k))
      ((canonicalGraph C).point other) ->
    q ≠ (canonicalGraph C).point (B.vertex k) ->
    other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
    other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
      BoundaryPredSuccPointAngularBetween C B k q

/-- Edge-direction form of the closed-segment local exterior-side residual.

The only remaining geometric/topological content is that a nearby noncenter
actual exterior-frontier point on a third incident closed segment forces that
incident edge direction into the predecessor/successor exterior sector.  The
point-ray conclusion of `BoundaryFrontierClosedSegmentLocalExteriorSector`
then follows formally from closed-segment collinearity. -/
abbrev BoundaryFrontierClosedSegmentLocalExteriorAngularSector
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
