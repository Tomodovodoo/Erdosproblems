              0 < r /\
                forall z : PlanarInterface.Point,
                  z ∈ Metric.ball q r ->
                  PlanarInterface.InOpenSegment z
                    ((canonicalGraph C).point
                      (B.vertex (PlanarInterface.cyclicSucc B.length_pos k)))
                    ((canonicalGraph C).point (B.vertex k)) ->
                  z ∈ closure
                    (unboundedExteriorComponentRows C inputs).exterior := by
      intro q hq hqclosure
      rcases hlocal q (inOpenSegment_symm hq) hqclosure with
        ⟨r, hrpos, hr⟩
      exact
        ⟨r, hrpos, by
          intro z hzball hzseg
          exact hr z hzball (inOpenSegment_symm hzseg)⟩
    intro q hq
    exact
      edge_openSegment_frontier_of_inOpenSegment_frontier_and_relative_ball_closure
        (C := C) (inputs := inputs)
        (e :=
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
            B.vertex k))
        he (inOpenSegment_symm hpEdge) hpFrontier hlocal_rev q
        (inOpenSegment_symm hq)

/-- Boundary-cycle edge propagation with the one-sided exterior-witness row
that the sector proof naturally supplies.  The relative-ball adapter turns the
nearby exterior points into closure along the open edge, and the existing
frontier wrapper then upgrades closure to frontier. -/
theorem boundary_cycle_edge_openSegment_frontier_of_inOpenSegment_frontier_and_nearby_edge_point_exterior_points
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (k : Fin B.length)
    (he :
      (B.vertex k,
        B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
          (canonicalGraph C).edgeSet ∨
        (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
          B.vertex k) ∈ (canonicalGraph C).edgeSet)
    {p : PlanarInterface.Point}
    (hpEdge :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point (B.vertex k))
        ((canonicalGraph C).point
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))))
    (hpFrontier :
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (hnear :
      forall q : PlanarInterface.Point,
        PlanarInterface.InOpenSegment q
          ((canonicalGraph C).point (B.vertex k))
          ((canonicalGraph C).point
            (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
        q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun r : Real =>
            0 < r /\
              forall z : PlanarInterface.Point,
                z ∈ Metric.ball q r ->
                PlanarInterface.InOpenSegment z
                  ((canonicalGraph C).point (B.vertex k))
                  ((canonicalGraph C).point
                    (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
                forall eps : Real,
                  0 < eps ->
                    Exists fun y : PlanarInterface.Point =>
                      y ∈ (unboundedExteriorComponentRows C inputs).exterior /\
                        dist y z < eps) :
    forall q : PlanarInterface.Point,
      PlanarInterface.InOpenSegment q
        ((canonicalGraph C).point (B.vertex k))
        ((canonicalGraph C).point
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
      q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  exact
    boundary_cycle_edge_openSegment_frontier_of_inOpenSegment_frontier_and_relative_ball_closure
      (C := C) (inputs := inputs) (B := B) k he hpEdge hpFrontier
      (relative_ball_closure_of_forall_nearby_edge_point_exterior_points
        (C := C) (inputs := inputs)
        (e :=
          (B.vertex k,
            B.vertex (PlanarInterface.cyclicSucc B.length_pos k)))
        hnear)

/-- Cycle-wide form of the relative-ball boundary-edge propagation row:
one actual frontier point on each consecutive cycle edge, plus nearby exterior
witnesses along that edge, gives the whole open-segment frontier row consumed
by the concrete carrier constructors. -/
theorem cycle_edge_openSegment_frontier_of_inOpenSegment_frontier_and_nearby_edge_point_exterior_points
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (edge_frontier_point :
      forall k : Fin B.length,
        Exists fun p : PlanarInterface.Point =>
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (B.vertex k))
            ((canonicalGraph C).point
              (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) /\
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (hnear :
      forall k : Fin B.length,
        forall q : PlanarInterface.Point,
          PlanarInterface.InOpenSegment q
            ((canonicalGraph C).point (B.vertex k))
            ((canonicalGraph C).point
              (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
          q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
            Exists fun r : Real =>
              0 < r /\
                forall z : PlanarInterface.Point,
                  z ∈ Metric.ball q r ->
                  PlanarInterface.InOpenSegment z
                    ((canonicalGraph C).point (B.vertex k))
                    ((canonicalGraph C).point
                      (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
                  forall eps : Real,
                    0 < eps ->
                      Exists fun y : PlanarInterface.Point =>
                        y ∈ (unboundedExteriorComponentRows C inputs).exterior /\
                          dist y z < eps) :
    forall k : Fin B.length,
      forall q : PlanarInterface.Point,
        PlanarInterface.InOpenSegment q
          ((canonicalGraph C).point (B.vertex k))
          ((canonicalGraph C).point
            (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
        q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  intro k q hq
  rcases edge_frontier_point k with ⟨p, hpEdge, hpFrontier⟩
  exact
    boundary_cycle_edge_openSegment_frontier_of_inOpenSegment_frontier_and_nearby_edge_point_exterior_points
      (C := C) (inputs := inputs) (B := B) k (B.adjacent k)
      hpEdge hpFrontier (hnear k) q hq

/-- Face-orbit version of the cycle-wide relative-ball propagation row.  This
is intentionally stated for an arbitrary actual exterior orbit, not for the
selected boundary. -/
theorem faceDartOrbit_edge_openSegment_frontier_of_inOpenSegment_frontier_and_nearby_edge_point_exterior_points
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    (O : FaceDartOrbit C R)
    (edge_frontier_point :
      forall k : Fin O.boundary.length,
        Exists fun p : PlanarInterface.Point =>
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.boundary.vertex k))
            ((canonicalGraph C).point
              (O.boundary.vertex
                (PlanarInterface.cyclicSucc O.boundary.length_pos k))) /\
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (hnear :
      forall k : Fin O.boundary.length,
        forall q : PlanarInterface.Point,
          PlanarInterface.InOpenSegment q
            ((canonicalGraph C).point (O.boundary.vertex k))
            ((canonicalGraph C).point
              (O.boundary.vertex
                (PlanarInterface.cyclicSucc O.boundary.length_pos k))) ->
          q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
            Exists fun r : Real =>
              0 < r /\
                forall z : PlanarInterface.Point,
                  z ∈ Metric.ball q r ->
                  PlanarInterface.InOpenSegment z
                    ((canonicalGraph C).point (O.boundary.vertex k))
                    ((canonicalGraph C).point
                      (O.boundary.vertex
                        (PlanarInterface.cyclicSucc
                          O.boundary.length_pos k))) ->
                  forall eps : Real,
                    0 < eps ->
                      Exists fun y : PlanarInterface.Point =>
                        y ∈ (unboundedExteriorComponentRows C inputs).exterior /\
                          dist y z < eps) :
    forall k : Fin O.boundary.length,
      forall q : PlanarInterface.Point,
        PlanarInterface.InOpenSegment q
          ((canonicalGraph C).point (O.boundary.vertex k))
          ((canonicalGraph C).point
            (O.boundary.vertex
              (PlanarInterface.cyclicSucc O.boundary.length_pos k))) ->
        q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  exact
    cycle_edge_openSegment_frontier_of_inOpenSegment_frontier_and_nearby_edge_point_exterior_points
      (C := C) (inputs := inputs) (B := O.boundary)
