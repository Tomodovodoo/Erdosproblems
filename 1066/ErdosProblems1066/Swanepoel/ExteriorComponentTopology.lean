/-- Exact raw-orbit frontier row extracted from an existing exterior
face-orbit carrier package.

The only extra data is the identification of the raw period/tail sequence with
the stored face-orbit boundary sequence.  The theorem therefore isolates the
remaining geometric source obligation for the raw handoff: prove that the raw
exterior face-successor orbit is this carrier boundary. -/
theorem frontier_iff_rawFaceSuccOrbit_tail
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit rows.rotation start)
    (hperiod : rows.orbit.boundary.length = O.period)
    (tail_eq :
      forall k : Fin rows.orbit.boundary.length,
        (O.dart (Fin.cast hperiod k)).tail =
          rows.orbit.boundary.vertex k) :
    forall v : Fin n,
      (canonicalGraph C).point v ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ↔
        Exists fun k : Fin O.period => (O.dart k).tail = v := by
  intro v
  constructor
  · intro hv
    rcases (rows.frontier_iff_orbit_vertex v).1 hv with ⟨k, hk⟩
    exact ⟨Fin.cast hperiod k, (tail_eq k).trans hk⟩
  · rintro ⟨k, hk⟩
    let j : Fin rows.orbit.boundary.length := Fin.cast hperiod.symm k
    have hcast : Fin.cast hperiod j = k := by
      ext
      simp [j]
    have htail :
        (O.dart k).tail = rows.orbit.boundary.vertex j := by
      simpa [hcast] using tail_eq j
    exact (rows.frontier_iff_orbit_vertex v).2
      ⟨j, htail.symm.trans hk⟩

/-- Iterating the face-successor permutation from the first stored face-orbit
dart follows the stored boundary orbit modulo its length. -/
theorem faceSuccPerm_pow_orbit_zero
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    (q : Nat) :
    (rows.rotation.faceSuccPerm ^ q)
        (rows.orbit.dart ⟨0, rows.orbit.boundary.length_pos⟩) =
      rows.orbit.dart
        ⟨q % rows.orbit.boundary.length,
          Nat.mod_lt _ rows.orbit.boundary.length_pos⟩ := by
  induction q with
  | zero =>
      simp
  | succ q ih =>
      have hidx :
          PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos
              ⟨q % rows.orbit.boundary.length,
                Nat.mod_lt _ rows.orbit.boundary.length_pos⟩ =
            ⟨Nat.succ q % rows.orbit.boundary.length,
              Nat.mod_lt _ rows.orbit.boundary.length_pos⟩ := by
        ext
        change
          ((q % rows.orbit.boundary.length + 1) %
              rows.orbit.boundary.length) =
            (Nat.succ q % rows.orbit.boundary.length)
        rw [Nat.succ_eq_add_one]
        rw [Nat.add_mod]
        simp
      rw [pow_succ', Equiv.Perm.mul_apply]
      change
        rows.rotation.faceSucc
            ((rows.rotation.faceSuccPerm ^ q)
              (rows.orbit.dart ⟨0, rows.orbit.boundary.length_pos⟩)) =
          rows.orbit.dart
            ⟨(q + 1) % rows.orbit.boundary.length,
              Nat.mod_lt _ rows.orbit.boundary.length_pos⟩
      rw [ih]
      calc
        rows.rotation.faceSucc
            (rows.orbit.dart
              ⟨q % rows.orbit.boundary.length,
                Nat.mod_lt _ rows.orbit.boundary.length_pos⟩) =
            rows.orbit.dart
              (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos
                ⟨q % rows.orbit.boundary.length,
                  Nat.mod_lt _ rows.orbit.boundary.length_pos⟩) :=
          rows.orbit.faceSucc_eq_next
            ⟨q % rows.orbit.boundary.length,
              Nat.mod_lt _ rows.orbit.boundary.length_pos⟩
        _ =
            rows.orbit.dart
              ⟨(q + 1) % rows.orbit.boundary.length,
                Nat.mod_lt _ rows.orbit.boundary.length_pos⟩ := by
          simpa [Nat.succ_eq_add_one] using congrArg rows.orbit.dart hidx

/-- The stored face orbit returns to its first dart after one full boundary
length. -/
theorem faceSuccPerm_pow_length_orbit_zero
    (rows : FaceDartOrbitExteriorCarrierRows C inputs) :
    (rows.rotation.faceSuccPerm ^ rows.orbit.boundary.length)
        (rows.orbit.dart ⟨0, rows.orbit.boundary.length_pos⟩) =
      rows.orbit.dart ⟨0, rows.orbit.boundary.length_pos⟩ := by
  have hpow := rows.faceSuccPerm_pow_orbit_zero rows.orbit.boundary.length
  simpa [Nat.mod_self] using hpow

/-- The raw face-successor period agrees with the stored exterior face-orbit
length when the raw orbit starts at the first stored dart. -/
theorem rawFaceSuccOrbit_period_eq_of_start_zero
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit rows.rotation start)
    (hstart :
      start = rows.orbit.dart ⟨0, rows.orbit.boundary.length_pos⟩) :
    rows.orbit.boundary.length = O.period := by
  have hreturn_length :
      (rows.rotation.faceSuccPerm ^ rows.orbit.boundary.length) start =
        start := by
    rw [hstart]
    exact rows.faceSuccPerm_pow_length_orbit_zero
  have hle_period :
      O.period <= rows.orbit.boundary.length :=
    O.period_minimal rows.orbit.boundary.length
      rows.orbit.boundary.length_pos hreturn_length
  have hge_period :
      rows.orbit.boundary.length <= O.period := by
    by_contra hnot
    have hlt : O.period < rows.orbit.boundary.length :=
      Nat.lt_of_not_ge hnot
    have hpow_period :
        (rows.rotation.faceSuccPerm ^ O.period)
            (rows.orbit.dart ⟨0, rows.orbit.boundary.length_pos⟩) =
          rows.orbit.dart ⟨0, rows.orbit.boundary.length_pos⟩ := by
      simpa [hstart] using O.period_return
    have hpow_mod := rows.faceSuccPerm_pow_orbit_zero O.period
    have hdart :
        rows.orbit.dart
            ⟨O.period % rows.orbit.boundary.length,
              Nat.mod_lt _ rows.orbit.boundary.length_pos⟩ =
          rows.orbit.dart ⟨0, rows.orbit.boundary.length_pos⟩ := by
      exact hpow_mod.symm.trans hpow_period
    have hfin :
        (⟨O.period % rows.orbit.boundary.length,
            Nat.mod_lt _ rows.orbit.boundary.length_pos⟩ :
          Fin rows.orbit.boundary.length) =
          ⟨0, rows.orbit.boundary.length_pos⟩ :=
      rows.orbit.dart_injective hdart
    have hperiod_zero : O.period = 0 := by
      have hval := congrArg Fin.val hfin
      simpa [Nat.mod_eq_of_lt hlt] using hval
    exact Nat.ne_of_gt O.period_pos hperiod_zero
  exact Nat.le_antisymm hge_period hle_period

/-- Tail identification for the raw orbit started at the first stored
face-orbit dart. -/
theorem rawFaceSuccOrbit_tail_eq_of_start_zero
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit rows.rotation start)
    (hstart :
      start = rows.orbit.dart ⟨0, rows.orbit.boundary.length_pos⟩)
    (hperiod : rows.orbit.boundary.length = O.period) :
    forall k : Fin rows.orbit.boundary.length,
      (O.dart (Fin.cast hperiod k)).tail =
        rows.orbit.boundary.vertex k := by
  intro k
  have hraw :
      O.dart (Fin.cast hperiod k) =
        (rows.rotation.faceSuccPerm ^ k.val) start := by
    simpa using O.dart_eq_iterate (Fin.cast hperiod k)
  have hpow :
      (rows.rotation.faceSuccPerm ^ k.val)
          (rows.orbit.dart ⟨0, rows.orbit.boundary.length_pos⟩) =
        rows.orbit.dart k := by
    have hiter := rows.faceSuccPerm_pow_orbit_zero k.val
    have hmod : k.val % rows.orbit.boundary.length = k.val :=
      Nat.mod_eq_of_lt k.isLt
    simpa [hmod] using hiter
  calc
    (O.dart (Fin.cast hperiod k)).tail =
        ((rows.rotation.faceSuccPerm ^ k.val) start).tail := by
          rw [hraw]
    _ = ((rows.rotation.faceSuccPerm ^ k.val)
          (rows.orbit.dart ⟨0, rows.orbit.boundary.length_pos⟩)).tail := by
          rw [hstart]
    _ = (rows.orbit.dart k).tail := by
          rw [hpow]
    _ = rows.orbit.boundary.vertex k :=
          rows.orbit.dart_tail_eq_vertex k

/-- A selected local frontier seed whose ordered endpoints are a forward edge
of the honest face orbit starts the raw orbit at the corresponding stored
face-orbit dart.

This is the endpoint-level seed/orientation residual behind the raw start
identification: callers only need to prove that the selected local edge is the
chosen forward boundary edge. -/
theorem raw_start_eq_orbit_dart_of_edgeLocalRows_orbit_succ
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    {e : PlanarInterface.Edge n}
    {p : PlanarInterface.Point}
    {start : UnitDistanceDart C}
    (_edgeRows : UnboundedExteriorFrontierEdgeLocalRows C inputs e p)
    (htail : start.tail = e.1)
    (hhead : start.head = e.2)
    (k : Fin rows.orbit.boundary.length)
    (hedge :
      e.1 = rows.orbit.boundary.vertex k ∧
        e.2 =
          rows.orbit.boundary.vertex
            (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k)) :
    start = rows.orbit.dart k := by
  apply UnitDistanceDart.ext_endpoints
  · calc
      start.tail = e.1 := htail
      _ = rows.orbit.boundary.vertex k := hedge.1
      _ = (rows.orbit.dart k).tail :=
        (rows.orbit.dart_tail_eq_vertex k).symm
  · calc
      start.head = e.2 := hhead
      _ =
          rows.orbit.boundary.vertex
            (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos k) :=
        hedge.2
      _ = (rows.orbit.dart k).head :=
        (rows.orbit.dart_head_eq_succ_vertex k).symm

/-- Zero-index specialization of
`raw_start_eq_orbit_dart_of_edgeLocalRows_orbit_succ`.

Thus the raw start residual for the selected orbit is reduced to the sharp
selected-seed orientation row saying that the chosen local edge is the first
forward edge of the honest face-dart carrier boundary. -/
theorem raw_start_eq_orbit_zero_of_edgeLocalRows_orbit_zero_succ
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    {e : PlanarInterface.Edge n}
    {p : PlanarInterface.Point}
    {start : UnitDistanceDart C}
    (edgeRows : UnboundedExteriorFrontierEdgeLocalRows C inputs e p)
    (htail : start.tail = e.1)
    (hhead : start.head = e.2)
    (hedge :
      e.1 =
          rows.orbit.boundary.vertex
            ⟨0, rows.orbit.boundary.length_pos⟩ ∧
        e.2 =
          rows.orbit.boundary.vertex
            (PlanarInterface.cyclicSucc rows.orbit.boundary.length_pos
              ⟨0, rows.orbit.boundary.length_pos⟩)) :
    start =
      rows.orbit.dart ⟨0, rows.orbit.boundary.length_pos⟩ :=
  rows.raw_start_eq_orbit_dart_of_edgeLocalRows_orbit_succ
    edgeRows htail hhead ⟨0, rows.orbit.boundary.length_pos⟩ hedge

end FaceDartOrbitExteriorCarrierRows

/-! ### Actual boundary-cycle frontier equivalence rows -/

/-- The exact honest output of the actual exterior boundary-cycle source.

The boundary is a genuine `UnitDistanceCycleBoundary`; the two rows record
that its vertices are exactly the graph vertices on the unbounded exterior
frontier and that each consecutive cycle edge has its whole relative interior
on that same frontier. -/
structure ActualBoundaryCycleFrontierEquivalenceRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) where
  boundary : JordanBoundaryConcrete.UnitDistanceCycleBoundary C
  frontier_iff_cycle_vertex :
    forall v : Fin n,
      (canonicalGraph C).point v ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ↔
        Exists fun k : Fin boundary.length => boundary.vertex k = v
  cycle_edge_openSegment_frontier :
    forall k : Fin boundary.length,
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (boundary.vertex k))
          ((canonicalGraph C).point
            (boundary.vertex
              (PlanarInterface.cyclicSucc boundary.length_pos k))) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior

namespace ActualBoundaryCycleFrontierEquivalenceRows

variable {C : _root_.UDConfig n}
variable {inputs : FinitePlanarOuterComponentInputs C}

/-- A genuine exterior face orbit sources the exact actual boundary-cycle
frontier-equivalence rows without passing through an arbitrary spanning cycle
or an induced frontier graph. -/
def ofFaceDartOrbitExteriorCarrierRows
    (rows : FaceDartOrbitExteriorCarrierRows C inputs) :
    ActualBoundaryCycleFrontierEquivalenceRows C inputs where
  boundary := rows.orbit.boundary
  frontier_iff_cycle_vertex := rows.frontier_iff_orbit_vertex
  cycle_edge_openSegment_frontier := rows.orbit_edge_openSegment_frontier

/-- Build actual boundary-cycle frontier-equivalence rows from a boundary cycle
whose consecutive sides are selected edges of the actual unbounded-frontier
carrier.  This avoids asking separately for the open-segment frontier row. -/
def ofBoundaryCycleEdgeMem
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
    (frontier_iff_cycle_vertex :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin B.length => B.vertex k = v)
    (cycle_edge_mem :
      forall k : Fin B.length,
        (B.vertex k,
            B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
            unboundedFrontierEdgeSet C inputs ∨
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
            B.vertex k) ∈
            unboundedFrontierEdgeSet C inputs) :
    ActualBoundaryCycleFrontierEquivalenceRows C inputs where
  boundary := B
  frontier_iff_cycle_vertex := frontier_iff_cycle_vertex
  cycle_edge_openSegment_frontier :=
    cycle_edge_openSegment_frontier_of_unboundedFrontierEdgeSet_or_symm
      cycle_edge_mem

/-- Named source shape for the actual boundary edge-membership route.

It asks for a genuine boundary cycle whose vertices are exactly the graph
vertices on the unbounded exterior frontier, and whose consecutive sides are
selected edges of the actual `unboundedFrontierEdgeSet`, up to orientation. -/
abbrev BoundaryCycleEdgeMemSource
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  Exists fun B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C =>
    (forall v : Fin n,
      (canonicalGraph C).point v ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ↔
        Exists fun k : Fin B.length => B.vertex k = v) ∧
      (forall k : Fin B.length,
        (B.vertex k,
            B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
            unboundedFrontierEdgeSet C inputs ∨
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
            B.vertex k) ∈
            unboundedFrontierEdgeSet C inputs)

/-- Source-erasing constructor for the actual exterior boundary-cycle route.

The source theorem for S2 should construct one boundary cycle together with
the vertex-frontier equivalence and the fact that each consecutive boundary
side is an actual selected unbounded-frontier edge.  This constructor packages
exactly those rows into `ActualBoundaryCycleFrontierEquivalenceRows`. -/
noncomputable def ofBoundaryCycleEdgeMemSource
    (source : BoundaryCycleEdgeMemSource C inputs) :
    ActualBoundaryCycleFrontierEquivalenceRows C inputs := by
  classical
  let B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C :=
    Classical.choose source
  have hsource :=
    Classical.choose_spec source
  rcases hsource with ⟨frontier_iff_cycle_vertex, cycle_edge_mem⟩
  exact ofBoundaryCycleEdgeMem B frontier_iff_cycle_vertex cycle_edge_mem

/-- Raw face-successor orbit reducer for the actual boundary-cycle frontier
equivalence rows.

The boundary is not manufactured by the generic two-regular spanning-cycle
handoff: it is supplied together with an exact period/tail identification with
the selected raw face-successor orbit.  The two frontier rows are transported
from the raw orbit tails to that same concrete `UnitDistanceCycleBoundary`. -/
def ofRawFaceSuccOrbitBoundaryRows
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
    (hperiod : B.length = O.period)
    (tail_eq : forall k : Fin B.length,
      (O.dart (Fin.cast hperiod k)).tail = B.vertex k)
    (frontier_iff_tail :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin O.period => (O.dart k).tail = v)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    ActualBoundaryCycleFrontierEquivalenceRows C inputs where
  boundary := B
  frontier_iff_cycle_vertex := by
    intro v
    constructor
    · intro hv
      rcases (frontier_iff_tail v).1 hv with ⟨k, hk⟩
      refine ⟨Fin.cast hperiod.symm k, ?_⟩
      have htail := tail_eq (Fin.cast hperiod.symm k)
      have hcast :
          Fin.cast hperiod (Fin.cast hperiod.symm k) = k := by
        ext
        simp
      have htail' :
          (O.dart k).tail = B.vertex (Fin.cast hperiod.symm k) := by
        simpa [hcast] using htail
      exact htail'.symm.trans hk
    · rintro ⟨k, hk⟩
      exact
        (frontier_iff_tail v).2
          ⟨Fin.cast hperiod k, (tail_eq k).trans hk⟩
  cycle_edge_openSegment_frontier := by
    intro k p hp
    have hcast_succ :
        Fin.cast hperiod (PlanarInterface.cyclicSucc B.length_pos k) =
          PlanarInterface.cyclicSucc O.period_pos (Fin.cast hperiod k) := by
      ext
      simp [PlanarInterface.cyclicSucc, hperiod]
    have htail_succ :
        (O.dart
            (PlanarInterface.cyclicSucc O.period_pos
              (Fin.cast hperiod k))).tail =
          B.vertex (PlanarInterface.cyclicSucc B.length_pos k) := by
      rw [← hcast_succ]
      exact tail_eq (PlanarInterface.cyclicSucc B.length_pos k)
    exact
      edge_openSegment_frontier (Fin.cast hperiod k) p (by
        simpa [tail_eq k, htail_succ] using hp)

theorem cycle_vertices_frontier
    (rows : ActualBoundaryCycleFrontierEquivalenceRows C inputs) :
    forall k : Fin rows.boundary.length,
      (canonicalGraph C).point (rows.boundary.vertex k) ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior := by
  intro k
  exact
    (rows.frontier_iff_cycle_vertex (rows.boundary.vertex k)).2
      ⟨k, rfl⟩

theorem frontier_vertices_are_cycle_vertices
    (rows : ActualBoundaryCycleFrontierEquivalenceRows C inputs) :
    forall v : Fin n,
      (canonicalGraph C).point v ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ->
        Exists fun k : Fin rows.boundary.length =>
          rows.boundary.vertex k = v := by
  intro v hv
  exact (rows.frontier_iff_cycle_vertex v).1 hv

theorem cycle_edge_mem_unboundedFrontierEdgeSet_or_symm
    (rows : ActualBoundaryCycleFrontierEquivalenceRows C inputs)
    (k : Fin rows.boundary.length) :
    (rows.boundary.vertex k,
        rows.boundary.vertex
          (PlanarInterface.cyclicSucc rows.boundary.length_pos k)) ∈
        unboundedFrontierEdgeSet C inputs ∨
      (rows.boundary.vertex
          (PlanarInterface.cyclicSucc rows.boundary.length_pos k),
        rows.boundary.vertex k) ∈
        unboundedFrontierEdgeSet C inputs :=
  cycle_edge_mem_unboundedFrontierEdgeSet_or_symm_of_openSegment_frontier
    rows.cycle_edge_openSegment_frontier k

/-- Actual boundary-cycle frontier-equivalence rows fill the sharper
edge-membership source required by `ofBoundaryCycleEdgeMemSource`.

The consecutive edge-membership row is not assumed: it is derived from the
actual open-segment frontier row and the concrete carrier definition. -/
theorem boundaryCycleEdgeMemSource
    (rows : ActualBoundaryCycleFrontierEquivalenceRows C inputs) :
    BoundaryCycleEdgeMemSource C inputs := by
  exact
    ⟨rows.boundary,
      rows.frontier_iff_cycle_vertex,
      fun k => rows.cycle_edge_mem_unboundedFrontierEdgeSet_or_symm k⟩

/-- Face-orbit actual exterior carrier rows source the boundary-cycle
edge-membership package consumed by `ofBoundaryCycleEdgeMemSource`. -/
theorem boundaryCycleEdgeMemSource_of_faceDartOrbit
    (rows : FaceDartOrbitExteriorCarrierRows C inputs) :
    BoundaryCycleEdgeMemSource C inputs :=
  boundaryCycleEdgeMemSource (ofFaceDartOrbitExteriorCarrierRows rows)

/-- Claim `S2-agent-actual-boundary-edge-mem-source`.

The source for `ofBoundaryCycleEdgeMemSource` is reduced to the already checked
actual boundary-cycle frontier-equivalence rows. -/
theorem S2_agent_actual_boundary_edge_mem_source
    (rows : ActualBoundaryCycleFrontierEquivalenceRows C inputs) :
    BoundaryCycleEdgeMemSource C inputs :=
  boundaryCycleEdgeMemSource rows

/-- Face-orbit specialization of
`S2_agent_actual_boundary_edge_mem_source`. -/
theorem S2_agent_actual_boundary_edge_mem_source_of_faceDartOrbit
    (rows : FaceDartOrbitExteriorCarrierRows C inputs) :
    BoundaryCycleEdgeMemSource C inputs :=
  boundaryCycleEdgeMemSource_of_faceDartOrbit rows

/-- The actual boundary-cycle rows give cyclic coverage of the concrete
unbounded-frontier carrier.  This consumes both frontier rows and keeps the
boundary edges tied to the actual open-segment frontier, rather than replacing
them by a separate cycle on the same vertices. -/
def toCyclicCoverageRows
    (rows : ActualBoundaryCycleFrontierEquivalenceRows C inputs) :
    UnboundedFrontierCarrierCyclicCoverageRows C inputs :=
  unboundedFrontierCarrierCyclicCoverageRows_of_boundaryCycle_openSegment_frontier
    rows.boundary
    rows.frontier_iff_cycle_vertex
    rows.cycle_edge_openSegment_frontier

/-- Claim `S2-agent-actual-boundary-cycle-frontier-equivalence`.

Checked reducer exposing the exact minimal honest rows still needed from the
