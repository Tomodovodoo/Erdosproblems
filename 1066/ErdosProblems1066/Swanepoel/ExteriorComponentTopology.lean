/-- The exact whole-edge frontier row for S2: every selected ordered frontier
edge has its entire relative interior on the unbounded exterior frontier. -/
def UnboundedFrontierEdgeSetWholeOpenSegmentFrontier
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall e : PlanarInterface.Edge n,
    e ∈ unboundedFrontierEdgeSet C inputs ->
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior

/-- Interior points of a selected unbounded-frontier edge cannot lie in the
unbounded exterior component, because that component is contained in the
complement of the embedded drawing while the whole unit-edge segment belongs to
the drawing. -/
theorem unboundedFrontierEdgeSet_inOpenSegment_not_mem_unboundedExterior
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs)
    {p : PlanarInterface.Point}
    (hp :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2)) :
    p ∉ (unboundedExteriorComponentRows C inputs).exterior := by
  intro hpE
  have hpDraw : p ∈ embeddedEdgeSet C :=
    inOpenSegment_mem_embeddedEdgeSet_of_adj
      (unboundedFrontierEdgeSet_adj he) hp
  exact
    ((unboundedExteriorComponentRows C inputs).exterior_subset_drawingComplement
      hpE) hpDraw

/-- Closure form of the whole-edge row.  With the concrete carrier defined by
whole open frontier segments, this follows directly from the definition. -/
def UnboundedFrontierEdgeSetOpenSegmentClosure
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall e : PlanarInterface.Edge n,
    e ∈ unboundedFrontierEdgeSet C inputs ->
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ closure (unboundedExteriorComponentRows C inputs).exterior

/-- The concrete carrier definition gives closure of the exterior along every
selected edge interior. -/
theorem unboundedFrontierEdgeSetOpenSegmentClosure_of_definition
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C} :
    UnboundedFrontierEdgeSetOpenSegmentClosure C inputs := by
  intro e he p hp
  exact frontier_subset_closure ((mem_unboundedFrontierEdgeSet_iff.1 he).2 p hp)

/-- Endpoint closure stated directly for the actual selected unbounded-frontier
carrier edges.

Unlike `AdjacentFrontierEndpointsClosedSegmentEndpointClosureSource`, this
does not quantify over arbitrary chords between two frontier vertices.  The
edge is already required to lie in `unboundedFrontierEdgeSet`. -/
def SelectedUnboundedFrontierEdgeEndpointClosureSource
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall {e : PlanarInterface.Edge n},
    e ∈ unboundedFrontierEdgeSet C inputs ->
      (Exists fun r : Real =>
        0 < r /\
          forall z : PlanarInterface.Point,
            z ∈ Metric.ball ((canonicalGraph C).point e.1) r ->
            z ∈ closedSegment
              ((canonicalGraph C).point e.1)
              ((canonicalGraph C).point e.2) ->
            z ∈ closure
              (unboundedExteriorComponentRows C inputs).exterior) /\
      (Exists fun r : Real =>
        0 < r /\
          forall z : PlanarInterface.Point,
            z ∈ Metric.ball ((canonicalGraph C).point e.2) r ->
            z ∈ closedSegment
              ((canonicalGraph C).point e.1)
              ((canonicalGraph C).point e.2) ->
            z ∈ closure
              (unboundedExteriorComponentRows C inputs).exterior)

/-- The selected frontier-edge endpoint closure row follows directly from the
definition of `unboundedFrontierEdgeSet`.

This is the endpoint theorem that is safe for S2 source work: it applies only
to actual selected unbounded-frontier edges, not to every unit edge between two
exterior-frontier vertices. -/
theorem selectedUnboundedFrontierEdgeEndpointClosureSource_of_definition
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C} :
    SelectedUnboundedFrontierEdgeEndpointClosureSource C inputs := by
  intro e he
  let a : PlanarInterface.Point := (canonicalGraph C).point e.1
  let b : PlanarInterface.Point := (canonicalGraph C).point e.2
  have hseg :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior :=
    (mem_unboundedFrontierEdgeSet_iff.1 he).2
  have hendpoints :
      e.1 ∈ unboundedFrontierVertexSet C inputs ∧
        e.2 ∈ unboundedFrontierVertexSet C inputs :=
    endpoints_mem_unboundedFrontierVertexSet_of_edge_openSegment_frontier
      (C := C) (inputs := inputs) (e := e) hseg
  have hleftFrontier :
      (canonicalGraph C).point e.1 ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior :=
    mem_unboundedFrontierVertexSet_iff.1 hendpoints.1
  have hrightFrontier :
      (canonicalGraph C).point e.2 ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior :=
    mem_unboundedFrontierVertexSet_iff.1 hendpoints.2
  have hadj : (canonicalGraph C).Adj e.1 e.2 :=
    unboundedFrontierEdgeSet_adj he
  have hdist_pos : 0 < dist a b := by
    exact dist_pos.mpr (by simpa [a, b] using canonical_adj_point_ne hadj)
  let r : Real := dist a b / 2
  have hrpos : 0 < r := half_pos hdist_pos
  constructor
  · refine ⟨r, hrpos, ?_⟩
    intro z hzball hzseg
    rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hzseg with
      hz_left | hz_right | hz_open
    · simpa [a, hz_left] using frontier_subset_closure hleftFrontier
    · have hlt : dist a b < dist a b / 2 := by
        simpa [Metric.mem_ball, a, b, r, hz_right, dist_comm] using hzball
      exact False.elim (by linarith)
    · exact
        frontier_subset_closure
          ((mem_unboundedFrontierEdgeSet_iff.1 he).2 z
            (by simpa [a, b] using hz_open))
  · refine ⟨r, hrpos, ?_⟩
    intro z hzball hzseg
    rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hzseg with
      hz_left | hz_right | hz_open
    · have hlt : dist a b < dist a b / 2 := by
        simpa [Metric.mem_ball, a, b, r, hz_left] using hzball
      exact False.elim (by linarith)
    · simpa [b, hz_right] using frontier_subset_closure hrightFrontier
    · exact
        frontier_subset_closure
          ((mem_unboundedFrontierEdgeSet_iff.1 he).2 z
            (by simpa [a, b] using hz_open))

/-- Endpoint closure for one local consumer from an actual selected incident
edge, with orientation erased.

This is the selected-edge reducer for adjacent local arguments: the only edge
hypothesis is membership in `unboundedFrontierEdgeSet`, in either orientation.
-/
theorem selectedUnboundedFrontierEdgeEndpointClosureSource_of_selectedIncidentEdge
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (selectedEndpointClosure :
      SelectedUnboundedFrontierEdgeEndpointClosureSource C inputs)
    {i j : Fin n}
    (hselected :
      (i, j) ∈ unboundedFrontierEdgeSet C inputs ∨
        (j, i) ∈ unboundedFrontierEdgeSet C inputs) :
    (Exists fun r : Real =>
      0 < r /\
        forall z : PlanarInterface.Point,
          z ∈ Metric.ball ((canonicalGraph C).point i) r ->
          z ∈ closedSegment
            ((canonicalGraph C).point i)
            ((canonicalGraph C).point j) ->
          z ∈ closure
            (unboundedExteriorComponentRows C inputs).exterior) /\
    (Exists fun r : Real =>
      0 < r /\
        forall z : PlanarInterface.Point,
          z ∈ Metric.ball ((canonicalGraph C).point j) r ->
          z ∈ closedSegment
            ((canonicalGraph C).point i)
            ((canonicalGraph C).point j) ->
          z ∈ closure
            (unboundedExteriorComponentRows C inputs).exterior) := by
  rcases hselected with hselected | hselected
  · simpa using selectedEndpointClosure (e := (i, j)) hselected
  · rcases selectedEndpointClosure (e := (j, i)) hselected with
      ⟨hnear_j, hnear_i⟩
    constructor
    · rcases hnear_i with ⟨r, hrpos, hnear⟩
      refine ⟨r, hrpos, ?_⟩
      intro z hzball hzseg
      have hzseg_rev :
          z ∈ closedSegment
            ((canonicalGraph C).point j)
            ((canonicalGraph C).point i) := by
        rw [closedSegment_symm]
        exact hzseg
      exact hnear z hzball hzseg_rev
    · rcases hnear_j with ⟨r, hrpos, hnear⟩
      refine ⟨r, hrpos, ?_⟩
      intro z hzball hzseg
      have hzseg_rev :
          z ∈ closedSegment
            ((canonicalGraph C).point j)
            ((canonicalGraph C).point i) := by
        rw [closedSegment_symm]
        exact hzseg
      exact hnear z hzball hzseg_rev

/-- Incident selected-edge rows are enough to feed the older adjacent-endpoint
endpoint-closure consumer, without any unconditional all-adjacent source. -/
theorem closedSegmentEndpointClosureSource_of_selectedEndpointClosure_incidentEdge
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (selectedEndpointClosure :
      SelectedUnboundedFrontierEdgeEndpointClosureSource C inputs)
    (incident_edge :
      AdjacentFrontierEndpointsIncidentUnboundedFrontierEdgeSource C inputs) :
    AdjacentFrontierEndpointsClosedSegmentEndpointClosureSource C inputs := by
  intro i j hij hifrontier hjfrontier
  exact
    selectedUnboundedFrontierEdgeEndpointClosureSource_of_selectedIncidentEdge
      (C := C) (inputs := inputs) selectedEndpointClosure
      (incident_edge hij hifrontier hjfrontier)

/-- A selected exterior-boundary edge supplies the local nearby-exterior-points
row along its relative interior.  This is the genuine exterior-side source row:
the selected edge already has its whole open segment on the unbounded exterior
frontier, and the metric closure criterion turns frontier membership into
arbitrarily close exterior points. -/
theorem unboundedFrontierEdgeSet_nearby_edge_point_exterior_points
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs) :
    forall q : PlanarInterface.Point,
      PlanarInterface.InOpenSegment q
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2) ->
      q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
        Exists fun r : Real =>
          0 < r /\
            forall z : PlanarInterface.Point,
              z ∈ Metric.ball q r ->
              PlanarInterface.InOpenSegment z
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2) ->
              forall eps : Real,
                0 < eps ->
                  Exists fun y : PlanarInterface.Point =>
                    y ∈ (unboundedExteriorComponentRows C inputs).exterior /\
                      dist y z < eps := by
  intro q _hq _hqclosure
  refine ⟨1, by norm_num, ?_⟩
  intro z _hzball hzseg eps heps
  have hzfrontier :
      z ∈ frontier (unboundedExteriorComponentRows C inputs).exterior :=
    (mem_unboundedFrontierEdgeSet_iff.1 he).2 z hzseg
  have hzclosure :
      z ∈ closure (unboundedExteriorComponentRows C inputs).exterior :=
    frontier_subset_closure hzfrontier
  rw [Metric.mem_closure_iff] at hzclosure
  rcases hzclosure eps heps with ⟨y, hyExterior, hydist⟩
  exact ⟨y, hyExterior, by simpa [dist_comm] using hydist⟩

/-- The exact residual carrier-membership source is enough to build the
nearby-exterior-points source row for all canonical interior frontier points.
No cyclic coverage, arbitrary cycle, induced frontier shortcut, or carrier
connectedness is used here. -/
theorem interiorEdgeNearbyExteriorPointSource_of_interior_frontier_edge_carrier_membership
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (interior_edge_mem :
      InteriorFrontierEdgeCarrierMembershipSource C inputs) :
    InteriorEdgeNearbyExteriorPointSource C inputs := by
  intro e p he hpEdge hpFrontier
  exact
    unboundedFrontierEdgeSet_nearby_edge_point_exterior_points
      (C := C) (inputs := inputs) (e := e)
      (interior_edge_mem he hpEdge hpFrontier)

/-- Claim `S2-agent-interior-relative-ball-closure-source`, reduced to the
exact local carrier-membership theorem for interior frontier edges. -/
theorem S2_agent_interior_relative_ball_closure_source_of_interior_frontier_edge_carrier_membership
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (interior_edge_mem :
      InteriorFrontierEdgeCarrierMembershipSource C inputs) :
    InteriorRelativeBallClosureRow C inputs :=
  S2_agent_interior_relative_ball_closure_source
    (interiorEdgeNearbyExteriorPointSource_of_interior_frontier_edge_carrier_membership
      interior_edge_mem)

/-- Closure along selected edge interiors plus the drawing-complement
nonmembership row proves the whole-edge frontier row. -/
theorem unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (hclosure : UnboundedFrontierEdgeSetOpenSegmentClosure C inputs) :
    UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs := by
  intro e he p hp
  rw [(unboundedExteriorComponentRows C inputs).exterior_open.frontier_eq]
  exact
    ⟨hclosure e he p hp,
      unboundedFrontierEdgeSet_inOpenSegment_not_mem_unboundedExterior
        he hp⟩

/-- The concrete carrier definition supplies the whole-open-segment frontier
row. -/
theorem unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C} :
    UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs := by
  intro e he p hp
  exact (mem_unboundedFrontierEdgeSet_iff.1 he).2 p hp

/-- A selected frontier edge has frontier endpoints once the whole-edge
frontier row is available. -/
theorem endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs)
    {e : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs) :
    e.1 ∈ unboundedFrontierVertexSet C inputs ∧
      e.2 ∈ unboundedFrontierVertexSet C inputs :=
  endpoints_mem_unboundedFrontierVertexSet_of_edge_openSegment_frontier
    (hwhole e he)

/-- A selected unbounded-frontier edge gives two distinct points on the actual
unbounded exterior frontier: its two graph endpoints. -/
theorem exists_two_frontier_points_of_unboundedFrontierEdgeSet
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs) :
    Exists fun p : PlanarInterface.Point =>
      Exists fun q : PlanarInterface.Point =>
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
          q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
            p ≠ q := by
  have hendpoints :
      e.1 ∈ unboundedFrontierVertexSet C inputs ∧
        e.2 ∈ unboundedFrontierVertexSet C inputs :=
    endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
      unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition he
  refine
    ⟨(canonicalGraph C).point e.1, (canonicalGraph C).point e.2,
      mem_unboundedFrontierVertexSet_iff.1 hendpoints.1,
      mem_unboundedFrontierVertexSet_iff.1 hendpoints.2, ?_⟩
  exact canonical_edge_point_ne_of_mem_edgeSet
    (mem_unboundedFrontierEdgeSet_iff.1 he).1

/-- A singleton graph-frontier carrier has no selected unbounded-frontier
edges.

Any selected edge has both endpoints in the graph-frontier carrier, and those
endpoints are distinct as canonical graph points. -/
theorem unboundedFrontierEdgeSet_empty_of_unboundedFrontierVertexSet_card_eq_one
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (hcard :
      (unboundedFrontierVertexSet C inputs).card = 1) :
    unboundedFrontierEdgeSet C inputs = ∅ := by
  classical
  apply Finset.eq_empty_iff_forall_notMem.2
  intro e he
  rcases Finset.card_eq_one.mp hcard with ⟨v, hsingleton⟩
  have hendpoints :
      e.1 ∈ unboundedFrontierVertexSet C inputs ∧
        e.2 ∈ unboundedFrontierVertexSet C inputs :=
    endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
      unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition he
  have hleft : e.1 = v := by
    simpa [hsingleton] using hendpoints.1
  have hright : e.2 = v := by
    simpa [hsingleton] using hendpoints.2
  have hpoint_ne :
      (canonicalGraph C).point e.1 ≠ (canonicalGraph C).point e.2 :=
    canonical_edge_point_ne_of_mem_edgeSet
      (mem_unboundedFrontierEdgeSet_iff.1 he).1
  exact hpoint_ne (by simp [hleft, hright])

/-- An unbounded-frontier point in the relative interior of a canonical edge
gives two distinct actual unbounded-frontier points.  The finite drawing's
fixed-side local theorem first promotes the interior point to membership of
the whole edge in `unboundedFrontierEdgeSet`; the selected-edge endpoint row
then supplies the two distinct frontier endpoints. -/
theorem exists_two_frontier_points_of_frontier_edgeInterior
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    {p : PlanarInterface.Point}
    (he : e ∈ (canonicalGraph C).edgeSet)
    (hpEdge :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2))
    (hpFrontier :
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    Exists fun p : PlanarInterface.Point =>
      Exists fun q : PlanarInterface.Point =>
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
          q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
            p ≠ q :=
  exists_two_frontier_points_of_unboundedFrontierEdgeSet
    (C := C) (inputs := inputs)
    (interiorFrontierEdgeCarrierMembershipSource_of_frontier_edge_point
      (C := C) (inputs := inputs) he hpEdge hpFrontier)

/-- In the singleton graph-frontier carrier case, no actual frontier point can
lie in the relative interior of a canonical edge.

Such an interior frontier point is promoted by the fixed-side local theorem to
a selected `unboundedFrontierEdgeSet` edge, contradicting the previous
singleton-edge emptiness lemma. -/
theorem no_frontier_edgeInterior_of_unboundedFrontierVertexSet_card_eq_one
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (hcard :
      (unboundedFrontierVertexSet C inputs).card = 1) :
    ¬ Exists fun e : PlanarInterface.Edge n =>
        Exists fun p : PlanarInterface.Point =>
          e ∈ (canonicalGraph C).edgeSet ∧
            p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
              PlanarInterface.InOpenSegment p
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2) := by
  intro h
  rcases h with ⟨e, p, he, hpFrontier, hpEdge⟩
  have hselected :
      e ∈ unboundedFrontierEdgeSet C inputs :=
    interiorFrontierEdgeCarrierMembershipSource_of_frontier_edge_point
      (C := C) (inputs := inputs) he hpEdge hpFrontier
  have hempty :
      unboundedFrontierEdgeSet C inputs = ∅ :=
    unboundedFrontierEdgeSet_empty_of_unboundedFrontierVertexSet_card_eq_one
      (C := C) (inputs := inputs) hcard
  have hnot : e ∉ unboundedFrontierEdgeSet C inputs := by
    rw [hempty]
    simp
  exact hnot hselected

/-- If the actual selected unbounded exterior frontier were a singleton graph
point, then some other ambient drawing-complement frontier point has
arbitrarily nearby complement points outside the selected unbounded exterior
component.

This is the concrete boundary-bumping residual left by the singleton case:
the finite drawing supplies an ambient edge-interior frontier point distinct
from the singleton, and the previous metric separation lemma supplies nearby
points belonging to other complement components. -/
theorem exists_ambient_frontier_nearby_complement_outside_unboundedExterior_of_frontier_singleton
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    {v : Fin n}
    (hfrontier :
      frontier (unboundedExteriorComponentRows C inputs).exterior =
        {(canonicalGraph C).point v}) :
    Exists fun q : PlanarInterface.Point =>
      q ∈ frontier (drawingComplement C) ∧
        q ≠ (canonicalGraph C).point v ∧
          forall ε : Real,
            0 < ε ->
              Exists fun y : PlanarInterface.Point =>
                y ∈ Metric.ball q ε ∧
                  y ∈ drawingComplement C ∧
                    y ∉ (unboundedExteriorComponentRows C inputs).exterior := by
  rcases exists_drawingComplement_frontier_point_ne_graph_vertex
      (C := C) inputs v with
    ⟨q, hqAmbient, hqne⟩
  have hqNotActual :
      q ∉ frontier (unboundedExteriorComponentRows C inputs).exterior := by
    intro hqActual
    have hqSingleton :
        q ∈ ({(canonicalGraph C).point v} : Set PlanarInterface.Point) := by
      simpa [hfrontier] using hqActual
    exact hqne (by simpa using hqSingleton)
  exact
    ⟨q, hqAmbient, hqne,
      exists_drawingComplement_point_not_unboundedExterior_near_of_ambient_frontier_not_unboundedExterior_frontier
        (C := C) (inputs := inputs) hqAmbient hqNotActual⟩

/-- If the graph-frontier carrier is a singleton, the whole actual unbounded
exterior frontier is that single graph point.

This isolates the remaining singleton residual as a pure point-frontier
topology contradiction: the open-edge branch is impossible by
`no_frontier_edgeInterior_of_unboundedFrontierVertexSet_card_eq_one`, and all
vertex points are forced to be the unique graph-frontier vertex. -/
theorem unboundedExterior_frontier_eq_singleton_of_unboundedFrontierVertexSet_card_eq_one
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (hcard :
      (unboundedFrontierVertexSet C inputs).card = 1) :
    Exists fun v : Fin n =>
      frontier (unboundedExteriorComponentRows C inputs).exterior =
        {(canonicalGraph C).point v} := by
  classical
  rcases Finset.card_eq_one.mp hcard with ⟨v, hsingleton⟩
  refine ⟨v, Set.Subset.antisymm ?_ ?_⟩
  · intro p hp
    rcases
        unboundedExterior_frontier_point_vertex_or_ordered_edgeInterior
          inputs hp with hvertex | hedge
    · rcases hvertex with ⟨w, hpw⟩
      have hw : w ∈ unboundedFrontierVertexSet C inputs :=
        mem_unboundedFrontierVertexSet_iff.2 (by simpa [hpw] using hp)
      have hwv : w = v := by
        simpa [hsingleton] using hw
      simp [hpw, hwv]
    · exact False.elim
        (no_frontier_edgeInterior_of_unboundedFrontierVertexSet_card_eq_one
          (C := C) (inputs := inputs) hcard
          (by
            rcases hedge with ⟨e, he, hpEdge⟩
            exact ⟨e, p, he, hp, hpEdge⟩))
  · intro p hp
    have hpv : p = (canonicalGraph C).point v := by
      simpa using hp
    rw [hpv]
    have hv : v ∈ unboundedFrontierVertexSet C inputs := by
      simp [hsingleton]
    exact mem_unboundedFrontierVertexSet_iff.1 hv

/-- Cardinality-one graph-frontier carriers reduce to the same concrete
boundary-bumping residual as the singleton actual-frontier case. -/
theorem exists_ambient_frontier_nearby_complement_outside_unboundedExterior_of_unboundedFrontierVertexSet_card_eq_one
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (hcard :
      (unboundedFrontierVertexSet C inputs).card = 1) :
    Exists fun q : PlanarInterface.Point =>
      q ∈ frontier (drawingComplement C) ∧
        (Exists fun v : Fin n =>
          q ≠ (canonicalGraph C).point v ∧
            frontier (unboundedExteriorComponentRows C inputs).exterior =
              {(canonicalGraph C).point v}) ∧
          forall ε : Real,
            0 < ε ->
              Exists fun y : PlanarInterface.Point =>
                y ∈ Metric.ball q ε ∧
                  y ∈ drawingComplement C ∧
                    y ∉ (unboundedExteriorComponentRows C inputs).exterior := by
  rcases
      unboundedExterior_frontier_eq_singleton_of_unboundedFrontierVertexSet_card_eq_one
        (C := C) (inputs := inputs) hcard with
    ⟨v, hfrontier⟩
  rcases
      exists_ambient_frontier_nearby_complement_outside_unboundedExterior_of_frontier_singleton
        (C := C) inputs hfrontier with
    ⟨q, hqAmbient, hqne, hnear⟩
  exact ⟨q, hqAmbient, ⟨v, hqne, hfrontier⟩, hnear⟩

/-- Two distinct graph vertices on the actual unbounded exterior frontier give
two distinct frontier points. -/
theorem exists_two_frontier_points_of_two_unboundedFrontierVertices
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {v w : Fin n}
    (hv : v ∈ unboundedFrontierVertexSet C inputs)
    (hw : w ∈ unboundedFrontierVertexSet C inputs)
    (hvw : v ≠ w) :
    Exists fun p : PlanarInterface.Point =>
      Exists fun q : PlanarInterface.Point =>
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
          q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
            p ≠ q := by
  refine
    ⟨(canonicalGraph C).point v, (canonicalGraph C).point w,
      mem_unboundedFrontierVertexSet_iff.1 hv,
      mem_unboundedFrontierVertexSet_iff.1 hw, ?_⟩
  intro hpoint
  exact hvw (canonical_point_injective C hpoint)

/-- The canonical unbounded-frontier seed either is already a graph-frontier
vertex, or it yields two distinct points on the actual unbounded exterior
frontier through the open-edge branch. -/
theorem exists_unboundedFrontierVertexSet_or_two_frontier_points
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) :
    (Exists fun v : Fin n => v ∈ unboundedFrontierVertexSet C inputs) ∨
      Exists fun p : PlanarInterface.Point =>
        Exists fun q : PlanarInterface.Point =>
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
              p ≠ q := by
  rcases exists_unboundedFrontierVertexSet_or_frontier_edgeInterior
      (C := C) inputs with hvertex | hedge
  · exact Or.inl hvertex
  · rcases hedge with ⟨e, p, he, hpfrontier, hpedge⟩
    exact Or.inr
      (exists_two_frontier_points_of_frontier_edgeInterior
        (C := C) (inputs := inputs) he hpedge hpfrontier)

/-- If the graph vertices on the actual unbounded exterior frontier do not
form a singleton, then either there are no such graph vertices or two distinct
actual frontier points are already available from two distinct graph vertices.

This isolates the only remaining graph-vertex seed case as the singleton
frontier-vertex carrier case. -/
theorem exists_two_frontier_points_or_no_unboundedFrontierVertexSet_of_card_ne_one
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (hcard_ne :
      (unboundedFrontierVertexSet C inputs).card ≠ 1) :
    (¬ Exists fun v : Fin n => v ∈ unboundedFrontierVertexSet C inputs) ∨
      Exists fun p : PlanarInterface.Point =>
        Exists fun q : PlanarInterface.Point =>
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
              p ≠ q := by
  classical
  let S : Finset (Fin n) := unboundedFrontierVertexSet C inputs
  by_cases hnonempty : Exists fun v : Fin n => v ∈ S
  · rcases hnonempty with ⟨v, hv⟩
    have hexists_other :
        Exists fun w : Fin n => w ∈ S ∧ w ≠ v := by
      by_contra hno
      have hall : forall w : Fin n, w ∈ S -> w = v := by
        intro w hw
        by_contra hwv
        exact hno ⟨w, hw, hwv⟩
      have hS_eq : S = {v} := by
        apply Finset.Subset.antisymm
        · intro w hw
          simp [hall w hw]
        · intro w hw
          simpa using (by
            have hwv : w = v := by simpa using hw
            simpa [hwv] using hv)
      exact hcard_ne (by simp [S, hS_eq])
    rcases hexists_other with ⟨w, hw, hw_ne_v⟩
    exact Or.inr
      (exists_two_frontier_points_of_two_unboundedFrontierVertices
        (C := C) (inputs := inputs) hv hw hw_ne_v.symm)
  · exact Or.inl (by simpa [S] using hnonempty)

/-- The actual finite boundary-edge carrier graph on unbounded-frontier
vertices.  Its edges are exactly ordered canonical graph edges whose relative
interiors meet the unbounded exterior frontier. -/
noncomputable def unboundedFrontierCarrierGraph
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    SimpleGraph {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} where
  Adj a b :=
    (a.1, b.1) ∈ unboundedFrontierEdgeSet C inputs \/
      (b.1, a.1) ∈ unboundedFrontierEdgeSet C inputs
  symm := by
    intro a b h
    exact h.symm
  loopless := by
    refine ⟨fun a h => ?_⟩
    rcases h with h | h
    · have hordered :
          (a.1, a.1).1 < (a.1, a.1).2 :=
        (canonicalGraph C).edge_mem_ordered
          (mem_unboundedFrontierEdgeSet_iff.1 h).1
      exact (lt_irrefl a.1) hordered
    · have hordered :
          (a.1, a.1).1 < (a.1, a.1).2 :=
        (canonicalGraph C).edge_mem_ordered
          (mem_unboundedFrontierEdgeSet_iff.1 h).1
      exact (lt_irrefl a.1) hordered

theorem unboundedFrontierCarrierGraph_adj_iff
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}} :
    (unboundedFrontierCarrierGraph C inputs).Adj a b ↔
      (a.1, b.1) ∈ unboundedFrontierEdgeSet C inputs \/
        (b.1, a.1) ∈ unboundedFrontierEdgeSet C inputs :=
  Iff.rfl

/-- The concrete unbounded-frontier carrier has decidable adjacency by
classical decidability of the finite edge set predicate. -/
noncomputable def unboundedFrontierCarrierGraph_decidableAdj
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    DecidableRel (unboundedFrontierCarrierGraph C inputs).Adj := by
  classical
  infer_instance

theorem unboundedFrontierCarrierGraph_adj_of_ordered_edge
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (hab : (a.1, b.1) ∈ unboundedFrontierEdgeSet C inputs) :
    (unboundedFrontierCarrierGraph C inputs).Adj a b :=
  (unboundedFrontierCarrierGraph_adj_iff).2 (Or.inl hab)

theorem unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (hba : (b.1, a.1) ∈ unboundedFrontierEdgeSet C inputs) :
    (unboundedFrontierCarrierGraph C inputs).Adj a b :=
  (unboundedFrontierCarrierGraph_adj_iff).2 (Or.inr hba)

/-- Whole-open-segment frontier evidence promotes a canonical ordered edge to
an adjacency in the concrete unbounded-frontier carrier graph. -/
theorem unboundedFrontierCarrierGraph_adj_of_edge_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ (canonicalGraph C).edgeSet)
    (hseg :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    (unboundedFrontierCarrierGraph C inputs).Adj
      ⟨e.1,
        (endpoints_mem_unboundedFrontierVertexSet_of_edge_openSegment_frontier
          hseg).1⟩
      ⟨e.2,
        (endpoints_mem_unboundedFrontierVertexSet_of_edge_openSegment_frontier
          hseg).2⟩ := by
  exact unboundedFrontierCarrierGraph_adj_of_ordered_edge
    (mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier he hseg)

/-- A cycle edge whose whole relative interior lies on the unbounded exterior
frontier determines a selected concrete frontier-carrier edge, up to the
stored ordering of canonical graph edges. -/
theorem cycle_edge_mem_unboundedFrontierEdgeSet_or_symm_of_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (cycle_edge_openSegment_frontier :
      forall k : Fin B.length,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (B.vertex k))
            ((canonicalGraph C).point
              (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (k : Fin B.length) :
    (B.vertex k,
        B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
        unboundedFrontierEdgeSet C inputs ∨
      (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
        B.vertex k) ∈ unboundedFrontierEdgeSet C inputs := by
  rcases B.adjacent k with h | h
  · left
    exact
      mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier
        (e :=
          (B.vertex k,
            B.vertex (PlanarInterface.cyclicSucc B.length_pos k)))
        h
        (cycle_edge_openSegment_frontier k)
  · right
    exact
      mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier
        (e :=
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
            B.vertex k))
        h
        (by
          intro p hp
          exact cycle_edge_openSegment_frontier k p
            (inOpenSegment_symm hp))

/-- If every consecutive boundary-cycle side is a selected edge of the actual
unbounded-frontier carrier, then its whole relative interior lies on the actual
unbounded exterior frontier.

This is the converse direction to
`cycle_edge_mem_unboundedFrontierEdgeSet_or_symm_of_openSegment_frontier` and is
the sharper source for the cycle-edge frontier row: the input is membership in
`unboundedFrontierEdgeSet C inputs`, not an arbitrary cycle-level frontier
assertion. -/
theorem cycle_edge_openSegment_frontier_of_unboundedFrontierEdgeSet_or_symm
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (cycle_edge_mem :
      forall k : Fin B.length,
        (B.vertex k,
            B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
            unboundedFrontierEdgeSet C inputs ∨
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
            B.vertex k) ∈
            unboundedFrontierEdgeSet C inputs) :
    forall k : Fin B.length,
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (B.vertex k))
          ((canonicalGraph C).point
            (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  intro k p hp
  rcases cycle_edge_mem k with hforward | hreverse
  · exact (mem_unboundedFrontierEdgeSet_iff.1 hforward).2 p hp
  · exact (mem_unboundedFrontierEdgeSet_iff.1 hreverse).2 p
      (inOpenSegment_symm hp)

/-- The consecutive boundary-cycle open-segment frontier row is equivalent to
membership of every boundary side in the actual unbounded-frontier edge carrier
up to stored orientation. -/
theorem cycle_edge_openSegment_frontier_iff_unboundedFrontierEdgeSet_or_symm
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C} :
    (forall k : Fin B.length,
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (B.vertex k))
          ((canonicalGraph C).point
            (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) ↔
      forall k : Fin B.length,
        (B.vertex k,
            B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
            unboundedFrontierEdgeSet C inputs ∨
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
            B.vertex k) ∈
            unboundedFrontierEdgeSet C inputs := by
  constructor
  · exact cycle_edge_mem_unboundedFrontierEdgeSet_or_symm_of_openSegment_frontier
  · exact cycle_edge_openSegment_frontier_of_unboundedFrontierEdgeSet_or_symm

/-- Boundary-cycle vertex/frontier equivalence plus whole-edge frontier
membership gives the concrete carrier adjacency from a cycle vertex to its
successor.  The harder incident-neighbour exclusion remains a separate
geometric row. -/
theorem unboundedFrontierCarrierGraph_adj_of_cycle_edge_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (frontier_iff_cycle_vertex :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin B.length => B.vertex k = v)
    (cycle_edge_openSegment_frontier :
      forall k : Fin B.length,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (B.vertex k))
            ((canonicalGraph C).point
              (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (k : Fin B.length) :
    (unboundedFrontierCarrierGraph C inputs).Adj
      ⟨B.vertex k,
        mem_unboundedFrontierVertexSet_iff.2
          ((frontier_iff_cycle_vertex (B.vertex k)).2 ⟨k, rfl⟩)⟩
      ⟨B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
        mem_unboundedFrontierVertexSet_iff.2
          ((frontier_iff_cycle_vertex
            (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))).2
            ⟨PlanarInterface.cyclicSucc B.length_pos k, rfl⟩)⟩ := by
  rcases
      cycle_edge_mem_unboundedFrontierEdgeSet_or_symm_of_openSegment_frontier
        cycle_edge_openSegment_frontier k with
    h | h
  · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge h
  · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm h

/-- Selected ordered frontier edges become concrete carrier adjacencies once
the whole-edge frontier row supplies endpoint membership. -/
theorem unboundedFrontierCarrierGraph_adj_of_unboundedFrontierEdgeSet
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs)
    {e : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs) :
    (unboundedFrontierCarrierGraph C inputs).Adj
      ⟨e.1,
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole he).1⟩
      ⟨e.2,
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole he).2⟩ :=
  unboundedFrontierCarrierGraph_adj_of_ordered_edge he

/-- Carrier adjacency always maps to a canonical unit-distance edge. -/
theorem unboundedFrontierCarrierGraph_adj_canonicalAdj
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (hab : (unboundedFrontierCarrierGraph C inputs).Adj a b) :
    (canonicalGraph C).Adj a.1 b.1 := by
  rcases hab with hab | hba
  · exact unboundedFrontierEdgeSet_adj hab
  · exact canonicalAdj_symm (unboundedFrontierEdgeSet_adj hba)

/-- With the whole-edge frontier row, every concrete carrier adjacency is an
actual exterior-frontier open segment. -/
theorem unboundedFrontierCarrierGraph_openSegment_frontier_of_adj
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs)
    {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (hab : (unboundedFrontierCarrierGraph C inputs).Adj a b) :
    forall p : PlanarInterface.Point,
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point a.1)
        ((canonicalGraph C).point b.1) ->
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  intro p hp
  rcases hab with hab | hba
  · exact hwhole (a.1, b.1) hab p hp
  · exact hwhole (b.1, a.1) hba p (inOpenSegment_symm hp)

/-- A local two-germ frontier containment row at a carrier vertex rules out all
other concrete unbounded-frontier carrier neighbours.

The row is deliberately phrased just at the vertex `a`: after shrinking to a
ball around `a`, every exterior-frontier point in that ball is carried by the
left or right incident vertex germ.  Given any carrier neighbour `b`, a
frontier point on the open segment from `a` to `b` can be chosen inside the
ball; the same-left unit-edge uniqueness lemma then identifies `b` with the
corresponding germ endpoint. -/
theorem unboundedFrontierCarrierGraph_only_of_local_frontier_germ_two
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    {left right : Fin n}
    (hleft : (canonicalGraph C).Adj a.1 left)
    (hright : (canonicalGraph C).Adj a.1 right)
    (hlocal :
      Exists fun ε : Real =>
        0 < ε ∧
          forall q : PlanarInterface.Point,
            q ∈ Metric.ball ((canonicalGraph C).point a.1) ε ->
              q ∈ frontier
                (unboundedExteriorComponentRows C inputs).exterior ->
                q ∈ vertexIncidentGermW3 C a.1 left ε ∨
                  q ∈ vertexIncidentGermW3 C a.1 right ε) :
    forall b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      (unboundedFrontierCarrierGraph C inputs).Adj a b ->
        b.1 = left ∨ b.1 = right := by
  rcases hlocal with ⟨ε, hεpos, hlocal⟩
  intro b hab
  have hab_canonical : (canonicalGraph C).Adj a.1 b.1 :=
    unboundedFrontierCarrierGraph_adj_canonicalAdj hab
  have hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
    unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
  have hfrontier_on_ab :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point a.1)
          ((canonicalGraph C).point b.1) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior :=
    unboundedFrontierCarrierGraph_openSegment_frontier_of_adj hwhole hab
  have hclosure_left :
      (canonicalGraph C).point a.1 ∈
        closure
          ({p : PlanarInterface.Point |
            PlanarInterface.InOpenSegment p
              ((canonicalGraph C).point a.1)
              ((canonicalGraph C).point b.1)}) :=
    left_mem_closure_inOpenSegment
      ((canonicalGraph C).point a.1)
      ((canonicalGraph C).point b.1)
  rw [Metric.mem_closure_iff] at hclosure_left
  rcases hclosure_left ε hεpos with ⟨p, hpopen_ab, hpball⟩
  have hpball_mem :
      p ∈ Metric.ball ((canonicalGraph C).point a.1) ε := by
    simpa [Metric.mem_ball, dist_comm] using hpball
  have hpfrontier :
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior :=
    hfrontier_on_ab p hpopen_ab
  rcases hlocal p hpball_mem hpfrontier with hpgerm | hpgerm
  · rcases hpgerm with ⟨_hpball, hpclosed⟩
    rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hpclosed with
      hpa | hpleft | hpopen_left
    · exact False.elim
        (graph_vertex_not_inOpenSegment_of_adj
          (C := C) (v := a.1) hab_canonical
          (by simpa [hpa] using hpopen_ab))
    · exact False.elim
        (graph_vertex_not_inOpenSegment_of_adj
          (C := C) (v := left) hab_canonical
          (by simpa [hpleft] using hpopen_ab))
    · exact Or.inl
        (same_left_inOpenSegment_other_endpoint_eq
          hab_canonical hleft hpopen_ab hpopen_left)
  · rcases hpgerm with ⟨_hpball, hpclosed⟩
    rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hpclosed with
      hpa | hpright | hpopen_right
    · exact False.elim
        (graph_vertex_not_inOpenSegment_of_adj
          (C := C) (v := a.1) hab_canonical
          (by simpa [hpa] using hpopen_ab))
    · exact False.elim
        (graph_vertex_not_inOpenSegment_of_adj
          (C := C) (v := right) hab_canonical
          (by simpa [hpright] using hpopen_ab))
    · exact Or.inr
        (same_left_inOpenSegment_other_endpoint_eq
          hab_canonical hright hpopen_ab hpopen_right)

/-- Local vertex-star isolation plus angular exclusion cuts the exterior
frontier near a boundary vertex down to the two selected exterior germs.

The geometric input `bad_germ_between` is the local angular-order fact: if a
nearby noncenter exterior-frontier point is carried by an incident germ other
than the selected predecessor/successor germs, that incident edge points into
the open angular sector between them.  The center case is already in each
closed incident germ, so the `no_between` row only has to rule out the
nondegenerate cases. -/
theorem exists_local_frontier_germ_two_of_vertex_star_isolation_and_angular_no_between
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (k : Fin B.length)
    (bad_germ_between :
      forall (ε : Real) (q : PlanarInterface.Point) (x : Fin n),
        q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) ε ->
          q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
            (canonicalGraph C).Adj (B.vertex k) x ->
              q ∈ vertexIncidentGermW3 C (B.vertex k) x ε ->
                q ≠ (canonicalGraph C).point (B.vertex k) ->
                x ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
                  x ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
                    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
                      C B k x)
    (no_between :
      forall x : Fin n,
        GraphBridge.UnitDistanceAdj C (B.vertex k) x ->
          x ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
            x ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
              ¬
                _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
                  C B k x) :
    Exists fun ε : Real =>
      0 < ε ∧
        forall q : PlanarInterface.Point,
          q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) ε ->
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
              q ∈ vertexIncidentGermW3 C (B.vertex k)
                    (B.vertex (PlanarInterface.cyclicPred B.length_pos k)) ε ∨
                q ∈ vertexIncidentGermW3 C (B.vertex k)
                    (B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ε := by
  rcases
      exists_ball_forall_unboundedExterior_frontier_mem_vertexIncidentGermW3
        C inputs (B.vertex k) with
    ⟨ε, hεpos, hstar⟩
  refine ⟨ε, hεpos, ?_⟩
  intro q hqball hqfrontier
  by_cases hqcenter :
      q = (canonicalGraph C).point (B.vertex k)
  · left
    rw [hqcenter]
    exact
      ⟨by
          simpa [Metric.mem_ball] using hεpos,
        left_mem_closedSegment _ _⟩
  rcases hstar q hqball hqfrontier with ⟨x, hvx, hqx⟩
  by_cases hx_pred :
      x = B.vertex (PlanarInterface.cyclicPred B.length_pos k)
  · left
    simpa [hx_pred] using hqx
  by_cases hx_succ :
      x = B.vertex (PlanarInterface.cyclicSucc B.length_pos k)
  · right
    simpa [hx_succ] using hqx
  have hx_unit : GraphBridge.UnitDistanceAdj C (B.vertex k) x :=
    ((canonicalGraph C).adj_iff_unitDistanceAdj (B.vertex k) x).1 hvx
  have hbetween :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
        C B k x :=
    bad_germ_between ε q x hqball hqfrontier hvx hqx hqcenter hx_pred hx_succ
  exact False.elim ((no_between x hx_unit hx_pred hx_succ) hbetween)

/-- Boundary-free local two-germ reducer at a concrete unbounded-frontier
carrier vertex.

This is the non-circular version of
`exists_local_frontier_germ_two_of_vertex_star_isolation_and_angular_no_between`:
the two selected incident endpoints are arbitrary `left`/`right` carrier
edges at `a`, and the geometric/topological proof only has to rule out a
third incident germ. -/
theorem exists_local_frontier_germ_two_of_vertex_star_isolation_no_third_germ
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    {left right : Fin n}
    (no_third_germ :
      forall (ε : Real) (q : PlanarInterface.Point) (x : Fin n),
        q ∈ Metric.ball ((canonicalGraph C).point a.1) ε ->
          q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
            (canonicalGraph C).Adj a.1 x ->
              q ∈ vertexIncidentGermW3 C a.1 x ε ->
                q ≠ (canonicalGraph C).point a.1 ->
                  x ≠ left ->
                    x ≠ right ->
                      False) :
    Exists fun ε : Real =>
      0 < ε ∧
        forall q : PlanarInterface.Point,
          q ∈ Metric.ball ((canonicalGraph C).point a.1) ε ->
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
              q ∈ vertexIncidentGermW3 C a.1 left ε ∨
                q ∈ vertexIncidentGermW3 C a.1 right ε := by
  rcases
      exists_ball_forall_unboundedExterior_frontier_mem_vertexIncidentGermW3
        C inputs a.1 with
    ⟨ε, hεpos, hstar⟩
  refine ⟨ε, hεpos, ?_⟩
  intro q hqball hqfrontier
  by_cases hqcenter : q = (canonicalGraph C).point a.1
  · left
    rw [hqcenter]
    exact
      ⟨by
          simpa [Metric.mem_ball] using hεpos,
        left_mem_closedSegment _ _⟩
  rcases hstar q hqball hqfrontier with ⟨x, hvx, hqx⟩
  by_cases hx_left : x = left
  · left
    simpa [hx_left] using hqx
  by_cases hx_right : x = right
  · right
    simpa [hx_right] using hqx
  exact False.elim
    (no_third_germ ε q x hqball hqfrontier hvx hqx hqcenter hx_left hx_right)

/-- The vector from the left endpoint to a parametrized point of a segment is
the positive/zero real multiple of the whole segment vector. -/
theorem dartVector_segmentPoint_eq_real_mul
    (a b : PlanarInterface.Point) (t : Real) :
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartVector
        a (PlanarInterface.segmentPoint a b t) =
      (t : Complex) *
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartVector
          a b := by
  rw [_root_.Complex.ext_iff]
  constructor <;>
    simp [
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartVector,
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.pointToComplex,
      PlanarInterface.segmentPoint] <;>
    ring

/-- A non-left-endpoint point on a closed segment has the same principal ray
angle from the left endpoint as the right endpoint. -/
theorem dartArg_eq_of_mem_closedSegment_ne_left
    {a b q : PlanarInterface.Point}
    (hqseg : q ∈ closedSegment a b)
    (hqne : q ≠ a) :
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg a q =
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg a b := by
  rcases hqseg with ⟨t, ht0, _ht1, hq⟩
  have htpos : 0 < t := by
    refine lt_of_le_of_ne ht0 ?_
    intro ht
    apply hqne
    have ht' : t = 0 := ht.symm
    rw [hq, ht']
    simp [PlanarInterface.segmentPoint]
  calc
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg a q =
        Complex.arg
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartVector
            a q) := rfl
    _ = Complex.arg
          ((t : Complex) *
            _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartVector
              a b) := by
        rw [hq]
        congr 1
        exact dartVector_segmentPoint_eq_real_mul a b t
    _ = Complex.arg
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartVector
            a b) := by
        simpa using
          Complex.arg_real_mul
            (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartVector
              a b)
            htpos
    _ =
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
          a b := rfl

/-- The point-ray form of the local exterior sector at a boundary vertex:
the ray from the boundary vertex to `q` lies strictly between the predecessor
and successor boundary rays. -/
abbrev BoundaryPredSuccPointAngularBetween
    (C : _root_.UDConfig n)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
    (k : Fin B.length) (q : PlanarInterface.Point) : Prop :=
  _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
      (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
      (B.vertex k)
      (B.vertex (PlanarInterface.cyclicPred B.length_pos k)) <
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
      ((canonicalGraph C).point (B.vertex k)) q ∧
  _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
      ((canonicalGraph C).point (B.vertex k)) q <
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
      (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
      (B.vertex k)
      (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))

/-- A nondegenerate point in an incident W3 germ has the same angular
coordinate as that incident graph dart. -/
theorem dartArg_eq_graphDartArg_of_mem_vertexIncidentGermW3_ne_center
    {C : _root_.UDConfig n} {v other : Fin n}
    {eps : Real} {q : PlanarInterface.Point}
    (hgerm : q ∈ vertexIncidentGermW3 C v other eps)
    (hqne : q ≠ (canonicalGraph C).point v) :
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
        ((canonicalGraph C).point v) q =
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
        v other := by
  exact dartArg_eq_of_mem_closedSegment_ne_left hgerm.2 hqne

/-- If the incident graph dart lies in the predecessor/successor angular
sector, then every noncenter point carried by that incident germ lies in the
corresponding point-ray sector. -/
theorem boundary_frontier_third_germ_point_between_of_graphDart_between
    {C : _root_.UDConfig n}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    {k : Fin B.length} {eps : Real}
    {q : PlanarInterface.Point} {other : Fin n}
    (hbetween :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
        C B k other)
    (hgerm : q ∈ vertexIncidentGermW3 C (B.vertex k) other eps)
    (hqne : q ≠ (canonicalGraph C).point (B.vertex k)) :
    BoundaryPredSuccPointAngularBetween C B k q := by
  have harg :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
          ((canonicalGraph C).point (B.vertex k)) q =
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
          (B.vertex k) other :=
    dartArg_eq_graphDartArg_of_mem_vertexIncidentGermW3_ne_center
      (C := C) (v := B.vertex k) (other := other)
      (eps := eps) (q := q) hgerm hqne
  exact ⟨by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hbetween.1,
    by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hbetween.2⟩

/-- The point-sector source row consumed by
`boundary_frontier_third_germ_between_of_local_exterior_sector`, obtained from
the honest edge-level third-germ angular row supplied by the exterior-side
argument. -/
theorem local_exterior_sector_of_boundary_frontier_third_germ_between
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (k : Fin B.length)
    (third_germ_between :
      forall (eps : Real) (q : PlanarInterface.Point) (other : Fin n),
        q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
        q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
        (canonicalGraph C).Adj (B.vertex k) other ->
        q ∈ vertexIncidentGermW3 C (B.vertex k) other eps ->
        q ≠ (canonicalGraph C).point (B.vertex k) ->
        other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
        other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
          _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
            C B k other) :
    forall (eps : Real) (q : PlanarInterface.Point) (other : Fin n),
      q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
      q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
      (canonicalGraph C).Adj (B.vertex k) other ->
      q ∈ vertexIncidentGermW3 C (B.vertex k) other eps ->
      q ≠ (canonicalGraph C).point (B.vertex k) ->
      other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
      other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
        BoundaryPredSuccPointAngularBetween C B k q := by
  intro eps q other hqball hqfrontier hadj hgerm hqne hother_pred hother_succ
  exact
    boundary_frontier_third_germ_point_between_of_graphDart_between
      (C := C) (B := B) (k := k) (eps := eps) (q := q)
      (other := other)
      (third_germ_between eps q other hqball hqfrontier hadj hgerm
        hqne hother_pred hother_succ)
      hgerm hqne

/-- Nondegenerate local exterior-sector theorem for a third incident germ.

The extra source row is the honest local exterior-sector side statement in
point-ray form: every nearby non-vertex exterior-frontier point carried by a
third germ lies in the open point-sector between the predecessor and successor
boundary rays.  The theorem converts that point-sector statement to the
edge-direction statement needed by the rotation-system rows.

The nondegeneracy hypothesis `q ≠ (canonicalGraph C).point (B.vertex k)` is
necessary because `vertexIncidentGermW3` is a closed germ and therefore
contains the center vertex for every incident edge. -/
theorem boundary_frontier_third_germ_between_of_local_exterior_sector
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (k : Fin B.length)
    (local_exterior_sector :
      forall (eps : Real) (q : PlanarInterface.Point) (other : Fin n),
        q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
        q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
        (canonicalGraph C).Adj (B.vertex k) other ->
        q ∈ vertexIncidentGermW3 C (B.vertex k) other eps ->
        q ≠ (canonicalGraph C).point (B.vertex k) ->
        other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
        other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
          BoundaryPredSuccPointAngularBetween C B k q) :
    forall (eps : Real) (q : PlanarInterface.Point) (other : Fin n),
      q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
      q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
      (canonicalGraph C).Adj (B.vertex k) other ->
      q ∈ vertexIncidentGermW3 C (B.vertex k) other eps ->
      q ≠ (canonicalGraph C).point (B.vertex k) ->
      other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
      other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
          C B k other := by
  intro eps q other hqball hqfrontier hadj hgerm hqne hother_pred hother_succ
  have hpoint :
      BoundaryPredSuccPointAngularBetween C B k q :=
    local_exterior_sector eps q other hqball hqfrontier hadj hgerm
      hqne hother_pred hother_succ
  have harg :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
          ((canonicalGraph C).point (B.vertex k)) q =
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
          (B.vertex k) other :=
    dartArg_eq_graphDartArg_of_mem_vertexIncidentGermW3_ne_center
      (C := C) (v := B.vertex k) (other := other)
      (eps := eps) (q := q) hgerm hqne
  exact ⟨by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hpoint.1,
    by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hpoint.2⟩

/-- Family reducer for the residual `third_germ_between` obligation in the
actual exterior-sector route.

The remaining source row is the concrete noncenter point-ray exterior-sector
statement: a nearby exterior-frontier point carried by a third incident germ
lies between the predecessor and successor boundary rays.  The closed-germ
noncenter hypothesis then identifies the point ray with the incident graph dart,
yielding the edge-direction `BoundaryPredSuccAngularBetween` row. -/
theorem boundary_frontier_third_germ_between_of_local_exterior_sector_source
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (boundary_frontier_local_exterior_sector :
      forall (k : Fin B.length) (eps : Real) (q : PlanarInterface.Point)
          (other : Fin n),
        q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
        q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
        (canonicalGraph C).Adj (B.vertex k) other ->
        q ∈ vertexIncidentGermW3 C (B.vertex k) other eps ->
        q ≠ (canonicalGraph C).point (B.vertex k) ->
        other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
        other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
          BoundaryPredSuccPointAngularBetween C B k q) :
    forall (k : Fin B.length) (eps : Real) (q : PlanarInterface.Point)
        (other : Fin n),
      q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
      q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
      (canonicalGraph C).Adj (B.vertex k) other ->
      q ∈ vertexIncidentGermW3 C (B.vertex k) other eps ->
      q ≠ (canonicalGraph C).point (B.vertex k) ->
      other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
      other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
          C B k other := by
  intro k
  exact
    boundary_frontier_third_germ_between_of_local_exterior_sector
      (C := C) (inputs := inputs) (B := B) k
      (boundary_frontier_local_exterior_sector k)

/-- Stronger local-side residual with the W3 bookkeeping removed.

For each boundary vertex, any noncenter actual unbounded-frontier point that
lies on a third incident closed segment and is sufficiently close to the vertex
already has its point-ray in the open predecessor/successor exterior sector.
This is a purely closed-segment local exterior-side statement; the W3 germ
condition is recovered from it by projection. -/
abbrev BoundaryFrontierClosedSegmentLocalExteriorSector
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall (k : Fin B.length) (eps : Real) (q : PlanarInterface.Point)
      (other : Fin n),
    q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
    q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
    (canonicalGraph C).Adj (B.vertex k) other ->
    q ∈ closedSegment
      ((canonicalGraph C).point (B.vertex k))
      ((canonicalGraph C).point other) ->
    q ≠ (canonicalGraph C).point (B.vertex k) ->
    other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
    other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
      BoundaryPredSuccPointAngularBetween C B k q

/-- Edge-direction form of the closed-segment local exterior-side residual.

The only remaining geometric/topological content is that a nearby noncenter
actual exterior-frontier point on a third incident closed segment forces that
incident edge direction into the predecessor/successor exterior sector.  The
point-ray conclusion of `BoundaryFrontierClosedSegmentLocalExteriorSector`
then follows formally from closed-segment collinearity. -/
abbrev BoundaryFrontierClosedSegmentLocalExteriorAngularSector
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall (k : Fin B.length) (eps : Real) (q : PlanarInterface.Point)
      (other : Fin n),
    q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
    q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
    (canonicalGraph C).Adj (B.vertex k) other ->
    q ∈ closedSegment
      ((canonicalGraph C).point (B.vertex k))
      ((canonicalGraph C).point other) ->
    q ≠ (canonicalGraph C).point (B.vertex k) ->
    other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
    other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
        C B k other

/-- Selected-edge form of the closed-segment local exterior residual.

This keeps the far-endpoint case honest: instead of classifying arbitrary
adjacent frontier endpoints as boundary predecessor/successor vertices, the
source says that the specific incident closed segment carrying the frontier
point is an actual selected `unboundedFrontierEdgeSet` edge. -/
abbrev BoundaryFrontierClosedSegmentSelectedEdgeSource
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall (k : Fin B.length) (eps : Real) (q : PlanarInterface.Point)
      (other : Fin n),
    q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
    q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
    (canonicalGraph C).Adj (B.vertex k) other ->
    q ∈ closedSegment
      ((canonicalGraph C).point (B.vertex k))
      ((canonicalGraph C).point other) ->
    q ≠ (canonicalGraph C).point (B.vertex k) ->
    other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
    other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
      ((B.vertex k, other) ∈ unboundedFrontierEdgeSet C inputs ∨
        (other, B.vertex k) ∈ unboundedFrontierEdgeSet C inputs)

/-- Open-segment form of the local exterior angular residual.

This isolates the genuinely local case of
`BoundaryFrontierClosedSegmentLocalExteriorAngularSector`: the frontier point is
in the relative interior of the third incident edge, rather than at the far
endpoint of the closed segment. -/
abbrev BoundaryFrontierOpenSegmentLocalExteriorAngularSector
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall (k : Fin B.length) (eps : Real) (q : PlanarInterface.Point)
      (other : Fin n),
    q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
    q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
    (canonicalGraph C).Adj (B.vertex k) other ->
    PlanarInterface.InOpenSegment q
      ((canonicalGraph C).point (B.vertex k))
      ((canonicalGraph C).point other) ->
    other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
    other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
        C B k other

/-- Point-ray form of the open-segment local exterior angular residual.

This is the genuinely local source row left after removing the graph-dart
angle bookkeeping: a nearby actual unbounded-frontier point in the relative
interior of a third incident edge has its ray from the boundary vertex in the
predecessor/successor exterior sector. -/
abbrev BoundaryFrontierOpenSegmentLocalExteriorSector
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall (k : Fin B.length) (eps : Real) (q : PlanarInterface.Point)
      (other : Fin n),
    q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
    q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
    (canonicalGraph C).Adj (B.vertex k) other ->
    PlanarInterface.InOpenSegment q
      ((canonicalGraph C).point (B.vertex k))
      ((canonicalGraph C).point other) ->
    other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
    other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
      BoundaryPredSuccPointAngularBetween C B k q

/-- Local propagation row for the open-segment source.

Starting from one actual exterior-frontier point in the relative interior of a
third incident edge, the closure locus of the unbounded exterior is locally open
inside that same edge interior.  Together with the connected open segment, this
upgrades the whole third-edge interior to frontier membership. -/
abbrev BoundaryFrontierOpenSegmentRelativeClosurePropagation
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall (k : Fin B.length) (q : PlanarInterface.Point) (other : Fin n),
    q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
    (canonicalGraph C).Adj (B.vertex k) other ->
    PlanarInterface.InOpenSegment q
      ((canonicalGraph C).point (B.vertex k))
      ((canonicalGraph C).point other) ->
    other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
    other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
      forall z : PlanarInterface.Point,
        PlanarInterface.InOpenSegment z
          ((canonicalGraph C).point (B.vertex k))
          ((canonicalGraph C).point other) ->
        z ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun r : Real =>
            0 < r /\
              forall y : PlanarInterface.Point,
                y ∈ Metric.ball z r ->
                PlanarInterface.InOpenSegment y
                  ((canonicalGraph C).point (B.vertex k))
                  ((canonicalGraph C).point other) ->
                y ∈ closure (unboundedExteriorComponentRows C inputs).exterior

/-- The boundary open-segment propagation row follows from the sharper
interior-edge carrier source.  Once the incident edge is already selected in
`unboundedFrontierEdgeSet`, its whole open segment is frontier by definition,
so every relative neighborhood along that segment is trivially in the exterior
closure. -/
theorem boundary_frontier_openSegment_relativeClosurePropagation_of_interior_edge_mem
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (interior_edge_mem :
      InteriorFrontierEdgeCarrierMembershipSource C inputs) :
    BoundaryFrontierOpenSegmentRelativeClosurePropagation inputs B := by
  intro k q other hqfrontier hadj hqopen _hother_pred _hother_succ
    _z _hzopen _hzclosure
  rcases hadj with hedge | hedge
  · have hedge_frontier :
        (B.vertex k, other) ∈ unboundedFrontierEdgeSet C inputs :=
      interior_edge_mem hedge hqopen hqfrontier
    refine ⟨1, by norm_num, ?_⟩
    intro y _hyball hyopen
    exact
      frontier_subset_closure
        ((mem_unboundedFrontierEdgeSet_iff.1 hedge_frontier).2 y hyopen)
  · have hedge_frontier :
        (other, B.vertex k) ∈ unboundedFrontierEdgeSet C inputs :=
      interior_edge_mem hedge (inOpenSegment_symm hqopen) hqfrontier
    refine ⟨1, by norm_num, ?_⟩
    intro y _hyball hyopen
    exact
      frontier_subset_closure
        ((mem_unboundedFrontierEdgeSet_iff.1 hedge_frontier).2 y
          (inOpenSegment_symm hyopen))

/-- Boundary-cycle specialization of the global interior relative-ball closure
row.  This removes the boundary-specific propagation assumption whenever the
existing interior-edge closure row is available. -/
theorem boundary_frontier_openSegment_relativeClosurePropagation_of_interior_relative_ball_closure
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (interior_relative_ball_closure :
      InteriorRelativeBallClosureRow C inputs) :
    BoundaryFrontierOpenSegmentRelativeClosurePropagation inputs B :=
  boundary_frontier_openSegment_relativeClosurePropagation_of_interior_edge_mem
    (C := C) (inputs := inputs) (B := B)
    (interior_frontier_edge_carrier_membership_source_of_relative_ball_closure
      interior_relative_ball_closure)

/-- Boundary-cycle specialization of the nearby-exterior-points source.  The
metric closure adapter is the existing `S2_agent_interior_relative_ball_closure_source`;
the boundary row is only its incident-edge restriction. -/
theorem boundary_frontier_openSegment_relativeClosurePropagation_of_nearby_edge_point_exterior_points
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (nearby_edge_point_exterior_points :
      InteriorEdgeNearbyExteriorPointSource C inputs) :
    BoundaryFrontierOpenSegmentRelativeClosurePropagation inputs B :=
  boundary_frontier_openSegment_relativeClosurePropagation_of_interior_relative_ball_closure
    (C := C) (inputs := inputs) (B := B)
    (S2_agent_interior_relative_ball_closure_source
      nearby_edge_point_exterior_points)

/-- Sharp local-edge-side reduction for the boundary propagation row.
It is enough to prove the honest local exterior-side patch statement for
interior points of canonical edges; the existing source reducers turn that
patch row into nearby exterior points and then into relative closure. -/
theorem boundary_frontier_openSegment_relativeClosurePropagation_of_local_exterior_side
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (local_exterior_side :
      InteriorEdgeLocalExteriorSideSource C inputs) :
    BoundaryFrontierOpenSegmentRelativeClosurePropagation inputs B :=
  boundary_frontier_openSegment_relativeClosurePropagation_of_nearby_edge_point_exterior_points
    (C := C) (inputs := inputs) (B := B)
    (S2_agent_interior_edge_nearby_exterior_point_source
      local_exterior_side)

/-- The fixed-side half-ball construction closes the boundary open-segment
relative-closure propagation row. -/
theorem boundary_frontier_openSegment_relativeClosurePropagation_of_fixed_side_halfballs
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C} :
    BoundaryFrontierOpenSegmentRelativeClosurePropagation inputs B :=
  boundary_frontier_openSegment_relativeClosurePropagation_of_interior_edge_mem
    (C := C) (inputs := inputs) (B := B)
    (interior_frontier_edge_carrier_membership_source_of_fixed_side_halfballs
      (C := C) (inputs := inputs))

/-- Edge-level angular source for selected third incident frontier edges.

This removes the moving point/radius bookkeeping from
`BoundaryFrontierOpenSegmentLocalExteriorSector`: once a third incident edge has
been promoted to the concrete unbounded-frontier edge set, only its graph-dart
direction must be shown to lie in the predecessor/successor angular sector. -/
abbrev BoundaryFrontierIncidentEdgeExteriorAngularSector
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall (k : Fin B.length) (other : Fin n),
    ((B.vertex k, other) ∈ unboundedFrontierEdgeSet C inputs ∨
      (other, B.vertex k) ∈ unboundedFrontierEdgeSet C inputs) ->
    other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
    other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
        C B k other

/-- Closed-segment angular control from selected-edge promotion plus the
selected incident-edge angular row.

The endpoint branch is not handled by an all-adjacent no-chord classifier: the
closed-segment source first promotes the exact incident edge to the actual
unbounded-frontier edge set, and the angular row is then applied to that
selected edge. -/
theorem boundary_frontier_closedSegment_local_exterior_angular_sector_of_closedSegment_selected_edge_incident_edge_angular
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (closedSegment_selected_edge :
      BoundaryFrontierClosedSegmentSelectedEdgeSource inputs B)
    (incident_edge_angular :
      BoundaryFrontierIncidentEdgeExteriorAngularSector inputs B) :
    BoundaryFrontierClosedSegmentLocalExteriorAngularSector inputs B := by
  intro k eps q other hqball hqfrontier hadj hqseg hqne hother_pred
    hother_succ
  exact
    incident_edge_angular k other
      (closedSegment_selected_edge k eps q other hqball hqfrontier hadj
        hqseg hqne hother_pred hother_succ)
      hother_pred hother_succ

/-- Promote the third open-segment frontier case to a concrete selected
unbounded-frontier edge, using the relative-closure propagation row. -/
theorem boundary_frontier_openSegment_frontierEdge_or_symm_of_relative_closure
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (relative_closure :
      BoundaryFrontierOpenSegmentRelativeClosurePropagation inputs B) :
    forall (k : Fin B.length) (q : PlanarInterface.Point) (other : Fin n),
      q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
      (canonicalGraph C).Adj (B.vertex k) other ->
      PlanarInterface.InOpenSegment q
        ((canonicalGraph C).point (B.vertex k))
        ((canonicalGraph C).point other) ->
      other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
      other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
        ((B.vertex k, other) ∈ unboundedFrontierEdgeSet C inputs ∨
          (other, B.vertex k) ∈ unboundedFrontierEdgeSet C inputs) := by
  intro k q other hqfrontier hadj hopen hother_pred hother_succ
  rcases hadj with hedge | hedge
  · have hfrontier :
        forall z : PlanarInterface.Point,
          PlanarInterface.InOpenSegment z
            ((canonicalGraph C).point (B.vertex k))
            ((canonicalGraph C).point other) ->
          z ∈ frontier (unboundedExteriorComponentRows C inputs).exterior :=
      edge_openSegment_frontier_of_inOpenSegment_frontier_and_relative_ball_closure
        (C := C) (inputs := inputs) (e := (B.vertex k, other))
        hedge hopen hqfrontier
        (relative_closure k q other hqfrontier (Or.inl hedge) hopen
          hother_pred hother_succ)
    exact Or.inl
      (mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier
        (C := C) (inputs := inputs) (e := (B.vertex k, other))
        hedge hfrontier)
  · have hfrontier_rev :
        forall z : PlanarInterface.Point,
          PlanarInterface.InOpenSegment z
            ((canonicalGraph C).point other)
            ((canonicalGraph C).point (B.vertex k)) ->
          z ∈ frontier (unboundedExteriorComponentRows C inputs).exterior :=
      edge_openSegment_frontier_of_inOpenSegment_frontier_and_relative_ball_closure
        (C := C) (inputs := inputs) (e := (other, B.vertex k))
        hedge (inOpenSegment_symm hopen) hqfrontier
        (by
          intro z hz hclosure
          rcases
              relative_closure k q other hqfrontier (Or.inr hedge) hopen
                hother_pred hother_succ z (inOpenSegment_symm hz) hclosure with
            ⟨r, hrpos, hnear⟩
          exact ⟨r, hrpos, by
            intro y hyball hyopen
            exact hnear y hyball (inOpenSegment_symm hyopen)⟩)
    exact Or.inr
      (mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier
        (C := C) (inputs := inputs) (e := (other, B.vertex k))
        hedge hfrontier_rev)

/-- Closed-segment selected-edge source from the endpoint-selected-edge row and
the open-segment relative-closure promotion.

The far-endpoint branch is handled only by the explicit adjacent-endpoint
selected-edge membership source.  The relative-interior branch reuses
`boundary_frontier_openSegment_frontierEdge_or_symm_of_relative_closure`, and
the center endpoint is ruled out by the noncenter hypothesis. -/
theorem boundary_frontier_closedSegment_selectedEdgeSource_of_endpoint_incident_and_relative_closure
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (boundary_vertex_frontier :
      forall k : Fin B.length,
        (canonicalGraph C).point (B.vertex k) ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior)
    (endpoint_incident_edge :
      AdjacentFrontierEndpointsIncidentUnboundedFrontierEdgeSource C inputs)
    (relative_closure :
      BoundaryFrontierOpenSegmentRelativeClosurePropagation inputs B) :
    BoundaryFrontierClosedSegmentSelectedEdgeSource inputs B := by
  intro k _eps q other _hqball hqfrontier hadj hqseg hqne hother_pred
    hother_succ
  rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hqseg with
      hleft | hright | hopen
  · exact False.elim (hqne hleft)
  · exact
      endpoint_incident_edge hadj (boundary_vertex_frontier k)
        (by simpa [hright] using hqfrontier)
  · exact
      boundary_frontier_openSegment_frontierEdge_or_symm_of_relative_closure
        (C := C) (inputs := inputs) (B := B) relative_closure
        k q other hqfrontier hadj hopen hother_pred hother_succ

/-- Reducer from the sharper edge/propagation source rows to the open-segment
point-sector row.

The topology row promotes the single open-segment frontier point to a selected
frontier edge.  The edge-level angular row supplies the graph-dart sector, and
collinearity of an interior point on that edge converts it back to the point-ray
sector expected by the downstream local-sector machinery. -/
theorem boundary_frontier_openSegment_local_exterior_sector_of_incident_edge_angular_and_relative_closure
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (incident_edge_angular :
      BoundaryFrontierIncidentEdgeExteriorAngularSector inputs B)
    (relative_closure :
      BoundaryFrontierOpenSegmentRelativeClosurePropagation inputs B) :
    BoundaryFrontierOpenSegmentLocalExteriorSector inputs B := by
  intro k _eps q other _hqball hqfrontier hadj hopen hother_pred hother_succ
  have hedge_frontier :
      ((B.vertex k, other) ∈ unboundedFrontierEdgeSet C inputs ∨
        (other, B.vertex k) ∈ unboundedFrontierEdgeSet C inputs) :=
    boundary_frontier_openSegment_frontierEdge_or_symm_of_relative_closure
      (C := C) (inputs := inputs) (B := B) relative_closure
      k q other hqfrontier hadj hopen hother_pred hother_succ
  have hbetween :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
        C B k other :=
    incident_edge_angular k other hedge_frontier hother_pred hother_succ
  have hqne :
      q ≠ (canonicalGraph C).point (B.vertex k) := by
    exact left_ne_of_inOpenSegment (canonical_adj_point_ne hadj) hopen
  have harg :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
          ((canonicalGraph C).point (B.vertex k)) q =
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
          (B.vertex k) other := by
    simpa [_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg_def]
      using
        dartArg_eq_of_mem_closedSegment_ne_left
          (inOpenSegment_mem_closedSegment hopen) hqne
  exact ⟨by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hbetween.1,
    by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hbetween.2⟩

/-- Boundary open-segment local exterior-sector row with the relative-closure
input discharged by the fixed-side half-ball construction. -/
theorem boundary_frontier_openSegment_local_exterior_sector_of_incident_edge_angular
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (incident_edge_angular :
      BoundaryFrontierIncidentEdgeExteriorAngularSector inputs B) :
    BoundaryFrontierOpenSegmentLocalExteriorSector inputs B :=
  boundary_frontier_openSegment_local_exterior_sector_of_incident_edge_angular_and_relative_closure
    (C := C) (inputs := inputs) (B := B)
    incident_edge_angular
    (boundary_frontier_openSegment_relativeClosurePropagation_of_fixed_side_halfballs
      (C := C) (inputs := inputs) (B := B))

/- The converse source direction: an honest open-segment exterior-sector row
puts the midpoint of every selected incident frontier edge in the same angular
sector as the graph dart. -/
theorem boundary_frontier_incident_edge_exterior_angular_sector_of_openSegment_local_exterior_sector
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (openSegment_local_exterior_sector :
      BoundaryFrontierOpenSegmentLocalExteriorSector inputs B) :
    BoundaryFrontierIncidentEdgeExteriorAngularSector inputs B := by
  intro k other hedge hother_pred hother_succ
  let center : PlanarInterface.Point := (canonicalGraph C).point (B.vertex k)
  let endpoint : PlanarInterface.Point := (canonicalGraph C).point other
  let q : PlanarInterface.Point :=
    PlanarInterface.segmentPoint center endpoint (1 / 2 : Real)
  have hqopen :
      PlanarInterface.InOpenSegment q center endpoint := by
    simpa [q, center, endpoint] using midpoint_inOpenSegment center endpoint
  have hadj : (canonicalGraph C).Adj (B.vertex k) other := by
    rcases hedge with hforward | hbackward
    · exact unboundedFrontierEdgeSet_adj hforward
    · exact canonicalAdj_symm (unboundedFrontierEdgeSet_adj hbackward)
  have hqfrontier :
      q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
    rcases hedge with hforward | hbackward
    · exact
        (mem_unboundedFrontierEdgeSet_iff.1 hforward).2 q
          (by simpa [center, endpoint] using hqopen)
    · exact
        (mem_unboundedFrontierEdgeSet_iff.1 hbackward).2 q
          (by simpa [center, endpoint] using inOpenSegment_symm hqopen)
  let eps : Real := dist center q + 1
  have hqball : q ∈ Metric.ball center eps := by
    have hlt : dist q center < dist center q + 1 := by
      calc
        dist q center = dist center q := dist_comm q center
        _ < dist center q + 1 := lt_add_of_pos_right _ zero_lt_one
    simpa [Metric.mem_ball, eps] using hlt
  have hpoint :
      BoundaryPredSuccPointAngularBetween C B k q :=
    openSegment_local_exterior_sector k eps q other
      hqball hqfrontier hadj
      (by simpa [center, endpoint] using hqopen)
      hother_pred hother_succ
  have hqne :
      q ≠ (canonicalGraph C).point (B.vertex k) := by
    exact
      left_ne_of_inOpenSegment (canonical_adj_point_ne hadj)
        (by simpa [center, endpoint] using hqopen)
  have harg :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
          ((canonicalGraph C).point (B.vertex k)) q =
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
          (B.vertex k) other := by
    simpa [_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg_def]
      using
        dartArg_eq_of_mem_closedSegment_ne_left
          (inOpenSegment_mem_closedSegment
            (by simpa [center, endpoint] using hqopen))
          hqne
  exact
    ⟨by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hpoint.1,
    by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hpoint.2⟩

/-- Reducer from the open-segment point-ray source to the requested
edge-direction angular residual.

The only proof content here is collinearity: an interior point of the incident
edge has the same ray angle from the boundary vertex as the incident graph
dart. -/
theorem boundary_frontier_openSegment_local_exterior_angular_sector_of_openSegment_local_exterior_sector
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (openSegment_local_exterior_sector :
      BoundaryFrontierOpenSegmentLocalExteriorSector inputs B) :
    BoundaryFrontierOpenSegmentLocalExteriorAngularSector inputs B := by
  intro k eps q other hqball hqfrontier hadj hopen hother_pred hother_succ
  have hpoint :
      BoundaryPredSuccPointAngularBetween C B k q :=
    openSegment_local_exterior_sector k eps q other
      hqball hqfrontier hadj hopen hother_pred hother_succ
  have hqne :
      q ≠ (canonicalGraph C).point (B.vertex k) := by
    exact left_ne_of_inOpenSegment (canonical_adj_point_ne hadj) hopen
  have harg :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
          ((canonicalGraph C).point (B.vertex k)) q =
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
          (B.vertex k) other := by
    simpa [_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg_def]
      using
        dartArg_eq_of_mem_closedSegment_ne_left
          (inOpenSegment_mem_closedSegment hopen) hqne
  exact ⟨by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hpoint.1,
    by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hpoint.2⟩

/-- Far-endpoint form of the closed-segment angular residual.

The closed-segment target quantifies over all radii, so after decomposing the
closed segment the case `q = point other` is not local unless the caller has
already supplied a small enough radius.  This names exactly that remaining
