  only_selected_incident :
    forall (a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs})
        (x : Fin n),
      (a.1, x) ∈ unboundedFrontierEdgeSet C inputs ∨
          (x, a.1) ∈ unboundedFrontierEdgeSet C inputs ->
