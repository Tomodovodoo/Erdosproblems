          inputs data.2 nearby_edge_point_exterior_points }

/-- Complete boundary-cycle rows, plus the existing edge-interior nearby
exterior-point source, prove the frontier-preconnectedness row. -/
theorem unboundedExterior_frontier_preconnected_of_boundaryCycle_complete
