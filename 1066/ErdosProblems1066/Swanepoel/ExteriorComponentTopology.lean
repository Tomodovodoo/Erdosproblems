      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin B.length => B.vertex k = v)
    (sectorRows :
      forall k : Fin B.length,
        BoundaryVertexExteriorSectorRowsAt inputs B k) :
    Nonempty
      (UnboundedFrontierCarrierCyclicCoverageRows C inputs ×
        (forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
          UnboundedFrontierCarrierLocalSectorRowsAt inputs a)) :=
  cyclicCoverageLocalSectorRows_of_boundaryCycle_complete
    B
    frontier_iff_cycle_vertex
    (fun k => (sectorRows k).succ_edge)
    (_root_.ErdosProblems1066.Swanepoel.ExteriorComponentTopology.BoundaryVertexExteriorSectorRowsAt.boundaryCycleIncidentFrontierEdgeCompleteness
      sectorRows)

/-- Carrier-row handoff for the primitive exterior-sector formulation.  This
keeps the remaining proof obligation local: find the actual exterior boundary
