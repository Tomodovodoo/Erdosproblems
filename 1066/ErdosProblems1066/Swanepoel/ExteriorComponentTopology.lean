        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin O.period => (O.dart k).tail = v)
    (hperiod : B.length = O.period)
    (tail_eq_boundary :
      forall k : Fin B.length,
        (O.dart (Fin.cast hperiod k)).tail = B.vertex k)
    (raw_edge_mem :
      forall k : Fin O.period,
        ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
            unboundedFrontierEdgeSet C inputs ∨
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
              (O.dart k).tail) ∈
            unboundedFrontierEdgeSet C inputs) :
    ActualBoundaryCycleFrontierEquivalenceRows.BoundaryCycleEdgeMemSource
      C inputs := by
  refine ⟨B, ?_, ?_⟩
  · exact
      frontier_iff_boundaryCycle_vertex_of_rawFaceSuccOrbit_tail
        (C := C) (inputs := inputs) B O frontier_iff_tail hperiod
        tail_eq_boundary
  · intro k
    have hcast_succ :
        Fin.cast hperiod (PlanarInterface.cyclicSucc B.length_pos k) =
          PlanarInterface.cyclicSucc O.period_pos (Fin.cast hperiod k) := by
      ext
      simp [PlanarInterface.cyclicSucc, hperiod]
    have htail_succ :
        (O.dart
            (PlanarInterface.cyclicSucc O.period_pos
              (Fin.cast hperiod k))).tail =
          B.vertex (PlanarInterface.cyclicSucc B.length_pos k) := by
      rw [← hcast_succ]
      exact tail_eq_boundary (PlanarInterface.cyclicSucc B.length_pos k)
    rcases raw_edge_mem (Fin.cast hperiod k) with hforward | hreverse
    · left
      simpa [tail_eq_boundary k, htail_succ] using hforward
    · right
      simpa [tail_eq_boundary k, htail_succ] using hreverse

/-- Frontier-row specialization of
`S2_agent_raw_orbit_boundary_edge_mem_source`.

The consecutive raw edge membership is produced from the raw open-segment
frontier row before transport to the identified concrete boundary cycle. -/
theorem S2_agent_raw_orbit_boundary_edge_mem_source_of_edge_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (frontier_iff_tail :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin O.period => (O.dart k).tail = v)
    (hperiod : B.length = O.period)
    (tail_eq_boundary :
      forall k : Fin B.length,
        (O.dart (Fin.cast hperiod k)).tail = B.vertex k)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    ActualBoundaryCycleFrontierEquivalenceRows.BoundaryCycleEdgeMemSource
      C inputs :=
  S2_agent_raw_orbit_boundary_edge_mem_source
    (C := C) (inputs := inputs) B O frontier_iff_tail hperiod
    tail_eq_boundary
    (rawFaceSuccOrbit_edge_mem_unboundedFrontierEdgeSet_or_symm
      O edge_openSegment_frontier)

/-- Geometric dart-edge frontier specialization of
`S2_agent_raw_orbit_boundary_edge_mem_source`.

This is the selected geometric raw-orbit handoff: dart-edge frontier rows first
source actual raw consecutive edge membership via
`S2_agent_raw_orbit_edge_membership_source`, and only then are transported to
the identified concrete boundary cycle. -/
theorem S2_agent_raw_orbit_boundary_edge_mem_source_of_dart_edge_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {start : UnitDistanceDart C}
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
    (O :
      UnitDistanceRotationSystem.RawFaceSuccOrbit
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C)
        start)
    (frontier_iff_tail :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin O.period => (O.dart k).tail = v)
    (hperiod : B.length = O.period)
    (tail_eq_boundary :
      forall k : Fin B.length,
        (O.dart (Fin.cast hperiod k)).tail = B.vertex k)
    (dart_edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point (O.dart k).head) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    ActualBoundaryCycleFrontierEquivalenceRows.BoundaryCycleEdgeMemSource
      C inputs :=
  S2_agent_raw_orbit_boundary_edge_mem_source
    (C := C) (inputs := inputs) B O frontier_iff_tail hperiod
    tail_eq_boundary
    (S2_agent_raw_orbit_edge_membership_source
