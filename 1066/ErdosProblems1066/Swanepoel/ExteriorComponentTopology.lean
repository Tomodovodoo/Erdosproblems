/-- A raw face-successor orbit with the actual exterior-frontier rows can be
used directly as the honest `ExteriorFrontierCarrierRows` input.  The
nondegeneracy row `3 <= O.period` is necessary here: a two-dart raw face orbit
can still be a bridge walk, while the carrier interface requires a two-regular
cycle graph. -/
noncomputable def exteriorFrontierCarrierRows_of_rawFaceSuccOrbit
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (period_ge_three : 3 <= O.period)
    (tail_injective :
      Function.Injective fun k : Fin O.period => (O.dart k).tail)
    (frontier_iff_tail :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin O.period => (O.dart k).tail = v)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    ExteriorFrontierCarrierRows.{0} C inputs where
  V := Fin O.period
  instFintype := inferInstance
  F := SimpleGraph.cycleGraph O.period
  instDecidableAdj := inferInstance
  phi :=
    { toFun := fun k => (O.dart k).tail
      map_rel' := by
        intro i j hij
        rcases cycleGraph_adj_eq_cyclicSucc_or_eq_cyclicPred
            O.period_pos period_ge_three hij with hsucc | hpred
        · subst j
          exact rawFaceSuccOrbit_tail_adj_cyclicSucc O i
        · subst j
          have hpred_succ :
              PlanarInterface.cyclicSucc O.period_pos
                  (PlanarInterface.cyclicPred O.period_pos i) = i :=
            PlanarInterface.cyclicSucc_cyclicPred O.period_pos i
          exact (GraphBridge.unitDistanceSimpleGraph C).symm (by
            simpa [hpred_succ] using
              rawFaceSuccOrbit_tail_adj_cyclicSucc O
                (PlanarInterface.cyclicPred O.period_pos i)) }
  phi_injective := tail_injective
  connected := by
    rw [SimpleGraph.connected_iff]
    exact ⟨SimpleGraph.cycleGraph_preconnected,
      Fin.pos_iff_nonempty.mp O.period_pos⟩
  degree_two := by
    intro v
    exact cycleGraph_degree_two_of_three_le period_ge_three v
  vertex_image_iff_frontier := frontier_iff_tail
  edge_openSegment_frontier := by
    intro i j hij p hp
    rcases cycleGraph_adj_eq_cyclicSucc_or_eq_cyclicPred
        O.period_pos period_ge_three hij with hsucc | hpred
    · subst j
      exact edge_openSegment_frontier i p hp
    · subst j
      have hpred_succ :
          PlanarInterface.cyclicSucc O.period_pos
              (PlanarInterface.cyclicPred O.period_pos i) = i :=
        PlanarInterface.cyclicSucc_cyclicPred O.period_pos i
      exact edge_openSegment_frontier
        (PlanarInterface.cyclicPred O.period_pos i) p (by
          simpa [hpred_succ] using inOpenSegment_symm hp)

/-- Nonempty wrapper for the raw-orbit-to-carrier conversion. -/
noncomputable def exteriorFrontierCarrierRows_nonempty_of_rawFaceSuccOrbit
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (period_ge_three : 3 <= O.period)
    (tail_injective :
      Function.Injective fun k : Fin O.period => (O.dart k).tail)
    (frontier_iff_tail :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin O.period => (O.dart k).tail = v)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    Nonempty (ExteriorFrontierCarrierRows.{0} C inputs) :=
  ⟨exteriorFrontierCarrierRows_of_rawFaceSuccOrbit
    O period_ge_three tail_injective frontier_iff_tail
    edge_openSegment_frontier⟩

/-- An exterior-dart orbit source fills the face-dart exterior carrier package
once its enclosure boundary is identified with the selected unbounded
component frontier, and the two carrier-side geometric rows are supplied. -/
theorem nonempty_faceDartOrbitExteriorCarrierRows_of_exteriorDartOrbitSource_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (S : ExteriorDartOrbitSource C)
    (frontier_iff_onBoundary :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          S.enclosure.onBoundary v)
    (orbit_edge_openSegment_frontier :
      forall k : Fin S.orbit.boundary.length,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (S.orbit.boundary.vertex k))
            ((canonicalGraph C).point
              (S.orbit.boundary.vertex
                (PlanarInterface.cyclicSucc
                  S.orbit.boundary.length_pos k))) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (incident_only_pred_succ :
      forall k : Fin S.orbit.boundary.length,
        forall a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
          a.1 = S.orbit.boundary.vertex k ->
            (unboundedFrontierCarrierGraph C inputs).Adj a b ->
              b.1 =
                  S.orbit.boundary.vertex
                    (PlanarInterface.cyclicPred
                      S.orbit.boundary.length_pos k) ∨
                b.1 =
                  S.orbit.boundary.vertex
                    (PlanarInterface.cyclicSucc
                      S.orbit.boundary.length_pos k)) :
    Nonempty (FaceDartOrbitExteriorCarrierRows C inputs) :=
  ⟨{ rotation := S.rotation
     orbit := S.orbit
     frontier_iff_orbit_vertex := by
       intro v
       exact
         (frontier_iff_onBoundary v).trans
           (S.enclosure.onBoundary_iff_orbit_vertex v)
     orbit_edge_openSegment_frontier := orbit_edge_openSegment_frontier
     incident_only_pred_succ := incident_only_pred_succ }⟩

/-- Boundary-cycle carrier facts package into the face-orbit exterior carrier
row.  This keeps the next proof target focused on the actual exterior cycle:
the cycle's vertex/frontier equivalence, its frontier edge interiors, and the
local incident-neighbor exclusion. -/
noncomputable def faceDartOrbitExteriorCarrierRows_of_boundaryCarrierRows
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (R : UnitDistanceRotationSystem C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
    (faceRows : UnitDistanceCycleFaceSuccRows C R B)
    (frontier_iff_cycle_vertex :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin B.length => B.vertex k = v)
    (cycle_edge_openSegment_frontier :
      forall k : Fin B.length,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (B.vertex k))
            ((canonicalGraph C).point
              (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (incident_only_pred_succ :
      forall k : Fin B.length,
        forall a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
          a.1 = B.vertex k ->
            (unboundedFrontierCarrierGraph C inputs).Adj a b ->
              b.1 =
                  B.vertex (PlanarInterface.cyclicPred B.length_pos k) ∨
                b.1 =
                  B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) :
    FaceDartOrbitExteriorCarrierRows C inputs where
  rotation := R
  orbit := FaceDartOrbit.ofBoundaryFaceSuccRows B faceRows
  frontier_iff_orbit_vertex := by
    intro v
    simpa [FaceDartOrbit.ofBoundaryFaceSuccRows] using
      frontier_iff_cycle_vertex v
  orbit_edge_openSegment_frontier := by
    intro k p hp
    exact cycle_edge_openSegment_frontier k p hp
  incident_only_pred_succ := by
    intro k a b hk hab
    exact incident_only_pred_succ k a b hk hab

/-- Local edge-completeness around a proposed exterior boundary cycle: every
selected unbounded-frontier carrier edge incident to `B.vertex k` has its other
endpoint equal to the predecessor or successor boundary vertex.  This is the
precise local row needed to rule out exterior-boundary chords at a frontier
vertex. -/
def BoundaryCycleIncidentFrontierEdgeCompleteness
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall k : Fin B.length, forall x : Fin n,
    ((B.vertex k, x) ∈ unboundedFrontierEdgeSet C inputs ∨
      (x, B.vertex k) ∈ unboundedFrontierEdgeSet C inputs) ->
      x = B.vertex (PlanarInterface.cyclicPred B.length_pos k) ∨
        x = B.vertex (PlanarInterface.cyclicSucc B.length_pos k)

/-- Edge-completeness of the proposed exterior boundary cycle supplies the
`incident_only_pred_succ` row consumed by the face-orbit carrier constructor. -/
theorem incident_only_pred_succ_of_boundaryCycleIncidentFrontierEdgeCompleteness
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (hcomplete : BoundaryCycleIncidentFrontierEdgeCompleteness inputs B) :
    forall k : Fin B.length,
      forall a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        a.1 = B.vertex k ->
          (unboundedFrontierCarrierGraph C inputs).Adj a b ->
            b.1 =
                B.vertex (PlanarInterface.cyclicPred B.length_pos k) ∨
              b.1 =
                B.vertex (PlanarInterface.cyclicSucc B.length_pos k) := by
  intro k a b ha hab
  have hedge :
      (B.vertex k, b.1) ∈ unboundedFrontierEdgeSet C inputs ∨
        (b.1, B.vertex k) ∈ unboundedFrontierEdgeSet C inputs := by
    rcases (unboundedFrontierCarrierGraph_adj_iff).1 hab with hab' | hba'
    · left
      simpa [ha] using hab'
    · right
      simpa [ha] using hba'
  exact hcomplete k b.1 hedge

/-- The carrier-neighbour exclusion row is equivalently strong enough to prove
the edge-set formulation of boundary-cycle incident frontier-edge
completeness. -/
theorem boundaryCycleIncidentFrontierEdgeCompleteness_of_incident_only_pred_succ
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (hincident :
      forall k : Fin B.length,
        forall a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
          a.1 = B.vertex k ->
            (unboundedFrontierCarrierGraph C inputs).Adj a b ->
              b.1 =
                  B.vertex (PlanarInterface.cyclicPred B.length_pos k) ∨
                b.1 =
                  B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) :
    BoundaryCycleIncidentFrontierEdgeCompleteness inputs B := by
  intro k x hedge
  rcases hedge with hbx | hxb
  · have hendpoints :=
      endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
        (C := C) (inputs := inputs)
        unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition hbx
    let a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
      ⟨B.vertex k, hendpoints.1⟩
    let b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
      ⟨x, hendpoints.2⟩
    have hab : (unboundedFrontierCarrierGraph C inputs).Adj a b :=
      unboundedFrontierCarrierGraph_adj_of_ordered_edge hbx
    exact hincident k a b rfl hab
  · have hendpoints :=
      endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
        (C := C) (inputs := inputs)
        unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition hxb
    let a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
      ⟨B.vertex k, hendpoints.2⟩
    let b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
      ⟨x, hendpoints.1⟩
    have hab : (unboundedFrontierCarrierGraph C inputs).Adj a b :=
      unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm hxb
    exact hincident k a b rfl hab

/-- Actual boundary/frontier rows identify a selected local frontier edge as a
boundary edge, with the only ambiguity being the cyclic orientation.

This is the honest endpoint part of Raman's `edgeRows_boundary_succ` residual:
local edge-carrier membership promotes the selected local row to the concrete
`unboundedFrontierEdgeSet`, frontier-equivalence places its tail on the actual
boundary cycle, and incident-completeness says the other endpoint is the
predecessor or successor boundary vertex. -/
theorem edgeLocalRows_boundary_succ_or_reverse_of_actualBoundaryCycleFrontierEquivalenceRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (actualRows : ActualBoundaryCycleFrontierEquivalenceRows C inputs)
    (hcomplete :
      BoundaryCycleIncidentFrontierEdgeCompleteness inputs
        actualRows.boundary)
    (interior_edge_mem :
      InteriorFrontierEdgeCarrierMembershipSource C inputs) :
    forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
      UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
        Exists fun j : Fin actualRows.boundary.length =>
          (e.1 = actualRows.boundary.vertex j /\
            e.2 =
              actualRows.boundary.vertex
                (PlanarInterface.cyclicSucc
                  actualRows.boundary.length_pos j)) \/
          (e.2 = actualRows.boundary.vertex j /\
            e.1 =
              actualRows.boundary.vertex
                (PlanarInterface.cyclicSucc
                  actualRows.boundary.length_pos j)) := by
  intro e p edgeRows
  let B := actualRows.boundary
  have he_frontier : e ∈ unboundedFrontierEdgeSet C inputs :=
    interior_edge_mem edgeRows.edge_mem edgeRows.center_in_openSegment
      edgeRows.center_frontier
  have hendpoints :
      e.1 ∈ unboundedFrontierVertexSet C inputs /\
        e.2 ∈ unboundedFrontierVertexSet C inputs :=
    endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
      (C := C) (inputs := inputs)
      unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
      he_frontier
  have htail_frontier :
      (canonicalGraph C).point e.1 ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior :=
    (mem_unboundedFrontierVertexSet_iff.1 hendpoints.1)
  rcases
      actualRows.frontier_vertices_are_cycle_vertices e.1
        htail_frontier with
    ⟨i, hi⟩
  have hedge_at_i :
      (B.vertex i, e.2) ∈ unboundedFrontierEdgeSet C inputs \/
        (e.2, B.vertex i) ∈ unboundedFrontierEdgeSet C inputs := by
    left
    simpa [B, hi] using he_frontier
  rcases hcomplete i e.2 hedge_at_i with hpred | hsucc
  · let j : Fin B.length := PlanarInterface.cyclicPred B.length_pos i
    have hsucc_pred :
        PlanarInterface.cyclicSucc B.length_pos j = i := by
      simpa [j] using PlanarInterface.cyclicSucc_cyclicPred B.length_pos i
    refine ⟨j, Or.inr ?_⟩
    constructor
    · simpa [B, j] using hpred
    · simpa [B, j, hsucc_pred] using hi.symm
  · refine ⟨i, Or.inl ?_⟩
    exact ⟨hi.symm, by simpa [B] using hsucc⟩

/-- The remaining orientation-only residual after the endpoint/frontier part
has been discharged: the selected local row is not the reverse orientation of
an actual boundary edge. -/
def EdgeLocalRowsBoundaryReverseExcluded
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
    UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
      forall j : Fin B.length,
        e.2 = B.vertex j ->
          e.1 = B.vertex (PlanarInterface.cyclicSucc B.length_pos j) ->
            False

/-- Sharper local-side residual for excluding the reverse boundary orientation.

If a selected local frontier edge is oriented as the reverse of the boundary
edge `j -> succ j`, then the actual exterior-side argument should put its
interior frontier point in the open predecessor/successor sector at the reverse
tail `succ j`.  The reducer below shows that this is already impossible by
collinearity: from that reverse tail, the point lies exactly on the predecessor
ray, not strictly between predecessor and successor. -/
def EdgeLocalRowsBoundaryReverseTailExteriorSector
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
    UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
      forall j : Fin B.length,
        e.2 = B.vertex j ->
          e.1 = B.vertex (PlanarInterface.cyclicSucc B.length_pos j) ->
            BoundaryPredSuccPointAngularBetween C B
              (PlanarInterface.cyclicSucc B.length_pos j) p

/-- Open-segment form of the reverse-tail exterior-sector residual.

This removes the selected local-edge bookkeeping from
`EdgeLocalRowsBoundaryReverseTailExteriorSector`: the remaining local
topology/geometry row is only that an actual unbounded-frontier point on the
reverse-oriented boundary open segment lies in the exterior angular sector at
the reverse tail. -/
def BoundaryReverseTailOpenSegmentExteriorSector
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall (j : Fin B.length) (p : PlanarInterface.Point),
    p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
    PlanarInterface.InOpenSegment p
      ((canonicalGraph C).point
        (B.vertex (PlanarInterface.cyclicSucc B.length_pos j)))
      ((canonicalGraph C).point (B.vertex j)) ->
      BoundaryPredSuccPointAngularBetween C B
        (PlanarInterface.cyclicSucc B.length_pos j) p

/-- A point on the incoming predecessor boundary segment is not in the strict
predecessor/successor point sector at that boundary vertex.

This is the honest geometric core behind the reverse-tail obstruction:
collinearity identifies the ray to the point with the predecessor boundary
ray, contradicting the strict lower inequality in
`BoundaryPredSuccPointAngularBetween`. -/
theorem not_boundaryPredSuccPointAngularBetween_of_inOpenSegment_pred
    {C : _root_.UDConfig n}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    {k : Fin B.length} {p : PlanarInterface.Point}
    (hp :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point (B.vertex k))
        ((canonicalGraph C).point
          (B.vertex (PlanarInterface.cyclicPred B.length_pos k)))) :
    ¬ BoundaryPredSuccPointAngularBetween C B k p := by
  intro hsector
  let pred : Fin B.length := PlanarInterface.cyclicPred B.length_pos k
  have hsucc_pred : PlanarInterface.cyclicSucc B.length_pos pred = k := by
    simpa [pred] using PlanarInterface.cyclicSucc_cyclicPred B.length_pos k
  have hadj_pred :
      (canonicalGraph C).Adj (B.vertex pred) (B.vertex k) := by
    simpa [pred, hsucc_pred] using B.adjacent pred
  have hpoints_ne :
      (canonicalGraph C).point (B.vertex k) ≠
        (canonicalGraph C).point (B.vertex pred) := by
    exact (canonical_adj_point_ne hadj_pred).symm
  have hp_ne_tail :
      p ≠ (canonicalGraph C).point (B.vertex k) :=
    left_ne_of_inOpenSegment
      (by simpa [pred] using hpoints_ne)
      (by simpa [pred] using hp)
  have harg_pred :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
          ((canonicalGraph C).point (B.vertex k)) p =
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
          (B.vertex k)
          (B.vertex (PlanarInterface.cyclicPred B.length_pos k)) := by
    simpa [pred,
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg_def]
      using
        dartArg_eq_of_mem_closedSegment_ne_left
          (inOpenSegment_mem_closedSegment (by simpa [pred] using hp))
          hp_ne_tail
  exact
    (lt_irrefl
      (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
        (B.vertex k)
        (B.vertex (PlanarInterface.cyclicPred B.length_pos k))))
      (by
        simpa [BoundaryPredSuccPointAngularBetween, harg_pred] using
          hsector.1)

/-- Sharper residual exposed by the reverse-tail sector row.

Since a reverse-tail point on the boundary segment lies exactly on the
predecessor ray, the strict sector conclusion can only be obtained vacuously:
there must be no actual unbounded-frontier point in that reverse-oriented open
boundary segment. -/
def BoundaryReverseTailOpenSegmentNoFrontier
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall (j : Fin B.length) (p : PlanarInterface.Point),
    PlanarInterface.InOpenSegment p
      ((canonicalGraph C).point
        (B.vertex (PlanarInterface.cyclicSucc B.length_pos j)))
      ((canonicalGraph C).point (B.vertex j)) ->
      p ∉ frontier (unboundedExteriorComponentRows C inputs).exterior

/-- The reverse-tail sector source reduces to the sharper vacuity row:
no actual exterior-frontier point can lie on the reverse-oriented boundary
open segment. -/
theorem boundaryReverseTailOpenSegment_noFrontier_of_exteriorSector
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (reverse_tail_openSegment_sector :
      BoundaryReverseTailOpenSegmentExteriorSector inputs B) :
    BoundaryReverseTailOpenSegmentNoFrontier inputs B := by
  intro j p hp hfrontier
  let k : Fin B.length := PlanarInterface.cyclicSucc B.length_pos j
  have hpred_k : PlanarInterface.cyclicPred B.length_pos k = j := by
    simpa [k] using PlanarInterface.cyclicPred_cyclicSucc B.length_pos j
  have hsector :
      BoundaryPredSuccPointAngularBetween C B k p := by
    simpa [k] using reverse_tail_openSegment_sector j p hfrontier hp
  exact
    (not_boundaryPredSuccPointAngularBetween_of_inOpenSegment_pred
      (C := C) (B := B) (k := k) (p := p)
      (by simpa [k, hpred_k] using hp)) hsector

/-- Conversely, the sharper no-frontier row proves the old reverse-tail sector
row by contradiction.  This direction is intentionally vacuous: it avoids
pretending that a predecessor-ray point is genuinely inside the strict sector. -/
theorem boundaryReverseTailOpenSegment_exteriorSector_of_noFrontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (reverse_tail_noFrontier :
      BoundaryReverseTailOpenSegmentNoFrontier inputs B) :
    BoundaryReverseTailOpenSegmentExteriorSector inputs B := by
  intro j p hfrontier hp
  exact False.elim ((reverse_tail_noFrontier j p hp) hfrontier)

/-- The previous reverse-tail sector source is exactly the vacuity of actual
frontier points on the reverse-oriented boundary open segments. -/
theorem boundaryReverseTailOpenSegment_exteriorSector_iff_noFrontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C} :
    BoundaryReverseTailOpenSegmentExteriorSector inputs B ↔
      BoundaryReverseTailOpenSegmentNoFrontier inputs B :=
  ⟨boundaryReverseTailOpenSegment_noFrontier_of_exteriorSector,
    boundaryReverseTailOpenSegment_exteriorSector_of_noFrontier⟩

/-- Direct reverse-orientation exclusion from the sharper no-frontier row.

This bypasses the old impossible sector detour: a selected local edge in the
reverse boundary orientation carries its center as an actual frontier point on
that reverse-oriented open segment, contradicting
`BoundaryReverseTailOpenSegmentNoFrontier`. -/
theorem edgeLocalRows_boundaryReverseExcluded_of_boundaryReverseTailOpenSegmentNoFrontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (reverse_tail_noFrontier :
      BoundaryReverseTailOpenSegmentNoFrontier inputs B) :
    EdgeLocalRowsBoundaryReverseExcluded inputs B := by
  intro e p edgeRows j hhead htail
  exact
    (reverse_tail_noFrontier j p
      (by simpa [hhead, htail] using edgeRows.center_in_openSegment))
      edgeRows.center_frontier

/-- Actual boundary-cycle open-segment frontier rows refute the sharper
reverse-tail no-frontier residual.  The midpoint of any boundary side is a
frontier point in both open-segment orientations. -/
theorem not_boundaryReverseTailOpenSegmentNoFrontier_of_cycle_edge_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (cycle_edge_openSegment_frontier :
      forall k : Fin B.length,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (B.vertex k))
            ((canonicalGraph C).point
              (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    ¬ BoundaryReverseTailOpenSegmentNoFrontier inputs B := by
  intro reverse_tail_noFrontier
  let j : Fin B.length := ⟨0, B.length_pos⟩
  let p : PlanarInterface.Point :=
    PlanarInterface.segmentPoint
      ((canonicalGraph C).point (B.vertex j))
      ((canonicalGraph C).point
        (B.vertex (PlanarInterface.cyclicSucc B.length_pos j)))
      (1 / 2 : Real)
  have hp_forward :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point (B.vertex j))
        ((canonicalGraph C).point
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos j))) := by
    exact midpoint_inOpenSegment _ _
  have hp_reverse :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos j)))
        ((canonicalGraph C).point (B.vertex j)) :=
    inOpenSegment_symm hp_forward
  exact
    (reverse_tail_noFrontier j p hp_reverse)
      (cycle_edge_openSegment_frontier j p hp_forward)

/-- Consequently, the old reverse-tail sector source is incompatible with the
actual boundary-cycle open-segment frontier row. -/
theorem not_boundaryReverseTailOpenSegmentExteriorSector_of_cycle_edge_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (cycle_edge_openSegment_frontier :
      forall k : Fin B.length,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (B.vertex k))
            ((canonicalGraph C).point
              (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    ¬ BoundaryReverseTailOpenSegmentExteriorSector inputs B := by
  intro reverse_tail_openSegment_sector
  exact
    not_boundaryReverseTailOpenSegmentNoFrontier_of_cycle_edge_openSegment_frontier
      (C := C) (inputs := inputs) (B := B)
      cycle_edge_openSegment_frontier
      (boundaryReverseTailOpenSegment_noFrontier_of_exteriorSector
        (C := C) (inputs := inputs) (B := B)
        reverse_tail_openSegment_sector)

/-- Reducer from the edge-local reverse-tail residual to its exact
open-segment source row.

The proof only substitutes the reverse boundary orientation into the selected
local edge row; the remaining source is
`BoundaryReverseTailOpenSegmentExteriorSector`. -/
theorem edgeLocalRows_boundaryReverseTailExteriorSector_of_boundaryReverseTailOpenSegmentExteriorSector
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (reverse_tail_openSegment_sector :
      BoundaryReverseTailOpenSegmentExteriorSector inputs B) :
    EdgeLocalRowsBoundaryReverseTailExteriorSector inputs B := by
  intro e p edgeRows j hhead htail
  exact
    reverse_tail_openSegment_sector j p edgeRows.center_frontier
      (by simpa [hhead, htail] using edgeRows.center_in_openSegment)

/-- Local-side reducer for the reverse-orientation residual.

The only remaining source row is
`EdgeLocalRowsBoundaryReverseTailExteriorSector`: prove that any selected local
edge carrying the reverse boundary orientation would place its center point in
the actual exterior angular sector at the reverse tail.  This theorem then
turns that sector claim into the contradiction needed by
`EdgeLocalRowsBoundaryReverseExcluded`. -/
theorem edgeLocalRows_boundaryReverseExcluded_of_reverseTailExteriorSector
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (reverse_tail_sector :
      EdgeLocalRowsBoundaryReverseTailExteriorSector inputs B) :
    EdgeLocalRowsBoundaryReverseExcluded inputs B := by
  intro e p edgeRows j hhead htail
  let k : Fin B.length := PlanarInterface.cyclicSucc B.length_pos j
  have hpred_k : PlanarInterface.cyclicPred B.length_pos k = j := by
    simpa [k] using PlanarInterface.cyclicPred_cyclicSucc B.length_pos j
  have hsector :
      BoundaryPredSuccPointAngularBetween C B k p := by
    simpa [k] using reverse_tail_sector edgeRows j hhead htail
  have hp_ne_tail :
      p ≠ (canonicalGraph C).point e.1 := by
    exact
      left_ne_of_inOpenSegment
        (canonical_edge_point_ne_of_mem_edgeSet edgeRows.edge_mem)
        edgeRows.center_in_openSegment
  have harg_edge :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
          ((canonicalGraph C).point e.1) p =
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) :=
    dartArg_eq_of_mem_closedSegment_ne_left
      (inOpenSegment_mem_closedSegment edgeRows.center_in_openSegment)
      hp_ne_tail
  have harg_pred :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
          ((canonicalGraph C).point (B.vertex k)) p =
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
          (B.vertex k)
          (B.vertex (PlanarInterface.cyclicPred B.length_pos k)) := by
    simpa [k, htail, hhead, hpred_k,
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg_def]
      using harg_edge
  exact
    (lt_irrefl
      (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
        (B.vertex k)
        (B.vertex (PlanarInterface.cyclicPred B.length_pos k))))
      (by
        simpa [BoundaryPredSuccPointAngularBetween, harg_pred] using
          hsector.1)

/-- Reducer for Raman's `edgeRows_boundary_succ` residual.

The endpoint/frontier work is handled by actual boundary-frontier equivalence,
incident-completeness, and the existing interior-edge carrier-membership row.
What remains is only the explicit orientation row ruling out the reverse
boundary orientation for the selected local edge. -/
theorem edgeRows_boundary_succ_of_actualBoundaryCycleFrontierEquivalenceRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (actualRows : ActualBoundaryCycleFrontierEquivalenceRows C inputs)
    (hcomplete :
      BoundaryCycleIncidentFrontierEdgeCompleteness inputs
        actualRows.boundary)
    (interior_edge_mem :
      InteriorFrontierEdgeCarrierMembershipSource C inputs)
    (not_reverse :
      EdgeLocalRowsBoundaryReverseExcluded inputs actualRows.boundary) :
    forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
      UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
        Exists fun j : Fin actualRows.boundary.length =>
          e.1 = actualRows.boundary.vertex j /\
            e.2 =
              actualRows.boundary.vertex
                (PlanarInterface.cyclicSucc
                  actualRows.boundary.length_pos j) := by
  intro e p edgeRows
  rcases
      edgeLocalRows_boundary_succ_or_reverse_of_actualBoundaryCycleFrontierEquivalenceRows
        (C := C) (inputs := inputs) actualRows hcomplete
        interior_edge_mem edgeRows with
    ⟨j, hforward | hreverse⟩
  · exact ⟨j, hforward⟩
  · exact False.elim (not_reverse edgeRows j hreverse.1 hreverse.2)

/-- `edgeRows_boundary_succ` reducer with the reverse-orientation row replaced
by the sharper actual exterior-sector residual at the reverse tail. -/
theorem edgeRows_boundary_succ_of_actualBoundaryCycleFrontierEquivalenceRows_reverseTailExteriorSector
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (actualRows : ActualBoundaryCycleFrontierEquivalenceRows C inputs)
    (hcomplete :
      BoundaryCycleIncidentFrontierEdgeCompleteness inputs
        actualRows.boundary)
    (interior_edge_mem :
      InteriorFrontierEdgeCarrierMembershipSource C inputs)
    (reverse_tail_sector :
      EdgeLocalRowsBoundaryReverseTailExteriorSector inputs
        actualRows.boundary) :
    forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
      UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
        Exists fun j : Fin actualRows.boundary.length =>
          e.1 = actualRows.boundary.vertex j /\
            e.2 =
              actualRows.boundary.vertex
                (PlanarInterface.cyclicSucc
                  actualRows.boundary.length_pos j) :=
  edgeRows_boundary_succ_of_actualBoundaryCycleFrontierEquivalenceRows
    (C := C) (inputs := inputs) actualRows hcomplete interior_edge_mem
    (edgeLocalRows_boundaryReverseExcluded_of_reverseTailExteriorSector
      (C := C) (inputs := inputs) (B := actualRows.boundary)
      reverse_tail_sector)

/-- `edgeRows_boundary_succ` reducer with the reverse-tail sector residual
sharpened to the exact reverse boundary open-segment source row. -/
theorem edgeRows_boundary_succ_of_actualBoundaryCycleFrontierEquivalenceRows_reverseTailOpenSegmentExteriorSector
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (actualRows : ActualBoundaryCycleFrontierEquivalenceRows C inputs)
    (hcomplete :
      BoundaryCycleIncidentFrontierEdgeCompleteness inputs
        actualRows.boundary)
    (interior_edge_mem :
      InteriorFrontierEdgeCarrierMembershipSource C inputs)
    (reverse_tail_openSegment_sector :
      BoundaryReverseTailOpenSegmentExteriorSector inputs
        actualRows.boundary) :
    forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
      UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
        Exists fun j : Fin actualRows.boundary.length =>
          e.1 = actualRows.boundary.vertex j /\
            e.2 =
              actualRows.boundary.vertex
                (PlanarInterface.cyclicSucc
                  actualRows.boundary.length_pos j) :=
  edgeRows_boundary_succ_of_actualBoundaryCycleFrontierEquivalenceRows_reverseTailExteriorSector
    (C := C) (inputs := inputs) actualRows hcomplete interior_edge_mem
    (edgeLocalRows_boundaryReverseTailExteriorSector_of_boundaryReverseTailOpenSegmentExteriorSector
      (C := C) (inputs := inputs) (B := actualRows.boundary)
      reverse_tail_openSegment_sector)

/-- Boundary-start reducer with Raman's residual replaced by actual
boundary/frontier rows plus the remaining orientation-only row. -/
theorem raw_start_on_boundary_of_actualBoundaryCycleFrontierEquivalenceRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (actualRows : ActualBoundaryCycleFrontierEquivalenceRows C inputs)
    (hcomplete :
      BoundaryCycleIncidentFrontierEdgeCompleteness inputs
        actualRows.boundary)
    (interior_edge_mem :
      InteriorFrontierEdgeCarrierMembershipSource C inputs)
    (not_reverse :
      EdgeLocalRowsBoundaryReverseExcluded inputs actualRows.boundary) :
    forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
        {start : UnitDistanceDart C},
      UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
      start.tail = e.1 ->
      start.head = e.2 ->
      Exists fun j : Fin actualRows.boundary.length =>
        start = UnitDistanceDart.ofBoundary actualRows.boundary j :=
  raw_start_on_boundary_of_edgeLocalRows_boundary_succ
    (C := C) (inputs := inputs) (B := actualRows.boundary)
    (edgeRows_boundary_succ_of_actualBoundaryCycleFrontierEquivalenceRows
      (C := C) (inputs := inputs) actualRows hcomplete
      interior_edge_mem not_reverse)

/-- Actual boundary/frontier rows select the boundary-oriented raw start.

The selected local edge row may be stored in either canonical direction.  In
both endpoint cases, choose the actual boundary dart `j -> succ j` as the raw
start and record unordered agreement with the selected local edge. -/
theorem exists_boundary_oriented_raw_start_of_actualBoundaryCycleFrontierEquivalenceRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (actualRows : ActualBoundaryCycleFrontierEquivalenceRows C inputs)
    (hcomplete :
      BoundaryCycleIncidentFrontierEdgeCompleteness inputs actualRows.boundary)
    (interior_edge_mem :
      InteriorFrontierEdgeCarrierMembershipSource C inputs) :
    forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
      UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
        Exists fun j : Fin actualRows.boundary.length =>
          Exists fun start : UnitDistanceDart C =>
            start = UnitDistanceDart.ofBoundary actualRows.boundary j ∧
              ((start.tail = e.1 ∧ start.head = e.2) ∨
                (start.tail = e.2 ∧ start.head = e.1)) ∧
              Nonempty
                (UnitDistanceRotationSystem.RawFaceSuccOrbit
                  (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
                    C)
                  start) := by
  intro e p edgeRows
  rcases
      edgeLocalRows_boundary_succ_or_reverse_of_actualBoundaryCycleFrontierEquivalenceRows
        (C := C) (inputs := inputs) actualRows hcomplete
        interior_edge_mem edgeRows with
    ⟨j, hforward | hreverse⟩
  · let start : UnitDistanceDart C :=
      UnitDistanceDart.ofBoundary actualRows.boundary j
    refine ⟨j, start, rfl, Or.inl ?_, ?_⟩
    · exact
        ⟨by simpa [start] using hforward.1.symm,
          by simpa [start] using hforward.2.symm⟩
    · exact
        UnitDistanceRotationSystem.RawFaceSuccOrbit.nonempty
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
            C)
          start
  · let start : UnitDistanceDart C :=
      UnitDistanceDart.ofBoundary actualRows.boundary j
    refine ⟨j, start, rfl, Or.inr ?_, ?_⟩
    · exact
        ⟨by simpa [start] using hreverse.1.symm,
          by simpa [start] using hreverse.2.symm⟩
    · exact
        UnitDistanceRotationSystem.RawFaceSuccOrbit.nonempty
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
            C)
          start

/-- Boundary-start compatibility reducer for older consumers that still require
the selected raw dart to follow the stored local-edge orientation.

The boundary-oriented actual-rows route is the primary seed source now.  The
reverse-tail row is used here only to discharge the obsolete reverse branch and
recover the older `start.tail = e.1`/`start.head = e.2` surface. -/
theorem raw_start_on_boundary_of_actualBoundaryCycleFrontierEquivalenceRows_reverseTailOpenSegmentExteriorSector
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (actualRows : ActualBoundaryCycleFrontierEquivalenceRows C inputs)
    (hcomplete :
      BoundaryCycleIncidentFrontierEdgeCompleteness inputs
        actualRows.boundary)
    (interior_edge_mem :
      InteriorFrontierEdgeCarrierMembershipSource C inputs)
    (reverse_tail_openSegment_sector :
      BoundaryReverseTailOpenSegmentExteriorSector inputs
        actualRows.boundary) :
    forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
        {start : UnitDistanceDart C},
      UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
      start.tail = e.1 ->
      start.head = e.2 ->
      Exists fun j : Fin actualRows.boundary.length =>
        start = UnitDistanceDart.ofBoundary actualRows.boundary j := by
  intro e p start edgeRows htail hhead
  let reverse_tail_noFrontier :
      BoundaryReverseTailOpenSegmentNoFrontier inputs actualRows.boundary :=
    boundaryReverseTailOpenSegment_noFrontier_of_exteriorSector
      (C := C) (inputs := inputs) (B := actualRows.boundary)
      reverse_tail_openSegment_sector
  rcases
      exists_boundary_oriented_raw_start_of_actualBoundaryCycleFrontierEquivalenceRows
        (C := C) (inputs := inputs) actualRows hcomplete
        interior_edge_mem edgeRows with
    ⟨j, boundaryStart, hboundaryStart, hendpoints, _horbit⟩
  rcases hendpoints with hforward | hreverse
  · refine ⟨j, ?_⟩
    exact
      UnitDistanceDart.eq_ofBoundary_of_tail_head actualRows.boundary j start
        (by
          have he1 : e.1 = actualRows.boundary.vertex j := by
            simpa [hboundaryStart] using hforward.1.symm
          exact htail.trans he1)
        (by
          have he2 :
              e.2 =
                actualRows.boundary.vertex
                  (PlanarInterface.cyclicSucc
                    actualRows.boundary.length_pos j) := by
            simpa [hboundaryStart] using hforward.2.symm
          exact hhead.trans he2)
  · have he2 : e.2 = actualRows.boundary.vertex j := by
      simpa [hboundaryStart] using hreverse.1.symm
    have he1 :
        e.1 =
          actualRows.boundary.vertex
            (PlanarInterface.cyclicSucc
              actualRows.boundary.length_pos j) := by
      simpa [hboundaryStart] using hreverse.2.symm
    have hp_reverse :
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point
            (actualRows.boundary.vertex
              (PlanarInterface.cyclicSucc
                actualRows.boundary.length_pos j)))
          ((canonicalGraph C).point (actualRows.boundary.vertex j)) := by
      simpa [he1, he2] using edgeRows.center_in_openSegment
    exact False.elim
      ((reverse_tail_noFrontier j p hp_reverse) edgeRows.center_frontier)

/-- Boundary-seed reducer selecting the raw start in the actual boundary-cycle
orientation.

Actual boundary/frontier equivalence gives forward-or-reverse endpoint data for
the selected local row.  The seed is then chosen as the corresponding boundary
dart, with unordered endpoint agreement recorded separately, so no
reverse-orientation exclusion row is needed. -/
theorem exists_geometricRawFaceSuccOrbitBoundarySeed_of_unboundedExteriorFrontierSeed_actualBoundaryRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (seed : UnboundedExteriorFrontierSeed inputs)
    (actualRows : ActualBoundaryCycleFrontierEquivalenceRows C inputs)
    (hvertex_side :
      forall {v : Fin n},
        seed.point = (canonicalGraph C).point v ->
          Exists fun e : PlanarInterface.Edge n =>
            Exists fun p : PlanarInterface.Point =>
              e ∈ (canonicalGraph C).edgeSet /\
                (e.1 = v \/ e.2 = v) /\
                  p ∈
                    frontier
                      (unboundedExteriorComponentRows C inputs).exterior /\
                    PlanarInterface.InOpenSegment p
                      ((canonicalGraph C).point e.1)
                      ((canonicalGraph C).point e.2))
    (hcomplete :
      BoundaryCycleIncidentFrontierEdgeCompleteness inputs
        actualRows.boundary)
    (interior_edge_mem :
      InteriorFrontierEdgeCarrierMembershipSource C inputs) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        Exists fun start : UnitDistanceDart C =>
          Exists fun j : Fin actualRows.boundary.length =>
            UnboundedExteriorFrontierEdgeLocalRows C inputs e p /\
              start = UnitDistanceDart.ofBoundary actualRows.boundary j /\
                Nonempty
                  (UnitDistanceRotationSystem.RawFaceSuccOrbit
                    (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
                      C)
                    start) /\
                  ((start.tail = e.1 /\ start.head = e.2) \/
                    (start.tail = e.2 /\ start.head = e.1)) :=
by
  rcases
      exists_geometricRawFaceSuccOrbitSeed_of_unboundedExteriorFrontierSeed
        (C := C) (inputs := inputs) seed hvertex_side with
    ⟨e, p, _storedStart, edgeRows, _htail, _hhead, _storedOrbit⟩
  rcases
      exists_boundary_oriented_raw_start_of_actualBoundaryCycleFrontierEquivalenceRows
        (C := C) (inputs := inputs) actualRows hcomplete
        interior_edge_mem edgeRows with
    ⟨j, start, hstart, hendpoints, horbit⟩
  exact ⟨e, p, start, j, edgeRows, hstart, horbit, hendpoints⟩

/-- Superseded boundary-seed compatibility reducer with the reverse-orientation
residual sharpened to the point-level reverse boundary open-segment sector row.

New consumers should prefer
`exists_geometricRawFaceSuccOrbitBoundarySeed_of_unboundedExteriorFrontierSeed_actualBoundaryRows`,
which selects the actual boundary-oriented dart and records unordered endpoint
agreement.  This wrapper keeps the older forward-tail/head surface alive for
downstream callers that have not yet been migrated. -/
theorem exists_geometricRawFaceSuccOrbitBoundarySeed_of_unboundedExteriorFrontierSeed_actualBoundaryRows_reverseTailOpenSegmentExteriorSector
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (seed : UnboundedExteriorFrontierSeed inputs)
    (actualRows : ActualBoundaryCycleFrontierEquivalenceRows C inputs)
    (hvertex_side :
      forall {v : Fin n},
        seed.point = (canonicalGraph C).point v ->
          Exists fun e : PlanarInterface.Edge n =>
            Exists fun p : PlanarInterface.Point =>
              e ∈ (canonicalGraph C).edgeSet ∧
                (e.1 = v ∨ e.2 = v) ∧
                  p ∈
                    frontier
                      (unboundedExteriorComponentRows C inputs).exterior ∧
                    PlanarInterface.InOpenSegment p
                      ((canonicalGraph C).point e.1)
                      ((canonicalGraph C).point e.2))
    (hcomplete :
      BoundaryCycleIncidentFrontierEdgeCompleteness inputs
        actualRows.boundary)
    (interior_edge_mem :
      InteriorFrontierEdgeCarrierMembershipSource C inputs)
    (reverse_tail_openSegment_sector :
      BoundaryReverseTailOpenSegmentExteriorSector inputs
        actualRows.boundary) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        Exists fun start : UnitDistanceDart C =>
          Exists fun j : Fin actualRows.boundary.length =>
            UnboundedExteriorFrontierEdgeLocalRows C inputs e p ∧
              start.tail = e.1 ∧
                start.head = e.2 ∧
                  start = UnitDistanceDart.ofBoundary actualRows.boundary j ∧
                    Nonempty
                      (UnitDistanceRotationSystem.RawFaceSuccOrbit
                        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
                          C)
                        start) := by
  let reverse_tail_noFrontier :
      BoundaryReverseTailOpenSegmentNoFrontier inputs actualRows.boundary :=
    boundaryReverseTailOpenSegment_noFrontier_of_exteriorSector
      (C := C) (inputs := inputs) (B := actualRows.boundary)
      reverse_tail_openSegment_sector
  rcases
      exists_geometricRawFaceSuccOrbitBoundarySeed_of_unboundedExteriorFrontierSeed_actualBoundaryRows
        (C := C) (inputs := inputs) seed actualRows hvertex_side
        hcomplete interior_edge_mem with
    ⟨e, p, start, j, edgeRows, hstart, horbit, hendpoints⟩
  rcases hendpoints with hforward | hreverse
  · exact ⟨e, p, start, j, edgeRows, hforward.1, hforward.2, hstart, horbit⟩
  · have he2 : e.2 = actualRows.boundary.vertex j := by
      simpa [hstart] using hreverse.1.symm
    have he1 :
        e.1 =
          actualRows.boundary.vertex
            (PlanarInterface.cyclicSucc
              actualRows.boundary.length_pos j) := by
      simpa [hstart] using hreverse.2.symm
    have hp_reverse :
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point
            (actualRows.boundary.vertex
              (PlanarInterface.cyclicSucc
                actualRows.boundary.length_pos j)))
          ((canonicalGraph C).point (actualRows.boundary.vertex j)) := by
      simpa [he1, he2] using edgeRows.center_in_openSegment
    exact False.elim
      ((reverse_tail_noFrontier j p hp_reverse) edgeRows.center_frontier)

/-! ### Boundary-vertex exterior-sector rows -/

/-- Primitive local exterior-sector data at one boundary-cycle vertex.

The fields are deliberately local: the angular predecessor/successor order,
the no-between angular exclusion for unit-distance neighbours, the two selected
frontier-edge rows, and the edge-level two-germ saying every selected frontier
edge incident to this boundary vertex uses one of those two germs. -/
structure BoundaryVertexExteriorSectorRowsAt
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
    (k : Fin B.length) where
  angle :
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
        (B.vertex k)
        (B.vertex (PlanarInterface.cyclicPred B.length_pos k)) <
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
        (B.vertex k)
        (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))
  no_between :
    forall other : Fin n,
      GraphBridge.UnitDistanceAdj C (B.vertex k) other ->
      other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
      other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
        ¬
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
              (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
              (B.vertex k)
              (B.vertex (PlanarInterface.cyclicPred B.length_pos k)) <
            _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
              (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
              (B.vertex k) other ∧
            _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
              (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
              (B.vertex k) other <
            _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
              (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
              (B.vertex k)
              (B.vertex (PlanarInterface.cyclicSucc B.length_pos k)))
  pred_edge :
    (B.vertex k, B.vertex (PlanarInterface.cyclicPred B.length_pos k)) ∈
        unboundedFrontierEdgeSet C inputs ∨
      (B.vertex (PlanarInterface.cyclicPred B.length_pos k), B.vertex k) ∈
        unboundedFrontierEdgeSet C inputs
  succ_edge :
    (B.vertex k, B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
        unboundedFrontierEdgeSet C inputs ∨
      (B.vertex (PlanarInterface.cyclicSucc B.length_pos k), B.vertex k) ∈
        unboundedFrontierEdgeSet C inputs
  local_two_germ :
    forall x : Fin n,
      ((B.vertex k, x) ∈ unboundedFrontierEdgeSet C inputs ∨
        (x, B.vertex k) ∈ unboundedFrontierEdgeSet C inputs) ->
        x = B.vertex (PlanarInterface.cyclicPred B.length_pos k) ∨
          x = B.vertex (PlanarInterface.cyclicSucc B.length_pos k)

namespace BoundaryVertexExteriorSectorRowsAt

variable {C : _root_.UDConfig n}
variable {inputs : FinitePlanarOuterComponentInputs C}
variable {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
variable {k : Fin B.length}

/-- The predecessor and successor germs at a simple boundary vertex are
distinct. -/
theorem pred_vertex_ne_succ_vertex
    (_rows : BoundaryVertexExteriorSectorRowsAt inputs B k) :
    B.vertex (PlanarInterface.cyclicPred B.length_pos k) ≠
      B.vertex (PlanarInterface.cyclicSucc B.length_pos k) := by
  intro h
  have hidx :
      PlanarInterface.cyclicPred B.length_pos k =
        PlanarInterface.cyclicSucc B.length_pos k :=
    B.simple h
  exact
    (PlanarInterface.cyclicPred_ne_cyclicSucc_of_three_le
      B.length_pos B.length_ge_three k) hidx

/-- Erase one primitive exterior-sector row to its honest angular
predecessor/successor no-between payload. -/
theorem toBoundaryVertexAngularNoBetweenRows
    (rows : BoundaryVertexExteriorSectorRowsAt inputs B k) :
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryVertexAngularNoBetweenRows
      C B k where
  angle := rows.angle
  no_between := rows.no_between

/-- Erase one primitive sector row to the geometric boundary-successor row at
the predecessor boundary edge. -/
theorem toGeometricBoundarySuccessorRow
    (rows : BoundaryVertexExteriorSectorRowsAt inputs B k) :
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.GeometricBoundarySuccessorRow
      C B (PlanarInterface.cyclicPred B.length_pos k) :=
  _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryVertexAngularNoBetweenRows.toGeometricBoundarySuccessorRow
    rows.toBoundaryVertexAngularNoBetweenRows

/-- One local exterior-sector row is exactly enough to preserve actual
unbounded-exterior frontier status across the geometric face-successor step.
The incoming predecessor boundary edge is an actual frontier edge, the
geometric `faceSucc` step selects the successor boundary dart, and that
successor edge is again an actual frontier edge. -/
theorem geometricFaceSucc_frontier_step
    (rows : BoundaryVertexExteriorSectorRowsAt inputs B k) :
    (forall p : PlanarInterface.Point,
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point
          (B.vertex (PlanarInterface.cyclicPred B.length_pos k)))
        ((canonicalGraph C).point (B.vertex k)) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) /\
      (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C).faceSucc
        (UnitDistanceDart.ofBoundary B
          (PlanarInterface.cyclicPred B.length_pos k)) =
        UnitDistanceDart.ofBoundary B k /\
      (forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (B.vertex k))
          ((canonicalGraph C).point
            (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) := by
  let pred := PlanarInterface.cyclicPred B.length_pos k
  have hsucc_pred : PlanarInterface.cyclicSucc B.length_pos pred = k := by
    dsimp [pred]
    exact PlanarInterface.cyclicSucc_cyclicPred B.length_pos k
  have hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
    unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
  have hpred_frontier :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (B.vertex pred))
          ((canonicalGraph C).point (B.vertex k)) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
    intro p hp
    rcases rows.pred_edge with h | h
    · exact
        hwhole (B.vertex k, B.vertex pred)
          (by simpa [pred] using h) p
          (by simpa [pred] using inOpenSegment_symm hp)
    · exact
        hwhole (B.vertex pred, B.vertex k)
          (by simpa [pred] using h) p hp
  have hface_to_succPred :
      (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C).faceSucc
        (UnitDistanceDart.ofBoundary B pred) =
        UnitDistanceDart.ofBoundary B
          (PlanarInterface.cyclicSucc B.length_pos pred) := by
    have hrow :
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.GeometricBoundarySuccessorRow
          C B pred := by
      simpa [pred] using rows.toGeometricBoundarySuccessorRow
    rcases hrow with hstep | hwrap
    · rcases hstep with ⟨i, hi, hreverse, htarget⟩
      exact
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem_faceSucc_eq_of_reverse_getElem_succ
          C
          (UnitDistanceDart.ofBoundary B pred)
          (UnitDistanceDart.ofBoundary B
            (PlanarInterface.cyclicSucc B.length_pos pred))
          i hi hreverse htarget
    · rcases hwrap with ⟨hpos, hreverse, htarget⟩
      exact
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem_faceSucc_eq_of_reverse_getElem_last
          C
          (UnitDistanceDart.ofBoundary B pred)
          (UnitDistanceDart.ofBoundary B
            (PlanarInterface.cyclicSucc B.length_pos pred))
          hpos hreverse htarget
  have hface :
      (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C).faceSucc
        (UnitDistanceDart.ofBoundary B pred) =
        UnitDistanceDart.ofBoundary B k := by
    simpa [hsucc_pred] using hface_to_succPred
  have hsucc_frontier :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (B.vertex k))
          ((canonicalGraph C).point
            (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
    intro p hp
    rcases rows.succ_edge with h | h
    · exact
        hwhole
          (B.vertex k,
            B.vertex (PlanarInterface.cyclicSucc B.length_pos k))
          h p hp
    · exact
        hwhole
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
            B.vertex k)
          h p (inOpenSegment_symm hp)
  exact ⟨by simpa [pred] using hpred_frontier, hface, hsucc_frontier⟩

/-- Erase a family of primitive sector rows to the geometric boundary-successor
rows for the whole boundary cycle. -/
theorem toGeometricBoundarySuccessorRows
    (rows :
      forall j : Fin B.length,
        BoundaryVertexExteriorSectorRowsAt inputs B j) :
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.GeometricBoundarySuccessorRows
      C B := by
  exact
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricBoundarySuccessorRows_of_boundary_vertex_angularNoBetweenRows
      C B
      (fun j => (rows j).toBoundaryVertexAngularNoBetweenRows)

/-- Claim `S2-agent-dart-edge-frontier-from-sectorRows`.

For the selected geometric raw face-successor orbit, once each raw dart has
been identified with a dart of the actual exterior boundary cycle, the primitive
sector rows prove exactly the dart-edge frontier row consumed by
`rawFaceSuccOrbit_source_inputs_of_dart_edge_openSegment_frontier`. -/
theorem S2_agent_dart_edge_frontier_from_sectorRows
    {start : UnitDistanceDart C}
    (O :
      UnitDistanceRotationSystem.RawFaceSuccOrbit
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C)
        start)
    (rows :
      forall j : Fin B.length,
        BoundaryVertexExteriorSectorRowsAt inputs B j)
    (dart_on_boundary :
      forall k : Fin O.period,
        Exists fun j : Fin B.length =>
          O.dart k = UnitDistanceDart.ofBoundary B j) :
    forall k : Fin O.period,
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (O.dart k).tail)
          ((canonicalGraph C).point (O.dart k).head) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  intro k p hp
  rcases dart_on_boundary k with ⟨j, hj⟩
  have hsucc_frontier :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (B.vertex j))
          ((canonicalGraph C).point
            (B.vertex (PlanarInterface.cyclicSucc B.length_pos j))) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior :=
    ((rows j).geometricFaceSucc_frontier_step).2.2
  exact hsucc_frontier p (by simpa [hj] using hp)

/-- Erase one primitive sector row to the concrete local-sector row at a
frontier vertex known to be this boundary vertex. -/
def toLocalSectorRowsAt
    (rows : BoundaryVertexExteriorSectorRowsAt inputs B k)
    {a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (ha : a.1 = B.vertex k) :
    UnboundedFrontierCarrierLocalSectorRowsAt inputs a where
  left := B.vertex (PlanarInterface.cyclicPred B.length_pos k)
  right := B.vertex (PlanarInterface.cyclicSucc B.length_pos k)
  left_edge := by
    rcases rows.pred_edge with h | h
    · left
      simpa [ha] using h
    · right
      simpa [ha] using h
  right_edge := by
    rcases rows.succ_edge with h | h
    · left
      simpa [ha] using h
    · right
      simpa [ha] using h
  heads_ne := rows.pred_vertex_ne_succ_vertex
  only := by
    intro b hab
    have hedge :
        (B.vertex k, b.1) ∈ unboundedFrontierEdgeSet C inputs ∨
          (b.1, B.vertex k) ∈ unboundedFrontierEdgeSet C inputs := by
      rcases (unboundedFrontierCarrierGraph_adj_iff).1 hab with h | h
      · left
        simpa [ha] using h
      · right
        simpa [ha] using h
    exact rows.local_two_germ b.1 hedge

/-- The primitive local two-germ rows imply boundary-cycle incident
frontier-edge completeness. -/
theorem boundaryCycleIncidentFrontierEdgeCompleteness
    (rows :
      forall j : Fin B.length,
        BoundaryVertexExteriorSectorRowsAt inputs B j) :
    BoundaryCycleIncidentFrontierEdgeCompleteness inputs B := by
  intro j x hedge
  exact (rows j).local_two_germ x hedge

end BoundaryVertexExteriorSectorRowsAt

/-- Primitive boundary-vertex exterior-sector rows construct the corresponding
geometric exterior face orbit and fill the honest face-dart carrier rows.

This constructor stays on the actual unbounded exterior frontier: the vertex
row is the supplied equivalence with
`frontier (unboundedExteriorComponentRows C inputs).exterior`, the edge row is
derived from the sector rows' selected `unboundedFrontierEdgeSet` successor
edges, and the incident-neighbour row is the sector rows' local two-germ
completeness. -/
noncomputable def faceDartOrbitExteriorCarrierRows_of_boundaryVertexExteriorSectorRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
    (frontier_iff_cycle_vertex :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin B.length => B.vertex k = v)
    (sectorRows :
      forall k : Fin B.length,
        BoundaryVertexExteriorSectorRowsAt inputs B k) :
    FaceDartOrbitExteriorCarrierRows C inputs := by
  let faceRows :
      UnitDistanceCycleFaceSuccRows C
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C)
        B :=
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.unitDistanceCycleFaceSuccRows_of_geometric_boundary_list_successors
      C B
      (BoundaryVertexExteriorSectorRowsAt.toGeometricBoundarySuccessorRows
        (C := C) (inputs := inputs) (B := B) sectorRows)
  exact
    faceDartOrbitExteriorCarrierRows_of_boundaryCarrierRows
      inputs
      (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
        C)
      B
      faceRows
      frontier_iff_cycle_vertex
      (fun k => ((sectorRows k).geometricFaceSucc_frontier_step).2.2)
      (incident_only_pred_succ_of_boundaryCycleIncidentFrontierEdgeCompleteness
        (BoundaryVertexExteriorSectorRowsAt.boundaryCycleIncidentFrontierEdgeCompleteness
          (C := C) (inputs := inputs) (B := B) sectorRows))

/-- A raw face-successor orbit stays on a supplied boundary cycle once its
starting dart is a boundary dart and the rotation system follows that boundary.

This is only the orbit-tracing bookkeeping: it uses the local face-successor
rows, not cyclic carrier coverage or a downstream frontier cycle row. -/
theorem rawFaceSuccOrbit_dart_on_boundary_of_boundary_faceSuccRows
    {C : _root_.UDConfig n}
    {R : UnitDistanceRotationSystem C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    {start : UnitDistanceDart C}
    (faceRows : UnitDistanceCycleFaceSuccRows C R B)
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (start_on_boundary :
      Exists fun j : Fin B.length => start = UnitDistanceDart.ofBoundary B j) :
    forall k : Fin O.period,
      Exists fun j : Fin B.length =>
        O.dart k = UnitDistanceDart.ofBoundary B j := by
  have hiter :
      forall m : Nat,
        Exists fun j : Fin B.length =>
          (R.faceSuccPerm ^ m) start = UnitDistanceDart.ofBoundary B j := by
    intro m
    induction m with
    | zero =>
        simpa using start_on_boundary
    | succ m ih =>
        rcases ih with ⟨j, hj⟩
        refine ⟨PlanarInterface.cyclicSucc B.length_pos j, ?_⟩
        rw [pow_succ', Equiv.Perm.mul_apply]
        change
          R.faceSucc ((R.faceSuccPerm ^ m) start) =
            UnitDistanceDart.ofBoundary B
              (PlanarInterface.cyclicSucc B.length_pos j)
        rw [hj]
        exact faceRows.faceSucc_eq_next j
  intro k
  rw [O.dart_eq_iterate k]
  exact hiter k.val

/-- Primitive exterior-sector rows propagate a boundary start dart around the
selected geometric raw face-successor orbit. -/
theorem rawFaceSuccOrbit_dart_on_boundary_of_sectorRows_start
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    {start : UnitDistanceDart C}
    (O :
      UnitDistanceRotationSystem.RawFaceSuccOrbit
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C)
        start)
    (sectorRows :
      forall j : Fin B.length,
        BoundaryVertexExteriorSectorRowsAt inputs B j)
    (start_on_boundary :
      Exists fun j : Fin B.length => start = UnitDistanceDart.ofBoundary B j) :
    forall k : Fin O.period,
      Exists fun j : Fin B.length =>
        O.dart k = UnitDistanceDart.ofBoundary B j := by
  let faceRows :
      UnitDistanceCycleFaceSuccRows C
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C)
        B :=
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.unitDistanceCycleFaceSuccRows_of_geometric_boundary_list_successors
      C B
      (BoundaryVertexExteriorSectorRowsAt.toGeometricBoundarySuccessorRows
        (C := C) (inputs := inputs) (B := B) sectorRows)
  exact
    rawFaceSuccOrbit_dart_on_boundary_of_boundary_faceSuccRows
      faceRows O start_on_boundary

/-- Claim `S2-agent-selected-seed-dart-edge-frontier`.

Selected-seed form of the raw dart-edge frontier row consumed by
`S2_agent_raw_tail_hit_source`.  Local-sector rows orient the unbounded
exterior frontier seed into the geometric raw face-successor orbit.  Primitive
actual exterior-sector rows then prove that every open segment of every raw
dart edge lies on the actual unbounded exterior frontier, once the selected
start dart has been identified with a dart of that same actual boundary cycle.

This deliberately does not use cyclic carrier coverage or any downstream final
cycle row; the remaining geometric tracing input is the selected
`raw_start_on_boundary` identification. -/
theorem S2_agent_selected_seed_dart_edge_frontier
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (seed : UnboundedExteriorFrontierSeed inputs)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (sectorRows :
      forall j : Fin B.length,
        BoundaryVertexExteriorSectorRowsAt inputs B j)
    (raw_start_on_boundary :
      forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
          {start : UnitDistanceDart C},
        UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
        start.tail = e.1 ->
        start.head = e.2 ->
        Exists fun j : Fin B.length =>
          start = UnitDistanceDart.ofBoundary B j) :
    Exists fun e : PlanarInterface.Edge n =>
      Exists fun p : PlanarInterface.Point =>
        Exists fun start : UnitDistanceDart C =>
          UnboundedExteriorFrontierEdgeLocalRows C inputs e p ∧
            start.tail = e.1 ∧
              start.head = e.2 ∧
                Nonempty
                  (UnitDistanceRotationSystem.RawFaceSuccOrbit
                    (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
                      C)
                    start) ∧
                  forall O :
                    UnitDistanceRotationSystem.RawFaceSuccOrbit
                      (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
                        C)
                      start,
                    forall k : Fin O.period,
                      forall q : PlanarInterface.Point,
                        PlanarInterface.InOpenSegment q
                          ((canonicalGraph C).point (O.dart k).tail)
                          ((canonicalGraph C).point (O.dart k).head) ->
                        q ∈
                          frontier
                            (unboundedExteriorComponentRows C inputs).exterior := by
  rcases
      exists_geometricRawFaceSuccOrbitSeed_of_unboundedExteriorFrontierSeed_localSectorRows
        (C := C) (inputs := inputs) localSectorRows seed with
    ⟨e, p, start, edgeRows, htail, hhead, horbit⟩
  refine ⟨e, p, start, edgeRows, htail, hhead, horbit, ?_⟩
  intro O
  exact
    BoundaryVertexExteriorSectorRowsAt.S2_agent_dart_edge_frontier_from_sectorRows
