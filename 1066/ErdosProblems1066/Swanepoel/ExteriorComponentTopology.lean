            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
    intro k p hp
    let j : Fin B.length := Fin.cast hperiod.symm k
    have hcast : Fin.cast hperiod j = k := by
      ext
      simp [j]
    have htail :
        (O.dart k).tail = B.vertex j := by
      simpa [hcast] using tail_eq j
    have hcast_succ :
        Fin.cast hperiod (PlanarInterface.cyclicSucc B.length_pos j) =
          PlanarInterface.cyclicSucc O.period_pos k := by
      calc
        Fin.cast hperiod (PlanarInterface.cyclicSucc B.length_pos j) =
            PlanarInterface.cyclicSucc O.period_pos (Fin.cast hperiod j) := by
              ext
              simp [PlanarInterface.cyclicSucc, hperiod]
        _ = PlanarInterface.cyclicSucc O.period_pos k := by
              rw [hcast]
    have htail_succ :
        (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail =
          B.vertex (PlanarInterface.cyclicSucc B.length_pos j) := by
      rw [← hcast_succ]
      exact tail_eq (PlanarInterface.cyclicSucc B.length_pos j)
    exact
      rows.orbit_edge_openSegment_frontier j p (by
        simpa [htail, htail_succ] using hp)
  exact
    ofRawFaceSuccOrbitBoundaryRows
      O B hperiod tail_eq frontier_iff_tail edge_openSegment_frontier

