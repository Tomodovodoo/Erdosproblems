successor edge is again an actual frontier edge. -/
theorem geometricFaceSucc_frontier_step
    (rows : BoundaryVertexExteriorSectorRowsAt inputs B k) :
    (forall p : PlanarInterface.Point,
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point
          (B.vertex (PlanarInterface.cyclicPred B.length_pos k)))
        ((canonicalGraph C).point (B.vertex k)) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) /\
      (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C).faceSucc
        (UnitDistanceDart.ofBoundary B
          (PlanarInterface.cyclicPred B.length_pos k)) =
        UnitDistanceDart.ofBoundary B k /\
      (forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (B.vertex k))
          ((canonicalGraph C).point
            (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) := by
  let pred := PlanarInterface.cyclicPred B.length_pos k
  have hsucc_pred : PlanarInterface.cyclicSucc B.length_pos pred = k := by
    dsimp [pred]
    exact PlanarInterface.cyclicSucc_cyclicPred B.length_pos k
  have hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
    unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
  have hpred_frontier :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (B.vertex pred))
          ((canonicalGraph C).point (B.vertex k)) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
    intro p hp
    rcases rows.pred_edge with h | h
    · exact
        hwhole (B.vertex k, B.vertex pred)
          (by simpa [pred] using h) p
          (by simpa [pred] using inOpenSegment_symm hp)
    · exact
        hwhole (B.vertex pred, B.vertex k)
          (by simpa [pred] using h) p hp
  have hface_to_succPred :
      (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C).faceSucc
        (UnitDistanceDart.ofBoundary B pred) =
        UnitDistanceDart.ofBoundary B
          (PlanarInterface.cyclicSucc B.length_pos pred) := by
    have hrow :
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.GeometricBoundarySuccessorRow
          C B pred := by
      simpa [pred] using rows.toGeometricBoundarySuccessorRow
    rcases hrow with hstep | hwrap
    · rcases hstep with ⟨i, hi, hreverse, htarget⟩
      exact
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem_faceSucc_eq_of_reverse_getElem_succ
          C
          (UnitDistanceDart.ofBoundary B pred)
          (UnitDistanceDart.ofBoundary B
            (PlanarInterface.cyclicSucc B.length_pos pred))
          i hi hreverse htarget
    · rcases hwrap with ⟨hpos, hreverse, htarget⟩
      exact
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem_faceSucc_eq_of_reverse_getElem_last
          C
          (UnitDistanceDart.ofBoundary B pred)
          (UnitDistanceDart.ofBoundary B
            (PlanarInterface.cyclicSucc B.length_pos pred))
          hpos hreverse htarget
  have hface :
      (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C).faceSucc
        (UnitDistanceDart.ofBoundary B pred) =
        UnitDistanceDart.ofBoundary B k := by
    simpa [hsucc_pred] using hface_to_succPred
  have hsucc_frontier :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (B.vertex k))
          ((canonicalGraph C).point
            (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
    intro p hp
    rcases rows.succ_edge with h | h
    · exact
        hwhole
          (B.vertex k,
            B.vertex (PlanarInterface.cyclicSucc B.length_pos k))
          h p hp
    · exact
        hwhole
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
            B.vertex k)
          h p (inOpenSegment_symm hp)
  exact ⟨by simpa [pred] using hpred_frontier, hface, hsucc_frontier⟩

