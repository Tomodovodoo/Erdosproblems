    (hAclosed : IsClosed A)
    (hBclosed : IsClosed B)
    (hABdisjoint : Disjoint A B)
    (hcover : frontier (connectedComponentIn Kᶜ x) = A ∪ B)
    (hTcompact : IsCompact T)
    (hTconnected : IsConnected T)
    (hTsubset : T ⊆ K)
    (hTA : (T ∩ A).Nonempty)
    (hTB : (T ∩ B).Nonempty) :
