theorem boundaryCycleIncidentFrontierEdgeCompleteness_of_pred_succ_angular_no_between
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (bad_incident_between :
