    cycle_edge_openSegment_frontier hcomplete

/-- Primitive boundary-vertex exterior-sector rows are enough to fill the
compact concrete-carrier source: their successor-edge fields give cyclic
coverage and their local two-germ fields give the pointwise local-sector rows. -/
noncomputable def cyclicCoverageLocalSectorRows_of_boundaryVertexExteriorSectorRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
