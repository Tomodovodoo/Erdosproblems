  intro n C inputs
  letI : DecidableRel (unboundedFrontierCarrierGraph C inputs).Adj :=
    unboundedFrontierCarrierGraph_decidableAdj C inputs
  exact
    unboundedExteriorFrontierCycleRows_of_frontierCarrierGraph_whole
      inputs
      (unboundedFrontierCarrierGraph_connected_of_cyclicCoverageRows
        (hcycle C inputs))
      (unboundedFrontierCarrierGraph_degree_two_of_dartPairRows
        inputs (hdart C inputs))
      unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition

/-- Named exterior-boundary handoff for the concrete two-row route.  This is
only a reducer: the real proof obligations remain the cyclic carrier coverage
from the exterior boundary and the local dart pairs from exterior sectors. -/
noncomputable def unboundedExteriorFrontierCycleRows_of_exteriorBoundaryRows
    (unboundedFrontierCarrierCyclicCoverageRows_of_exterior_boundary :
      forall {n : Nat} (C : _root_.UDConfig n)
        (inputs : FinitePlanarOuterComponentInputs C),
