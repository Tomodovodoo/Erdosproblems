          (unboundedFrontierCarrierGraph C inputs) v
          ((unboundedFrontierCarrierGraph C inputs).neighborSetFintype v) =
            2)
    (hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs) :
    ExteriorFrontierCarrierRows C inputs :=
  exteriorFrontierCarrierRows_of_frontierCarrierGraph
    inputs hconn hdegree_two hwhole

/-- Nonempty form of the concrete carrier constructor, ready to feed the S2
family reducers. -/
noncomputable def exteriorFrontierCarrierRows_nonempty_of_frontierCarrierGraph
