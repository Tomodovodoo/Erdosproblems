      local_exterior_side)

/-- Edge-level angular source for selected third incident frontier edges.

This removes the moving point/radius bookkeeping from
`BoundaryFrontierOpenSegmentLocalExteriorSector`: once a third incident edge has
been promoted to the concrete unbounded-frontier edge set, only its graph-dart
direction must be shown to lie in the predecessor/successor angular sector. -/
abbrev BoundaryFrontierIncidentEdgeExteriorAngularSector
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall (k : Fin B.length) (other : Fin n),
    ((B.vertex k, other) ∈ unboundedFrontierEdgeSet C inputs ∨
      (other, B.vertex k) ∈ unboundedFrontierEdgeSet C inputs) ->
    other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
    other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
        C B k other

/-- Promote the third open-segment frontier case to a concrete selected
unbounded-frontier edge, using the relative-closure propagation row. -/
theorem boundary_frontier_openSegment_frontierEdge_or_symm_of_relative_closure
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (relative_closure :
      BoundaryFrontierOpenSegmentRelativeClosurePropagation inputs B) :
    forall (k : Fin B.length) (q : PlanarInterface.Point) (other : Fin n),
      q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
      (canonicalGraph C).Adj (B.vertex k) other ->
      PlanarInterface.InOpenSegment q
        ((canonicalGraph C).point (B.vertex k))
        ((canonicalGraph C).point other) ->
      other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
      other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
        ((B.vertex k, other) ∈ unboundedFrontierEdgeSet C inputs ∨
          (other, B.vertex k) ∈ unboundedFrontierEdgeSet C inputs) := by
  intro k q other hqfrontier hadj hopen hother_pred hother_succ
  rcases hadj with hedge | hedge
  · have hfrontier :
        forall z : PlanarInterface.Point,
          PlanarInterface.InOpenSegment z
            ((canonicalGraph C).point (B.vertex k))
            ((canonicalGraph C).point other) ->
          z ∈ frontier (unboundedExteriorComponentRows C inputs).exterior :=
      edge_openSegment_frontier_of_inOpenSegment_frontier_and_relative_ball_closure
        (C := C) (inputs := inputs) (e := (B.vertex k, other))
        hedge hopen hqfrontier
        (relative_closure k q other hqfrontier (Or.inl hedge) hopen
          hother_pred hother_succ)
    exact Or.inl
      (mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier
        (C := C) (inputs := inputs) (e := (B.vertex k, other))
        hedge hfrontier)
  · have hfrontier_rev :
        forall z : PlanarInterface.Point,
          PlanarInterface.InOpenSegment z
            ((canonicalGraph C).point other)
            ((canonicalGraph C).point (B.vertex k)) ->
          z ∈ frontier (unboundedExteriorComponentRows C inputs).exterior :=
      edge_openSegment_frontier_of_inOpenSegment_frontier_and_relative_ball_closure
        (C := C) (inputs := inputs) (e := (other, B.vertex k))
        hedge (inOpenSegment_symm hopen) hqfrontier
        (by
          intro z hz hclosure
          rcases
              relative_closure k q other hqfrontier (Or.inr hedge) hopen
                hother_pred hother_succ z (inOpenSegment_symm hz) hclosure with
            ⟨r, hrpos, hnear⟩
          exact ⟨r, hrpos, by
            intro y hyball hyopen
            exact hnear y hyball (inOpenSegment_symm hyopen)⟩)
    exact Or.inr
      (mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier
        (C := C) (inputs := inputs) (e := (other, B.vertex k))
        hedge hfrontier_rev)

/-- Reducer from the sharper edge/propagation source rows to the open-segment
point-sector row.

The topology row promotes the single open-segment frontier point to a selected
frontier edge.  The edge-level angular row supplies the graph-dart sector, and
collinearity of an interior point on that edge converts it back to the point-ray
sector expected by the downstream local-sector machinery. -/
theorem boundary_frontier_openSegment_local_exterior_sector_of_incident_edge_angular_and_relative_closure
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (incident_edge_angular :
      BoundaryFrontierIncidentEdgeExteriorAngularSector inputs B)
    (relative_closure :
      BoundaryFrontierOpenSegmentRelativeClosurePropagation inputs B) :
    BoundaryFrontierOpenSegmentLocalExteriorSector inputs B := by
  intro k _eps q other _hqball hqfrontier hadj hopen hother_pred hother_succ
  have hedge_frontier :
      ((B.vertex k, other) ∈ unboundedFrontierEdgeSet C inputs ∨
        (other, B.vertex k) ∈ unboundedFrontierEdgeSet C inputs) :=
    boundary_frontier_openSegment_frontierEdge_or_symm_of_relative_closure
      (C := C) (inputs := inputs) (B := B) relative_closure
      k q other hqfrontier hadj hopen hother_pred hother_succ
  have hbetween :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
        C B k other :=
    incident_edge_angular k other hedge_frontier hother_pred hother_succ
  have hqne :
      q ≠ (canonicalGraph C).point (B.vertex k) := by
    exact left_ne_of_inOpenSegment (canonical_adj_point_ne hadj) hopen
  have harg :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
          ((canonicalGraph C).point (B.vertex k)) q =
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
          (B.vertex k) other := by
    simpa [_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg_def]
      using
        dartArg_eq_of_mem_closedSegment_ne_left
          (inOpenSegment_mem_closedSegment hopen) hqne
  exact ⟨by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hbetween.1,
    by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hbetween.2⟩

/-- Reducer from the open-segment point-ray source to the requested
edge-direction angular residual.

The only proof content here is collinearity: an interior point of the incident
edge has the same ray angle from the boundary vertex as the incident graph
dart. -/
theorem boundary_frontier_openSegment_local_exterior_angular_sector_of_openSegment_local_exterior_sector
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (openSegment_local_exterior_sector :
      BoundaryFrontierOpenSegmentLocalExteriorSector inputs B) :
    BoundaryFrontierOpenSegmentLocalExteriorAngularSector inputs B := by
  intro k eps q other hqball hqfrontier hadj hopen hother_pred hother_succ
  have hpoint :
      BoundaryPredSuccPointAngularBetween C B k q :=
    openSegment_local_exterior_sector k eps q other
      hqball hqfrontier hadj hopen hother_pred hother_succ
  have hqne :
      q ≠ (canonicalGraph C).point (B.vertex k) := by
    exact left_ne_of_inOpenSegment (canonical_adj_point_ne hadj) hopen
  have harg :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
          ((canonicalGraph C).point (B.vertex k)) q =
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
          (B.vertex k) other := by
    simpa [_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg_def]
      using
        dartArg_eq_of_mem_closedSegment_ne_left
          (inOpenSegment_mem_closedSegment hopen) hqne
  exact ⟨by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hpoint.1,
    by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hpoint.2⟩

/-- Far-endpoint form of the closed-segment angular residual.

The closed-segment target quantifies over all radii, so after decomposing the
closed segment the case `q = point other` is not local unless the caller has
already supplied a small enough radius.  This names exactly that remaining
endpoint obligation. -/
abbrev BoundaryFrontierClosedSegmentEndpointExteriorAngularSector
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall (k : Fin B.length) (eps : Real) (other : Fin n),
    (canonicalGraph C).point other ∈
      Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
    (canonicalGraph C).point other ∈
      frontier (unboundedExteriorComponentRows C inputs).exterior ->
    (canonicalGraph C).Adj (B.vertex k) other ->
    other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
    other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
        C B k other

/-- Endpoint incident-neighbour row for the closed-segment local exterior
angular sector.

The endpoint branch is vacuous once any graph vertex on the unbounded exterior
frontier adjacent to `B.vertex k` is known to be one of the two boundary
neighbours at `k`. -/
abbrev BoundaryFrontierEndpointIncidentOnlyPredSucc
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall (k : Fin B.length) (other : Fin n),
    (canonicalGraph C).point other ∈
      frontier (unboundedExteriorComponentRows C inputs).exterior ->
    (canonicalGraph C).Adj (B.vertex k) other ->
      other = B.vertex (PlanarInterface.cyclicPred B.length_pos k) ∨
        other = B.vertex (PlanarInterface.cyclicSucc B.length_pos k)

/-- Reducer for the endpoint branch of
`BoundaryFrontierClosedSegmentLocalExteriorAngularSector`.

The incident-only endpoint row turns the far-endpoint case into a contradiction
with the two disequality hypotheses, so no synthetic angular conclusion is
introduced. -/
theorem boundary_frontier_closedSegment_endpoint_exterior_angular_sector_of_endpoint_incident_only_pred_succ
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (hendpoint : BoundaryFrontierEndpointIncidentOnlyPredSucc inputs B) :
    BoundaryFrontierClosedSegmentEndpointExteriorAngularSector inputs B := by
  intro k _eps other _hball hfrontier hadj hother_pred hother_succ
  rcases hendpoint k other hfrontier hadj with h | h
  · exact False.elim (hother_pred h)
  · exact False.elim (hother_succ h)

/-- Reducer from the closed-segment angular residual to its honest local
open-segment part plus the unavoidable far-endpoint case.

The proof is only the finite-drawing closed-segment trichotomy: the left
endpoint contradicts the noncenter hypothesis, the right endpoint is delegated
to `BoundaryFrontierClosedSegmentEndpointExteriorAngularSector`, and the
relative-interior case is delegated to
`BoundaryFrontierOpenSegmentLocalExteriorAngularSector`. -/
theorem boundary_frontier_closedSegment_local_exterior_angular_sector_of_openSegment_endpoint_sources
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (openSegment_local_exterior_angular_sector :
      BoundaryFrontierOpenSegmentLocalExteriorAngularSector inputs B)
    (endpoint_exterior_angular_sector :
      BoundaryFrontierClosedSegmentEndpointExteriorAngularSector inputs B) :
    BoundaryFrontierClosedSegmentLocalExteriorAngularSector inputs B := by
  intro k eps q other hqball hqfrontier hadj hqseg hqne hother_pred hother_succ
  rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hqseg with
      hleft | hright | hopen
  · exact False.elim (hqne hleft)
  · exact
      endpoint_exterior_angular_sector k eps other
        (by simpa [hright] using hqball)
        (by simpa [hright] using hqfrontier)
        hadj hother_pred hother_succ
  · exact
      openSegment_local_exterior_angular_sector k eps q other
        hqball hqfrontier hadj hopen hother_pred hother_succ

/-- Checked reducer with the open-segment angular row sharpened to the
point-ray local source row.

What remains is precisely the local open-segment point-sector statement plus
the already named far-endpoint closed-segment residual. -/
theorem boundary_frontier_closedSegment_local_exterior_angular_sector_of_openSegment_pointSector_endpoint_sources
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (openSegment_local_exterior_sector :
      BoundaryFrontierOpenSegmentLocalExteriorSector inputs B)
    (endpoint_exterior_angular_sector :
      BoundaryFrontierClosedSegmentEndpointExteriorAngularSector inputs B) :
    BoundaryFrontierClosedSegmentLocalExteriorAngularSector inputs B :=
  boundary_frontier_closedSegment_local_exterior_angular_sector_of_openSegment_endpoint_sources
    (C := C) (inputs := inputs) (B := B)
    (boundary_frontier_openSegment_local_exterior_angular_sector_of_openSegment_local_exterior_sector
      (C := C) (inputs := inputs) (B := B)
      openSegment_local_exterior_sector)
    endpoint_exterior_angular_sector

/-- Reducer from the honest open-segment point-sector row plus the far-endpoint
incident-only row to the W3-carried local exterior point-sector obligation.

The closed-segment endpoint branch is not hidden: it is discharged only by the
explicit row saying every frontier graph-vertex endpoint adjacent to the
boundary vertex is one of the predecessor/successor boundary neighbours. -/
theorem boundary_frontier_local_exterior_sector_of_openSegment_pointSector_endpoint_incident_only
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (openSegment_local_exterior_sector :
      BoundaryFrontierOpenSegmentLocalExteriorSector inputs B)
    (endpoint_incident_only :
      BoundaryFrontierEndpointIncidentOnlyPredSucc inputs B) :
    forall (k : Fin B.length) (eps : Real) (q : PlanarInterface.Point)
        (other : Fin n),
      q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
      q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
      (canonicalGraph C).Adj (B.vertex k) other ->
      q ∈ vertexIncidentGermW3 C (B.vertex k) other eps ->
      q ≠ (canonicalGraph C).point (B.vertex k) ->
      other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
      other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
        BoundaryPredSuccPointAngularBetween C B k q := by
  intro k eps q other hqball hqfrontier hadj hgerm hqne hother_pred
    hother_succ
  have hbetween :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
        C B k other :=
    boundary_frontier_closedSegment_local_exterior_angular_sector_of_openSegment_pointSector_endpoint_sources
      (C := C) (inputs := inputs) (B := B)
      openSegment_local_exterior_sector
      (boundary_frontier_closedSegment_endpoint_exterior_angular_sector_of_endpoint_incident_only_pred_succ
        (C := C) (inputs := inputs) (B := B)
        endpoint_incident_only)
      k eps q other hqball hqfrontier hadj hgerm.2 hqne hother_pred
      hother_succ
  have harg :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
          ((canonicalGraph C).point (B.vertex k)) q =
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
          (B.vertex k) other := by
    exact dartArg_eq_of_mem_closedSegment_ne_left hgerm.2 hqne
  exact ⟨by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hbetween.1,
    by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hbetween.2⟩

/-- Claim `S2-agent-local-exterior-point-sector-source`.

Narrow source reducer for the noncenter local exterior point-sector row used by
`S2_agent_actual_exterior_sector_input_source_2` and the primitive
`BoundaryVertexExteriorSectorRowsAt` constructors.  The moving W3 obligation is
reduced to selected-edge angular data, the relative-closure propagation needed
to promote an open-segment frontier point to a selected frontier edge, and the
separate far-endpoint incident-only row. -/
theorem S2_agent_local_exterior_point_sector_source
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (incident_edge_angular :
      BoundaryFrontierIncidentEdgeExteriorAngularSector inputs B)
    (relative_closure :
      BoundaryFrontierOpenSegmentRelativeClosurePropagation inputs B)
    (endpoint_incident_only :
      BoundaryFrontierEndpointIncidentOnlyPredSucc inputs B) :
    forall (k : Fin B.length) (eps : Real) (q : PlanarInterface.Point)
        (other : Fin n),
      q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
      q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
      (canonicalGraph C).Adj (B.vertex k) other ->
      q ∈ vertexIncidentGermW3 C (B.vertex k) other eps ->
      q ≠ (canonicalGraph C).point (B.vertex k) ->
      other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
      other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
        BoundaryPredSuccPointAngularBetween C B k q :=
  boundary_frontier_local_exterior_sector_of_openSegment_pointSector_endpoint_incident_only
    (C := C) (inputs := inputs) (B := B)
    (boundary_frontier_openSegment_local_exterior_sector_of_incident_edge_angular_and_relative_closure
      (C := C) (inputs := inputs) (B := B)
      incident_edge_angular relative_closure)
    endpoint_incident_only

/-- Reducer from the edge-direction closed-segment exterior-side residual to
the point-ray closed-segment residual.

This discharges the collinearity bookkeeping: a noncenter point on the closed
segment from the boundary vertex to `other` has the same ray angle as the
incident graph dart. -/
theorem boundary_frontier_closedSegment_local_exterior_sector_of_closedSegment_local_exterior_angular_sector
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (closedSegment_local_exterior_angular_sector :
      BoundaryFrontierClosedSegmentLocalExteriorAngularSector inputs B) :
    BoundaryFrontierClosedSegmentLocalExteriorSector inputs B := by
  intro k eps q other hqball hqfrontier hadj hqseg hqne hother_pred hother_succ
  have hbetween :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
        C B k other :=
    closedSegment_local_exterior_angular_sector k eps q other hqball
      hqfrontier hadj hqseg hqne hother_pred hother_succ
  have harg :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
          ((canonicalGraph C).point (B.vertex k)) q =
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.graphDartArg
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.canonicalGeometricGraph C)
          (B.vertex k) other := by
    exact dartArg_eq_of_mem_closedSegment_ne_left hqseg hqne
  exact ⟨by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hbetween.1,
    by
      simpa [BoundaryPredSuccPointAngularBetween, harg] using hbetween.2⟩

/-- Reducer from the closed-segment local exterior-side residual to the
W3-carried point-sector residual used by the S2 exterior-sector source. -/
theorem boundary_frontier_local_exterior_sector_of_closedSegment_local_exterior_sector
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (closedSegment_local_exterior_sector :
      BoundaryFrontierClosedSegmentLocalExteriorSector inputs B) :
    forall (k : Fin B.length) (eps : Real) (q : PlanarInterface.Point)
        (other : Fin n),
      q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
      q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
      (canonicalGraph C).Adj (B.vertex k) other ->
      q ∈ vertexIncidentGermW3 C (B.vertex k) other eps ->
      q ≠ (canonicalGraph C).point (B.vertex k) ->
      other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
      other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
        BoundaryPredSuccPointAngularBetween C B k q := by
  intro k eps q other hqball hqfrontier hadj hgerm hqne hother_pred hother_succ
  exact
    closedSegment_local_exterior_sector k eps q other hqball hqfrontier
      hadj hgerm.2 hqne hother_pred hother_succ

/-- Reducer from the edge-direction closed-segment exterior-side residual to
the W3-carried point-sector residual used by the S2 exterior-sector source. -/
theorem boundary_frontier_local_exterior_sector_of_closedSegment_local_exterior_angular_sector
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (closedSegment_local_exterior_angular_sector :
      BoundaryFrontierClosedSegmentLocalExteriorAngularSector inputs B) :
    forall (k : Fin B.length) (eps : Real) (q : PlanarInterface.Point)
        (other : Fin n),
      q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
      q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
      (canonicalGraph C).Adj (B.vertex k) other ->
      q ∈ vertexIncidentGermW3 C (B.vertex k) other eps ->
      q ≠ (canonicalGraph C).point (B.vertex k) ->
      other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
      other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
        BoundaryPredSuccPointAngularBetween C B k q :=
  boundary_frontier_local_exterior_sector_of_closedSegment_local_exterior_sector
    (C := C) (inputs := inputs) (B := B)
    (boundary_frontier_closedSegment_local_exterior_sector_of_closedSegment_local_exterior_angular_sector
      (C := C) (inputs := inputs) (B := B)
      closedSegment_local_exterior_angular_sector)

/-- Point-sector form of the local two-germ source.

This is the center-aware version of
`exists_local_frontier_germ_two_of_vertex_star_isolation_and_angular_no_between`:
the local exterior-side row is stated for noncenter points, and the center case
is handled by the vertex-star isolation theorem. -/
theorem exists_local_frontier_germ_two_of_vertex_star_isolation_local_exterior_sector
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (k : Fin B.length)
    (local_exterior_sector :
      forall (eps : Real) (q : PlanarInterface.Point) (other : Fin n),
        q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
        q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
        (canonicalGraph C).Adj (B.vertex k) other ->
        q ∈ vertexIncidentGermW3 C (B.vertex k) other eps ->
        q ≠ (canonicalGraph C).point (B.vertex k) ->
        other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
        other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
          BoundaryPredSuccPointAngularBetween C B k q)
    (no_between :
      forall other : Fin n,
        GraphBridge.UnitDistanceAdj C (B.vertex k) other ->
        other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
        other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
          ¬
            _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
              C B k other) :
    Exists fun eps : Real =>
      0 < eps ∧
        forall q : PlanarInterface.Point,
          q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
              q ∈ vertexIncidentGermW3 C (B.vertex k)
                    (B.vertex (PlanarInterface.cyclicPred B.length_pos k)) eps ∨
                q ∈ vertexIncidentGermW3 C (B.vertex k)
                    (B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) eps :=
  exists_local_frontier_germ_two_of_vertex_star_isolation_and_angular_no_between
    (C := C) (inputs := inputs) (B := B) k
    (boundary_frontier_third_germ_between_of_local_exterior_sector
      (C := C) (inputs := inputs) (B := B) k local_exterior_sector)
    no_between

/-- The carrier graph forgets to the ambient unit-distance graph. -/
noncomputable def unboundedFrontierCarrierGraphHom
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    SimpleGraph.Hom
      (unboundedFrontierCarrierGraph C inputs)
      (GraphBridge.unitDistanceSimpleGraph C) where
  toFun := fun v => v.1
  map_rel' := by
    intro a b h
    rcases h with h | h
    · exact
        (GraphBridge.unitDistanceSimpleGraph_adj C a.1 b.1).2
          (((canonicalGraph C).adj_iff_unitDistanceAdj a.1 b.1).1
            (unboundedFrontierEdgeSet_adj h))
    · exact
        (GraphBridge.unitDistanceSimpleGraph C).symm
          ((GraphBridge.unitDistanceSimpleGraph_adj C b.1 a.1).2
            (((canonicalGraph C).adj_iff_unitDistanceAdj b.1 a.1).1
              (unboundedFrontierEdgeSet_adj h)))

theorem unboundedFrontierCarrierGraphHom_injective
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    Function.Injective (unboundedFrontierCarrierGraphHom C inputs) := by
  intro a b h
  exact Subtype.ext h

theorem unboundedFrontierCarrierGraph_vertex_image_iff_frontier
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    forall v : Fin n,
      (canonicalGraph C).point v ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ↔
        Exists fun x :
          {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} =>
          (unboundedFrontierCarrierGraphHom C inputs) x = v := by
  intro v
  constructor
  · intro hv
    exact ⟨⟨v, mem_unboundedFrontierVertexSet_iff.2 hv⟩, rfl⟩
  · rintro ⟨x, hx⟩
    rw [← hx]
    exact mem_unboundedFrontierVertexSet_iff.1 x.2

/-! ### Degree-two bookkeeping for the concrete carrier -/

/-- Local finite-graph row saying that a concrete unbounded-frontier carrier
vertex has exactly two carrier neighbours.  This isolates the pure
finite-graph/cardinality step from the later geometric proof that the exterior
sector has two boundary darts. -/
structure UnboundedFrontierCarrierNeighborPairAt
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) where
  left : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}
  right : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}
  left_ne_right : left ≠ right
  neighbor_iff :
    forall b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      (unboundedFrontierCarrierGraph C inputs).Adj a b ↔
        b = left ∨ b = right

/-- The concrete carrier's neighbours are the two vertices in a supplied local
neighbour-pair row. -/
theorem unboundedFrontierCarrierGraph_neighborFinset_eq_pair
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    [DecidableRel (unboundedFrontierCarrierGraph C inputs).Adj]
    {a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (P : UnboundedFrontierCarrierNeighborPairAt inputs a) :
    (unboundedFrontierCarrierGraph C inputs).neighborFinset a =
      {P.left, P.right} := by
  classical
  ext b
  simp [SimpleGraph.mem_neighborFinset, P.neighbor_iff b]

/-- If every concrete unbounded-frontier carrier vertex has exactly the two
neighbours supplied by a local row, the carrier graph is two-regular. -/
theorem unboundedFrontierCarrierGraph_degree_two_of_neighborPairRows
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    [DecidableRel (unboundedFrontierCarrierGraph C inputs).Adj]
    (rows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierNeighborPairAt inputs a) :
    forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      @SimpleGraph.degree _
        (unboundedFrontierCarrierGraph C inputs) a
        ((unboundedFrontierCarrierGraph C inputs).neighborSetFintype a) =
          2 := by
  classical
  intro a
  let P := rows a
  rw [SimpleGraph.degree]
  have hfin :
      (unboundedFrontierCarrierGraph C inputs).neighborFinset a =
        {P.left, P.right} :=
    unboundedFrontierCarrierGraph_neighborFinset_eq_pair (C := C)
      (inputs := inputs) P
  rw [hfin]
  simp [P.left_ne_right]

/-! ### Dart-pair bookkeeping for local exterior sectors -/

/-- A carrier dart at an unbounded-frontier vertex.  This is the local shape
produced by the exterior-sector analysis: an outgoing unit dart whose head is
again on the exterior frontier and whose underlying ordered edge is selected by
the concrete exterior-boundary carrier. -/
structure UnboundedFrontierCarrierDartAt
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) where
  dart : UnitDistanceDart C
  tail_eq : dart.tail = a.1
  head_mem : dart.head ∈ unboundedFrontierVertexSet C inputs
  carrier_edge :
    (a.1, dart.head) ∈ unboundedFrontierEdgeSet C inputs ∨
      (dart.head, a.1) ∈ unboundedFrontierEdgeSet C inputs

namespace UnboundedFrontierCarrierDartAt

variable {C : _root_.UDConfig n}
variable {inputs : FinitePlanarOuterComponentInputs C}
variable {a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}

def headVertex (D : UnboundedFrontierCarrierDartAt inputs a) :
    {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
  ⟨D.dart.head, D.head_mem⟩

theorem adj (D : UnboundedFrontierCarrierDartAt inputs a) :
    (unboundedFrontierCarrierGraph C inputs).Adj a D.headVertex := by
  rcases D.carrier_edge with h | h
  · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge h
  · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm h

end UnboundedFrontierCarrierDartAt

/-- Local exterior-sector row saying the concrete boundary carrier has exactly
two incident carrier darts at this frontier vertex. -/
structure UnboundedFrontierCarrierDartPairAt
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) where
  left : UnboundedFrontierCarrierDartAt inputs a
  right : UnboundedFrontierCarrierDartAt inputs a
  heads_ne : left.dart.head ≠ right.dart.head
  only :
    forall b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      (unboundedFrontierCarrierGraph C inputs).Adj a b ->
        b.1 = left.dart.head ∨ b.1 = right.dart.head

/-- Build the local dart-pair row from two concrete selected frontier edges
incident to the same frontier vertex, plus the geometric row saying every
carrier neighbour is one of those two endpoints. -/
noncomputable def unboundedFrontierCarrierDartPairAt_of_incident_unboundedFrontierEdges
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    {l r : Fin n}
    (hl :
      (a.1, l) ∈ unboundedFrontierEdgeSet C inputs ∨
        (l, a.1) ∈ unboundedFrontierEdgeSet C inputs)
    (hr :
      (a.1, r) ∈ unboundedFrontierEdgeSet C inputs ∨
        (r, a.1) ∈ unboundedFrontierEdgeSet C inputs)
    (hlr : l ≠ r)
    (honly :
      forall b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        (unboundedFrontierCarrierGraph C inputs).Adj a b ->
          b.1 = l ∨ b.1 = r) :
    UnboundedFrontierCarrierDartPairAt inputs a := by
  let hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
    unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
  have hl_head : l ∈ unboundedFrontierVertexSet C inputs := by
    rcases hl with hl | hl
    · exact
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole hl).2
    · exact
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole hl).1
  have hr_head : r ∈ unboundedFrontierVertexSet C inputs := by
    rcases hr with hr | hr
    · exact
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole hr).2
    · exact
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole hr).1
  have hl_canonical : (canonicalGraph C).Adj a.1 l := by
    rcases hl with hl | hl
    · exact unboundedFrontierEdgeSet_adj hl
    · exact canonicalAdj_symm (unboundedFrontierEdgeSet_adj hl)
  have hr_canonical : (canonicalGraph C).Adj a.1 r := by
    rcases hr with hr | hr
    · exact unboundedFrontierEdgeSet_adj hr
    · exact canonicalAdj_symm (unboundedFrontierEdgeSet_adj hr)
  have hl_graph :
      (GraphBridge.unitDistanceSimpleGraph C).Adj a.1 l :=
    (GraphBridge.unitDistanceSimpleGraph_adj C a.1 l).2
      (((canonicalGraph C).adj_iff_unitDistanceAdj a.1 l).1 hl_canonical)
  have hr_graph :
      (GraphBridge.unitDistanceSimpleGraph C).Adj a.1 r :=
    (GraphBridge.unitDistanceSimpleGraph_adj C a.1 r).2
      (((canonicalGraph C).adj_iff_unitDistanceAdj a.1 r).1 hr_canonical)
  exact
    { left :=
        { dart := { tail := a.1, head := l, adj := hl_graph }
          tail_eq := rfl
          head_mem := hl_head
          carrier_edge := hl }
      right :=
        { dart := { tail := a.1, head := r, adj := hr_graph }
          tail_eq := rfl
          head_mem := hr_head
          carrier_edge := hr }
      heads_ne := hlr
      only := honly }

/-- Pointwise local-sector rows in the exact shape needed by the concrete
carrier dart-pair constructor: two selected incident unbounded-frontier edges,
distinct heads, and the proof that every concrete carrier neighbour is one of
those two heads. -/
structure UnboundedFrontierCarrierLocalSectorRowsAt
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) where
  left : Fin n
  right : Fin n
  left_edge :
    (a.1, left) ∈ unboundedFrontierEdgeSet C inputs ∨
      (left, a.1) ∈ unboundedFrontierEdgeSet C inputs
  right_edge :
    (a.1, right) ∈ unboundedFrontierEdgeSet C inputs ∨
      (right, a.1) ∈ unboundedFrontierEdgeSet C inputs
  heads_ne : left ≠ right
  only :
    forall b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      (unboundedFrontierCarrierGraph C inputs).Adj a b ->
        b.1 = left ∨ b.1 = right

/-- A local two-germ frontier containment row at a boundary vertex supplies the
pointwise local-sector rows for the concrete carrier. -/
noncomputable def unboundedFrontierCarrierLocalSectorRowsAt_of_boundary_vertex_local_frontier_germ_two
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    {k : Fin B.length}
    {a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (ha : a.1 = B.vertex k)
    (pred_edge :
      (B.vertex k, B.vertex (PlanarInterface.cyclicPred B.length_pos k)) ∈
          unboundedFrontierEdgeSet C inputs ∨
        (B.vertex (PlanarInterface.cyclicPred B.length_pos k), B.vertex k) ∈
          unboundedFrontierEdgeSet C inputs)
    (succ_edge :
      (B.vertex k, B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
          unboundedFrontierEdgeSet C inputs ∨
        (B.vertex (PlanarInterface.cyclicSucc B.length_pos k), B.vertex k) ∈
          unboundedFrontierEdgeSet C inputs)
    (hlocal :
      Exists fun ε : Real =>
        0 < ε ∧
          forall q : PlanarInterface.Point,
            q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) ε ->
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
              q ∈ vertexIncidentGermW3 C (B.vertex k)
                    (B.vertex (PlanarInterface.cyclicPred B.length_pos k)) ε ∨
                q ∈ vertexIncidentGermW3 C (B.vertex k)
                    (B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ε) :
    UnboundedFrontierCarrierLocalSectorRowsAt inputs a := by
  let pred := B.vertex (PlanarInterface.cyclicPred B.length_pos k)
  let succ := B.vertex (PlanarInterface.cyclicSucc B.length_pos k)
  have hpred_adj : (canonicalGraph C).Adj a.1 pred := by
    rcases pred_edge with h | h
    · simpa [pred, ha] using unboundedFrontierEdgeSet_adj h
    · simpa [pred, ha] using
        canonicalAdj_symm (unboundedFrontierEdgeSet_adj h)
  have hsucc_adj : (canonicalGraph C).Adj a.1 succ := by
    rcases succ_edge with h | h
    · simpa [succ, ha] using unboundedFrontierEdgeSet_adj h
    · simpa [succ, ha] using
        canonicalAdj_symm (unboundedFrontierEdgeSet_adj h)
  have hlocal' :
      Exists fun ε : Real =>
        0 < ε ∧
          forall q : PlanarInterface.Point,
            q ∈ Metric.ball ((canonicalGraph C).point a.1) ε ->
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
              q ∈ vertexIncidentGermW3 C a.1 pred ε ∨
                q ∈ vertexIncidentGermW3 C a.1 succ ε := by
    simpa [pred, succ, ha] using hlocal
  refine
    { left := pred
      right := succ
      left_edge := ?_
      right_edge := ?_
      heads_ne := ?_
      only := ?_ }
  · rcases pred_edge with h | h
    · left
      simpa [pred, ha] using h
    · right
      simpa [pred, ha] using h
  · rcases succ_edge with h | h
    · left
      simpa [succ, ha] using h
    · right
      simpa [succ, ha] using h
  · intro h
    have hidx :
        PlanarInterface.cyclicPred B.length_pos k =
          PlanarInterface.cyclicSucc B.length_pos k := by
      exact B.simple (by simpa [pred, succ] using h)
    exact
      (PlanarInterface.cyclicPred_ne_cyclicSucc_of_three_le
        B.length_pos B.length_ge_three k) hidx
  · exact
      unboundedFrontierCarrierGraph_only_of_local_frontier_germ_two
        hpred_adj hsucc_adj hlocal'

/-- Pointwise local-sector source from local vertex-star isolation and geometric
angular order, with the two selected exterior boundary edges supplied as actual
unbounded-frontier edges. -/
noncomputable def unboundedFrontierCarrierLocalSectorRowsAt_of_vertex_star_isolation_angular_order
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    {k : Fin B.length}
    {a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (ha : a.1 = B.vertex k)
    (pred_edge :
      (B.vertex k, B.vertex (PlanarInterface.cyclicPred B.length_pos k)) ∈
          unboundedFrontierEdgeSet C inputs ∨
        (B.vertex (PlanarInterface.cyclicPred B.length_pos k), B.vertex k) ∈
          unboundedFrontierEdgeSet C inputs)
    (succ_edge :
      (B.vertex k, B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
          unboundedFrontierEdgeSet C inputs ∨
        (B.vertex (PlanarInterface.cyclicSucc B.length_pos k), B.vertex k) ∈
          unboundedFrontierEdgeSet C inputs)
    (bad_germ_between :
      forall (ε : Real) (q : PlanarInterface.Point) (x : Fin n),
        q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) ε ->
          q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
            (canonicalGraph C).Adj (B.vertex k) x ->
              q ∈ vertexIncidentGermW3 C (B.vertex k) x ε ->
                q ≠ (canonicalGraph C).point (B.vertex k) ->
                x ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
                  x ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
                    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
                      C B k x)
    (no_between :
      forall x : Fin n,
        GraphBridge.UnitDistanceAdj C (B.vertex k) x ->
          x ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
            x ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
              ¬
                _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
                  C B k x) :
    UnboundedFrontierCarrierLocalSectorRowsAt inputs a :=
  unboundedFrontierCarrierLocalSectorRowsAt_of_boundary_vertex_local_frontier_germ_two
    ha pred_edge succ_edge
    (exists_local_frontier_germ_two_of_vertex_star_isolation_and_angular_no_between
      k bad_germ_between no_between)

/-- Point-sector version of the pointwise local-sector source.

The local exterior-sector row is the honest noncenter point-ray statement; the
center case is discharged inside
`exists_local_frontier_germ_two_of_vertex_star_isolation_local_exterior_sector`.
-/
noncomputable def unboundedFrontierCarrierLocalSectorRowsAt_of_vertex_star_isolation_local_exterior_sector
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    {k : Fin B.length}
    {a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (ha : a.1 = B.vertex k)
