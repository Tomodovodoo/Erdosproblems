    forall {n : Nat} (C : _root_.UDConfig n),
      (inputs : FinitePlanarOuterComponentInputs C) ->
        UnboundedExteriorFrontierCycleRows C inputs :=
  unboundedExteriorFrontierCycleRows_of_cyclicCoverageDartPairRows
    unboundedFrontierCarrierCyclicCoverageRows_of_exterior_boundary
    unboundedFrontierCarrierDartPairRows_of_exterior_sectors

/-- The compact concrete-carrier source handoff for S2.  A genuine exterior
boundary proof can supply cyclic coverage of the selected carrier together
with local sector rows at every selected carrier vertex; these are exactly the
two rows consumed by the connectedness and degree-two reducers. -/
noncomputable def unboundedExteriorFrontierCycleRows_of_cyclicCoverageLocalSectorRows
    (rows :
      forall {n : Nat} (C : _root_.UDConfig n)
        (inputs : FinitePlanarOuterComponentInputs C),
          Nonempty
            (UnboundedFrontierCarrierCyclicCoverageRows C inputs ×
              (forall a :
                {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
                  UnboundedFrontierCarrierLocalSectorRowsAt inputs a))) :
    forall {n : Nat} (C : _root_.UDConfig n),
      (inputs : FinitePlanarOuterComponentInputs C) ->
        UnboundedExteriorFrontierCycleRows C inputs :=
  unboundedExteriorFrontierCycleRows_of_cyclicCoverageDartPairRows
    (fun C inputs => (Classical.choice (rows C inputs)).1)
    (fun C inputs =>
      unboundedFrontierCarrierDartPairRows_of_localSectorRows inputs
        (Classical.choice (rows C inputs)).2)

/-- Pointwise version of the compact concrete-carrier source handoff. -/
noncomputable def unboundedExteriorFrontierCycleRows_of_pointwise_cyclicCoverageLocalSectorRows
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
