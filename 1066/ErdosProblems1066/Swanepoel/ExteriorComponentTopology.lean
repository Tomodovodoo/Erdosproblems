/-- A candidate exterior set lies in the complement of the embedded drawing. -/
structure ExteriorComponentRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) where
  exterior : Set PlanarInterface.Point
  exterior_subset_drawingComplement :
    exterior ⊆ drawingComplement C
  exterior_open : IsOpen exterior

/-- The whole complement of the finite drawing is always an open exterior
candidate.  The remaining S2 theorem must select its unbounded component and
identify the simple unit-distance cycle on that component's frontier. -/
def drawingComplementRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    ExteriorComponentRows C inputs where
  exterior := drawingComplement C
  exterior_subset_drawingComplement := fun _ hp => hp
  exterior_open := drawingComplement_open C

/-- A component-level exterior candidate obtained by choosing a base point in
the drawing complement.  The true S2 proof must choose the unbounded such
component and identify its frontier cycle. -/
structure ExteriorConnectedComponentRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) where
  base : PlanarInterface.Point
  base_mem_drawingComplement : base ∈ drawingComplement C

namespace ExteriorConnectedComponentRows

variable {C : _root_.UDConfig n}
variable {inputs : FinitePlanarOuterComponentInputs C}

/-- The selected connected component of the drawing complement. -/
def exterior (E : ExteriorConnectedComponentRows C inputs) :
    Set PlanarInterface.Point :=
  connectedComponentIn (drawingComplement C) E.base

theorem exterior_subset_drawingComplement
    (E : ExteriorConnectedComponentRows C inputs) :
    E.exterior ⊆ drawingComplement C :=
  connectedComponentIn_subset (drawingComplement C) E.base

theorem exterior_open
    (E : ExteriorConnectedComponentRows C inputs) :
    IsOpen E.exterior :=
  (drawingComplement_open C).connectedComponentIn

theorem base_mem_exterior
    (E : ExteriorConnectedComponentRows C inputs) :
    E.base ∈ E.exterior :=
  mem_connectedComponentIn E.base_mem_drawingComplement

/-- A selected complement component is preconnected by construction. -/
theorem exterior_preconnected
    (E : ExteriorConnectedComponentRows C inputs) :
    IsPreconnected E.exterior :=
  isPreconnected_connectedComponentIn

/-- A selected complement component is connected when its base point lies in
the drawing complement. -/
theorem exterior_connected
    (E : ExteriorConnectedComponentRows C inputs) :
    IsConnected E.exterior :=
  isConnected_connectedComponentIn_iff.mpr E.base_mem_drawingComplement

/-- The frontier of a selected complement component is carried by the embedded
unit-edge drawing.  The remaining S2 theorem must identify which drawing
vertices on this frontier form the outer cycle. -/
theorem frontier_subset_embeddedEdgeSet
    (E : ExteriorConnectedComponentRows C inputs) :
    frontier E.exterior ⊆ embeddedEdgeSet C := by
  simpa [ExteriorConnectedComponentRows.exterior] using
    frontier_connectedComponentIn_drawingComplement_subset_embeddedEdgeSet
      C E.base

/-- A point on a selected complement component's frontier lies on some
canonical unit-edge segment.  The remaining S2 proof must show which of these
frontier-carried edge pieces form the unbounded exterior boundary cycle. -/
theorem exists_edge_segment_of_mem_frontier
    (E : ExteriorConnectedComponentRows C inputs)
    {p : PlanarInterface.Point}
    (hp : p ∈ frontier E.exterior) :
    Exists fun i : Fin n =>
      Exists fun j : Fin n =>
        (canonicalGraph C).Adj i j /\
          p ∈ closedSegment
            ((canonicalGraph C).point i)
            ((canonicalGraph C).point j) := by
  exact
    exists_edge_segment_of_mem_frontier_connectedComponentIn_drawingComplement
      (by simpa [ExteriorConnectedComponentRows.exterior] using hp)

theorem frontier_graph_vertex_mem_embeddedEdgeSet
    (E : ExteriorConnectedComponentRows C inputs)
    {v : Fin n}
    (hv : (canonicalGraph C).point v ∈ frontier E.exterior) :
    (canonicalGraph C).point v ∈ embeddedEdgeSet C :=
  E.frontier_subset_embeddedEdgeSet hv

theorem frontier_graph_vertex_incident
    (E : ExteriorConnectedComponentRows C inputs)
    {v : Fin n}
    (hv : (canonicalGraph C).point v ∈ frontier E.exterior) :
    Exists fun w : Fin n => (canonicalGraph C).Adj v w := by
  exact
    frontier_connectedComponentIn_drawingComplement_graph_vertex_incident
      (C := C) (base := E.base)
      (by simpa [ExteriorConnectedComponentRows.exterior] using hv)

theorem frontier_not_mem_exterior
    (E : ExteriorConnectedComponentRows C inputs)
    {p : PlanarInterface.Point}
    (hp : p ∈ frontier E.exterior) :
    p ∉ E.exterior := by
  have hp_not_complement : p ∉ drawingComplement C :=
    not_mem_open_of_mem_frontier_connectedComponentIn
      (drawingComplement_open C)
      (by simpa [ExteriorConnectedComponentRows.exterior] using hp)
  intro hpE
  exact hp_not_complement (E.exterior_subset_drawingComplement hpE)

theorem graph_vertex_not_mem_exterior
    (E : ExteriorConnectedComponentRows C inputs) :
    forall v : Fin n, (canonicalGraph C).point v ∉ E.exterior := by
  intro v hv
  have hnot :
      (canonicalGraph C).point v ∉ embeddedEdgeSet C := by
    simpa [drawingComplement] using E.exterior_subset_drawingComplement hv
  exact hnot (vertex_mem_embeddedEdgeSet_of_inputs inputs v)

/-- Forget a connected-component exterior candidate to the weaker exterior-row
interface consumed by the current S2 reducer. -/
def toExteriorComponentRows
    (E : ExteriorConnectedComponentRows C inputs) :
    ExteriorComponentRows C inputs where
  exterior := E.exterior
  exterior_subset_drawingComplement := E.exterior_subset_drawingComplement
  exterior_open := E.exterior_open

end ExteriorConnectedComponentRows

/-- A canonical complement-component candidate obtained from an arbitrary point
outside the compact embedded drawing.  The remaining planar theorem must show
which connected component is the unbounded exterior component and identify its
frontier cycle. -/
noncomputable def defaultExteriorConnectedComponentRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    ExteriorConnectedComponentRows C inputs where
  base := Classical.choose (drawingComplement_nonempty C)
  base_mem_drawingComplement := Classical.choose_spec (drawingComplement_nonempty C)

noncomputable def defaultExteriorComponentRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    ExteriorComponentRows C inputs :=
  (defaultExteriorConnectedComponentRows C inputs).toExteriorComponentRows

/-- A selected connected component of the drawing complement that is certified
to be unbounded.  This is the component-level exterior object needed before
the final plane-graph theorem identifies the boundary cycle on its frontier. -/
structure ExteriorUnboundedComponentRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) where
  component : ExteriorConnectedComponentRows C inputs
  exterior_unbounded : ¬ Bornology.IsBounded component.exterior

namespace ExteriorUnboundedComponentRows

variable {C : _root_.UDConfig n}
variable {inputs : FinitePlanarOuterComponentInputs C}

def exterior (E : ExteriorUnboundedComponentRows C inputs) :
    Set PlanarInterface.Point :=
  E.component.exterior

theorem exterior_subset_drawingComplement
    (E : ExteriorUnboundedComponentRows C inputs) :
    E.exterior ⊆ drawingComplement C :=
  E.component.exterior_subset_drawingComplement

theorem exterior_open
    (E : ExteriorUnboundedComponentRows C inputs) :
    IsOpen E.exterior :=
  E.component.exterior_open

theorem frontier_subset_embeddedEdgeSet
    (E : ExteriorUnboundedComponentRows C inputs) :
    frontier E.exterior ⊆ embeddedEdgeSet C :=
  E.component.frontier_subset_embeddedEdgeSet

/-- A point on the unbounded complement component's frontier lies on a
canonical unit-edge segment. -/
theorem exists_edge_segment_of_mem_frontier
    (E : ExteriorUnboundedComponentRows C inputs)
    {p : PlanarInterface.Point}
    (hp : p ∈ frontier E.exterior) :
    Exists fun i : Fin n =>
      Exists fun j : Fin n =>
        (canonicalGraph C).Adj i j /\
          p ∈ closedSegment
            ((canonicalGraph C).point i)
            ((canonicalGraph C).point j) :=
  E.component.exists_edge_segment_of_mem_frontier hp

theorem frontier_graph_vertex_mem_embeddedEdgeSet
    (E : ExteriorUnboundedComponentRows C inputs)
    {v : Fin n}
    (hv : (canonicalGraph C).point v ∈ frontier E.exterior) :
    (canonicalGraph C).point v ∈ embeddedEdgeSet C :=
  E.frontier_subset_embeddedEdgeSet hv

theorem frontier_graph_vertex_incident
    (E : ExteriorUnboundedComponentRows C inputs)
    {v : Fin n}
    (hv : (canonicalGraph C).point v ∈ frontier E.exterior) :
    Exists fun w : Fin n => (canonicalGraph C).Adj v w := by
  exact
    graph_vertex_mem_embeddedEdgeSet_iff_exists_adj.1
      (E.frontier_graph_vertex_mem_embeddedEdgeSet hv)

theorem frontier_not_mem_exterior
    (E : ExteriorUnboundedComponentRows C inputs)
    {p : PlanarInterface.Point}
    (hp : p ∈ frontier E.exterior) :
    p ∉ E.exterior :=
  E.component.frontier_not_mem_exterior hp

theorem graph_vertex_not_mem_exterior
    (E : ExteriorUnboundedComponentRows C inputs) :
    forall v : Fin n, (canonicalGraph C).point v ∉ E.exterior :=
  E.component.graph_vertex_not_mem_exterior

def toExteriorComponentRows
    (E : ExteriorUnboundedComponentRows C inputs) :
    ExteriorComponentRows C inputs :=
  E.component.toExteriorComponentRows

end ExteriorUnboundedComponentRows

/-- The finite embedded drawing has a concrete unbounded complement component:
take a rightward x-axis ray outside a compact ball containing the drawing, and
then take the complement component containing that ray. -/
noncomputable def unboundedExteriorComponentRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    ExteriorUnboundedComponentRows C inputs := by
  classical
  let R : Real := Classical.choose (exists_xAxisRay_subset_drawingComplement C)
  have hR_spec : 0 <= R /\ xAxisRay R ⊆ drawingComplement C :=
    Classical.choose_spec (exists_xAxisRay_subset_drawingComplement C)
  have hR_subset : xAxisRay R ⊆ drawingComplement C := hR_spec.2
  let base : PlanarInterface.Point := (R + 1, 0)
  have hbase_ray : base ∈ xAxisRay R := by
    exact ⟨R + 1, by linarith, rfl⟩
  have hbase : base ∈ drawingComplement C := hR_subset hbase_ray
  let component : ExteriorConnectedComponentRows C inputs :=
    { base := base
      base_mem_drawingComplement := hbase }
  refine
    { component := component
      exterior_unbounded := ?_ }
  intro hbounded_component
  have hray_subset_component : xAxisRay R ⊆ component.exterior :=
    (xAxisRay_preconnected R).subset_connectedComponentIn hbase_ray hR_subset
  exact xAxisRay_unbounded R (hbounded_component.subset hray_subset_component)

theorem unboundedExteriorComponent_not_isBounded
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    ¬ Bornology.IsBounded (unboundedExteriorComponentRows C inputs).exterior :=
  (unboundedExteriorComponentRows C inputs).exterior_unbounded

/-- The concrete unbounded exterior component contains the rightward x-axis
ray used in its construction.  This is the seed-at-infinity row for the later
exterior face-orbit construction. -/
theorem exists_xAxisRay_subset_unboundedExteriorComponent
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    Exists fun R : Real =>
      0 <= R /\
        xAxisRay R ⊆ (unboundedExteriorComponentRows C inputs).exterior := by
  classical
  let R : Real := Classical.choose (exists_xAxisRay_subset_drawingComplement C)
  have hR_spec : 0 <= R /\ xAxisRay R ⊆ drawingComplement C :=
    Classical.choose_spec (exists_xAxisRay_subset_drawingComplement C)
  refine ⟨R, hR_spec.1, ?_⟩
  intro p hp
  change
    p ∈
      connectedComponentIn (drawingComplement C)
        ((R + 1, 0) : PlanarInterface.Point)
  exact
    (xAxisRay_preconnected R).subset_connectedComponentIn
      (xAxisRayBase_mem R) hR_spec.2 hp

/-- The base point of the rightward x-axis ray belongs to the concrete
unbounded exterior component selected by `unboundedExteriorComponentRows`. -/
theorem exists_xAxisRayBase_mem_unboundedExteriorComponent
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    Exists fun R : Real =>
      0 <= R /\
        xAxisRayBase R ∈ (unboundedExteriorComponentRows C inputs).exterior := by
  rcases exists_xAxisRay_subset_unboundedExteriorComponent C inputs with
    ⟨R, hR_nonneg, hsubset⟩
  exact ⟨R, hR_nonneg, hsubset (xAxisRayBase_mem R)⟩

/-- A preconnected local patch in the drawing complement that touches the
chosen unbounded exterior component is entirely contained in that exterior
component.  This is the component-propagation step needed by the local
open-edge side proof: once a same-side half-neighborhood contains one exterior
point, no additional global exterior choice is required. -/
theorem preconnected_subset_unboundedExterior_of_subset_drawingComplement_of_mem
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {S : Set PlanarInterface.Point} {y : PlanarInterface.Point}
    (hS_preconnected : IsPreconnected S)
    (hS_subset_drawingComplement : S ⊆ drawingComplement C)
    (hyS : y ∈ S)
    (hyExterior : y ∈ (unboundedExteriorComponentRows C inputs).exterior) :
    S ⊆ (unboundedExteriorComponentRows C inputs).exterior := by
  let E := (unboundedExteriorComponentRows C inputs).component
  have hS_component_y :
      S ⊆ connectedComponentIn (drawingComplement C) y :=
    hS_preconnected.subset_connectedComponentIn hyS
      hS_subset_drawingComplement
  have hcomponent_eq :
      connectedComponentIn (drawingComplement C) E.base =
        connectedComponentIn (drawingComplement C) y := by
    exact
      connectedComponentIn_eq
        (by
          simpa [ExteriorUnboundedComponentRows.exterior,
            ExteriorConnectedComponentRows.exterior, E] using hyExterior)
  intro z hzS
  have hz_component_y :
      z ∈ connectedComponentIn (drawingComplement C) y :=
    hS_component_y hzS
  simpa [ExteriorUnboundedComponentRows.exterior,
    ExteriorConnectedComponentRows.exterior, E, hcomponent_eq] using
    hz_component_y

/-- Ball-local version of
`preconnected_subset_unboundedExterior_of_subset_drawingComplement_of_mem`.
It packages the exact containment shape consumed by the local exterior-side
patch reducers. -/
theorem preconnected_subset_unboundedExterior_inter_ball_of_subset_drawingComplement_inter_ball_of_mem
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {S : Set PlanarInterface.Point} {y z : PlanarInterface.Point}
    {r : Real}
    (hS_preconnected : IsPreconnected S)
    (hS_subset_drawingComplement :
      S ⊆ drawingComplement C)
    (hS_subset_ball : S ⊆ Metric.ball z r)
    (hyS : y ∈ S)
    (hyExterior : y ∈ (unboundedExteriorComponentRows C inputs).exterior) :
    S ⊆ (unboundedExteriorComponentRows C inputs).exterior ∩
      Metric.ball z r := by
  intro w hwS
  exact
    ⟨preconnected_subset_unboundedExterior_of_subset_drawingComplement_of_mem
        (C := C) (inputs := inputs)
        hS_preconnected hS_subset_drawingComplement hyS hyExterior hwS,
      hS_subset_ball hwS⟩

theorem unboundedExteriorComponent_frontier_subset_embeddedEdgeSet
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    frontier (unboundedExteriorComponentRows C inputs).exterior ⊆
      embeddedEdgeSet C :=
  (unboundedExteriorComponentRows C inputs).frontier_subset_embeddedEdgeSet

/-- Any point on the canonical unbounded exterior frontier lies on a concrete
canonical unit-edge segment. -/
theorem exists_edge_segment_of_mem_unboundedExterior_frontier
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C)
    {p : PlanarInterface.Point}
    (hp :
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    Exists fun i : Fin n =>
      Exists fun j : Fin n =>
        (canonicalGraph C).Adj i j /\
          p ∈ closedSegment
            ((canonicalGraph C).point i)
            ((canonicalGraph C).point j) :=
  (unboundedExteriorComponentRows C inputs).exists_edge_segment_of_mem_frontier hp

theorem unboundedExterior_frontier_vertex_incident
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C)
    {v : Fin n}
    (hv :
      (canonicalGraph C).point v ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior) :
    Exists fun w : Fin n => (canonicalGraph C).Adj v w := by
  exact
    _root_.ErdosProblems1066.Swanepoel.FinitePlaneDrawing.graph_vertex_mem_embeddedEdgeSet_iff_exists_adj.1
      ((unboundedExteriorComponentRows C inputs).frontier_subset_embeddedEdgeSet hv)

/-- The unbounded exterior component has a nonempty frontier: it is unbounded,
while graph vertices from the nonempty connected graph lie outside it. -/
theorem unboundedExterior_frontier_nonempty
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    (frontier (unboundedExteriorComponentRows C inputs).exterior).Nonempty := by
  rw [nonempty_frontier_iff]
  constructor
  · exact Bornology.nonempty_of_not_isBounded
      (unboundedExteriorComponent_not_isBounded C inputs)
  · intro h_univ
    obtain ⟨v⟩ := inputs.vertex_nonempty
    exact ((unboundedExteriorComponentRows C inputs).graph_vertex_not_mem_exterior v) (by
      rw [h_univ]
      exact Set.mem_univ _)

/-- A point on the unbounded exterior frontier can be chosen either at a graph
vertex or in the relative interior of a canonical unit edge.  This is the
first compactness/topology seed for the exterior carrier construction. -/
theorem exists_unboundedExterior_frontier_vertex_or_edgeInterior
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) :
    Exists fun p : PlanarInterface.Point =>
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior /\
        ((Exists fun v : Fin n => p = (canonicalGraph C).point v) ∨
          Exists fun i : Fin n =>
            Exists fun j : Fin n =>
              (canonicalGraph C).Adj i j /\
                PlanarInterface.InOpenSegment p
                  ((canonicalGraph C).point i)
                  ((canonicalGraph C).point j)) := by
  rcases unboundedExterior_frontier_nonempty C inputs with ⟨p, hp⟩
  rcases exists_edge_segment_of_mem_unboundedExterior_frontier C inputs hp with
    ⟨i, j, hij, hpseg⟩
  refine ⟨p, hp, ?_⟩
  rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hpseg with
      hleft | hright | hinside
  · exact Or.inl ⟨i, hleft⟩
  · exact Or.inl ⟨j, hright⟩
  · exact Or.inr ⟨i, j, hij, hinside⟩

/-- Pointwise frontier classification: every point on the unbounded exterior
frontier is either a graph vertex or lies in the relative interior of an
ordered canonical edge. -/
theorem unboundedExterior_frontier_point_vertex_or_ordered_edgeInterior
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    {p : PlanarInterface.Point}
    (hp :
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    (Exists fun v : Fin n => p = (canonicalGraph C).point v) ∨
      Exists fun e : PlanarInterface.Edge n =>
        e ∈ (canonicalGraph C).edgeSet ∧
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point e.1)
            ((canonicalGraph C).point e.2) := by
  rcases exists_edge_segment_of_mem_unboundedExterior_frontier C inputs hp with
    ⟨i, j, hij, hpseg⟩
  rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hpseg with
      hleft | hright | hinside
  · exact Or.inl ⟨i, hleft⟩
  · exact Or.inl ⟨j, hright⟩
  · rcases hij with hij_edge | hji_edge
    · exact Or.inr ⟨(i, j), hij_edge, hinside⟩
    · exact Or.inr ⟨(j, i), hji_edge, inOpenSegment_symm hinside⟩

/-- A named seed point on the unbounded exterior frontier, preserving whether
the selected point is a graph vertex or lies in the relative interior of a
canonical unit edge. -/
structure UnboundedExteriorFrontierSeed
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) where
  point : PlanarInterface.Point
  point_mem_frontier :
    point ∈ frontier (unboundedExteriorComponentRows C inputs).exterior
  vertex_or_edgeInterior :
    (Exists fun v : Fin n => point = (canonicalGraph C).point v) ∨
      Exists fun i : Fin n =>
        Exists fun j : Fin n =>
          (canonicalGraph C).Adj i j /\
            PlanarInterface.InOpenSegment point
              ((canonicalGraph C).point i)
              ((canonicalGraph C).point j)

/-- Nonempty packaged form of
`exists_unboundedExterior_frontier_vertex_or_edgeInterior`. -/
theorem unboundedExteriorFrontierSeed_nonempty
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) :
    Nonempty (UnboundedExteriorFrontierSeed inputs) := by
  rcases exists_unboundedExterior_frontier_vertex_or_edgeInterior inputs with
    ⟨p, hp, hp_kind⟩
  exact
    ⟨{ point := p
       point_mem_frontier := hp
       vertex_or_edgeInterior := hp_kind }⟩

/-- Local vertex-star isolation specialized to points of the unbounded
exterior frontier: sufficiently near a graph vertex, every frontier point is
carried by a canonical edge incident to that vertex. -/
theorem exists_ball_forall_unboundedExterior_frontier_mem_incident_closedSegment_of_vertex
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C)
    (v : Fin n) :
    Exists fun ε : Real =>
      0 < ε ∧
        forall q : PlanarInterface.Point,
          q ∈ Metric.ball ((canonicalGraph C).point v) ε ->
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
              Exists fun w : Fin n =>
                (canonicalGraph C).Adj v w ∧
                  q ∈ closedSegment
                    ((canonicalGraph C).point v)
                    ((canonicalGraph C).point w) := by
  let E := (unboundedExteriorComponentRows C inputs).component
  rcases
      exists_ball_inter_frontier_connectedComponentIn_drawingComplement_subset_incident_closedSegment
        (C := C) E.base v with
    ⟨ε, hεpos, hsubset⟩
  refine ⟨ε, hεpos, ?_⟩
  intro q hqball hqfrontier
  exact
    hsubset
      ⟨hqball,
        by
          simpa [ExteriorUnboundedComponentRows.exterior,
            ExteriorConnectedComponentRows.exterior, E] using hqfrontier⟩

/-- Pointed local frontier isolation at a graph vertex: after shrinking around
`v`, every non-vertex frontier point near `v` lies in the relative interior of
an incident unit-edge segment. -/
theorem exists_ball_forall_unboundedExterior_frontier_mem_incident_inOpenSegment_of_vertex_ne
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C)
    (v : Fin n) :
    Exists fun ε : Real =>
      0 < ε ∧
        forall q : PlanarInterface.Point,
          q ∈ Metric.ball ((canonicalGraph C).point v) ε ->
            q ≠ (canonicalGraph C).point v ->
              q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
                Exists fun w : Fin n =>
                  (canonicalGraph C).Adj v w ∧
                    PlanarInterface.InOpenSegment q
                      ((canonicalGraph C).point v)
                      ((canonicalGraph C).point w) := by
  rcases
      exists_ball_forall_unboundedExterior_frontier_mem_incident_closedSegment_of_vertex
        C inputs v with
    ⟨δ, hδpos, hclosed⟩
  rcases
      _root_.ErdosProblems1066.Swanepoel.FinitePlaneDrawing.exists_ball_forall_graph_vertex_eq_of_mem_ball
        (C := C) v with
    ⟨η, hηpos, hvertex⟩
  refine ⟨min δ η, lt_min hδpos hηpos, ?_⟩
  intro q hqball hq_ne hqfrontier
  have hqballδ : q ∈ Metric.ball ((canonicalGraph C).point v) δ := by
    have hdist :
        dist q ((canonicalGraph C).point v) < min δ η := by
      simpa [Metric.mem_ball] using hqball
    exact (Metric.mem_ball).2 (lt_of_lt_of_le hdist (min_le_left δ η))
  have hqballη : q ∈ Metric.ball ((canonicalGraph C).point v) η := by
    have hdist :
        dist q ((canonicalGraph C).point v) < min δ η := by
      simpa [Metric.mem_ball] using hqball
    exact (Metric.mem_ball).2 (lt_of_lt_of_le hdist (min_le_right δ η))
  rcases hclosed q hqballδ hqfrontier with ⟨w, hvw, hqseg⟩
  rcases
      _root_.ErdosProblems1066.Swanepoel.FinitePlaneDrawing.mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment
        hqseg with hleft | hright | hinside
  · exact False.elim (hq_ne hleft)
  · have hw_eq : w = v := by
      exact hvertex w (by simpa [hright] using hqballη)
    have hvv : (canonicalGraph C).Adj v v := by
      simpa [hw_eq] using hvw
    exact False.elim
      (GraphBridge.unitDistanceAdj_loopless C v
        (((canonicalGraph C).adj_iff_unitDistanceAdj v v).1 hvv))
  · exact ⟨w, hvw, hinside⟩

/-- Germ-level form of local vertex-star isolation for the unbounded exterior
frontier.  Near a graph vertex, every exterior-frontier point lies on one of
the incident unit-edge germs from that vertex. -/
theorem exists_ball_forall_unboundedExterior_frontier_mem_vertexIncidentGermW3
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C)
    (v : Fin n) :
    Exists fun ε : Real =>
      0 < ε ∧
        forall q : PlanarInterface.Point,
          q ∈ Metric.ball ((canonicalGraph C).point v) ε ->
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
              Exists fun w : Fin n =>
                (canonicalGraph C).Adj v w ∧
                  q ∈ vertexIncidentGermW3 C v w ε := by
  rcases
      exists_ball_forall_mem_vertexIncidentGermW3
        (C := C) v with
    ⟨ε, hεpos, hlocal⟩
  refine ⟨ε, hεpos, ?_⟩
  intro q hqball hqfrontier
  exact hlocal q hqball
    ((unboundedExteriorComponentRows C inputs).frontier_subset_embeddedEdgeSet
      hqfrontier)

/-- The exterior component of the drawing complement contains no graph vertex. -/
theorem graph_vertex_not_mem_exterior
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (E : ExteriorComponentRows C inputs) :
    forall v : Fin n, (canonicalGraph C).point v ∉ E.exterior := by
  intro v hv
  have hnot :
      (canonicalGraph C).point v ∉ embeddedEdgeSet C := by
    simpa [drawingComplement] using E.exterior_subset_drawingComplement hv
  exact hnot (vertex_mem_embeddedEdgeSet_of_inputs inputs v)

theorem graph_vertex_mem_closure_exterior_compl
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (E : ExteriorComponentRows C inputs) :
    forall v : Fin n,
      (canonicalGraph C).point v ∈ closure E.exteriorᶜ := by
  intro v
  exact
    mem_closure_compl_of_not_mem
      (graph_vertex_not_mem_exterior E v)

theorem graph_vertex_not_mem_unboundedExterior
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) :
    forall v : Fin n,
      (canonicalGraph C).point v ∉
        (unboundedExteriorComponentRows C inputs).exterior :=
  (unboundedExteriorComponentRows C inputs).graph_vertex_not_mem_exterior

theorem graph_vertex_mem_closure_unboundedExterior_compl
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) :
    forall v : Fin n,
      (canonicalGraph C).point v ∈
        closure (unboundedExteriorComponentRows C inputs).exteriorᶜ := by
  intro v
  exact
    mem_closure_compl_of_not_mem
      (graph_vertex_not_mem_unboundedExterior inputs v)

theorem graph_vertex_mem_unboundedExterior_frontier_iff_mem_closure
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (v : Fin n) :
    (canonicalGraph C).point v ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior ↔
      (canonicalGraph C).point v ∈
        closure (unboundedExteriorComponentRows C inputs).exterior := by
  rw [(unboundedExteriorComponentRows C inputs).exterior_open.frontier_eq]
  constructor
  · exact fun h => h.1
  · intro hv
    exact ⟨hv, graph_vertex_not_mem_unboundedExterior inputs v⟩

/-! ## Concrete unbounded-frontier carrier sets -/

/-- The finite set of graph vertices whose points lie on the unbounded
component frontier.  This is only a vertex carrier; the actual S2 boundary
edge graph must still use boundary-carrier edges, not the full induced graph
on this set. -/
noncomputable def unboundedFrontierVertexSet
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    Finset (Fin n) := by
  classical
  exact
    Finset.univ.filter
      (fun v : Fin n =>
        (canonicalGraph C).point v ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior)

theorem mem_unboundedFrontierVertexSet_iff
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {v : Fin n} :
    v ∈ unboundedFrontierVertexSet C inputs ↔
      (canonicalGraph C).point v ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior := by
  classical
  simp [unboundedFrontierVertexSet]

/-- The finite planar S2 input has at least two ambient vertices.

This is graph-side bookkeeping from the supplied simple unit-distance cycle:
two distinct positions on the cycle give two distinct vertices of `Fin n`. -/
theorem nontrivial_vertices_of_finitePlanarOuterComponentInputs
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) :
    Nontrivial (Fin n) := by
  rcases inputs.hasUnitDistanceCycle with ⟨B⟩
  let k0 : Fin B.length := ⟨0, B.length_pos⟩
  let k1 : Fin B.length :=
    ⟨1, Nat.lt_of_lt_of_le (by decide : 1 < 3) B.length_ge_three⟩
  have hk : k0 ≠ k1 := by
    intro h
    have hval : (k0 : Fin B.length).val = k1.val := congrArg Fin.val h
    norm_num [k0, k1] at hval
  have hv : B.vertex k0 ≠ B.vertex k1 := by
    intro h
    exact hk (B.simple h)
  exact ⟨⟨B.vertex k0, B.vertex k1, hv⟩⟩

/-- Every graph vertex has a unit-distance neighbour under the finite planar
S2 inputs.  This is only a graph-side no-isolated-vertex fact; it does not
claim the neighbour is selected on the unbounded exterior frontier. -/
theorem exists_unitDistanceSimpleGraph_adjacent_of_finitePlanarOuterComponentInputs
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (v : Fin n) :
    Exists fun w : Fin n =>
      (GraphBridge.unitDistanceSimpleGraph C).Adj v w := by
  letI : Nontrivial (Fin n) :=
    nontrivial_vertices_of_finitePlanarOuterComponentInputs
      (C := C) inputs
  exact inputs.preconnected.exists_adj_of_nontrivial v

/-- The finite planar S2 input has at least three ambient vertices.

This is again pure graph-side bookkeeping from the supplied simple
unit-distance cycle: its injective vertex map embeds a length-at-least-three
finite type into `Fin n`. -/
theorem three_le_vertices_of_finitePlanarOuterComponentInputs
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) :
    3 <= n := by
  rcases inputs.hasUnitDistanceCycle with ⟨B⟩
  have hcard :
      Fintype.card (Fin B.length) <= Fintype.card (Fin n) :=
    Fintype.card_le_of_injective B.vertex B.simple
  have hle : B.length <= n := by
    simpa only [Fintype.card_fin] using hcard
  exact Nat.le_trans (JordanBoundaryConcrete.UnitDistanceCycleBoundary.length_ge_three B) hle

/-- If a vertex has a unique unit-distance neighbour and there is at least one
other vertex, that unique neighbour is a cut vertex.

The partition is completely explicit: the leaf vertex is one side and all
remaining non-cut vertices are the other side. -/
noncomputable def cutVertexPartition_of_unique_unitDistance_neighbor
    {C : _root_.UDConfig n} {v u : Fin n}
    (hn : 3 <= n)
    (hvu : (GraphBridge.unitDistanceSimpleGraph C).Adj v u)
    (hunique :
      forall w : Fin n,
        (GraphBridge.unitDistanceSimpleGraph C).Adj v w -> w = u) :
    CutVertexInterface.CutVertexPartition C := by
  classical
  let G := GraphBridge.unitDistanceSimpleGraph C
  let left : Finset (Fin n) := {v}
  let right : Finset (Fin n) := (Finset.univ.erase u).erase v
  have hv_ne_u : v ≠ u := G.ne_of_adj hvu
  have hv_mem : v ∈ (Finset.univ : Finset (Fin n)).erase u := by
    simp [Finset.mem_erase, hv_ne_u]
  refine
    { cut := u
      left := left
      right := right
      left_nonempty := ?_
      right_nonempty := ?_
      left_cut_not_mem := ?_
      right_cut_not_mem := ?_
      disjoint := ?_
      cover_without_cut := ?_
      anticomplete := ?_ }
  · simp [left]
  · have hcard :
        right.card = n - 2 := by
      rw [show right = ((Finset.univ : Finset (Fin n)).erase u).erase v by rfl]
      rw [Finset.card_erase_of_mem hv_mem]
      rw [Finset.card_erase_of_mem (Finset.mem_univ u)]
      simp only [Finset.card_univ, Fintype.card_fin]
      omega
    exact Finset.card_pos.1 (by
      rw [hcard]
      omega)
  · simp [left, hv_ne_u.symm]
  · simp [right]
  · rw [Finset.disjoint_left]
    intro x hxleft hxright
    have hxv : x = v := by
      simpa [left] using hxleft
    have hxnotv : x ≠ v := by
      have hxright' :
          x ∈ ((Finset.univ : Finset (Fin n)).erase u).erase v := by
        simpa [right] using hxright
      exact (Finset.mem_erase.mp hxright').1
    exact hxnotv hxv
  · rw [Finset.singleton_union]
    exact Finset.insert_erase hv_mem
  · intro i hi j hj hij
    have hiv : i = v := by
      simpa [left] using hi
    have hju : j ≠ u := by
      have hjright :
          j ∈ ((Finset.univ : Finset (Fin n)).erase u).erase v := by
        simpa [right] using hj
      exact (Finset.mem_erase.mp (Finset.mem_erase.mp hjright).2).1
    have hvj : G.Adj v j := by
      simpa [G, hiv] using hij
    exact hju (hunique j hvj)

/-- Under the finite planar S2 inputs, the ambient unit-distance graph has no
leaf vertices, in neighbour-set cardinality form.

This is a genuine use of the no-cut input: a degree-one vertex would make its
unique neighbour into the explicit cut partition above. -/
theorem two_le_unitDistanceSimpleGraph_neighborSet_ncard_of_finitePlanarOuterComponentInputs
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (v : Fin n) :
    2 <= ((GraphBridge.unitDistanceSimpleGraph C).neighborSet v).ncard := by
  let G := GraphBridge.unitDistanceSimpleGraph C
  letI : Nontrivial (Fin n) :=
    nontrivial_vertices_of_finitePlanarOuterComponentInputs
      (C := C) inputs
  have hneighbor_nonempty : (G.neighborSet v).Nonempty := by
    cases inputs.preconnected.exists_adj_of_nontrivial v with
    | intro u hvu =>
        exact Exists.intro u hvu
  have hcard_pos : 0 < (G.neighborSet v).ncard :=
    (Set.ncard_pos (s := G.neighborSet v)).mpr hneighbor_nonempty
  by_contra hnot
  have hlt : (G.neighborSet v).ncard < 2 := Nat.lt_of_not_ge hnot
  have hcard : (G.neighborSet v).ncard = 1 := by omega
  have hsingle := Set.ncard_eq_one.mp hcard
  cases hsingle with
  | intro u hneighbors =>
      have hvu : G.Adj v u := by
        have hu_mem : (G.neighborSet v) u := by
          rw [hneighbors]
          exact Set.mem_singleton u
        exact hu_mem
      have hunique : forall w : Fin n, G.Adj v w -> w = u := by
        intro w hw
        have hw_mem : (G.neighborSet v) w := hw
        rw [hneighbors] at hw_mem
        exact Set.mem_singleton_iff.mp hw_mem
      exact
        inputs.noCutVertex
          (Nonempty.intro
            (cutVertexPartition_of_unique_unitDistance_neighbor
              (C := C)
              (hn := three_le_vertices_of_finitePlanarOuterComponentInputs
                (C := C) inputs)
              hvu hunique))

/-- No-cut plus the supplied cycle gives two distinct ambient unit-distance
neighbours at every vertex. -/
theorem exists_two_unitDistanceSimpleGraph_adjacent_of_finitePlanarOuterComponentInputs
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (v : Fin n) :
    Exists fun w1 : Fin n =>
      Exists fun w2 : Fin n =>
        And (Ne w1 w2)
          (And ((GraphBridge.unitDistanceSimpleGraph C).Adj v w1)
            ((GraphBridge.unitDistanceSimpleGraph C).Adj v w2)) := by
  classical
  let G := GraphBridge.unitDistanceSimpleGraph C
  have hcard : 2 <= (G.neighborSet v).ncard := by
    simpa [G] using
      two_le_unitDistanceSimpleGraph_neighborSet_ncard_of_finitePlanarOuterComponentInputs
        (C := C) inputs v
  have htwo :
      Exists fun w1 : Fin n =>
        Exists fun w2 : Fin n =>
          And (Ne w1 w2)
            (And ((G.neighborSet v) w1) ((G.neighborSet v) w2)) := by
    by_contra hnot
    have hsubsingleton : (G.neighborSet v).Subsingleton := by
      intro a ha b hb
      by_contra hne
      exact hnot
        (Exists.intro a
          (Exists.intro b (And.intro hne (And.intro ha hb))))
    have hcard_le_one : (G.neighborSet v).ncard <= 1 := by
      exact (Set.ncard_le_one_iff_subsingleton (s := G.neighborSet v)).2
        hsubsingleton
    omega
  cases htwo with
  | intro w1 htwo1 =>
      cases htwo1 with
      | intro w2 hprops =>
          exact
            Exists.intro w1
              (Exists.intro w2
                (And.intro hprops.1
                  (And.intro (by simpa [G] using hprops.2.1)
                    (by simpa [G] using hprops.2.2))))

/-- Canonical-graph form of the two-neighbour no-leaf consequence. -/
theorem exists_two_canonicalGraph_adjacent_of_finitePlanarOuterComponentInputs
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (v : Fin n) :
    Exists fun w₁ : Fin n =>
      Exists fun w₂ : Fin n =>
        w₁ ≠ w₂ ∧
          (canonicalGraph C).Adj v w₁ ∧
            (canonicalGraph C).Adj v w₂ := by
  rcases
      exists_two_unitDistanceSimpleGraph_adjacent_of_finitePlanarOuterComponentInputs
        (C := C) inputs v with
    ⟨w₁, w₂, hne, hw₁, hw₂⟩
  exact
    ⟨w₁, w₂, hne,
      ((canonicalGraph C).adj_iff_unitDistanceAdj v w₁).2
        ((GraphBridge.unitDistanceSimpleGraph_adj C v w₁).1 hw₁),
      ((canonicalGraph C).adj_iff_unitDistanceAdj v w₂).2
        ((GraphBridge.unitDistanceSimpleGraph_adj C v w₂).1 hw₂)⟩

/-- Canonical-graph form of
`exists_unitDistanceSimpleGraph_adjacent_of_finitePlanarOuterComponentInputs`. -/
theorem exists_canonicalGraph_adjacent_of_finitePlanarOuterComponentInputs
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (v : Fin n) :
    Exists fun w : Fin n => (canonicalGraph C).Adj v w := by
  rcases
      exists_unitDistanceSimpleGraph_adjacent_of_finitePlanarOuterComponentInputs
        (C := C) inputs v with
    ⟨w, hw⟩
  exact
    ⟨w,
      ((canonicalGraph C).adj_iff_unitDistanceAdj v w).2
        ((GraphBridge.unitDistanceSimpleGraph_adj C v w).1 hw)⟩

/-- Every graph vertex has a distinct nearby point on the frontier of the
whole drawing complement.

Choose any incident canonical edge and take its midpoint.  The finite-drawing
edge-interior half-ball theorem puts that midpoint on the ambient drawing
complement frontier, and open-segment nondegeneracy keeps it distinct from the
chosen vertex. -/
theorem exists_drawingComplement_frontier_point_ne_graph_vertex
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (v : Fin n) :
    Exists fun p : PlanarInterface.Point =>
      p ∈ frontier (drawingComplement C) ∧
        p ≠ (canonicalGraph C).point v := by
  rcases
      exists_canonicalGraph_adjacent_of_finitePlanarOuterComponentInputs
        (C := C) inputs v with
    ⟨w, hvw⟩
  let p : PlanarInterface.Point :=
    PlanarInterface.segmentPoint
      ((canonicalGraph C).point v)
      ((canonicalGraph C).point w)
      (1 / 2 : Real)
  have hpopen :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point v)
        ((canonicalGraph C).point w) := by
    simpa [p] using
      midpoint_inOpenSegment
        ((canonicalGraph C).point v)
        ((canonicalGraph C).point w)
  refine
    ⟨p,
      inOpenSegment_mem_frontier_drawingComplement_of_adj
        (C := C) hvw hpopen,
      ?_⟩
  exact left_ne_of_inOpenSegment (canonical_adj_point_ne hvw) hpopen

/-- Ambient drawing-complement frontier points that are not on the selected
unbounded exterior frontier have arbitrarily close complement points outside
the selected unbounded exterior component.

This is the metric separation adapter needed for the singleton-frontier
residual: once a nearby ambient frontier point is known not to be part of the
actual unbounded exterior frontier, openness of the selected exterior
component gives a punctured neighbourhood missed by that component, while the
ambient frontier supplies complement points in every smaller ball. -/
theorem exists_drawingComplement_point_not_unboundedExterior_near_of_ambient_frontier_not_unboundedExterior_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {q : PlanarInterface.Point}
    (hqAmbient : q ∈ frontier (drawingComplement C))
    (hqNotActual :
      q ∉ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    forall ε : Real,
      0 < ε ->
        Exists fun y : PlanarInterface.Point =>
          y ∈ Metric.ball q ε ∧
            y ∈ drawingComplement C ∧
              y ∉ (unboundedExteriorComponentRows C inputs).exterior := by
  intro ε hεpos
  have hqAmbient' := hqAmbient
  rw [(drawingComplement_open C).frontier_eq] at hqAmbient'
  have hqClosureComplement :
      q ∈ closure (drawingComplement C) := hqAmbient'.1
  have hqNotComplement :
      q ∉ drawingComplement C := hqAmbient'.2
  have hqNotExterior :
      q ∉ (unboundedExteriorComponentRows C inputs).exterior := by
    intro hqExterior
    exact hqNotComplement
      ((unboundedExteriorComponentRows C inputs).exterior_subset_drawingComplement
        hqExterior)
  have hqNotClosureExterior :
      q ∉ closure (unboundedExteriorComponentRows C inputs).exterior := by
    intro hqClosureExterior
    exact hqNotActual (by
      rw [(unboundedExteriorComponentRows C inputs).exterior_open.frontier_eq]
      exact ⟨hqClosureExterior, hqNotExterior⟩)
  have hmetric :
      ¬ forall δ : Real,
          0 < δ ->
            Exists fun y : PlanarInterface.Point =>
              y ∈ (unboundedExteriorComponentRows C inputs).exterior ∧
                dist y q < δ := by
    intro hnear
    exact hqNotClosureExterior (by
      rw [Metric.mem_closure_iff]
      intro δ hδpos
      rcases hnear δ hδpos with ⟨y, hyExterior, hydist⟩
      exact ⟨y, hyExterior, by simpa [dist_comm] using hydist⟩)
  push_neg at hmetric
  rcases hmetric with ⟨δ, hδpos, hδ⟩
  have hqClosureComplementMetric := hqClosureComplement
  rw [Metric.mem_closure_iff] at hqClosureComplementMetric
  let ρ : Real := min ε δ / 2
  have hρpos : 0 < ρ := by
    exact half_pos (lt_min hεpos hδpos)
  rcases hqClosureComplementMetric ρ hρpos with ⟨y, hyComplement, hyρ⟩
  have hyball : y ∈ Metric.ball q ε := by
    have hyε : dist q y < ε := by
      calc
        dist q y < ρ := hyρ
        _ = min ε δ / 2 := rfl
        _ ≤ min ε δ := by linarith [lt_min hεpos hδpos]
        _ ≤ ε := min_le_left ε δ
    have hyε' : dist y q < ε := by
      simpa [dist_comm] using hyε
    simpa [Metric.mem_ball] using hyε'
  have hyNotExterior :
      y ∉ (unboundedExteriorComponentRows C inputs).exterior := by
    intro hyExterior
    have hyδ : dist y q < δ := by
      calc
        dist y q = dist q y := dist_comm y q
        _ < ρ := hyρ
        _ = min ε δ / 2 := rfl
        _ ≤ min ε δ := by linarith [lt_min hεpos hδpos]
        _ ≤ δ := min_le_right ε δ
    exact not_lt_of_ge (hδ y hyExterior) hyδ
  exact ⟨y, hyball, hyComplement, hyNotExterior⟩

/-- The unbounded exterior frontier seed can be read either as a selected
frontier graph vertex or as a frontier point in the relative interior of an
ordered canonical edge. -/
theorem exists_unboundedFrontierVertexSet_or_frontier_edgeInterior
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) :
    (Exists fun v : Fin n => v ∈ unboundedFrontierVertexSet C inputs) ∨
      Exists fun e : PlanarInterface.Edge n =>
        Exists fun p : PlanarInterface.Point =>
          e ∈ (canonicalGraph C).edgeSet ∧
            p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
              PlanarInterface.InOpenSegment p
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2) := by
  rcases exists_unboundedExterior_frontier_vertex_or_edgeInterior inputs with
    ⟨p, hpfrontier, hkind⟩
  rcases hkind with hvertex | hedge
  · rcases hvertex with ⟨v, rfl⟩
    exact Or.inl ⟨v, mem_unboundedFrontierVertexSet_iff.2 hpfrontier⟩
  · rcases hedge with ⟨i, j, hij, hpseg⟩
    rcases hij with hij | hji
    · exact Or.inr ⟨(i, j), p, hij, hpfrontier, hpseg⟩
    · exact Or.inr
        ⟨(j, i), p, hji, hpfrontier, inOpenSegment_symm hpseg⟩

/-- Ordered canonical graph edges whose relative interiors lie on the unbounded
component frontier.  This is the concrete boundary-edge carrier that the final
S2 planar theorem has to prove connected and two-regular. -/
noncomputable def unboundedFrontierEdgeSet
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    Finset (PlanarInterface.Edge n) := by
  classical
  exact
    (canonicalGraph C).edgeSet.filter
      (fun e : PlanarInterface.Edge n =>
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point e.1)
            ((canonicalGraph C).point e.2) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)

theorem mem_unboundedFrontierEdgeSet_iff
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n} :
    e ∈ unboundedFrontierEdgeSet C inputs ↔
      e ∈ (canonicalGraph C).edgeSet /\
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point e.1)
            ((canonicalGraph C).point e.2) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  classical
  simp [unboundedFrontierEdgeSet]

theorem unboundedFrontierEdgeSet_adj
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs) :
    (canonicalGraph C).Adj e.1 e.2 := by
  exact Or.inl (mem_unboundedFrontierEdgeSet_iff.1 he).1

theorem unboundedFrontierEdgeSet_has_frontier_interior_point
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs) :
    Exists fun p : PlanarInterface.Point =>
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior /\
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) := by
  let p : PlanarInterface.Point :=
    PlanarInterface.segmentPoint
      ((canonicalGraph C).point e.1)
      ((canonicalGraph C).point e.2)
      (1 / 2 : Real)
  have hp :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2) :=
    midpoint_inOpenSegment _ _
  exact ⟨p, (mem_unboundedFrontierEdgeSet_iff.1 he).2 p hp, hp⟩

/-- Boundary-carrier edges are uniquely determined by any shared relative
interior point. -/
theorem unboundedFrontierEdgeSet_eq_of_common_interior_point
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e f : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs)
    (hf : f ∈ unboundedFrontierEdgeSet C inputs)
    {p : PlanarInterface.Point}
    (hpe :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2))
    (hpf :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point f.1)
        ((canonicalGraph C).point f.2)) :
    e = f :=
  common_inOpenSegment_ordered_edges_eq
    (mem_unboundedFrontierEdgeSet_iff.1 he).1
    (mem_unboundedFrontierEdgeSet_iff.1 hf).1
    hpe hpf

/-- Boundary-carrier edges are also uniquely determined by any point that is
interior to one selected edge and lies on the closed segment of another ordered
canonical edge.  This is the closed-segment version needed for local edge
isolation near frontier points. -/
theorem unboundedFrontierEdgeSet_eq_of_common_interior_closed_point
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e f : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs)
    (hf : f ∈ (canonicalGraph C).edgeSet)
    {p : PlanarInterface.Point}
    (hpe :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2))
    (hpf :
      p ∈ closedSegment
        ((canonicalGraph C).point f.1)
        ((canonicalGraph C).point f.2)) :
    e = f :=
  common_inOpenSegment_closedSegment_ordered_edges_eq
    (mem_unboundedFrontierEdgeSet_iff.1 he).1 hf hpe hpf

/-- If an interior point of a selected unbounded-frontier edge lies on a
closed segment carried by any adjacent pair, then that pair is the same
unordered unit edge.  This is the unbounded-frontier specialization of the
local carrier uniqueness used by the edge-isolation proof. -/
theorem unboundedFrontierEdgeSet_same_unordered_of_common_interior_closed_adj
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n} {i j : Fin n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs)
    (hij : (canonicalGraph C).Adj i j)
    {p : PlanarInterface.Point}
    (hpe :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2))
    (hpij :
      p ∈ closedSegment
        ((canonicalGraph C).point i)
        ((canonicalGraph C).point j)) :
    (e.1 = i ∧ e.2 = j) ∨ (e.1 = j ∧ e.2 = i) :=
  common_inOpenSegment_closedSegment_adj_same_unordered
    (mem_unboundedFrontierEdgeSet_iff.1 he).1 hij hpe hpij

/-- If the whole open segment of an edge lies in a closed frontier, then the
left endpoint also lies in that frontier. -/
theorem left_endpoint_frontier_of_openSegment_frontier
    {s : Set PlanarInterface.Point}
    {a b : PlanarInterface.Point}
    (hseg :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p a b -> p ∈ frontier s) :
    a ∈ frontier s := by
  exact
    (closure_minimal
      (s := {p : PlanarInterface.Point |
        PlanarInterface.InOpenSegment p a b})
      (t := frontier s)
      (by intro p hp; exact hseg p hp)
      isClosed_frontier)
      (_root_.ErdosProblems1066.Swanepoel.FinitePlaneDrawing.left_mem_closure_inOpenSegment
        a b)

/-- Right-endpoint version of
`left_endpoint_frontier_of_openSegment_frontier`. -/
theorem right_endpoint_frontier_of_openSegment_frontier
    {s : Set PlanarInterface.Point}
    {a b : PlanarInterface.Point}
    (hseg :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p a b -> p ∈ frontier s) :
    b ∈ frontier s := by
  exact
    (closure_minimal
      (s := {p : PlanarInterface.Point |
        PlanarInterface.InOpenSegment p a b})
      (t := frontier s)
      (by intro p hp; exact hseg p hp)
      isClosed_frontier)
      (_root_.ErdosProblems1066.Swanepoel.FinitePlaneDrawing.right_mem_closure_inOpenSegment
        a b)

/-- Once a selected unbounded-frontier edge is known to have its whole relative
interior on the unbounded exterior frontier, both endpoints are graph frontier
vertices. -/
theorem endpoints_mem_unboundedFrontierVertexSet_of_edge_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (hseg :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    e.1 ∈ unboundedFrontierVertexSet C inputs ∧
      e.2 ∈ unboundedFrontierVertexSet C inputs := by
  constructor
  · exact mem_unboundedFrontierVertexSet_iff.2
      (left_endpoint_frontier_of_openSegment_frontier hseg)
  · exact mem_unboundedFrontierVertexSet_iff.2
      (right_endpoint_frontier_of_openSegment_frontier hseg)

/-- A canonical ordered edge whose whole relative interior lies on the
unbounded exterior frontier belongs to the concrete frontier edge set. -/
theorem mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ (canonicalGraph C).edgeSet)
    (hseg :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    e ∈ unboundedFrontierEdgeSet C inputs := by
  exact mem_unboundedFrontierEdgeSet_iff.2 ⟨he, hseg⟩

/-- An unoriented canonical adjacency whose whole open segment lies on the
unbounded exterior frontier determines a selected frontier carrier edge in one
of the two ordered orientations. -/
theorem unboundedFrontierEdgeSet_or_symm_of_adj_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {i j : Fin n}
    (hij : (canonicalGraph C).Adj i j)
    (hseg :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point i)
          ((canonicalGraph C).point j) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    (i, j) ∈ unboundedFrontierEdgeSet C inputs ∨
      (j, i) ∈ unboundedFrontierEdgeSet C inputs := by
  rcases hij with hij | hji
  · exact Or.inl
      (mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier
        (e := (i, j)) hij hseg)
  · exact Or.inr
      (mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier
        (e := (j, i)) hji (by
          intro p hp
          exact hseg p (inOpenSegment_symm hp)))

/-- Interior points of any canonical edge cannot lie in the selected unbounded
exterior component: the component is contained in the drawing complement, while
the whole edge segment is part of the embedded drawing. -/
theorem canonicalEdge_inOpenSegment_not_mem_unboundedExterior
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    {e : PlanarInterface.Edge n}
    (he : e ∈ (canonicalGraph C).edgeSet)
    {p : PlanarInterface.Point}
    (hp :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2)) :
    p ∉ (unboundedExteriorComponentRows C inputs).exterior := by
  intro hpExterior
  have hpDrawing : p ∈ embeddedEdgeSet C :=
    inOpenSegment_mem_embeddedEdgeSet_of_adj (Or.inl he) hp
  exact
    ((unboundedExteriorComponentRows C inputs).exterior_subset_drawingComplement
      hpExterior) hpDrawing

/-- If exterior-component points approach an interior point of a canonical
edge from arbitrarily close range, then that edge-interior point is on the
unbounded exterior frontier. -/
theorem canonicalEdge_inOpenSegment_frontier_of_exterior_points_arbitrarily_close
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    {p : PlanarInterface.Point}
    (he : e ∈ (canonicalGraph C).edgeSet)
    (hp :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2))
    (hnear :
      forall eps : Real,
        0 < eps ->
          Exists fun y : PlanarInterface.Point =>
            y ∈ (unboundedExteriorComponentRows C inputs).exterior ∧
              dist y p < eps) :
    p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  rw [(unboundedExteriorComponentRows C inputs).exterior_open.frontier_eq]
  constructor
  · rw [Metric.mem_closure_iff]
    intro eps heps
    rcases hnear eps heps with ⟨y, hyExterior, hydist⟩
    exact ⟨y, hyExterior, by simpa [dist_comm] using hydist⟩
  · exact canonicalEdge_inOpenSegment_not_mem_unboundedExterior inputs he hp

/-- Minimal endpoint-to-interior local topology source for adjacent frontier
endpoints.

If two adjacent graph vertices both lie on the selected unbounded exterior
frontier, the source asks only that the open edge between them contain one
point in the closure of the same exterior component.  The edge-interior
nonmembership row then upgrades that point to frontier membership. -/
def AdjacentFrontierEndpointsInteriorClosurePointSource
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall {i j : Fin n},
    (canonicalGraph C).Adj i j ->
      (canonicalGraph C).point i ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ->
        (canonicalGraph C).point j ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun p : PlanarInterface.Point =>
            PlanarInterface.InOpenSegment p
              ((canonicalGraph C).point i)
              ((canonicalGraph C).point j) /\
            p ∈ closure (unboundedExteriorComponentRows C inputs).exterior

/-- Sharper local component source for adjacent frontier endpoints.

For an adjacent pair of graph vertices already on the selected unbounded
exterior frontier, it is enough to find a relative-open point of their edge and
a small interval around it whose same-edge points are accumulated by one local
connected component of the exterior inside the ball.  This is deliberately a
local component/interval closure row; it does not identify the edge through an
induced frontier graph or any cycle shortcut. -/
def AdjacentFrontierEndpointsLocalComponentIntervalClosureSource
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall {i j : Fin n},
    (canonicalGraph C).Adj i j ->
      (canonicalGraph C).point i ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ->
        (canonicalGraph C).point j ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun p : PlanarInterface.Point =>
            PlanarInterface.InOpenSegment p
              ((canonicalGraph C).point i)
              ((canonicalGraph C).point j) /\
            Exists fun r : Real =>
              0 < r /\
              Exists fun y : PlanarInterface.Point =>
                y ∈ (unboundedExteriorComponentRows C inputs).exterior ∩
                    Metric.ball p r /\
                forall z : PlanarInterface.Point,
                  z ∈ Metric.ball p r ->
                    PlanarInterface.InOpenSegment z
                      ((canonicalGraph C).point i)
                      ((canonicalGraph C).point j) ->
                    z ∈ closure
                      (connectedComponentIn
                        ((unboundedExteriorComponentRows C inputs).exterior ∩
                          Metric.ball p r) y)

/-- Non-circular local endpoint-to-edge source for adjacent frontier endpoints.

For the closed geometric segment of an adjacent edge whose two endpoints lie on
the selected unbounded exterior frontier, the points already in the exterior
closure form a relatively open subset of that closed segment.  Closedness of
`closure exterior` and connectedness of the closed segment then force the
midpoint, hence a relative-open point of the edge, to lie in the closure. -/
def AdjacentFrontierEndpointsClosedSegmentClosureLocusRelativeOpenSource
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall {i j : Fin n},
    (canonicalGraph C).Adj i j ->
      (canonicalGraph C).point i ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ->
        (canonicalGraph C).point j ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ->
          IsOpen
            ({q :
                {q : PlanarInterface.Point //
                  q ∈ closedSegment
                    ((canonicalGraph C).point i)
                    ((canonicalGraph C).point j)} |
              (q : PlanarInterface.Point) ∈
                closure (unboundedExteriorComponentRows C inputs).exterior})

/-- Endpoint-only residual for the closed-segment source.

This is intentionally not an input-level source target: for arbitrary adjacent
exterior-frontier endpoints the edge may be an interior boundary chord.  Use
this only after a separate row proves that the adjacent edge is one of the
actual selected edges in `unboundedFrontierEdgeSet`. -/
def AdjacentFrontierEndpointsClosedSegmentEndpointClosureSource
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall {i j : Fin n},
    (canonicalGraph C).Adj i j ->
      (canonicalGraph C).point i ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ->
        (canonicalGraph C).point j ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ->
          (Exists fun r : Real =>
            0 < r /\
              forall z : PlanarInterface.Point,
                z ∈ Metric.ball ((canonicalGraph C).point i) r ->
                z ∈ closedSegment
                  ((canonicalGraph C).point i)
                  ((canonicalGraph C).point j) ->
                z ∈ closure
                  (unboundedExteriorComponentRows C inputs).exterior) /\
          (Exists fun r : Real =>
            0 < r /\
              forall z : PlanarInterface.Point,
                z ∈ Metric.ball ((canonicalGraph C).point j) r ->
                z ∈ closedSegment
                  ((canonicalGraph C).point i)
                  ((canonicalGraph C).point j) ->
                z ∈ closure
                  (unboundedExteriorComponentRows C inputs).exterior)

/-- Primitive non-circular edge-carrier row for the endpoint one-sided closure
source.

For adjacent graph vertices already on the selected unbounded exterior
frontier, the row asks that their actual geometric edge be selected in
`unboundedFrontierEdgeSet` in one of the two orientations.  This is the real
frontier-edge carrier predicate; it does not use an induced frontier graph,
cycle shortcut, or synthetic enclosure predicate. -/
def AdjacentFrontierEndpointsIncidentUnboundedFrontierEdgeSource
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall {i j : Fin n},
    (canonicalGraph C).Adj i j ->
      (canonicalGraph C).point i ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ->
        (canonicalGraph C).point j ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ->
          (i, j) ∈ unboundedFrontierEdgeSet C inputs ∨
            (j, i) ∈ unboundedFrontierEdgeSet C inputs

/-- A selected unbounded-frontier edge supplies an open-edge point in the
exterior closure.

This is the corrected adjacent-endpoint primitive: it applies only to the
actual selected frontier edge, not to an arbitrary graph edge whose endpoints
happen to lie on the frontier. -/
theorem selectedUnboundedFrontierEdge_interiorClosurePoint
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {i j : Fin n}
    (hselected :
      (i, j) ∈ unboundedFrontierEdgeSet C inputs ∨
        (j, i) ∈ unboundedFrontierEdgeSet C inputs) :
    Exists fun p : PlanarInterface.Point =>
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point i)
        ((canonicalGraph C).point j) ∧
      p ∈ closure (unboundedExteriorComponentRows C inputs).exterior := by
  let a : PlanarInterface.Point := (canonicalGraph C).point i
  let b : PlanarInterface.Point := (canonicalGraph C).point j
  let p : PlanarInterface.Point :=
    PlanarInterface.segmentPoint a b (1 / 2 : Real)
  have hpopen : PlanarInterface.InOpenSegment p a b := by
    simpa [p] using midpoint_inOpenSegment a b
  refine ⟨p, by simpa [a, b] using hpopen, ?_⟩
  have hpfrontier :
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
    rcases hselected with hselected | hselected
    · exact
        (mem_unboundedFrontierEdgeSet_iff.1 hselected).2 p
          (by simpa [a, b] using hpopen)
    · exact
        (mem_unboundedFrontierEdgeSet_iff.1 hselected).2 p
          (by simpa [a, b] using inOpenSegment_symm hpopen)
  exact frontier_subset_closure hpfrontier

/-- Incident selected-edge rows safely imply the interior-closure source.

This is the selected-edge version of claim
`S2-agent-adjacent-endpoint-interior-source-20260520an`: the arbitrary
adjacent-frontier-endpoint statement is used only after the missing hypothesis
has been made explicit, namely that the adjacent geometric edge is one of the
actual `unboundedFrontierEdgeSet` edges in either orientation. -/
theorem S2_agent_adjacent_endpoint_interior_source_20260520an
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (incident_edge :
      AdjacentFrontierEndpointsIncidentUnboundedFrontierEdgeSource C inputs) :
    AdjacentFrontierEndpointsInteriorClosurePointSource C inputs := by
  intro i j hij hifrontier hjfrontier
  exact
    selectedUnboundedFrontierEdge_interiorClosurePoint
      (C := C) (inputs := inputs)
      (incident_edge hij hifrontier hjfrontier)

/-- The actual incident `unboundedFrontierEdgeSet` row sharply reduces the
endpoint one-sided closure source.

Near either endpoint of the selected edge, a closed-segment point is either
the endpoint itself, hence in exterior closure by frontier membership, or a
relative-interior point of the selected frontier edge, hence again in exterior
closure.  The radius excludes the opposite endpoint. -/
theorem closedSegmentEndpointClosureSource_of_incidentUnboundedFrontierEdgeSource
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (incident_edge :
      AdjacentFrontierEndpointsIncidentUnboundedFrontierEdgeSource C inputs) :
    AdjacentFrontierEndpointsClosedSegmentEndpointClosureSource C inputs := by
  intro i j hij hifrontier hjfrontier
  let a : PlanarInterface.Point := (canonicalGraph C).point i
  let b : PlanarInterface.Point := (canonicalGraph C).point j
  have hedge :
      (i, j) ∈ unboundedFrontierEdgeSet C inputs ∨
        (j, i) ∈ unboundedFrontierEdgeSet C inputs :=
    incident_edge hij hifrontier hjfrontier
  have hdist_pos : 0 < dist a b := by
    exact dist_pos.mpr (by simpa [a, b] using canonical_adj_point_ne hij)
  let r : Real := dist a b / 2
  have hrpos : 0 < r := half_pos hdist_pos
  constructor
  · refine ⟨r, hrpos, ?_⟩
    intro z hzball hzseg
    rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hzseg with
      hz_left | hz_right | hz_open
    · simpa [a, hz_left] using frontier_subset_closure hifrontier
    · have hlt : dist a b < dist a b / 2 := by
        simpa [Metric.mem_ball, a, b, r, hz_right, dist_comm] using hzball
      exact False.elim (by linarith)
    · have hzfrontier :
          z ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
        rcases hedge with hedge | hedge
        · exact
            (mem_unboundedFrontierEdgeSet_iff.1 hedge).2 z
              (by simpa [a, b] using hz_open)
        · exact
            (mem_unboundedFrontierEdgeSet_iff.1 hedge).2 z
              (by simpa [a, b] using inOpenSegment_symm hz_open)
      exact frontier_subset_closure hzfrontier
  · refine ⟨r, hrpos, ?_⟩
    intro z hzball hzseg
    rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hzseg with
      hz_left | hz_right | hz_open
    · have hlt : dist a b < dist a b / 2 := by
        simpa [Metric.mem_ball, a, b, r, hz_left] using hzball
      exact False.elim (by linarith)
    · simpa [b, hz_right] using frontier_subset_closure hjfrontier
    · have hzfrontier :
          z ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
        rcases hedge with hedge | hedge
        · exact
            (mem_unboundedFrontierEdgeSet_iff.1 hedge).2 z
              (by simpa [a, b] using hz_open)
        · exact
            (mem_unboundedFrontierEdgeSet_iff.1 hedge).2 z
              (by simpa [a, b] using inOpenSegment_symm hz_open)
      exact frontier_subset_closure hzfrontier

/-- Claim `S2-agent-endpoint-one-sided-closure-source-20260520bt`.

The honest endpoint one-sided closure source is reduced to the actual adjacent
unbounded-frontier edge carrier row.  This uses only the selected unbounded
exterior frontier edge predicate: near an endpoint, a point of the closed edge
is either the endpoint, already in exterior closure, or an open-edge point of
the selected unbounded frontier edge. -/
theorem S2_agent_endpoint_one_sided_closure_source_20260520bt
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (incident_edge :
      AdjacentFrontierEndpointsIncidentUnboundedFrontierEdgeSource C inputs) :
    AdjacentFrontierEndpointsClosedSegmentEndpointClosureSource C inputs :=
  closedSegmentEndpointClosureSource_of_incidentUnboundedFrontierEdgeSource
    (C := C) (inputs := inputs) incident_edge

/-- Claim `S2-agent-adjacent-endpoint-closedsegment-20260520ca`.

The CA endpoint-closure task is the same non-circular eraser as the existing
one-sided closure source: once an adjacent graph edge is known to be an actual
selected unbounded-frontier edge, endpoint closure along its closed segment is
immediate from the selected-edge frontier row. -/
theorem S2_agent_adjacent_endpoint_closedsegment_20260520ca
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (incident_edge :
      AdjacentFrontierEndpointsIncidentUnboundedFrontierEdgeSource C inputs) :
    AdjacentFrontierEndpointsClosedSegmentEndpointClosureSource C inputs :=
  closedSegmentEndpointClosureSource_of_incidentUnboundedFrontierEdgeSource
    (C := C) (inputs := inputs) incident_edge

/-- The closed segment between two points is preconnected in the project-local
segment model. -/
theorem isPreconnected_closedSegment
    (a b : PlanarInterface.Point) :
    IsPreconnected (closedSegment a b) := by
  rw [closedSegment_eq_image_Icc]
  exact isPreconnected_Icc.image _
    (continuous_segmentPoint a b).continuousOn

/-- Relative openness of the exterior-closure locus on the closed adjacent edge
is enough to produce the required open-edge closure point. -/
theorem AdjacentFrontierEndpointsInteriorClosurePointSource_of_closedSegmentClosureLocusRelativeOpen
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (closure_locus_relative_open :
      AdjacentFrontierEndpointsClosedSegmentClosureLocusRelativeOpenSource
        C inputs) :
    AdjacentFrontierEndpointsInteriorClosurePointSource C inputs := by
  intro i j hij hifrontier hjfrontier
  let a : PlanarInterface.Point := (canonicalGraph C).point i
  let b : PlanarInterface.Point := (canonicalGraph C).point j
  let segment : Set PlanarInterface.Point := closedSegment a b
  let closureLocus : Set segment :=
    {q : segment |
      (q : PlanarInterface.Point) ∈
        closure (unboundedExteriorComponentRows C inputs).exterior}
  have hclosed : IsClosed closureLocus := by
    change
      IsClosed
        (((↑) : segment -> PlanarInterface.Point) ⁻¹'
          closure (unboundedExteriorComponentRows C inputs).exterior)
    exact IsClosed.preimage continuous_subtype_val isClosed_closure
  have hopen : IsOpen closureLocus := by
    simpa [closureLocus, segment, a, b] using
      closure_locus_relative_open hij hifrontier hjfrontier
  have hpre :
      IsPreconnected (Set.univ : Set segment) := by
    haveI : PreconnectedSpace segment :=
      Subtype.preconnectedSpace (by
        simpa [segment, a, b] using isPreconnected_closedSegment a b)
    exact preconnectedSpace_iff_univ.mp inferInstance
  have hnonempty : (Set.univ ∩ closureLocus).Nonempty := by
    refine ⟨⟨a, by simpa [segment] using left_mem_closedSegment a b⟩, ?_⟩
    exact
      ⟨Set.mem_univ _,
        by
          simpa [closureLocus, a] using
            (frontier_subset_closure hifrontier)⟩
  have hsubset : (Set.univ : Set segment) ⊆ closureLocus :=
    hpre.subset_isClopen ⟨hclosed, hopen⟩ hnonempty
  refine
    ⟨PlanarInterface.segmentPoint a b (1 / 2 : Real), ?_, ?_⟩
  · simpa [a, b] using midpoint_inOpenSegment a b
  · have hmid_segment :
        PlanarInterface.segmentPoint a b (1 / 2 : Real) ∈ segment := by
      exact segmentPoint_mem_closedSegment (a := a) (b := b)
        (t := (1 / 2 : Real)) (by norm_num) (by norm_num)
    exact
      hsubset
        (Set.mem_univ
          ⟨PlanarInterface.segmentPoint a b (1 / 2 : Real),
            hmid_segment⟩)

/-- Claim
`S2-agent-adjacent-frontier-endpoints-interior-closure-real-source-20260520ac`.

The adjacent-endpoint closure row is reduced directly to the local
closed-segment relative-openness statement above, avoiding any dependence on
the local component-interval row. -/
theorem S2_agent_adjacent_frontier_endpoints_interior_closure_real_source_20260520ac
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (closure_locus_relative_open :
      AdjacentFrontierEndpointsClosedSegmentClosureLocusRelativeOpenSource
        C inputs) :
    AdjacentFrontierEndpointsInteriorClosurePointSource C inputs :=
  AdjacentFrontierEndpointsInteriorClosurePointSource_of_closedSegmentClosureLocusRelativeOpen
    closure_locus_relative_open

/-- The local connected-component interval closure row is exactly strong enough
to supply the endpoint closure point needed by the S2 endpoint reducer. -/
theorem AdjacentFrontierEndpointsInteriorClosurePointSource_of_localComponentIntervalClosure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (local_component_interval :
      AdjacentFrontierEndpointsLocalComponentIntervalClosureSource C inputs) :
    AdjacentFrontierEndpointsInteriorClosurePointSource C inputs := by
  intro i j hij hifrontier hjfrontier
  rcases local_component_interval hij hifrontier hjfrontier with
    ⟨p, hpseg, r, hrpos, y, _hy, hinterval⟩
  refine ⟨p, hpseg, ?_⟩
  let localExterior : Set PlanarInterface.Point :=
    (unboundedExteriorComponentRows C inputs).exterior ∩ Metric.ball p r
  have hpLocalClosure :
      p ∈ closure (connectedComponentIn localExterior y) := by
    exact hinterval p (Metric.mem_ball_self hrpos) hpseg
  have hcomponent_subset_exterior :
      connectedComponentIn localExterior y ⊆
        (unboundedExteriorComponentRows C inputs).exterior := by
    intro z hz
    exact (connectedComponentIn_subset localExterior y hz).1
  exact closure_mono hcomponent_subset_exterior hpLocalClosure

/-- Claim `S2-agent-adjacent-frontier-endpoints-closure-point-source-20260520aa`.

This leaves the remaining endpoint-to-open-edge closure fact as the smallest
local connected-component interval row: one local exterior component in a ball
accumulates a relative-open interval point of the adjacent endpoint edge. -/
theorem S2_agent_adjacent_frontier_endpoints_closure_point_source_20260520aa
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (local_component_interval :
      AdjacentFrontierEndpointsLocalComponentIntervalClosureSource C inputs) :
    AdjacentFrontierEndpointsInteriorClosurePointSource C inputs :=
  AdjacentFrontierEndpointsInteriorClosurePointSource_of_localComponentIntervalClosure
    local_component_interval

/-- Closure along the whole relative interior of a canonical edge is enough to
upgrade to frontier along that whole interior, because canonical edge interiors
are outside the selected unbounded exterior component. -/
theorem edge_openSegment_frontier_of_edge_openSegment_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ (canonicalGraph C).edgeSet)
    (hclosure :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ closure (unboundedExteriorComponentRows C inputs).exterior) :
    forall p : PlanarInterface.Point,
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2) ->
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  intro p hp
  rw [(unboundedExteriorComponentRows C inputs).exterior_open.frontier_eq]
  exact
    ⟨hclosure p hp,
      canonicalEdge_inOpenSegment_not_mem_unboundedExterior inputs he hp⟩

/-- Reducer for propagation arguments: once the propagated topological fact is
closure of the unbounded exterior along the whole open segment, the actual
frontier-edge carrier membership follows. -/
theorem mem_unboundedFrontierEdgeSet_of_edge_openSegment_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ (canonicalGraph C).edgeSet)
    (hclosure :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ closure (unboundedExteriorComponentRows C inputs).exterior) :
    e ∈ unboundedFrontierEdgeSet C inputs :=
  mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier he
    (edge_openSegment_frontier_of_edge_openSegment_closure he hclosure)

/-- Ordered adjacent frontier endpoints whose whole open segment lies in the
exterior closure determine the ordered concrete unbounded-frontier edge.

The endpoint frontier hypotheses keep this in the adjacent-frontier-endpoint
API, while the proof uses only the defining carrier row: closure along the
open segment plus drawing-complement nonmembership upgrades the open segment to
frontier, hence to `unboundedFrontierEdgeSet`. -/
theorem orderedAdjacentFrontierEndpoints_mem_unboundedFrontierEdgeSet_of_openSegment_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {i j : Fin n}
    (hij : (i, j) ∈ (canonicalGraph C).edgeSet)
    (_hifrontier :
      (canonicalGraph C).point i ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior)
    (_hjfrontier :
      (canonicalGraph C).point j ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior)
    (hclosure :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point i)
          ((canonicalGraph C).point j) ->
        p ∈ closure (unboundedExteriorComponentRows C inputs).exterior) :
    (i, j) ∈ unboundedFrontierEdgeSet C inputs :=
  mem_unboundedFrontierEdgeSet_of_edge_openSegment_closure
    (C := C) (inputs := inputs) (e := (i, j)) hij hclosure

/-- Adjacent frontier endpoints are incident to the concrete frontier edge
once the local source supplies exterior closure along their whole open
segment.

This is the source-shaped version of
`orderedAdjacentFrontierEndpoints_mem_unboundedFrontierEdgeSet_of_openSegment_closure`;
it stays local to the defining endpoint and adjacency data and does not use
completed boundary-cycle rows or synthetic rows. -/
theorem adjacentFrontierEndpointsIncidentUnboundedFrontierEdgeSource_of_openSegment_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (openSegment_closure :
      forall {i j : Fin n},
        (canonicalGraph C).Adj i j ->
          (canonicalGraph C).point i ∈
              frontier (unboundedExteriorComponentRows C inputs).exterior ->
            (canonicalGraph C).point j ∈
              frontier (unboundedExteriorComponentRows C inputs).exterior ->
              forall p : PlanarInterface.Point,
                PlanarInterface.InOpenSegment p
                  ((canonicalGraph C).point i)
                  ((canonicalGraph C).point j) ->
                p ∈
                  closure
                    (unboundedExteriorComponentRows C inputs).exterior) :
    AdjacentFrontierEndpointsIncidentUnboundedFrontierEdgeSource C inputs := by
  intro i j hij hifrontier hjfrontier
  rcases hij with hij | hji
  · exact Or.inl
      (orderedAdjacentFrontierEndpoints_mem_unboundedFrontierEdgeSet_of_openSegment_closure
        (C := C) (inputs := inputs) (i := i) (j := j)
        hij hifrontier hjfrontier
        (openSegment_closure (Or.inl hij) hifrontier hjfrontier))
  · exact Or.inr
      (orderedAdjacentFrontierEndpoints_mem_unboundedFrontierEdgeSet_of_openSegment_closure
        (C := C) (inputs := inputs) (i := j) (j := i)
        hji hjfrontier hifrontier
        (by
          intro p hp
          exact
            openSegment_closure (Or.inr hji) hifrontier hjfrontier
              p (inOpenSegment_symm hp)))

/-- Closure of the unbounded exterior along a whole canonical edge interior
puts both endpoints of that edge on the graph-vertex frontier carrier. -/
theorem endpoints_mem_unboundedFrontierVertexSet_of_openSegment_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ (canonicalGraph C).edgeSet)
    (hclosure :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ closure (unboundedExteriorComponentRows C inputs).exterior) :
    e.1 ∈ unboundedFrontierVertexSet C inputs ∧
      e.2 ∈ unboundedFrontierVertexSet C inputs :=
  endpoints_mem_unboundedFrontierVertexSet_of_edge_openSegment_frontier
    (edge_openSegment_frontier_of_edge_openSegment_closure he hclosure)

/-- Local propagation data at an interior frontier point of a canonical edge.
The radius is supplied by the finite-drawing edge-isolation lemma; inside that
ball, every nearby drawing point, hence every nearby unbounded-frontier point,
is carried by the same closed edge segment.  The remaining global propagation
step is to prove closure of the unbounded exterior along the whole open segment. -/
structure UnboundedExteriorFrontierEdgeLocalRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C)
    (e : PlanarInterface.Edge n)
    (p : PlanarInterface.Point) : Prop where
  edge_mem : e ∈ (canonicalGraph C).edgeSet
  center_in_openSegment :
    PlanarInterface.InOpenSegment p
      ((canonicalGraph C).point e.1)
      ((canonicalGraph C).point e.2)
  center_frontier :
    p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior
  center_mem_closure :
    p ∈ closure (unboundedExteriorComponentRows C inputs).exterior
  center_not_mem_exterior :
    p ∉ (unboundedExteriorComponentRows C inputs).exterior
  exists_local_radius :
    Exists fun radius : Real =>
      0 < radius /\
        (forall q : PlanarInterface.Point,
          q ∈ Metric.ball p radius ->
            q ∈ embeddedEdgeSet C ->
              q ∈ closedSegment
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2)) /\
