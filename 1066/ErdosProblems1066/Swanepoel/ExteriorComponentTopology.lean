    (C := C) (inputs := inputs)
    rows.orbit.boundary.length_pos
    rows.orbit.boundary.length_ge_three
    rows.carrierVertex
    (fun k => rows.carrier_adj_succ k)
    (by
    intro a
    have hfrontier :
        (canonicalGraph C).point a.1 ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior :=
      mem_unboundedFrontierVertexSet_iff.1 a.2
