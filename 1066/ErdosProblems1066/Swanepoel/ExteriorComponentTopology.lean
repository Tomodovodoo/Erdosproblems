/-- The exact whole-edge frontier row for S2: every selected ordered frontier
edge has its entire relative interior on the unbounded exterior frontier. -/
def UnboundedFrontierEdgeSetWholeOpenSegmentFrontier
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall e : PlanarInterface.Edge n,
    e ∈ unboundedFrontierEdgeSet C inputs ->
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior

/-- Interior points of a selected unbounded-frontier edge cannot lie in the
unbounded exterior component, because that component is contained in the
complement of the embedded drawing while the whole unit-edge segment belongs to
the drawing. -/
theorem unboundedFrontierEdgeSet_inOpenSegment_not_mem_unboundedExterior
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs)
    {p : PlanarInterface.Point}
    (hp :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2)) :
    p ∉ (unboundedExteriorComponentRows C inputs).exterior := by
  intro hpE
  have hpDraw : p ∈ embeddedEdgeSet C :=
    inOpenSegment_mem_embeddedEdgeSet_of_adj
      (unboundedFrontierEdgeSet_adj he) hp
  exact
    ((unboundedExteriorComponentRows C inputs).exterior_subset_drawingComplement
      hpE) hpDraw

/-- Closure form of the whole-edge row.  With the concrete carrier defined by
whole open frontier segments, this follows directly from the definition. -/
def UnboundedFrontierEdgeSetOpenSegmentClosure
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall e : PlanarInterface.Edge n,
    e ∈ unboundedFrontierEdgeSet C inputs ->
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ closure (unboundedExteriorComponentRows C inputs).exterior

/-- The concrete carrier definition gives closure of the exterior along every
selected edge interior. -/
theorem unboundedFrontierEdgeSetOpenSegmentClosure_of_definition
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C} :
    UnboundedFrontierEdgeSetOpenSegmentClosure C inputs := by
  intro e he p hp
  exact frontier_subset_closure ((mem_unboundedFrontierEdgeSet_iff.1 he).2 p hp)

/-- A selected exterior-boundary edge supplies the local nearby-exterior-points
row along its relative interior.  This is the genuine exterior-side source row:
the selected edge already has its whole open segment on the unbounded exterior
frontier, and the metric closure criterion turns frontier membership into
arbitrarily close exterior points. -/
theorem unboundedFrontierEdgeSet_nearby_edge_point_exterior_points
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs) :
    forall q : PlanarInterface.Point,
      PlanarInterface.InOpenSegment q
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2) ->
      q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
        Exists fun r : Real =>
          0 < r /\
            forall z : PlanarInterface.Point,
              z ∈ Metric.ball q r ->
              PlanarInterface.InOpenSegment z
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2) ->
              forall eps : Real,
                0 < eps ->
                  Exists fun y : PlanarInterface.Point =>
                    y ∈ (unboundedExteriorComponentRows C inputs).exterior /\
                      dist y z < eps := by
  intro q _hq _hqclosure
  refine ⟨1, by norm_num, ?_⟩
  intro z _hzball hzseg eps heps
  have hzfrontier :
      z ∈ frontier (unboundedExteriorComponentRows C inputs).exterior :=
    (mem_unboundedFrontierEdgeSet_iff.1 he).2 z hzseg
  have hzclosure :
      z ∈ closure (unboundedExteriorComponentRows C inputs).exterior :=
    frontier_subset_closure hzfrontier
  rw [Metric.mem_closure_iff] at hzclosure
  rcases hzclosure eps heps with ⟨y, hyExterior, hydist⟩
  exact ⟨y, hyExterior, by simpa [dist_comm] using hydist⟩

/-- The exact residual carrier-membership source is enough to build the
nearby-exterior-points source row for all canonical interior frontier points.
No cyclic coverage, arbitrary cycle, induced frontier shortcut, or carrier
connectedness is used here. -/
theorem interiorEdgeNearbyExteriorPointSource_of_interior_frontier_edge_carrier_membership
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (interior_edge_mem :
      InteriorFrontierEdgeCarrierMembershipSource C inputs) :
    InteriorEdgeNearbyExteriorPointSource C inputs := by
  intro e p he hpEdge hpFrontier
  exact
    unboundedFrontierEdgeSet_nearby_edge_point_exterior_points
      (C := C) (inputs := inputs) (e := e)
      (interior_edge_mem he hpEdge hpFrontier)

/-- Claim `S2-agent-interior-relative-ball-closure-source`, reduced to the
exact local carrier-membership theorem for interior frontier edges. -/
theorem S2_agent_interior_relative_ball_closure_source_of_interior_frontier_edge_carrier_membership
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (interior_edge_mem :
      InteriorFrontierEdgeCarrierMembershipSource C inputs) :
    InteriorRelativeBallClosureRow C inputs :=
  S2_agent_interior_relative_ball_closure_source
    (interiorEdgeNearbyExteriorPointSource_of_interior_frontier_edge_carrier_membership
      interior_edge_mem)

/-- Closure along selected edge interiors plus the drawing-complement
nonmembership row proves the whole-edge frontier row. -/
theorem unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (hclosure : UnboundedFrontierEdgeSetOpenSegmentClosure C inputs) :
    UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs := by
  intro e he p hp
  rw [(unboundedExteriorComponentRows C inputs).exterior_open.frontier_eq]
  exact
    ⟨hclosure e he p hp,
      unboundedFrontierEdgeSet_inOpenSegment_not_mem_unboundedExterior
        he hp⟩

/-- The concrete carrier definition supplies the whole-open-segment frontier
row. -/
theorem unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C} :
    UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs := by
  intro e he p hp
  exact (mem_unboundedFrontierEdgeSet_iff.1 he).2 p hp

/-- A selected frontier edge has frontier endpoints once the whole-edge
frontier row is available. -/
theorem endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs)
    {e : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs) :
    e.1 ∈ unboundedFrontierVertexSet C inputs ∧
      e.2 ∈ unboundedFrontierVertexSet C inputs :=
  endpoints_mem_unboundedFrontierVertexSet_of_edge_openSegment_frontier
    (hwhole e he)

/-- The actual finite boundary-edge carrier graph on unbounded-frontier
vertices.  Its edges are exactly ordered canonical graph edges whose relative
interiors meet the unbounded exterior frontier. -/
noncomputable def unboundedFrontierCarrierGraph
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    SimpleGraph {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} where
  Adj a b :=
    (a.1, b.1) ∈ unboundedFrontierEdgeSet C inputs \/
      (b.1, a.1) ∈ unboundedFrontierEdgeSet C inputs
  symm := by
    intro a b h
    exact h.symm
  loopless := by
    refine ⟨fun a h => ?_⟩
    rcases h with h | h
    · have hordered :
          (a.1, a.1).1 < (a.1, a.1).2 :=
        (canonicalGraph C).edge_mem_ordered
          (mem_unboundedFrontierEdgeSet_iff.1 h).1
      exact (lt_irrefl a.1) hordered
    · have hordered :
          (a.1, a.1).1 < (a.1, a.1).2 :=
        (canonicalGraph C).edge_mem_ordered
          (mem_unboundedFrontierEdgeSet_iff.1 h).1
      exact (lt_irrefl a.1) hordered

theorem unboundedFrontierCarrierGraph_adj_iff
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}} :
    (unboundedFrontierCarrierGraph C inputs).Adj a b ↔
      (a.1, b.1) ∈ unboundedFrontierEdgeSet C inputs \/
        (b.1, a.1) ∈ unboundedFrontierEdgeSet C inputs :=
  Iff.rfl

/-- The concrete unbounded-frontier carrier has decidable adjacency by
classical decidability of the finite edge set predicate. -/
noncomputable def unboundedFrontierCarrierGraph_decidableAdj
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    DecidableRel (unboundedFrontierCarrierGraph C inputs).Adj := by
  classical
  infer_instance

theorem unboundedFrontierCarrierGraph_adj_of_ordered_edge
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (hab : (a.1, b.1) ∈ unboundedFrontierEdgeSet C inputs) :
    (unboundedFrontierCarrierGraph C inputs).Adj a b :=
  (unboundedFrontierCarrierGraph_adj_iff).2 (Or.inl hab)

theorem unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (hba : (b.1, a.1) ∈ unboundedFrontierEdgeSet C inputs) :
    (unboundedFrontierCarrierGraph C inputs).Adj a b :=
  (unboundedFrontierCarrierGraph_adj_iff).2 (Or.inr hba)

/-- Whole-open-segment frontier evidence promotes a canonical ordered edge to
an adjacency in the concrete unbounded-frontier carrier graph. -/
theorem unboundedFrontierCarrierGraph_adj_of_edge_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ (canonicalGraph C).edgeSet)
    (hseg :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    (unboundedFrontierCarrierGraph C inputs).Adj
      ⟨e.1,
        (endpoints_mem_unboundedFrontierVertexSet_of_edge_openSegment_frontier
          hseg).1⟩
      ⟨e.2,
        (endpoints_mem_unboundedFrontierVertexSet_of_edge_openSegment_frontier
          hseg).2⟩ := by
  exact unboundedFrontierCarrierGraph_adj_of_ordered_edge
    (mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier he hseg)

/-- A cycle edge whose whole relative interior lies on the unbounded exterior
frontier determines a selected concrete frontier-carrier edge, up to the
stored ordering of canonical graph edges. -/
theorem cycle_edge_mem_unboundedFrontierEdgeSet_or_symm_of_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (cycle_edge_openSegment_frontier :
      forall k : Fin B.length,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (B.vertex k))
            ((canonicalGraph C).point
              (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (k : Fin B.length) :
    (B.vertex k,
        B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
        unboundedFrontierEdgeSet C inputs ∨
      (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
        B.vertex k) ∈ unboundedFrontierEdgeSet C inputs := by
  rcases B.adjacent k with h | h
  · left
    exact
      mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier
        (e :=
          (B.vertex k,
            B.vertex (PlanarInterface.cyclicSucc B.length_pos k)))
        h
        (cycle_edge_openSegment_frontier k)
  · right
    exact
      mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier
        (e :=
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
            B.vertex k))
        h
        (by
          intro p hp
          exact cycle_edge_openSegment_frontier k p
            (inOpenSegment_symm hp))

/-- If every consecutive boundary-cycle side is a selected edge of the actual
unbounded-frontier carrier, then its whole relative interior lies on the actual
unbounded exterior frontier.

This is the converse direction to
`cycle_edge_mem_unboundedFrontierEdgeSet_or_symm_of_openSegment_frontier` and is
the sharper source for the cycle-edge frontier row: the input is membership in
`unboundedFrontierEdgeSet C inputs`, not an arbitrary cycle-level frontier
assertion. -/
theorem cycle_edge_openSegment_frontier_of_unboundedFrontierEdgeSet_or_symm
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (cycle_edge_mem :
      forall k : Fin B.length,
        (B.vertex k,
            B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
            unboundedFrontierEdgeSet C inputs ∨
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
            B.vertex k) ∈
            unboundedFrontierEdgeSet C inputs) :
    forall k : Fin B.length,
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (B.vertex k))
          ((canonicalGraph C).point
            (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  intro k p hp
  rcases cycle_edge_mem k with hforward | hreverse
  · exact (mem_unboundedFrontierEdgeSet_iff.1 hforward).2 p hp
  · exact (mem_unboundedFrontierEdgeSet_iff.1 hreverse).2 p
      (inOpenSegment_symm hp)

/-- The consecutive boundary-cycle open-segment frontier row is equivalent to
membership of every boundary side in the actual unbounded-frontier edge carrier
up to stored orientation. -/
theorem cycle_edge_openSegment_frontier_iff_unboundedFrontierEdgeSet_or_symm
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C} :
    (forall k : Fin B.length,
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (B.vertex k))
          ((canonicalGraph C).point
            (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) ↔
      forall k : Fin B.length,
        (B.vertex k,
            B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
            unboundedFrontierEdgeSet C inputs ∨
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
            B.vertex k) ∈
            unboundedFrontierEdgeSet C inputs := by
  constructor
  · exact cycle_edge_mem_unboundedFrontierEdgeSet_or_symm_of_openSegment_frontier
  · exact cycle_edge_openSegment_frontier_of_unboundedFrontierEdgeSet_or_symm

/-- Boundary-cycle vertex/frontier equivalence plus whole-edge frontier
membership gives the concrete carrier adjacency from a cycle vertex to its
successor.  The harder incident-neighbour exclusion remains a separate
geometric row. -/
theorem unboundedFrontierCarrierGraph_adj_of_cycle_edge_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (frontier_iff_cycle_vertex :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin B.length => B.vertex k = v)
    (cycle_edge_openSegment_frontier :
      forall k : Fin B.length,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (B.vertex k))
            ((canonicalGraph C).point
              (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (k : Fin B.length) :
    (unboundedFrontierCarrierGraph C inputs).Adj
      ⟨B.vertex k,
        mem_unboundedFrontierVertexSet_iff.2
          ((frontier_iff_cycle_vertex (B.vertex k)).2 ⟨k, rfl⟩)⟩
      ⟨B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
        mem_unboundedFrontierVertexSet_iff.2
          ((frontier_iff_cycle_vertex
            (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))).2
            ⟨PlanarInterface.cyclicSucc B.length_pos k, rfl⟩)⟩ := by
  rcases
      cycle_edge_mem_unboundedFrontierEdgeSet_or_symm_of_openSegment_frontier
        cycle_edge_openSegment_frontier k with
    h | h
  · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge h
  · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm h

/-- Selected ordered frontier edges become concrete carrier adjacencies once
the whole-edge frontier row supplies endpoint membership. -/
theorem unboundedFrontierCarrierGraph_adj_of_unboundedFrontierEdgeSet
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs)
    {e : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs) :
    (unboundedFrontierCarrierGraph C inputs).Adj
      ⟨e.1,
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole he).1⟩
      ⟨e.2,
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole he).2⟩ :=
  unboundedFrontierCarrierGraph_adj_of_ordered_edge he

/-- Carrier adjacency always maps to a canonical unit-distance edge. -/
theorem unboundedFrontierCarrierGraph_adj_canonicalAdj
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (hab : (unboundedFrontierCarrierGraph C inputs).Adj a b) :
    (canonicalGraph C).Adj a.1 b.1 := by
  rcases hab with hab | hba
  · exact unboundedFrontierEdgeSet_adj hab
  · exact canonicalAdj_symm (unboundedFrontierEdgeSet_adj hba)

/-- With the whole-edge frontier row, every concrete carrier adjacency is an
actual exterior-frontier open segment. -/
theorem unboundedFrontierCarrierGraph_openSegment_frontier_of_adj
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs)
    {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    (hab : (unboundedFrontierCarrierGraph C inputs).Adj a b) :
    forall p : PlanarInterface.Point,
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point a.1)
        ((canonicalGraph C).point b.1) ->
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  intro p hp
  rcases hab with hab | hba
  · exact hwhole (a.1, b.1) hab p hp
  · exact hwhole (b.1, a.1) hba p (inOpenSegment_symm hp)

/-- A local two-germ frontier containment row at a carrier vertex rules out all
other concrete unbounded-frontier carrier neighbours.

The row is deliberately phrased just at the vertex `a`: after shrinking to a
ball around `a`, every exterior-frontier point in that ball is carried by the
left or right incident vertex germ.  Given any carrier neighbour `b`, a
frontier point on the open segment from `a` to `b` can be chosen inside the
ball; the same-left unit-edge uniqueness lemma then identifies `b` with the
corresponding germ endpoint. -/
theorem unboundedFrontierCarrierGraph_only_of_local_frontier_germ_two
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}}
    {left right : Fin n}
    (hleft : (canonicalGraph C).Adj a.1 left)
    (hright : (canonicalGraph C).Adj a.1 right)
    (hlocal :
      Exists fun ε : Real =>
        0 < ε ∧
          forall q : PlanarInterface.Point,
            q ∈ Metric.ball ((canonicalGraph C).point a.1) ε ->
              q ∈ frontier
                (unboundedExteriorComponentRows C inputs).exterior ->
                q ∈ vertexIncidentGermW3 C a.1 left ε ∨
                  q ∈ vertexIncidentGermW3 C a.1 right ε) :
    forall b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      (unboundedFrontierCarrierGraph C inputs).Adj a b ->
        b.1 = left ∨ b.1 = right := by
  rcases hlocal with ⟨ε, hεpos, hlocal⟩
  intro b hab
  have hab_canonical : (canonicalGraph C).Adj a.1 b.1 :=
    unboundedFrontierCarrierGraph_adj_canonicalAdj hab
  have hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
    unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
  have hfrontier_on_ab :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point a.1)
          ((canonicalGraph C).point b.1) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior :=
    unboundedFrontierCarrierGraph_openSegment_frontier_of_adj hwhole hab
  have hclosure_left :
      (canonicalGraph C).point a.1 ∈
        closure
          ({p : PlanarInterface.Point |
            PlanarInterface.InOpenSegment p
              ((canonicalGraph C).point a.1)
              ((canonicalGraph C).point b.1)}) :=
    left_mem_closure_inOpenSegment
      ((canonicalGraph C).point a.1)
      ((canonicalGraph C).point b.1)
  rw [Metric.mem_closure_iff] at hclosure_left
  rcases hclosure_left ε hεpos with ⟨p, hpopen_ab, hpball⟩
  have hpball_mem :
      p ∈ Metric.ball ((canonicalGraph C).point a.1) ε := by
    simpa [Metric.mem_ball, dist_comm] using hpball
  have hpfrontier :
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior :=
    hfrontier_on_ab p hpopen_ab
  rcases hlocal p hpball_mem hpfrontier with hpgerm | hpgerm
  · rcases hpgerm with ⟨_hpball, hpclosed⟩
    rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hpclosed with
      hpa | hpleft | hpopen_left
    · exact False.elim
        (graph_vertex_not_inOpenSegment_of_adj
          (C := C) (v := a.1) hab_canonical
          (by simpa [hpa] using hpopen_ab))
    · exact False.elim
        (graph_vertex_not_inOpenSegment_of_adj
          (C := C) (v := left) hab_canonical
          (by simpa [hpleft] using hpopen_ab))
    · exact Or.inl
        (same_left_inOpenSegment_other_endpoint_eq
          hab_canonical hleft hpopen_ab hpopen_left)
  · rcases hpgerm with ⟨_hpball, hpclosed⟩
    rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hpclosed with
      hpa | hpright | hpopen_right
    · exact False.elim
        (graph_vertex_not_inOpenSegment_of_adj
          (C := C) (v := a.1) hab_canonical
          (by simpa [hpa] using hpopen_ab))
    · exact False.elim
        (graph_vertex_not_inOpenSegment_of_adj
          (C := C) (v := right) hab_canonical
          (by simpa [hpright] using hpopen_ab))
    · exact Or.inr
        (same_left_inOpenSegment_other_endpoint_eq
          hab_canonical hright hpopen_ab hpopen_right)

/-- Local vertex-star isolation plus angular exclusion cuts the exterior
frontier near a boundary vertex down to the two selected exterior germs.

The geometric input `bad_germ_between` is the local angular-order fact: if a
nearby noncenter exterior-frontier point is carried by an incident germ other
than the selected predecessor/successor germs, that incident edge points into
the open angular sector between them.  The center case is already in each
closed incident germ, so the `no_between` row only has to rule out the
nondegenerate cases. -/
theorem exists_local_frontier_germ_two_of_vertex_star_isolation_and_angular_no_between
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (k : Fin B.length)
    (bad_germ_between :
      forall (ε : Real) (q : PlanarInterface.Point) (x : Fin n),
        q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) ε ->
          q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
            (canonicalGraph C).Adj (B.vertex k) x ->
              q ∈ vertexIncidentGermW3 C (B.vertex k) x ε ->
                q ≠ (canonicalGraph C).point (B.vertex k) ->
                x ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
                  x ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
                    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
                      C B k x)
    (no_between :
      forall x : Fin n,
        GraphBridge.UnitDistanceAdj C (B.vertex k) x ->
          x ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
            x ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
              ¬
                _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
                  C B k x) :
    Exists fun ε : Real =>
      0 < ε ∧
        forall q : PlanarInterface.Point,
          q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) ε ->
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
              q ∈ vertexIncidentGermW3 C (B.vertex k)
                    (B.vertex (PlanarInterface.cyclicPred B.length_pos k)) ε ∨
                q ∈ vertexIncidentGermW3 C (B.vertex k)
                    (B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ε := by
  rcases
      exists_ball_forall_unboundedExterior_frontier_mem_vertexIncidentGermW3
        C inputs (B.vertex k) with
    ⟨ε, hεpos, hstar⟩
  refine ⟨ε, hεpos, ?_⟩
  intro q hqball hqfrontier
  by_cases hqcenter :
      q = (canonicalGraph C).point (B.vertex k)
  · left
    rw [hqcenter]
    exact
      ⟨by
          simpa [Metric.mem_ball] using hεpos,
        left_mem_closedSegment _ _⟩
  rcases hstar q hqball hqfrontier with ⟨x, hvx, hqx⟩
  by_cases hx_pred :
      x = B.vertex (PlanarInterface.cyclicPred B.length_pos k)
  · left
    simpa [hx_pred] using hqx
  by_cases hx_succ :
      x = B.vertex (PlanarInterface.cyclicSucc B.length_pos k)
  · right
    simpa [hx_succ] using hqx
  have hx_unit : GraphBridge.UnitDistanceAdj C (B.vertex k) x :=
    ((canonicalGraph C).adj_iff_unitDistanceAdj (B.vertex k) x).1 hvx
  have hbetween :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.BoundaryPredSuccAngularBetween
        C B k x :=
    bad_germ_between ε q x hqball hqfrontier hvx hqx hqcenter hx_pred hx_succ
  exact False.elim ((no_between x hx_unit hx_pred hx_succ) hbetween)

/-- The vector from the left endpoint to a parametrized point of a segment is
the positive/zero real multiple of the whole segment vector. -/
theorem dartVector_segmentPoint_eq_real_mul
    (a b : PlanarInterface.Point) (t : Real) :
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartVector
        a (PlanarInterface.segmentPoint a b t) =
      (t : Complex) *
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartVector
          a b := by
  rw [_root_.Complex.ext_iff]
  constructor <;>
    simp [
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartVector,
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.pointToComplex,
      PlanarInterface.segmentPoint] <;>
    ring

/-- A non-left-endpoint point on a closed segment has the same principal ray
angle from the left endpoint as the right endpoint. -/
theorem dartArg_eq_of_mem_closedSegment_ne_left
    {a b q : PlanarInterface.Point}
    (hqseg : q ∈ closedSegment a b)
    (hqne : q ≠ a) :
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg a q =
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg a b := by
  rcases hqseg with ⟨t, ht0, _ht1, hq⟩
  have htpos : 0 < t := by
    refine lt_of_le_of_ne ht0 ?_
    intro ht
    apply hqne
    have ht' : t = 0 := ht.symm
    rw [hq, ht']
    simp [PlanarInterface.segmentPoint]
  calc
    _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg a q =
        Complex.arg
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartVector
            a q) := rfl
    _ = Complex.arg
          ((t : Complex) *
            _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartVector
              a b) := by
        rw [hq]
        congr 1
        exact dartVector_segmentPoint_eq_real_mul a b t
    _ = Complex.arg
          (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartVector
            a b) := by
        simpa using
          Complex.arg_real_mul
            (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartVector
              a b)
            htpos
    _ =
        _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.dartArg
          a b := rfl

/-- The point-ray form of the local exterior sector at a boundary vertex:
the ray from the boundary vertex to `q` lies strictly between the predecessor
and successor boundary rays. -/
