/-- Following the raw face-successor orbit gives a carrier-graph path from the
initial raw tail to any later raw tail.

This is the graph-theoretic reachability core of the raw-root source: it uses
the actual whole-open-segment frontier row for consecutive raw tails, and does
not pass through cyclic coverage rows. -/
theorem rawFaceSuccOrbit_tail_reachable_from_zero_of_edge_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (k : Fin O.period) :
    (unboundedFrontierCarrierGraph C inputs).Reachable
      ⟨(O.dart ⟨0, O.period_pos⟩).tail,
        rawFaceSuccOrbit_tail_mem_unboundedFrontierVertexSet
          O edge_openSegment_frontier ⟨0, O.period_pos⟩⟩
      ⟨(O.dart k).tail,
        rawFaceSuccOrbit_tail_mem_unboundedFrontierVertexSet
          O edge_openSegment_frontier k⟩ := by
  classical
  let tail_mem :
      forall k : Fin O.period,
        (O.dart k).tail ∈ unboundedFrontierVertexSet C inputs :=
    rawFaceSuccOrbit_tail_mem_unboundedFrontierVertexSet
      O edge_openSegment_frontier
  let tailVertex
      (k : Fin O.period) :
      {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨(O.dart k).tail, tail_mem k⟩
  have step :
      forall i : Fin O.period,
        (unboundedFrontierCarrierGraph C inputs).Adj
          (tailVertex i)
          (tailVertex (PlanarInterface.cyclicSucc O.period_pos i)) := by
    intro i
    rcases
        rawFaceSuccOrbit_edge_mem_unboundedFrontierEdgeSet_or_symm
          O edge_openSegment_frontier i with
      hedge | hedge
    · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge hedge
    · exact unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm hedge
  have reach_nat :
      forall m : Nat,
        forall hm : m < O.period,
          (unboundedFrontierCarrierGraph C inputs).Reachable
            (tailVertex ⟨0, O.period_pos⟩)
            (tailVertex ⟨m, hm⟩) := by
    intro m
    induction m with
    | zero =>
        intro hm
        exact SimpleGraph.Reachable.refl _
    | succ m ih =>
        intro hm
        have hm_prev : m < O.period := by omega
        have hsucc :
            PlanarInterface.cyclicSucc O.period_pos
                (⟨m, hm_prev⟩ : Fin O.period) =
              (⟨m + 1, hm⟩ : Fin O.period) := by
          exact Fin.ext (by
            simp [PlanarInterface.cyclicSucc, Nat.mod_eq_of_lt hm])
        have hstep :
            (unboundedFrontierCarrierGraph C inputs).Adj
              (tailVertex (⟨m, hm_prev⟩ : Fin O.period))
              (tailVertex (⟨m + 1, hm⟩ : Fin O.period)) := by
          simpa [tailVertex, hsucc] using
            step (⟨m, hm_prev⟩ : Fin O.period)
        exact
          (ih hm_prev).trans
            hstep.reachable
  simpa [tailVertex, tail_mem] using reach_nat k.val k.isLt

/-- Claim `S2-agent-raw-reachable-root-source`.

The selected raw face-successor orbit supplies the concrete carrier
reachability root once the exterior-orbit tracing row has shown that every
unbounded-frontier carrier vertex occurs as one of the raw tails.  The proof
walks along raw successor edges in the concrete `unboundedFrontierCarrierGraph`
and does not use cyclic carrier coverage. -/
theorem S2_agent_raw_reachable_root_source
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (frontier_vertex_tail_coverage :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        Exists fun k : Fin O.period => (O.dart k).tail = a.1) :
    (Exists fun root :
      {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} =>
        forall x :
          {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
            (unboundedFrontierCarrierGraph C inputs).Reachable root x) := by
  classical
  let tail_mem :
      forall k : Fin O.period,
        (O.dart k).tail ∈ unboundedFrontierVertexSet C inputs :=
    rawFaceSuccOrbit_tail_mem_unboundedFrontierVertexSet
      O edge_openSegment_frontier
  let root : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨(O.dart ⟨0, O.period_pos⟩).tail,
      tail_mem ⟨0, O.period_pos⟩⟩
  refine ⟨root, ?_⟩
  intro x
  rcases frontier_vertex_tail_coverage x with ⟨k, hk⟩
  have hreach :=
    rawFaceSuccOrbit_tail_reachable_from_zero_of_edge_openSegment_frontier
      (C := C) (inputs := inputs) O edge_openSegment_frontier k
  have hx :
      (⟨(O.dart k).tail, tail_mem k⟩ :
        {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) = x :=
    Subtype.ext hk
  simpa [root, tail_mem, hx] using hreach

/-- Local-sector rows close the raw-tail subset under all concrete carrier
neighbours once the raw orbit is known not to immediately reverse at any
frontier vertex.

The extra nonbacktracking row is deliberately explicit: without it, the raw
predecessor and successor tails may coincide, while a local-sector row still
supplies two distinct concrete frontier neighbours. -/
theorem rawFaceSuccOrbit_neighbor_tail_closed_of_localSectorRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (raw_pred_succ_tail_ne :
      forall k : Fin O.period,
        (O.dart (PlanarInterface.cyclicPred O.period_pos k)).tail ≠
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) :
    forall k : Fin O.period,
      forall hk :
        (O.dart k).tail ∈ unboundedFrontierVertexSet C inputs,
      forall b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        (unboundedFrontierCarrierGraph C inputs).Adj
          ⟨(O.dart k).tail, hk⟩ b ->
        Exists fun l : Fin O.period => (O.dart l).tail = b.1 := by
  classical
  let raw_edge_mem :
      forall k : Fin O.period,
        ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
            unboundedFrontierEdgeSet C inputs ∨
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
            (O.dart k).tail) ∈ unboundedFrontierEdgeSet C inputs :=
    rawFaceSuccOrbit_edge_mem_unboundedFrontierEdgeSet_or_symm
      O edge_openSegment_frontier
  let raw_tail_mem :
      forall k : Fin O.period,
        (O.dart k).tail ∈ unboundedFrontierVertexSet C inputs :=
    rawFaceSuccOrbit_tail_mem_unboundedFrontierVertexSet
      O edge_openSegment_frontier
  intro k hk b hab
  let a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨(O.dart k).tail, hk⟩
  let rows := localSectorRows a
  let pred : Fin O.period := PlanarInterface.cyclicPred O.period_pos k
  let succ : Fin O.period := PlanarInterface.cyclicSucc O.period_pos k
  let predVertex : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨(O.dart pred).tail, raw_tail_mem pred⟩
  let succVertex : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨(O.dart succ).tail, raw_tail_mem succ⟩
  have hpred_succ : PlanarInterface.cyclicSucc O.period_pos pred = k := by
    simpa [pred] using PlanarInterface.cyclicSucc_cyclicPred O.period_pos k
  have hpred_adj :
      (unboundedFrontierCarrierGraph C inputs).Adj a predVertex := by
    rcases raw_edge_mem pred with hedge | hedge
    · exact
        unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm
          (a := a) (b := predVertex)
          (by
            simpa [a, predVertex, pred, hpred_succ] using hedge)
    · exact
        unboundedFrontierCarrierGraph_adj_of_ordered_edge
          (a := a) (b := predVertex)
          (by
            simpa [a, predVertex, pred, hpred_succ] using hedge)
  have hsucc_adj :
      (unboundedFrontierCarrierGraph C inputs).Adj a succVertex := by
    rcases raw_edge_mem k with hedge | hedge
    · exact
        unboundedFrontierCarrierGraph_adj_of_ordered_edge
          (a := a) (b := succVertex)
          (by
            simpa [a, succVertex, succ] using hedge)
    · exact
        unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm
          (a := a) (b := succVertex)
          (by
            simpa [a, succVertex, succ] using hedge)
  have hpred_succ_ne : predVertex ≠ succVertex := by
    intro h
    have htail :
        (O.dart (PlanarInterface.cyclicPred O.period_pos k)).tail =
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail := by
      simpa [predVertex, succVertex, pred, succ] using congrArg Subtype.val h
    exact raw_pred_succ_tail_ne k htail
  have hpred_cases := (rows.neighbor_iff predVertex).1 hpred_adj
  have hsucc_cases := (rows.neighbor_iff succVertex).1 hsucc_adj
  have hb_cases := (rows.neighbor_iff b).1 (by simpa [a] using hab)
  have hb_raw : b = predVertex ∨ b = succVertex := by
    rcases hb_cases with hb_left | hb_right
    · rcases hpred_cases with hpred_left | hpred_right
      · exact Or.inl (hb_left.trans hpred_left.symm)
      · rcases hsucc_cases with hsucc_left | hsucc_right
        · exact Or.inr (hb_left.trans hsucc_left.symm)
        · exact False.elim
            (hpred_succ_ne (hpred_right.trans hsucc_right.symm))
    · rcases hpred_cases with hpred_left | hpred_right
      · rcases hsucc_cases with hsucc_left | hsucc_right
        · exact False.elim
            (hpred_succ_ne (hpred_left.trans hsucc_left.symm))
        · exact Or.inr (hb_right.trans hsucc_right.symm)
      · exact Or.inl (hb_right.trans hpred_right.symm)
  rcases hb_raw with hb_pred | hb_succ
  · exact ⟨pred, (congrArg Subtype.val hb_pred).symm⟩
  · exact ⟨succ, (congrArg Subtype.val hb_succ).symm⟩

/-- Tail injectivity plus period at least three gives the raw
predecessor/successor nonbacktracking row used by the local neighbour-closure
argument. -/
theorem rawFaceSuccOrbit_pred_succ_tail_ne_of_period_three_tail_injective
    {C : _root_.UDConfig n}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (period_ge_three : 3 <= O.period)
    (tail_injective :
      Function.Injective fun k : Fin O.period => (O.dart k).tail) :
    forall k : Fin O.period,
      (O.dart (PlanarInterface.cyclicPred O.period_pos k)).tail ≠
        (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail := by
  intro k htail
  exact
    (PlanarInterface.cyclicPred_ne_cyclicSucc_of_three_le
      O.period_pos period_ge_three k)
      (tail_injective htail)

/-- Closed-carrier source for raw-orbit tail coverage from independently
proved connectedness of the concrete carrier.

The raw edge-frontier row makes every raw tail a vertex of the concrete
unbounded-frontier carrier.  If the raw-tail subset is closed under all
carrier neighbours of its vertices, connectedness of that concrete carrier
forces every carrier vertex to occur as a raw tail.  This version takes
connectedness directly, so it does not need the cyclic coverage row that this
route is meant to source. -/
theorem rawFaceSuccOrbit_frontier_vertex_tail_coverage_of_carrier_connected_closed
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (hconn : (unboundedFrontierCarrierGraph C inputs).Connected)
    (neighbor_tail_closed :
      forall k : Fin O.period,
        forall hk :
          (O.dart k).tail ∈ unboundedFrontierVertexSet C inputs,
        forall b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
          (unboundedFrontierCarrierGraph C inputs).Adj
            ⟨(O.dart k).tail, hk⟩ b ->
            Exists fun l : Fin O.period => (O.dart l).tail = b.1) :
    forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      Exists fun k : Fin O.period => (O.dart k).tail = a.1 := by
  classical
  let G := unboundedFrontierCarrierGraph C inputs
  let covered
      (a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}) :
      Prop :=
    Exists fun k : Fin O.period => (O.dart k).tail = a.1
  have raw_edge_mem :
      forall k : Fin O.period,
        ((O.dart k).tail,
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
            unboundedFrontierEdgeSet C inputs ∨
          ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
            (O.dart k).tail) ∈ unboundedFrontierEdgeSet C inputs := by
    intro k
    have hadj :
        (canonicalGraph C).Adj
          (O.dart k).tail
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail := by
      exact
        ((canonicalGraph C).adj_iff_unitDistanceAdj
          (O.dart k).tail
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail).2
          ((GraphBridge.unitDistanceSimpleGraph_adj C
            (O.dart k).tail
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail).1
            (rawFaceSuccOrbit_tail_adj_cyclicSucc O k))
    exact
      unboundedFrontierEdgeSet_or_symm_of_adj_openSegment_frontier
        (C := C) (inputs := inputs) hadj (edge_openSegment_frontier k)
  have raw_tail_mem :
      forall k : Fin O.period,
        (O.dart k).tail ∈ unboundedFrontierVertexSet C inputs := by
    intro k
    let hwhole :
        UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
      unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
    rcases raw_edge_mem k with hedge | hedge
    · exact
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole hedge).1
    · exact
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole hedge).2
  have neighbor_closed :
      forall {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
        covered a ->
          (unboundedFrontierCarrierGraph C inputs).Adj a b ->
            covered b := by
    intro a b ha hab
    rcases ha with ⟨k, hk⟩
    have ha_eq :
        a = ⟨(O.dart k).tail, raw_tail_mem k⟩ := Subtype.ext hk.symm
    have hab_raw :
        (unboundedFrontierCarrierGraph C inputs).Adj
          ⟨(O.dart k).tail, raw_tail_mem k⟩ b := by
      simpa [G, ha_eq] using hab
    exact neighbor_tail_closed k (raw_tail_mem k) b hab_raw
  have walk_closed :
      forall {a b : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}},
        (unboundedFrontierCarrierGraph C inputs).Walk a b ->
          covered a ->
            covered b := by
    intro a b walk
    induction walk with
    | nil =>
        intro ha
        exact ha
    | cons hab rest ih =>
        intro ha
        exact ih (neighbor_closed ha hab)
  let root : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨(O.dart ⟨0, O.period_pos⟩).tail, raw_tail_mem ⟨0, O.period_pos⟩⟩
  have hroot : covered root := ⟨⟨0, O.period_pos⟩, rfl⟩
  intro a
  exact (hconn root a).elim fun walk => walk_closed walk hroot

/-- Claim `S2-agent-tail-coverage-from-connected-carrier`.

For the selected geometric raw face-successor orbit, the dart-edge frontier row
coming from the exterior-sector proof is enough to build the consecutive
raw-tail open-segment frontier row.  With independent connectedness of the
concrete unbounded-frontier carrier, and the local-sector neighbour-closure
row, this proves the positive raw-tail coverage statement without assuming
cyclic coverage. -/
theorem S2_agent_tail_coverage_from_connected_carrier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {start : UnitDistanceDart C}
    (O :
      UnitDistanceRotationSystem.RawFaceSuccOrbit
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C)
        start)
    (dart_edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point (O.dart k).head) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (carrier_connected : (unboundedFrontierCarrierGraph C inputs).Connected)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (raw_pred_succ_tail_ne :
      forall k : Fin O.period,
        (O.dart (PlanarInterface.cyclicPred O.period_pos k)).tail ≠
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) :
    forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      Exists fun k : Fin O.period => (O.dart k).tail = a.1 := by
  let edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
    intro k p hp
    let next : Fin O.period := PlanarInterface.cyclicSucc O.period_pos k
    have hsucc := rawFaceSuccOrbit_faceSucc_eq_cyclicSucc O k
    have hhead : (O.dart k).head = (O.dart next).tail := by
      simpa [next] using
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C).endpoint_chaining_of_faceSucc_eq_next hsucc
    exact dart_edge_openSegment_frontier k p (by simpa [next, hhead] using hp)
  exact
    rawFaceSuccOrbit_frontier_vertex_tail_coverage_of_carrier_connected_closed
      O edge_openSegment_frontier carrier_connected
      (rawFaceSuccOrbit_neighbor_tail_closed_of_localSectorRows
        O edge_openSegment_frontier localSectorRows raw_pred_succ_tail_ne)

/-- Claim `S2-agent-raw-tail-hit-from-exterior-frontier`.

For the selected geometric raw face-successor orbit, the actual exterior
frontier row on every raw dart edge hits all concrete unbounded-frontier
carrier vertices once the honest carrier is connected and the local-sector
rows close the raw-tail set under carrier neighbours.  This is only the
positive raw-tail coverage row; it does not assume cyclic coverage or a final
carrier cycle. -/
theorem S2_agent_raw_tail_hit_from_exterior_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {start : UnitDistanceDart C}
    (O :
      UnitDistanceRotationSystem.RawFaceSuccOrbit
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C)
        start)
    (dart_edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point (O.dart k).head) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (carrier_connected : (unboundedFrontierCarrierGraph C inputs).Connected)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (raw_pred_succ_tail_ne :
      forall k : Fin O.period,
        (O.dart (PlanarInterface.cyclicPred O.period_pos k)).tail ≠
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) :
    forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      Exists fun k : Fin O.period => (O.dart k).tail = a.1 :=
  S2_agent_tail_coverage_from_connected_carrier
    (C := C) (inputs := inputs) O
    dart_edge_openSegment_frontier
    carrier_connected
    localSectorRows
    raw_pred_succ_tail_ne

/-- Topology-row variant of
`S2_agent_raw_tail_hit_from_exterior_frontier`.

The raw dart-edge frontier row gives a concrete unbounded-frontier vertex, so
the adjacency-closed topology rows can be used directly to source connectedness
of the honest carrier before applying the raw-tail hit row. -/
theorem S2_agent_raw_tail_hit_from_exterior_frontier_topologyRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {start : UnitDistanceDart C}
    (O :
      UnitDistanceRotationSystem.RawFaceSuccOrbit
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C)
        start)
    (dart_edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point (O.dart k).head) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (topologyRows : UnboundedFrontierCarrierAdjClosedTopologySourceRows inputs)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (raw_pred_succ_tail_ne :
      forall k : Fin O.period,
        (O.dart (PlanarInterface.cyclicPred O.period_pos k)).tail ≠
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) :
    forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      Exists fun k : Fin O.period => (O.dart k).tail = a.1 := by
  let edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior :=
    rawFaceSuccOrbit_edge_openSegment_frontier_of_dart_edge_openSegment_frontier
      (inputs := inputs) O dart_edge_openSegment_frontier
  let frontier_vertices_nonempty :
      Nonempty {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨⟨(O.dart ⟨0, O.period_pos⟩).tail,
        rawFaceSuccOrbit_tail_mem_unboundedFrontierVertexSet
          O edge_openSegment_frontier ⟨0, O.period_pos⟩⟩⟩
  exact
    S2_agent_raw_tail_hit_from_exterior_frontier
      (C := C) (inputs := inputs) O
      dart_edge_openSegment_frontier
      (unboundedFrontierCarrierGraph_connected_of_adjClosed_topologyRows
        inputs frontier_vertices_nonempty topologyRows)
      localSectorRows
      raw_pred_succ_tail_ne

/-- The raw-tail hit row also gives the raw reachable-root handoff along the
selected exterior face-successor orbit. -/
theorem S2_agent_raw_tail_hit_reachable_root_from_exterior_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {start : UnitDistanceDart C}
    (O :
      UnitDistanceRotationSystem.RawFaceSuccOrbit
        (_root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.geometricUnitDistanceRotationSystem
          C)
        start)
    (dart_edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point (O.dart k).head) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (carrier_connected : (unboundedFrontierCarrierGraph C inputs).Connected)
    (localSectorRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalSectorRowsAt inputs a)
    (raw_pred_succ_tail_ne :
      forall k : Fin O.period,
        (O.dart (PlanarInterface.cyclicPred O.period_pos k)).tail ≠
          (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) :
    (forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
      Exists fun k : Fin O.period => (O.dart k).tail = a.1) ∧
      Exists fun root :
        {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} =>
          forall x :
            {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
