/-- Finite planar outer-component theorem from the direct same-`B` raw
face-successor boundary handoff. -/
def finitePlanarStraightLineOuterComponentTheorem_of_rawFaceSuccOrbitBoundaryRows
    (rows :
      forall {n : Nat} (C : _root_.UDConfig n)
        (inputs : FinitePlanarOuterComponentInputs C),
          Exists fun R : UnitDistanceRotationSystem C =>
            Exists fun start : UnitDistanceDart C =>
              Exists fun O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start =>
                Exists fun B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C =>
                  Exists fun hperiod : B.length = O.period =>
                    (forall k : Fin B.length,
                      (O.dart (Fin.cast hperiod k)).tail = B.vertex k) ∧
                    (forall v : Fin n,
                      (canonicalGraph C).point v ∈
                          frontier
                            (unboundedExteriorComponentRows C inputs).exterior ↔
                        Exists fun k : Fin O.period =>
                          (O.dart k).tail = v)) :
    FinitePlanarStraightLineOuterComponentTheorem :=
  finitePlanarStraightLineOuterComponentTheorem_of_unboundedExteriorFrontierCycleRows
    (fun C inputs =>
      let source := rows C inputs
      let R : UnitDistanceRotationSystem C := Classical.choose source
      let hstart := Classical.choose_spec source
      let start : UnitDistanceDart C := Classical.choose hstart
      let hO := Classical.choose_spec hstart
      let O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start :=
        Classical.choose hO
      let hB := Classical.choose_spec hO
      let B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C :=
        Classical.choose hB
      let hperiod_ex := Classical.choose_spec hB
      let hperiod : B.length = O.period := Classical.choose hperiod_ex
      let hrows := Classical.choose_spec hperiod_ex
      unboundedExteriorFrontierCycleRows_of_rawFaceSuccOrbitBoundaryRows
        O B hperiod hrows.1 hrows.2)

/-- Concrete-carrier family handoff for S2.  Once the actual
`unboundedFrontierCarrierGraph` is proved decidable, connected, two-regular,
and whole-edge-frontier for every `FinitePlanarOuterComponentInputs`, the
finite planar outer-component theorem follows. -/
noncomputable def finitePlanarStraightLineOuterComponentTheorem_of_frontierCarrierGraph_wholeRows
    (hdec :
      forall {n : Nat} (C : _root_.UDConfig n)
        (inputs : FinitePlanarOuterComponentInputs C),
          DecidableRel (unboundedFrontierCarrierGraph C inputs).Adj)
    (hconn :
      forall {n : Nat} (C : _root_.UDConfig n)
        (inputs : FinitePlanarOuterComponentInputs C),
          letI : DecidableRel (unboundedFrontierCarrierGraph C inputs).Adj :=
            hdec C inputs
          (unboundedFrontierCarrierGraph C inputs).Connected)
    (hdegree_two :
      forall {n : Nat} (C : _root_.UDConfig n)
        (inputs : FinitePlanarOuterComponentInputs C),
          letI : DecidableRel (unboundedFrontierCarrierGraph C inputs).Adj :=
            hdec C inputs
          forall v :
            {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
              @SimpleGraph.degree _
                (unboundedFrontierCarrierGraph C inputs) v
                ((unboundedFrontierCarrierGraph C inputs).neighborSetFintype v) =
                  2)
    (hwhole :
      forall {n : Nat} (C : _root_.UDConfig n)
        (inputs : FinitePlanarOuterComponentInputs C),
          UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs) :
    FinitePlanarStraightLineOuterComponentTheorem :=
  finitePlanarStraightLineOuterComponentTheorem_of_unboundedExteriorFrontierCycleRows
    (unboundedExteriorFrontierCycleRows_of_frontierCarrierGraph_wholeRows
      hdec hconn hdegree_two hwhole)

/-- Concrete-carrier family handoff with carrier-adjacency decidability already
discharged.  The remaining S2 inputs are exactly connectedness, degree two, and
whole-edge-frontier for the actual unbounded-frontier carrier. -/
noncomputable def finitePlanarStraightLineOuterComponentTheorem_of_frontierCarrierGraph_geometricRows
    (hconn :
      forall {n : Nat} (C : _root_.UDConfig n)
        (inputs : FinitePlanarOuterComponentInputs C),
          letI : DecidableRel (unboundedFrontierCarrierGraph C inputs).Adj :=
            unboundedFrontierCarrierGraph_decidableAdj C inputs
          (unboundedFrontierCarrierGraph C inputs).Connected)
    (hdegree_two :
      forall {n : Nat} (C : _root_.UDConfig n)
        (inputs : FinitePlanarOuterComponentInputs C),
          letI : DecidableRel (unboundedFrontierCarrierGraph C inputs).Adj :=
            unboundedFrontierCarrierGraph_decidableAdj C inputs
          forall v :
            {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
              @SimpleGraph.degree _
                (unboundedFrontierCarrierGraph C inputs) v
                ((unboundedFrontierCarrierGraph C inputs).neighborSetFintype v) =
                  2)
    (hwhole :
      forall {n : Nat} (C : _root_.UDConfig n)
        (inputs : FinitePlanarOuterComponentInputs C),
          UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs) :
    FinitePlanarStraightLineOuterComponentTheorem :=
  finitePlanarStraightLineOuterComponentTheorem_of_unboundedExteriorFrontierCycleRows
    (unboundedExteriorFrontierCycleRows_of_frontierCarrierGraph_geometricRows
      hconn hdegree_two hwhole)

/-- Finite planar outer-component theorem from cyclic coverage of the concrete
carrier plus local dart-pair rows. -/
noncomputable def finitePlanarStraightLineOuterComponentTheorem_of_cyclicCoverageDartPairRows
    (hcycle :
      forall {n : Nat} (C : _root_.UDConfig n)
        (inputs : FinitePlanarOuterComponentInputs C),
          UnboundedFrontierCarrierCyclicCoverageRows C inputs)
    (hdart :
      forall {n : Nat} (C : _root_.UDConfig n)
        (inputs : FinitePlanarOuterComponentInputs C),
          forall a :
            {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
              UnboundedFrontierCarrierDartPairAt inputs a) :
    FinitePlanarStraightLineOuterComponentTheorem :=
  finitePlanarStraightLineOuterComponentTheorem_of_unboundedExteriorFrontierCycleRows
    (unboundedExteriorFrontierCycleRows_of_cyclicCoverageDartPairRows
      hcycle hdart)

/-- Finite planar outer-component theorem from the compact concrete-carrier
source rows: cyclic coverage of the actual unbounded-frontier carrier and
local sector rows at every selected carrier vertex. -/
noncomputable def finitePlanarStraightLineOuterComponentTheorem_of_cyclicCoverageLocalSectorRows
    (rows :
      forall {n : Nat} (C : _root_.UDConfig n)
        (inputs : FinitePlanarOuterComponentInputs C),
          Nonempty
            (UnboundedFrontierCarrierCyclicCoverageRows C inputs ×
              (forall a :
                {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
                  UnboundedFrontierCarrierLocalSectorRowsAt inputs a))) :
    FinitePlanarStraightLineOuterComponentTheorem :=
  finitePlanarStraightLineOuterComponentTheorem_of_unboundedExteriorFrontierCycleRows
    (unboundedExteriorFrontierCycleRows_of_cyclicCoverageLocalSectorRows rows)

/-- Finite planar outer-component theorem from the complete exterior
boundary-cycle source shape.

This is a consumer route only: the source theorem still has to construct the
boundary cycle, prove frontier-vertex exactness, prove selected boundary sides,
and prove incident-edge completeness. -/
noncomputable def finitePlanarStraightLineOuterComponentTheorem_of_exists_boundaryCycle_complete
    (rows :
      forall {n : Nat} (C : _root_.UDConfig n)
        (inputs : FinitePlanarOuterComponentInputs C),
          Exists fun B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C =>
            (forall v : Fin n,
              (canonicalGraph C).point v ∈
                  frontier (unboundedExteriorComponentRows C inputs).exterior ↔
                Exists fun k : Fin B.length => B.vertex k = v) ∧
            (forall k : Fin B.length,
              (B.vertex k,
                  B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
                  unboundedFrontierEdgeSet C inputs ∨
                (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
                  B.vertex k) ∈
                  unboundedFrontierEdgeSet C inputs) ∧
            BoundaryCycleIncidentFrontierEdgeCompleteness inputs B) :
    FinitePlanarStraightLineOuterComponentTheorem :=
  finitePlanarStraightLineOuterComponentTheorem_of_unboundedExteriorFrontierCycleRows
    (fun C inputs =>
      unboundedExteriorFrontierCycleRows_of_exists_boundaryCycle_complete
        inputs (rows C inputs))

/-- Finite planar outer-component theorem from the primitive local-sector
source shape.

This is the direct consumer for the repaired route: the source theorem
constructs the actual exterior boundary cycle, proves graph-vertex frontier
exactness, and supplies the local exterior-sector rows at its vertices.  The
successor-edge and incident-completeness data are read from those sector rows. -/
noncomputable def finitePlanarStraightLineOuterComponentTheorem_of_boundaryVertexExteriorSectorRows
    (rows :
      forall {n : Nat} (C : _root_.UDConfig n)
        (inputs : FinitePlanarOuterComponentInputs C),
          Exists fun B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C =>
            (forall v : Fin n,
              (canonicalGraph C).point v ∈
                  frontier (unboundedExteriorComponentRows C inputs).exterior ↔
                Exists fun k : Fin B.length => B.vertex k = v) ∧
            (forall k : Fin B.length,
              BoundaryVertexExteriorSectorRowsAt inputs B k)) :
    FinitePlanarStraightLineOuterComponentTheorem :=
  finitePlanarStraightLineOuterComponentTheorem_of_unboundedExteriorFrontierCycleRows
    (fun C inputs =>
      let source := rows C inputs
      let B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C :=
        Classical.choose source
      let hsource := Classical.choose_spec source
      unboundedExteriorFrontierCycleRows_of_boundaryVertexExteriorSectorRows
        B hsource.1 hsource.2)

/-- Finite planar outer-component theorem from orbit-first exterior face-dart
carrier rows. -/
noncomputable def finitePlanarStraightLineOuterComponentTheorem_of_faceDartOrbitExteriorCarrierRows
    (rows :
      forall {n : Nat} (C : _root_.UDConfig n)
        (inputs : FinitePlanarOuterComponentInputs C),
          FaceDartOrbitExteriorCarrierRows C inputs) :
    FinitePlanarStraightLineOuterComponentTheorem :=
  finitePlanarStraightLineOuterComponentTheorem_of_unboundedExteriorFrontierCycleRows
    (unboundedExteriorFrontierCycleRows_of_faceDartOrbitExteriorCarrierRows rows)

/-- Honest carrier rows are enough for the finite planar outer-component
theorem.  This is only an erasing reducer: the proof obligation remains the
construction of `ExteriorFrontierCarrierRows` from
`FinitePlanarOuterComponentInputs`. -/
def finitePlanarStraightLineOuterComponentTheorem_of_exteriorFrontierCarrierRows
    (rows :
      forall {n : Nat} (C : _root_.UDConfig n),
        (inputs : FinitePlanarOuterComponentInputs C) ->
          Nonempty (ExteriorFrontierCarrierRows C inputs)) :
    FinitePlanarStraightLineOuterComponentTheorem :=
  finitePlanarStraightLineOuterComponentTheorem_of_unboundedExteriorFrontierCycleRows
    (unboundedExteriorFrontierCycleRows_of_carrierRows rows)

end

