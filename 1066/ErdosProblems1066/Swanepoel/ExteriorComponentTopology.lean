/-!
# Exterior component topology rows for S2

This file records the next honest S2 reduction after the finite drawing layer:
once an exterior component of the complement of the embedded unit-edge drawing
has a frontier carried by a selected unit-distance cycle, the off-cycle
not-in-exterior row is automatic for all graph vertices.
-/

namespace ErdosProblems1066
namespace Swanepoel
namespace ExteriorComponentTopology

open JordanTopologyFactsConcrete
open JordanTopologyFactsConcrete.MinimalFailureTopology
open FinitePlaneDrawing
open JordanTopologyExteriorEnclosure

noncomputable section

universe u

variable {n : Nat}

section FiniteTwoRegularGraph

variable {V : Type u}

/-- A surjective graph homomorphism from a finite cycle graph transports
connectedness to the target graph. -/
theorem simpleGraph_connected_of_cycleGraph_surjective_hom
    {G : SimpleGraph V} {m : Nat} (hm : 0 < m)
    (x : Fin m -> V)
    (hadj :
      forall {i j : Fin m},
        (SimpleGraph.cycleGraph m).Adj i j -> G.Adj (x i) (x j))
    (hcover : forall v : V, Exists fun i : Fin m => x i = v) :
    G.Connected := by
  classical
  let phi : SimpleGraph.Hom (SimpleGraph.cycleGraph m) G := {
    toFun := x
    map_rel' := by
      intro i j hij
      exact hadj hij }
  have hsurj : Function.Surjective phi := by
    intro v
    rcases hcover v with ⟨i, hi⟩
    exact ⟨i, hi⟩
  have hnonempty : Nonempty (Fin m) := Fin.pos_iff_nonempty.mp hm
  have hcycle : (SimpleGraph.cycleGraph m).Connected := by
    rw [SimpleGraph.connected_iff]
    exact ⟨SimpleGraph.cycleGraph_preconnected, hnonempty⟩
  exact hcycle.map phi hsurj

theorem isCycles_of_degree_eq_two
    [Fintype V]
    (F : SimpleGraph V) [DecidableRel F.Adj]
    (hdegree_two : forall v : V, F.degree v = 2) :
    F.IsCycles := by
  intro v _hv
  rw [show (F.neighborSet v).ncard = F.degree v by
    rw [Set.ncard_eq_toFinset_card]
    simp [SimpleGraph.degree, SimpleGraph.neighborFinset]]
  exact hdegree_two v

theorem connected_two_regular_spanning_cycle
    [Fintype V]
    (F : SimpleGraph V) [DecidableRel F.Adj]
    (hconn : F.Connected)
    (hdegree_two : forall v : V, F.degree v = 2) :
    Exists fun base : V =>
      Exists fun w : F.Walk base base =>
        And w.IsCycle (forall v : V, Set.Mem w.toSubgraph.verts v) := by
  classical
  have hcycF : F.IsCycles :=
    isCycles_of_degree_eq_two F hdegree_two
  cases hconn.nonempty with
  | intro v0 =>
    have hnv0 : (F.neighborSet v0).Nonempty := by
      have hdeg : F.degree v0 = 2 := hdegree_two v0
      rw [SimpleGraph.degree] at hdeg
      have hcardpos : 0 < (F.neighborFinset v0).card := by omega
      cases Finset.card_pos.mp hcardpos with
      | intro w hw =>
        exact Exists.intro w (by simpa [SimpleGraph.neighborFinset] using hw)
    let c : F.ConnectedComponent := F.connectedComponentMk v0
    have hv0c : Set.Mem c.supp v0 :=
      (SimpleGraph.ConnectedComponent.mem_supp_iff c v0).2 rfl
    cases hcycF.exists_cycle_toSubgraph_verts_eq_connectedComponentSupp
        (c := c) (v := v0) hv0c hnv0 with
    | intro p hp =>
      cases hp with
      | intro hpcycle hpverts =>
        exact Exists.intro v0 (Exists.intro p (And.intro hpcycle (by
          intro v
          have hvc : Set.Mem c.supp v :=
            (SimpleGraph.ConnectedComponent.mem_supp_iff c v).2
              ((SimpleGraph.ConnectedComponent.eq (G := F)).2
                (hconn.preconnected v v0))
          rw [hpverts]
          exact hvc)))

/-- Map a spanning finite graph cycle injectively into the unit-distance graph
of a `UDConfig`, producing the concrete cycle-boundary object used by the S2
topology rows. -/
theorem exists_unitDistanceCycleBoundary_covering_spanning_cycle_hom
    {C : _root_.UDConfig n}
    (F : SimpleGraph V)
    (phi : SimpleGraph.Hom F (GraphBridge.unitDistanceSimpleGraph C))
    (hphi : Function.Injective phi)
    (hspan : Exists fun base : V =>
      Exists fun w : F.Walk base base =>
        And w.IsCycle (forall v : V, Set.Mem w.toSubgraph.verts v)) :
    Exists fun B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C =>
      And (forall v : V, Exists fun k : Fin B.length => B.vertex k = phi v)
        (forall k : Fin B.length, Exists fun v : V => B.vertex k = phi v) := by
  classical
  cases hspan with
  | intro base hbase =>
    cases hbase with
    | intro w hw =>
      cases hw with
      | intro hwcycle hwspan =>
        let mapped :
            (GraphBridge.unitDistanceSimpleGraph C).Walk (phi base) (phi base) :=
          w.map phi
        have hmapped_cycle : mapped.IsCycle := by
          dsimp [mapped]
          exact hwcycle.map hphi
        let B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C := {
          base := phi base
          walk := mapped
          isCycle := hmapped_cycle
        }
        refine Exists.intro B ?_
        constructor
        case left =>
          intro v
          have hvset : Set.Mem w.toSubgraph.verts v := hwspan v
          have hvlist : List.Mem v w.support :=
            (w.mem_verts_toSubgraph).1 hvset
          have hex := (SimpleGraph.Walk.mem_support_iff_exists_getVert).1 hvlist
          cases hex with
          | intro m hmAll =>
            cases hmAll with
            | intro hm hmle =>
              by_cases hmlt : m < w.length
              case pos =>
                let k : Fin B.length := Fin.mk m (by
                  simpa [B, JordanBoundaryConcrete.UnitDistanceCycleBoundary.length,
                    mapped, SimpleGraph.Walk.length_map] using hmlt)
                refine Exists.intro k ?_
                simp [k, B, JordanBoundaryConcrete.UnitDistanceCycleBoundary.vertex,
                  mapped, SimpleGraph.Walk.getVert_map, hm]
              case neg =>
                have hm_eq_len : m = w.length := by omega
                let k : Fin B.length := Fin.mk 0 (by
                  have hpos : 0 < B.length := B.length_pos
                  simpa using hpos)
                refine Exists.intro k ?_
                have hbase : w.getVert m = base := by
                  rw [hm_eq_len, SimpleGraph.Walk.getVert_length]
                have hvbase : v = base := by
                  simpa [hbase] using hm.symm
                simp [k, B, JordanBoundaryConcrete.UnitDistanceCycleBoundary.vertex,
                  mapped, hvbase]
        case right =>
          intro k
          refine Exists.intro (w.getVert k.val) ?_
          simp [B, JordanBoundaryConcrete.UnitDistanceCycleBoundary.vertex,
            mapped, SimpleGraph.Walk.getVert_map]

/-- Strengthening of
`exists_unitDistanceCycleBoundary_covering_spanning_cycle_hom` that also records
that every displayed consecutive boundary side lifts to an actual edge of the
source cycle walk. -/
theorem exists_unitDistanceCycleBoundary_covering_spanning_cycle_hom_edge_lifts
    {C : _root_.UDConfig n}
    (F : SimpleGraph V)
    (phi : SimpleGraph.Hom F (GraphBridge.unitDistanceSimpleGraph C))
    (hphi : Function.Injective phi)
    (hspan : Exists fun base : V =>
      Exists fun w : F.Walk base base =>
        And w.IsCycle (forall v : V, Set.Mem w.toSubgraph.verts v)) :
    Exists fun B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C =>
      (forall v : V, Exists fun k : Fin B.length => B.vertex k = phi v) /\
        (forall k : Fin B.length, Exists fun v : V => B.vertex k = phi v) /\
          (forall k : Fin B.length,
            Exists fun x : V =>
              Exists fun y : V =>
                F.Adj x y /\
                  B.vertex k = phi x /\
                    B.vertex
                        (PlanarInterface.cyclicSucc B.length_pos k) =
                      phi y) := by
  classical
  cases hspan with
  | intro base hbase =>
    cases hbase with
    | intro w hw =>
      cases hw with
      | intro hwcycle hwspan =>
        let mapped :
            (GraphBridge.unitDistanceSimpleGraph C).Walk (phi base) (phi base) :=
          w.map phi
        have hmapped_cycle : mapped.IsCycle := by
          dsimp [mapped]
          exact hwcycle.map hphi
        let B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C := {
          base := phi base
          walk := mapped
          isCycle := hmapped_cycle
        }
        refine Exists.intro B ?_
        constructor
        case left =>
          intro v
          have hvset : Set.Mem w.toSubgraph.verts v := hwspan v
          have hvlist : List.Mem v w.support :=
            (w.mem_verts_toSubgraph).1 hvset
          have hex := (SimpleGraph.Walk.mem_support_iff_exists_getVert).1 hvlist
          cases hex with
          | intro m hmAll =>
            cases hmAll with
            | intro hm hmle =>
              by_cases hmlt : m < w.length
              case pos =>
                let k : Fin B.length := Fin.mk m (by
                  simpa [B, JordanBoundaryConcrete.UnitDistanceCycleBoundary.length,
                    mapped, SimpleGraph.Walk.length_map] using hmlt)
                refine Exists.intro k ?_
                simp [k, B, JordanBoundaryConcrete.UnitDistanceCycleBoundary.vertex,
                  mapped, SimpleGraph.Walk.getVert_map, hm]
              case neg =>
                have hm_eq_len : m = w.length := by omega
                let k : Fin B.length := Fin.mk 0 (by
                  have hpos : 0 < B.length := B.length_pos
                  simpa using hpos)
                refine Exists.intro k ?_
                have hbase : w.getVert m = base := by
                  rw [hm_eq_len, SimpleGraph.Walk.getVert_length]
                have hvbase : v = base := by
                  simpa [hbase] using hm.symm
                simp [k, B, JordanBoundaryConcrete.UnitDistanceCycleBoundary.vertex,
                  mapped, hvbase]
        case right =>
          constructor
          case left =>
            intro k
            refine Exists.intro (w.getVert k.val) ?_
            simp [B, JordanBoundaryConcrete.UnitDistanceCycleBoundary.vertex,
              mapped, SimpleGraph.Walk.getVert_map]
          case right =>
            intro k
            by_cases hnext : k.val + 1 < B.length
            case pos =>
              have hnext_w : k.val + 1 < w.length := by
                simpa [B, JordanBoundaryConcrete.UnitDistanceCycleBoundary.length,
                  mapped, SimpleGraph.Walk.length_map] using hnext
              refine Exists.intro (w.getVert k.val) ?_
              refine Exists.intro (w.getVert (k.val + 1)) ?_
              constructor
              · exact w.adj_getVert_succ (Nat.lt_of_succ_lt hnext_w)
              constructor
              · simp [B, JordanBoundaryConcrete.UnitDistanceCycleBoundary.vertex,
                  mapped, SimpleGraph.Walk.getVert_map]
              · have hmod : (k.val + 1) % B.length = k.val + 1 :=
                  Nat.mod_eq_of_lt hnext
                simp [B, JordanBoundaryConcrete.UnitDistanceCycleBoundary.vertex,
                  mapped, SimpleGraph.Walk.getVert_map,
                  PlanarInterface.cyclicSucc, hmod]
            case neg =>
              have hlast_B : k.val + 1 = B.length :=
                eq_of_le_of_not_lt (Nat.succ_le_of_lt k.isLt) hnext
              have hlast_w : k.val + 1 = w.length := by
                simpa [B, JordanBoundaryConcrete.UnitDistanceCycleBoundary.length,
                  mapped, SimpleGraph.Walk.length_map] using hlast_B
              have hadj :
                  F.Adj (w.getVert k.val) (w.getVert 0) := by
                have hstep : F.Adj (w.getVert k.val) (w.getVert (k.val + 1)) :=
                  w.adj_getVert_succ (by omega)
                have hend : w.getVert (k.val + 1) = w.getVert 0 := by
                  rw [hlast_w, SimpleGraph.Walk.getVert_length,
                    SimpleGraph.Walk.getVert_zero]
                simpa [hend] using hstep
              refine Exists.intro (w.getVert k.val) ?_
              refine Exists.intro (w.getVert 0) ?_
              constructor
              · exact hadj
              constructor
              · simp [B, JordanBoundaryConcrete.UnitDistanceCycleBoundary.vertex,
                  mapped, SimpleGraph.Walk.getVert_map]
              · have hmod : (k.val + 1) % B.length = 0 := by
                  simp [hlast_B]
                simp [B, JordanBoundaryConcrete.UnitDistanceCycleBoundary.vertex,
                  mapped, PlanarInterface.cyclicSucc, hmod]

/-- One-direction projection of
`exists_unitDistanceCycleBoundary_covering_spanning_cycle_hom`. -/
theorem exists_unitDistanceCycleBoundary_of_spanning_cycle_hom
    {C : _root_.UDConfig n}
    (F : SimpleGraph V)
    (phi : SimpleGraph.Hom F (GraphBridge.unitDistanceSimpleGraph C))
    (hphi : Function.Injective phi)
    (hspan : Exists fun base : V =>
      Exists fun w : F.Walk base base =>
        And w.IsCycle (forall v : V, Set.Mem w.toSubgraph.verts v)) :
    Exists fun B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C =>
      forall v : V, Exists fun k : Fin B.length => B.vertex k = phi v := by
  cases exists_unitDistanceCycleBoundary_covering_spanning_cycle_hom
      F phi hphi hspan with
  | intro B hB =>
    exact Exists.intro B hB.left

/-- A connected finite two-regular frontier graph whose vertices inject into
the unit-distance graph yields a concrete unit-distance cycle boundary
covering every frontier vertex. -/
theorem exists_unitDistanceCycleBoundary_of_connected_two_regular_hom
    {C : _root_.UDConfig n}
    [Fintype V]
    (F : SimpleGraph V) [DecidableRel F.Adj]
    (hconn : F.Connected)
    (hdegree_two : forall v : V, F.degree v = 2)
    (phi : SimpleGraph.Hom F (GraphBridge.unitDistanceSimpleGraph C))
    (hphi : Function.Injective phi) :
    Exists fun B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C =>
      forall v : V, Exists fun k : Fin B.length => B.vertex k = phi v :=
  exists_unitDistanceCycleBoundary_of_spanning_cycle_hom
    F phi hphi (connected_two_regular_spanning_cycle F hconn hdegree_two)

end FiniteTwoRegularGraph

section ComponentFrontier

variable {α : Type u} [TopologicalSpace α] [LocallyConnectedSpace α]

/-- A point on the frontier of an open-set connected component cannot still
lie in the ambient open set.  Otherwise the ambient component of that point is
an open neighborhood meeting the selected component, hence the same component,
contradicting `IsOpen.inter_frontier_eq`. -/
theorem not_mem_open_of_mem_frontier_connectedComponentIn
    {U : Set α} {x y : α} (hU : IsOpen U)
    (hy : y ∈ frontier (connectedComponentIn U x)) :
    y ∉ U := by
  intro hyU
  let E : Set α := connectedComponentIn U x
  let Ey : Set α := connectedComponentIn U y
  have hEopen : IsOpen E := hU.connectedComponentIn
  have hEyopen : IsOpen Ey := hU.connectedComponentIn
  have hy_closureE : y ∈ closure E := frontier_subset_closure hy
  have hyEy : y ∈ Ey := mem_connectedComponentIn hyU
  have hEy_inter_E : (Ey ∩ E).Nonempty :=
    (mem_closure_iff.mp hy_closureE) Ey hEyopen hyEy
  rcases hEy_inter_E with ⟨z, hzEy, hzE⟩
  have hExz : connectedComponentIn U x = connectedComponentIn U z :=
    connectedComponentIn_eq hzE
  have hEyz : connectedComponentIn U y = connectedComponentIn U z :=
    connectedComponentIn_eq hzEy
  have hEy_eq_E : Ey = E := by
    dsimp [Ey, E]
    exact hEyz.trans hExz.symm
  have hyE : y ∈ E := by
    simpa [hEy_eq_E] using hyEy
  have hmem : y ∈ E ∩ frontier E := ⟨hyE, hy⟩
  have hdisj : E ∩ frontier E = ∅ := hEopen.inter_frontier_eq
  rw [hdisj] at hmem
  exact hmem

/-- The frontier of an open-set connected component lies in the frontier of
the ambient open set. -/
theorem frontier_connectedComponentIn_subset_frontier
    {U : Set α} {x : α} (hU : IsOpen U) :
    frontier (connectedComponentIn U x) ⊆ frontier U := by
  intro y hy
  rw [hU.frontier_eq]
  exact
    ⟨closure_mono (connectedComponentIn_subset U x)
        (frontier_subset_closure hy),
      not_mem_open_of_mem_frontier_connectedComponentIn hU hy⟩

end ComponentFrontier

/-- A candidate exterior set lies in the complement of the embedded drawing. -/
structure ExteriorComponentRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) where
  exterior : Set PlanarInterface.Point
  exterior_subset_drawingComplement :
    exterior ⊆ drawingComplement C
  exterior_open : IsOpen exterior

/-- The whole complement of the finite drawing is always an open exterior
candidate.  The remaining S2 theorem must select its unbounded component and
identify the simple unit-distance cycle on that component's frontier. -/
def drawingComplementRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    ExteriorComponentRows C inputs where
  exterior := drawingComplement C
  exterior_subset_drawingComplement := fun _ hp => hp
  exterior_open := drawingComplement_open C

/-- A component-level exterior candidate obtained by choosing a base point in
the drawing complement.  The true S2 proof must choose the unbounded such
component and identify its frontier cycle. -/
structure ExteriorConnectedComponentRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) where
  base : PlanarInterface.Point
  base_mem_drawingComplement : base ∈ drawingComplement C

namespace ExteriorConnectedComponentRows

variable {C : _root_.UDConfig n}
variable {inputs : FinitePlanarOuterComponentInputs C}

/-- The selected connected component of the drawing complement. -/
def exterior (E : ExteriorConnectedComponentRows C inputs) :
    Set PlanarInterface.Point :=
  connectedComponentIn (drawingComplement C) E.base

theorem exterior_subset_drawingComplement
    (E : ExteriorConnectedComponentRows C inputs) :
    E.exterior ⊆ drawingComplement C :=
  connectedComponentIn_subset (drawingComplement C) E.base

theorem exterior_open
    (E : ExteriorConnectedComponentRows C inputs) :
    IsOpen E.exterior :=
  (drawingComplement_open C).connectedComponentIn

theorem base_mem_exterior
    (E : ExteriorConnectedComponentRows C inputs) :
    E.base ∈ E.exterior :=
  mem_connectedComponentIn E.base_mem_drawingComplement

/-- A selected complement component is preconnected by construction. -/
theorem exterior_preconnected
    (E : ExteriorConnectedComponentRows C inputs) :
    IsPreconnected E.exterior :=
  isPreconnected_connectedComponentIn

/-- A selected complement component is connected when its base point lies in
the drawing complement. -/
theorem exterior_connected
    (E : ExteriorConnectedComponentRows C inputs) :
    IsConnected E.exterior :=
  isConnected_connectedComponentIn_iff.mpr E.base_mem_drawingComplement

/-- The frontier of a selected complement component is carried by the embedded
unit-edge drawing.  The remaining S2 theorem must identify which drawing
vertices on this frontier form the outer cycle. -/
theorem frontier_subset_embeddedEdgeSet
    (E : ExteriorConnectedComponentRows C inputs) :
    frontier E.exterior ⊆ embeddedEdgeSet C := by
  intro p hp
  exact
    frontier_drawingComplement_subset_embeddedEdgeSet C
      (frontier_connectedComponentIn_subset_frontier
        (drawingComplement_open C) hp)

/-- A point on a selected complement component's frontier lies on some
canonical unit-edge segment.  The remaining S2 proof must show which of these
frontier-carried edge pieces form the unbounded exterior boundary cycle. -/
theorem exists_edge_segment_of_mem_frontier
    (E : ExteriorConnectedComponentRows C inputs)
    {p : PlanarInterface.Point}
    (hp : p ∈ frontier E.exterior) :
    Exists fun i : Fin n =>
      Exists fun j : Fin n =>
        (canonicalGraph C).Adj i j /\
          p ∈ closedSegment
            ((canonicalGraph C).point i)
            ((canonicalGraph C).point j) := by
  simpa [embeddedEdgeSet] using E.frontier_subset_embeddedEdgeSet hp

theorem frontier_graph_vertex_mem_embeddedEdgeSet
    (E : ExteriorConnectedComponentRows C inputs)
    {v : Fin n}
    (hv : (canonicalGraph C).point v ∈ frontier E.exterior) :
    (canonicalGraph C).point v ∈ embeddedEdgeSet C :=
  E.frontier_subset_embeddedEdgeSet hv

theorem frontier_graph_vertex_incident
    (E : ExteriorConnectedComponentRows C inputs)
    {v : Fin n}
    (hv : (canonicalGraph C).point v ∈ frontier E.exterior) :
    Exists fun w : Fin n => (canonicalGraph C).Adj v w := by
  exact
    graph_vertex_mem_embeddedEdgeSet_iff_exists_adj.1
      (E.frontier_graph_vertex_mem_embeddedEdgeSet hv)

theorem frontier_not_mem_exterior
    (E : ExteriorConnectedComponentRows C inputs)
    {p : PlanarInterface.Point}
    (hp : p ∈ frontier E.exterior) :
    p ∉ E.exterior := by
  have hp_not_complement : p ∉ drawingComplement C :=
    not_mem_open_of_mem_frontier_connectedComponentIn
      (drawingComplement_open C)
      (by simpa [ExteriorConnectedComponentRows.exterior] using hp)
  intro hpE
  exact hp_not_complement (E.exterior_subset_drawingComplement hpE)

theorem graph_vertex_not_mem_exterior
    (E : ExteriorConnectedComponentRows C inputs) :
    forall v : Fin n, (canonicalGraph C).point v ∉ E.exterior := by
  intro v hv
  have hnot :
      (canonicalGraph C).point v ∉ embeddedEdgeSet C := by
    simpa [drawingComplement] using E.exterior_subset_drawingComplement hv
  exact hnot (vertex_mem_embeddedEdgeSet_of_inputs inputs v)

/-- Forget a connected-component exterior candidate to the weaker exterior-row
interface consumed by the current S2 reducer. -/
def toExteriorComponentRows
    (E : ExteriorConnectedComponentRows C inputs) :
    ExteriorComponentRows C inputs where
  exterior := E.exterior
  exterior_subset_drawingComplement := E.exterior_subset_drawingComplement
  exterior_open := E.exterior_open

end ExteriorConnectedComponentRows

/-- A canonical complement-component candidate obtained from an arbitrary point
outside the compact embedded drawing.  The remaining planar theorem must show
which connected component is the unbounded exterior component and identify its
frontier cycle. -/
noncomputable def defaultExteriorConnectedComponentRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    ExteriorConnectedComponentRows C inputs where
  base := Classical.choose (drawingComplement_nonempty C)
  base_mem_drawingComplement := Classical.choose_spec (drawingComplement_nonempty C)

noncomputable def defaultExteriorComponentRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    ExteriorComponentRows C inputs :=
  (defaultExteriorConnectedComponentRows C inputs).toExteriorComponentRows

/-- A selected connected component of the drawing complement that is certified
to be unbounded.  This is the component-level exterior object needed before
the final plane-graph theorem identifies the boundary cycle on its frontier. -/
structure ExteriorUnboundedComponentRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) where
  component : ExteriorConnectedComponentRows C inputs
  exterior_unbounded : ¬ Bornology.IsBounded component.exterior

namespace ExteriorUnboundedComponentRows

variable {C : _root_.UDConfig n}
variable {inputs : FinitePlanarOuterComponentInputs C}

def exterior (E : ExteriorUnboundedComponentRows C inputs) :
    Set PlanarInterface.Point :=
  E.component.exterior

theorem exterior_subset_drawingComplement
    (E : ExteriorUnboundedComponentRows C inputs) :
    E.exterior ⊆ drawingComplement C :=
  E.component.exterior_subset_drawingComplement

theorem exterior_open
    (E : ExteriorUnboundedComponentRows C inputs) :
    IsOpen E.exterior :=
  E.component.exterior_open

theorem frontier_subset_embeddedEdgeSet
    (E : ExteriorUnboundedComponentRows C inputs) :
    frontier E.exterior ⊆ embeddedEdgeSet C :=
  E.component.frontier_subset_embeddedEdgeSet

/-- A point on the unbounded complement component's frontier lies on a
canonical unit-edge segment. -/
theorem exists_edge_segment_of_mem_frontier
    (E : ExteriorUnboundedComponentRows C inputs)
    {p : PlanarInterface.Point}
    (hp : p ∈ frontier E.exterior) :
    Exists fun i : Fin n =>
      Exists fun j : Fin n =>
        (canonicalGraph C).Adj i j /\
          p ∈ closedSegment
            ((canonicalGraph C).point i)
            ((canonicalGraph C).point j) :=
  E.component.exists_edge_segment_of_mem_frontier hp

theorem frontier_graph_vertex_mem_embeddedEdgeSet
    (E : ExteriorUnboundedComponentRows C inputs)
    {v : Fin n}
    (hv : (canonicalGraph C).point v ∈ frontier E.exterior) :
    (canonicalGraph C).point v ∈ embeddedEdgeSet C :=
  E.frontier_subset_embeddedEdgeSet hv

theorem frontier_graph_vertex_incident
    (E : ExteriorUnboundedComponentRows C inputs)
    {v : Fin n}
    (hv : (canonicalGraph C).point v ∈ frontier E.exterior) :
    Exists fun w : Fin n => (canonicalGraph C).Adj v w := by
  exact
    graph_vertex_mem_embeddedEdgeSet_iff_exists_adj.1
      (E.frontier_graph_vertex_mem_embeddedEdgeSet hv)

theorem frontier_not_mem_exterior
    (E : ExteriorUnboundedComponentRows C inputs)
    {p : PlanarInterface.Point}
    (hp : p ∈ frontier E.exterior) :
    p ∉ E.exterior :=
  E.component.frontier_not_mem_exterior hp

theorem graph_vertex_not_mem_exterior
    (E : ExteriorUnboundedComponentRows C inputs) :
    forall v : Fin n, (canonicalGraph C).point v ∉ E.exterior :=
  E.component.graph_vertex_not_mem_exterior

def toExteriorComponentRows
    (E : ExteriorUnboundedComponentRows C inputs) :
    ExteriorComponentRows C inputs :=
  E.component.toExteriorComponentRows

end ExteriorUnboundedComponentRows

/-- The finite embedded drawing has a concrete unbounded complement component:
take a rightward x-axis ray outside a compact ball containing the drawing, and
then take the complement component containing that ray. -/
noncomputable def unboundedExteriorComponentRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    ExteriorUnboundedComponentRows C inputs := by
  classical
  let R : Real := Classical.choose (exists_xAxisRay_subset_drawingComplement C)
  have hR_spec : 0 <= R /\ xAxisRay R ⊆ drawingComplement C :=
    Classical.choose_spec (exists_xAxisRay_subset_drawingComplement C)
  have hR_subset : xAxisRay R ⊆ drawingComplement C := hR_spec.2
  let base : PlanarInterface.Point := (R + 1, 0)
  have hbase_ray : base ∈ xAxisRay R := by
    exact ⟨R + 1, by linarith, rfl⟩
  have hbase : base ∈ drawingComplement C := hR_subset hbase_ray
  let component : ExteriorConnectedComponentRows C inputs :=
    { base := base
      base_mem_drawingComplement := hbase }
  refine
    { component := component
      exterior_unbounded := ?_ }
  intro hbounded_component
  have hray_subset_component : xAxisRay R ⊆ component.exterior :=
    (xAxisRay_preconnected R).subset_connectedComponentIn hbase_ray hR_subset
  exact xAxisRay_unbounded R (hbounded_component.subset hray_subset_component)

theorem unboundedExteriorComponent_not_isBounded
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    ¬ Bornology.IsBounded (unboundedExteriorComponentRows C inputs).exterior :=
  (unboundedExteriorComponentRows C inputs).exterior_unbounded

/-- The concrete unbounded exterior component contains the rightward x-axis
ray used in its construction.  This is the seed-at-infinity row for the later
exterior face-orbit construction. -/
theorem exists_xAxisRay_subset_unboundedExteriorComponent
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    Exists fun R : Real =>
      0 <= R /\
        xAxisRay R ⊆ (unboundedExteriorComponentRows C inputs).exterior := by
  classical
  let R : Real := Classical.choose (exists_xAxisRay_subset_drawingComplement C)
  have hR_spec : 0 <= R /\ xAxisRay R ⊆ drawingComplement C :=
    Classical.choose_spec (exists_xAxisRay_subset_drawingComplement C)
  refine ⟨R, hR_spec.1, ?_⟩
  intro p hp
  change
    p ∈
      connectedComponentIn (drawingComplement C)
        ((R + 1, 0) : PlanarInterface.Point)
  exact
    (xAxisRay_preconnected R).subset_connectedComponentIn
      (xAxisRayBase_mem R) hR_spec.2 hp

/-- The base point of the rightward x-axis ray belongs to the concrete
unbounded exterior component selected by `unboundedExteriorComponentRows`. -/
theorem exists_xAxisRayBase_mem_unboundedExteriorComponent
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    Exists fun R : Real =>
      0 <= R /\
        xAxisRayBase R ∈ (unboundedExteriorComponentRows C inputs).exterior := by
  rcases exists_xAxisRay_subset_unboundedExteriorComponent C inputs with
    ⟨R, hR_nonneg, hsubset⟩
  exact ⟨R, hR_nonneg, hsubset (xAxisRayBase_mem R)⟩

/-- A preconnected local patch in the drawing complement that touches the
chosen unbounded exterior component is entirely contained in that exterior
component.  This is the component-propagation step needed by the local
open-edge side proof: once a same-side half-neighborhood contains one exterior
point, no additional global exterior choice is required. -/
theorem preconnected_subset_unboundedExterior_of_subset_drawingComplement_of_mem
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {S : Set PlanarInterface.Point} {y : PlanarInterface.Point}
    (hS_preconnected : IsPreconnected S)
    (hS_subset_drawingComplement : S ⊆ drawingComplement C)
    (hyS : y ∈ S)
    (hyExterior : y ∈ (unboundedExteriorComponentRows C inputs).exterior) :
    S ⊆ (unboundedExteriorComponentRows C inputs).exterior := by
  let E := (unboundedExteriorComponentRows C inputs).component
  have hS_component_y :
      S ⊆ connectedComponentIn (drawingComplement C) y :=
    hS_preconnected.subset_connectedComponentIn hyS
      hS_subset_drawingComplement
  have hcomponent_eq :
      connectedComponentIn (drawingComplement C) E.base =
        connectedComponentIn (drawingComplement C) y := by
    exact
      connectedComponentIn_eq
        (by
          simpa [ExteriorUnboundedComponentRows.exterior,
            ExteriorConnectedComponentRows.exterior, E] using hyExterior)
  intro z hzS
  have hz_component_y :
      z ∈ connectedComponentIn (drawingComplement C) y :=
    hS_component_y hzS
  simpa [ExteriorUnboundedComponentRows.exterior,
    ExteriorConnectedComponentRows.exterior, E, hcomponent_eq] using
    hz_component_y

/-- Ball-local version of
`preconnected_subset_unboundedExterior_of_subset_drawingComplement_of_mem`.
It packages the exact containment shape consumed by the local exterior-side
patch reducers. -/
theorem preconnected_subset_unboundedExterior_inter_ball_of_subset_drawingComplement_inter_ball_of_mem
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {S : Set PlanarInterface.Point} {y z : PlanarInterface.Point}
    {r : Real}
    (hS_preconnected : IsPreconnected S)
    (hS_subset_drawingComplement :
      S ⊆ drawingComplement C)
    (hS_subset_ball : S ⊆ Metric.ball z r)
    (hyS : y ∈ S)
    (hyExterior : y ∈ (unboundedExteriorComponentRows C inputs).exterior) :
    S ⊆ (unboundedExteriorComponentRows C inputs).exterior ∩
      Metric.ball z r := by
  intro w hwS
  exact
    ⟨preconnected_subset_unboundedExterior_of_subset_drawingComplement_of_mem
        (C := C) (inputs := inputs)
        hS_preconnected hS_subset_drawingComplement hyS hyExterior hwS,
      hS_subset_ball hwS⟩

theorem unboundedExteriorComponent_frontier_subset_embeddedEdgeSet
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    frontier (unboundedExteriorComponentRows C inputs).exterior ⊆
      embeddedEdgeSet C :=
  (unboundedExteriorComponentRows C inputs).frontier_subset_embeddedEdgeSet

/-- Any point on the canonical unbounded exterior frontier lies on a concrete
canonical unit-edge segment. -/
theorem exists_edge_segment_of_mem_unboundedExterior_frontier
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C)
    {p : PlanarInterface.Point}
    (hp :
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    Exists fun i : Fin n =>
      Exists fun j : Fin n =>
        (canonicalGraph C).Adj i j /\
          p ∈ closedSegment
            ((canonicalGraph C).point i)
            ((canonicalGraph C).point j) :=
  (unboundedExteriorComponentRows C inputs).exists_edge_segment_of_mem_frontier hp

theorem unboundedExterior_frontier_vertex_incident
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C)
    {v : Fin n}
    (hv :
      (canonicalGraph C).point v ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior) :
    Exists fun w : Fin n => (canonicalGraph C).Adj v w := by
  exact
    _root_.ErdosProblems1066.Swanepoel.FinitePlaneDrawing.graph_vertex_mem_embeddedEdgeSet_iff_exists_adj.1
      ((unboundedExteriorComponentRows C inputs).frontier_subset_embeddedEdgeSet hv)

/-- The unbounded exterior component has a nonempty frontier: it is unbounded,
while graph vertices from the nonempty connected graph lie outside it. -/
theorem unboundedExterior_frontier_nonempty
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    (frontier (unboundedExteriorComponentRows C inputs).exterior).Nonempty := by
  rw [nonempty_frontier_iff]
  constructor
  · exact Bornology.nonempty_of_not_isBounded
      (unboundedExteriorComponent_not_isBounded C inputs)
  · intro h_univ
    obtain ⟨v⟩ := inputs.vertex_nonempty
    exact ((unboundedExteriorComponentRows C inputs).graph_vertex_not_mem_exterior v) (by
      rw [h_univ]
      exact Set.mem_univ _)

/-- A point on the unbounded exterior frontier can be chosen either at a graph
vertex or in the relative interior of a canonical unit edge.  This is the
first compactness/topology seed for the exterior carrier construction. -/
theorem exists_unboundedExterior_frontier_vertex_or_edgeInterior
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) :
    Exists fun p : PlanarInterface.Point =>
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior /\
        ((Exists fun v : Fin n => p = (canonicalGraph C).point v) ∨
          Exists fun i : Fin n =>
            Exists fun j : Fin n =>
              (canonicalGraph C).Adj i j /\
                PlanarInterface.InOpenSegment p
                  ((canonicalGraph C).point i)
                  ((canonicalGraph C).point j)) := by
  rcases unboundedExterior_frontier_nonempty C inputs with ⟨p, hp⟩
  rcases exists_edge_segment_of_mem_unboundedExterior_frontier C inputs hp with
    ⟨i, j, hij, hpseg⟩
  refine ⟨p, hp, ?_⟩
  rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hpseg with
      hleft | hright | hinside
  · exact Or.inl ⟨i, hleft⟩
  · exact Or.inl ⟨j, hright⟩
  · exact Or.inr ⟨i, j, hij, hinside⟩

/-- Pointwise frontier classification: every point on the unbounded exterior
frontier is either a graph vertex or lies in the relative interior of an
ordered canonical edge. -/
theorem unboundedExterior_frontier_point_vertex_or_ordered_edgeInterior
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    {p : PlanarInterface.Point}
    (hp :
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    (Exists fun v : Fin n => p = (canonicalGraph C).point v) ∨
      Exists fun e : PlanarInterface.Edge n =>
        e ∈ (canonicalGraph C).edgeSet ∧
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point e.1)
            ((canonicalGraph C).point e.2) := by
  rcases exists_edge_segment_of_mem_unboundedExterior_frontier C inputs hp with
    ⟨i, j, hij, hpseg⟩
  rcases mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment hpseg with
      hleft | hright | hinside
  · exact Or.inl ⟨i, hleft⟩
  · exact Or.inl ⟨j, hright⟩
  · rcases hij with hij_edge | hji_edge
    · exact Or.inr ⟨(i, j), hij_edge, hinside⟩
    · exact Or.inr ⟨(j, i), hji_edge, inOpenSegment_symm hinside⟩

/-- A named seed point on the unbounded exterior frontier, preserving whether
the selected point is a graph vertex or lies in the relative interior of a
canonical unit edge. -/
structure UnboundedExteriorFrontierSeed
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) where
  point : PlanarInterface.Point
  point_mem_frontier :
    point ∈ frontier (unboundedExteriorComponentRows C inputs).exterior
  vertex_or_edgeInterior :
    (Exists fun v : Fin n => point = (canonicalGraph C).point v) ∨
      Exists fun i : Fin n =>
        Exists fun j : Fin n =>
          (canonicalGraph C).Adj i j /\
            PlanarInterface.InOpenSegment point
              ((canonicalGraph C).point i)
              ((canonicalGraph C).point j)

/-- Nonempty packaged form of
`exists_unboundedExterior_frontier_vertex_or_edgeInterior`. -/
theorem unboundedExteriorFrontierSeed_nonempty
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) :
    Nonempty (UnboundedExteriorFrontierSeed inputs) := by
  rcases exists_unboundedExterior_frontier_vertex_or_edgeInterior inputs with
    ⟨p, hp, hp_kind⟩
  exact
    ⟨{ point := p
       point_mem_frontier := hp
       vertex_or_edgeInterior := hp_kind }⟩

/-- Local vertex-star isolation specialized to points of the unbounded
exterior frontier: sufficiently near a graph vertex, every frontier point is
carried by a canonical edge incident to that vertex. -/
theorem exists_ball_forall_unboundedExterior_frontier_mem_incident_closedSegment_of_vertex
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C)
    (v : Fin n) :
    Exists fun ε : Real =>
      0 < ε ∧
        forall q : PlanarInterface.Point,
          q ∈ Metric.ball ((canonicalGraph C).point v) ε ->
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
              Exists fun w : Fin n =>
                (canonicalGraph C).Adj v w ∧
                  q ∈ closedSegment
                    ((canonicalGraph C).point v)
                    ((canonicalGraph C).point w) := by
  rcases
      exists_ball_forall_mem_incident_closedSegment_of_vertex
        (C := C) v with
    ⟨ε, hεpos, hlocal⟩
  refine ⟨ε, hεpos, ?_⟩
  intro q hqball hqfrontier
  exact hlocal q hqball
    ((unboundedExteriorComponentRows C inputs).frontier_subset_embeddedEdgeSet
      hqfrontier)

/-- Pointed local frontier isolation at a graph vertex: after shrinking around
`v`, every non-vertex frontier point near `v` lies in the relative interior of
an incident unit-edge segment. -/
theorem exists_ball_forall_unboundedExterior_frontier_mem_incident_inOpenSegment_of_vertex_ne
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C)
    (v : Fin n) :
    Exists fun ε : Real =>
      0 < ε ∧
        forall q : PlanarInterface.Point,
          q ∈ Metric.ball ((canonicalGraph C).point v) ε ->
            q ≠ (canonicalGraph C).point v ->
              q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
                Exists fun w : Fin n =>
                  (canonicalGraph C).Adj v w ∧
                    PlanarInterface.InOpenSegment q
                      ((canonicalGraph C).point v)
                      ((canonicalGraph C).point w) := by
  rcases
      exists_ball_forall_unboundedExterior_frontier_mem_incident_closedSegment_of_vertex
        C inputs v with
    ⟨δ, hδpos, hclosed⟩
  rcases
      _root_.ErdosProblems1066.Swanepoel.FinitePlaneDrawing.exists_ball_forall_graph_vertex_eq_of_mem_ball
        (C := C) v with
    ⟨η, hηpos, hvertex⟩
  refine ⟨min δ η, lt_min hδpos hηpos, ?_⟩
  intro q hqball hq_ne hqfrontier
  have hqballδ : q ∈ Metric.ball ((canonicalGraph C).point v) δ := by
    have hdist :
        dist q ((canonicalGraph C).point v) < min δ η := by
      simpa [Metric.mem_ball] using hqball
    exact (Metric.mem_ball).2 (lt_of_lt_of_le hdist (min_le_left δ η))
  have hqballη : q ∈ Metric.ball ((canonicalGraph C).point v) η := by
    have hdist :
        dist q ((canonicalGraph C).point v) < min δ η := by
      simpa [Metric.mem_ball] using hqball
    exact (Metric.mem_ball).2 (lt_of_lt_of_le hdist (min_le_right δ η))
  rcases hclosed q hqballδ hqfrontier with ⟨w, hvw, hqseg⟩
  rcases
      _root_.ErdosProblems1066.Swanepoel.FinitePlaneDrawing.mem_closedSegment_eq_left_or_eq_right_or_inOpenSegment
        hqseg with hleft | hright | hinside
  · exact False.elim (hq_ne hleft)
  · have hw_eq : w = v := by
      exact hvertex w (by simpa [hright] using hqballη)
    have hvv : (canonicalGraph C).Adj v v := by
      simpa [hw_eq] using hvw
    exact False.elim
      (GraphBridge.unitDistanceAdj_loopless C v
        (((canonicalGraph C).adj_iff_unitDistanceAdj v v).1 hvv))
  · exact ⟨w, hvw, hinside⟩

/-- Germ-level form of local vertex-star isolation for the unbounded exterior
frontier.  Near a graph vertex, every exterior-frontier point lies on one of
the incident unit-edge germs from that vertex. -/
theorem exists_ball_forall_unboundedExterior_frontier_mem_vertexIncidentGermW3
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C)
    (v : Fin n) :
    Exists fun ε : Real =>
      0 < ε ∧
        forall q : PlanarInterface.Point,
          q ∈ Metric.ball ((canonicalGraph C).point v) ε ->
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
              Exists fun w : Fin n =>
                (canonicalGraph C).Adj v w ∧
                  q ∈ vertexIncidentGermW3 C v w ε := by
  rcases
      exists_ball_forall_mem_vertexIncidentGermW3
        (C := C) v with
    ⟨ε, hεpos, hlocal⟩
  refine ⟨ε, hεpos, ?_⟩
  intro q hqball hqfrontier
  exact hlocal q hqball
    ((unboundedExteriorComponentRows C inputs).frontier_subset_embeddedEdgeSet
      hqfrontier)

/-- The exterior component of the drawing complement contains no graph vertex. -/
theorem graph_vertex_not_mem_exterior
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (E : ExteriorComponentRows C inputs) :
    forall v : Fin n, (canonicalGraph C).point v ∉ E.exterior := by
  intro v hv
  have hnot :
      (canonicalGraph C).point v ∉ embeddedEdgeSet C := by
    simpa [drawingComplement] using E.exterior_subset_drawingComplement hv
  exact hnot (vertex_mem_embeddedEdgeSet_of_inputs inputs v)

theorem graph_vertex_mem_closure_exterior_compl
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (E : ExteriorComponentRows C inputs) :
    forall v : Fin n,
      (canonicalGraph C).point v ∈ closure E.exteriorᶜ := by
  intro v
  exact
    mem_closure_compl_of_not_mem
      (graph_vertex_not_mem_exterior E v)

theorem graph_vertex_not_mem_unboundedExterior
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) :
    forall v : Fin n,
      (canonicalGraph C).point v ∉
        (unboundedExteriorComponentRows C inputs).exterior :=
  (unboundedExteriorComponentRows C inputs).graph_vertex_not_mem_exterior

theorem graph_vertex_mem_closure_unboundedExterior_compl
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) :
    forall v : Fin n,
      (canonicalGraph C).point v ∈
        closure (unboundedExteriorComponentRows C inputs).exteriorᶜ := by
  intro v
  exact
    mem_closure_compl_of_not_mem
      (graph_vertex_not_mem_unboundedExterior inputs v)

theorem graph_vertex_mem_unboundedExterior_frontier_iff_mem_closure
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (v : Fin n) :
    (canonicalGraph C).point v ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior ↔
      (canonicalGraph C).point v ∈
        closure (unboundedExteriorComponentRows C inputs).exterior := by
  rw [(unboundedExteriorComponentRows C inputs).exterior_open.frontier_eq]
  constructor
  · exact fun h => h.1
  · intro hv
    exact ⟨hv, graph_vertex_not_mem_unboundedExterior inputs v⟩

/-! ## Concrete unbounded-frontier carrier sets -/

/-- The finite set of graph vertices whose points lie on the unbounded
component frontier.  This is only a vertex carrier; the actual S2 boundary
edge graph must still use boundary-carrier edges, not the full induced graph
on this set. -/
noncomputable def unboundedFrontierVertexSet
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    Finset (Fin n) := by
  classical
  exact
    Finset.univ.filter
      (fun v : Fin n =>
        (canonicalGraph C).point v ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior)

theorem mem_unboundedFrontierVertexSet_iff
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {v : Fin n} :
    v ∈ unboundedFrontierVertexSet C inputs ↔
      (canonicalGraph C).point v ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior := by
  classical
  simp [unboundedFrontierVertexSet]

/-- The unbounded exterior frontier seed can be read either as a selected
frontier graph vertex or as a frontier point in the relative interior of an
ordered canonical edge. -/
theorem exists_unboundedFrontierVertexSet_or_frontier_edgeInterior
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) :
    (Exists fun v : Fin n => v ∈ unboundedFrontierVertexSet C inputs) ∨
      Exists fun e : PlanarInterface.Edge n =>
        Exists fun p : PlanarInterface.Point =>
          e ∈ (canonicalGraph C).edgeSet ∧
            p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ∧
              PlanarInterface.InOpenSegment p
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2) := by
  rcases exists_unboundedExterior_frontier_vertex_or_edgeInterior inputs with
    ⟨p, hpfrontier, hkind⟩
  rcases hkind with hvertex | hedge
  · rcases hvertex with ⟨v, rfl⟩
    exact Or.inl ⟨v, mem_unboundedFrontierVertexSet_iff.2 hpfrontier⟩
  · rcases hedge with ⟨i, j, hij, hpseg⟩
    rcases hij with hij | hji
    · exact Or.inr ⟨(i, j), p, hij, hpfrontier, hpseg⟩
    · exact Or.inr
        ⟨(j, i), p, hji, hpfrontier, inOpenSegment_symm hpseg⟩

/-- Ordered canonical graph edges whose relative interiors lie on the unbounded
component frontier.  This is the concrete boundary-edge carrier that the final
S2 planar theorem has to prove connected and two-regular. -/
noncomputable def unboundedFrontierEdgeSet
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) :
    Finset (PlanarInterface.Edge n) := by
  classical
  exact
    (canonicalGraph C).edgeSet.filter
      (fun e : PlanarInterface.Edge n =>
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point e.1)
            ((canonicalGraph C).point e.2) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)

theorem mem_unboundedFrontierEdgeSet_iff
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n} :
    e ∈ unboundedFrontierEdgeSet C inputs ↔
      e ∈ (canonicalGraph C).edgeSet /\
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point e.1)
            ((canonicalGraph C).point e.2) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  classical
  simp [unboundedFrontierEdgeSet]

theorem unboundedFrontierEdgeSet_adj
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs) :
    (canonicalGraph C).Adj e.1 e.2 := by
  exact Or.inl (mem_unboundedFrontierEdgeSet_iff.1 he).1

theorem unboundedFrontierEdgeSet_has_frontier_interior_point
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs) :
    Exists fun p : PlanarInterface.Point =>
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior /\
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) := by
  let p : PlanarInterface.Point :=
    PlanarInterface.segmentPoint
      ((canonicalGraph C).point e.1)
      ((canonicalGraph C).point e.2)
      (1 / 2 : Real)
  have hp :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2) :=
    midpoint_inOpenSegment _ _
  exact ⟨p, (mem_unboundedFrontierEdgeSet_iff.1 he).2 p hp, hp⟩

/-- Boundary-carrier edges are uniquely determined by any shared relative
interior point. -/
theorem unboundedFrontierEdgeSet_eq_of_common_interior_point
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e f : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs)
    (hf : f ∈ unboundedFrontierEdgeSet C inputs)
    {p : PlanarInterface.Point}
    (hpe :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2))
    (hpf :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point f.1)
        ((canonicalGraph C).point f.2)) :
    e = f :=
  common_inOpenSegment_ordered_edges_eq
    (mem_unboundedFrontierEdgeSet_iff.1 he).1
    (mem_unboundedFrontierEdgeSet_iff.1 hf).1
    hpe hpf

/-- Boundary-carrier edges are also uniquely determined by any point that is
interior to one selected edge and lies on the closed segment of another ordered
canonical edge.  This is the closed-segment version needed for local edge
isolation near frontier points. -/
theorem unboundedFrontierEdgeSet_eq_of_common_interior_closed_point
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e f : PlanarInterface.Edge n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs)
    (hf : f ∈ (canonicalGraph C).edgeSet)
    {p : PlanarInterface.Point}
    (hpe :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2))
    (hpf :
      p ∈ closedSegment
        ((canonicalGraph C).point f.1)
        ((canonicalGraph C).point f.2)) :
    e = f :=
  common_inOpenSegment_closedSegment_ordered_edges_eq
    (mem_unboundedFrontierEdgeSet_iff.1 he).1 hf hpe hpf

/-- If an interior point of a selected unbounded-frontier edge lies on a
closed segment carried by any adjacent pair, then that pair is the same
unordered unit edge.  This is the unbounded-frontier specialization of the
local carrier uniqueness used by the edge-isolation proof. -/
theorem unboundedFrontierEdgeSet_same_unordered_of_common_interior_closed_adj
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n} {i j : Fin n}
    (he : e ∈ unboundedFrontierEdgeSet C inputs)
    (hij : (canonicalGraph C).Adj i j)
    {p : PlanarInterface.Point}
    (hpe :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2))
    (hpij :
      p ∈ closedSegment
        ((canonicalGraph C).point i)
        ((canonicalGraph C).point j)) :
    (e.1 = i ∧ e.2 = j) ∨ (e.1 = j ∧ e.2 = i) :=
  common_inOpenSegment_closedSegment_adj_same_unordered
    (mem_unboundedFrontierEdgeSet_iff.1 he).1 hij hpe hpij

/-- If the whole open segment of an edge lies in a closed frontier, then the
left endpoint also lies in that frontier. -/
theorem left_endpoint_frontier_of_openSegment_frontier
    {s : Set PlanarInterface.Point}
    {a b : PlanarInterface.Point}
    (hseg :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p a b -> p ∈ frontier s) :
    a ∈ frontier s := by
  exact
    (closure_minimal
      (s := {p : PlanarInterface.Point |
        PlanarInterface.InOpenSegment p a b})
      (t := frontier s)
      (by intro p hp; exact hseg p hp)
      isClosed_frontier)
      (_root_.ErdosProblems1066.Swanepoel.FinitePlaneDrawing.left_mem_closure_inOpenSegment
        a b)

/-- Right-endpoint version of
`left_endpoint_frontier_of_openSegment_frontier`. -/
theorem right_endpoint_frontier_of_openSegment_frontier
    {s : Set PlanarInterface.Point}
    {a b : PlanarInterface.Point}
    (hseg :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p a b -> p ∈ frontier s) :
    b ∈ frontier s := by
  exact
    (closure_minimal
      (s := {p : PlanarInterface.Point |
        PlanarInterface.InOpenSegment p a b})
      (t := frontier s)
      (by intro p hp; exact hseg p hp)
      isClosed_frontier)
      (_root_.ErdosProblems1066.Swanepoel.FinitePlaneDrawing.right_mem_closure_inOpenSegment
        a b)

/-- Once a selected unbounded-frontier edge is known to have its whole relative
interior on the unbounded exterior frontier, both endpoints are graph frontier
vertices. -/
theorem endpoints_mem_unboundedFrontierVertexSet_of_edge_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (hseg :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    e.1 ∈ unboundedFrontierVertexSet C inputs ∧
      e.2 ∈ unboundedFrontierVertexSet C inputs := by
  constructor
  · exact mem_unboundedFrontierVertexSet_iff.2
      (left_endpoint_frontier_of_openSegment_frontier hseg)
  · exact mem_unboundedFrontierVertexSet_iff.2
      (right_endpoint_frontier_of_openSegment_frontier hseg)

/-- A canonical ordered edge whose whole relative interior lies on the
unbounded exterior frontier belongs to the concrete frontier edge set. -/
theorem mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ (canonicalGraph C).edgeSet)
    (hseg :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    e ∈ unboundedFrontierEdgeSet C inputs := by
  exact mem_unboundedFrontierEdgeSet_iff.2 ⟨he, hseg⟩

/-- An unoriented canonical adjacency whose whole open segment lies on the
unbounded exterior frontier determines a selected frontier carrier edge in one
of the two ordered orientations. -/
theorem unboundedFrontierEdgeSet_or_symm_of_adj_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {i j : Fin n}
    (hij : (canonicalGraph C).Adj i j)
    (hseg :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point i)
          ((canonicalGraph C).point j) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    (i, j) ∈ unboundedFrontierEdgeSet C inputs ∨
      (j, i) ∈ unboundedFrontierEdgeSet C inputs := by
  rcases hij with hij | hji
  · exact Or.inl
      (mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier
        (e := (i, j)) hij hseg)
  · exact Or.inr
      (mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier
        (e := (j, i)) hji (by
          intro p hp
          exact hseg p (inOpenSegment_symm hp)))

/-- Interior points of any canonical edge cannot lie in the selected unbounded
exterior component: the component is contained in the drawing complement, while
the whole edge segment is part of the embedded drawing. -/
theorem canonicalEdge_inOpenSegment_not_mem_unboundedExterior
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    {e : PlanarInterface.Edge n}
    (he : e ∈ (canonicalGraph C).edgeSet)
    {p : PlanarInterface.Point}
    (hp :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2)) :
    p ∉ (unboundedExteriorComponentRows C inputs).exterior := by
  intro hpExterior
  have hpDrawing : p ∈ embeddedEdgeSet C :=
    inOpenSegment_mem_embeddedEdgeSet_of_adj (Or.inl he) hp
  exact
    ((unboundedExteriorComponentRows C inputs).exterior_subset_drawingComplement
      hpExterior) hpDrawing

/-- If exterior-component points approach an interior point of a canonical
edge from arbitrarily close range, then that edge-interior point is on the
unbounded exterior frontier. -/
theorem canonicalEdge_inOpenSegment_frontier_of_exterior_points_arbitrarily_close
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    {p : PlanarInterface.Point}
    (he : e ∈ (canonicalGraph C).edgeSet)
    (hp :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2))
    (hnear :
      forall eps : Real,
        0 < eps ->
          Exists fun y : PlanarInterface.Point =>
            y ∈ (unboundedExteriorComponentRows C inputs).exterior ∧
              dist y p < eps) :
    p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  rw [(unboundedExteriorComponentRows C inputs).exterior_open.frontier_eq]
  constructor
  · rw [Metric.mem_closure_iff]
    intro eps heps
    rcases hnear eps heps with ⟨y, hyExterior, hydist⟩
    exact ⟨y, hyExterior, by simpa [dist_comm] using hydist⟩
  · exact canonicalEdge_inOpenSegment_not_mem_unboundedExterior inputs he hp

/-- Closure along the whole relative interior of a canonical edge is enough to
upgrade to frontier along that whole interior, because canonical edge interiors
are outside the selected unbounded exterior component. -/
theorem edge_openSegment_frontier_of_edge_openSegment_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ (canonicalGraph C).edgeSet)
    (hclosure :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ closure (unboundedExteriorComponentRows C inputs).exterior) :
    forall p : PlanarInterface.Point,
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2) ->
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  intro p hp
  rw [(unboundedExteriorComponentRows C inputs).exterior_open.frontier_eq]
  exact
    ⟨hclosure p hp,
      canonicalEdge_inOpenSegment_not_mem_unboundedExterior inputs he hp⟩

/-- Reducer for propagation arguments: once the propagated topological fact is
closure of the unbounded exterior along the whole open segment, the actual
frontier-edge carrier membership follows. -/
theorem mem_unboundedFrontierEdgeSet_of_edge_openSegment_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ (canonicalGraph C).edgeSet)
    (hclosure :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ closure (unboundedExteriorComponentRows C inputs).exterior) :
    e ∈ unboundedFrontierEdgeSet C inputs :=
  mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier he
    (edge_openSegment_frontier_of_edge_openSegment_closure he hclosure)

/-- Closure of the unbounded exterior along a whole canonical edge interior
puts both endpoints of that edge on the graph-vertex frontier carrier. -/
theorem endpoints_mem_unboundedFrontierVertexSet_of_openSegment_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (he : e ∈ (canonicalGraph C).edgeSet)
    (hclosure :
      forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        p ∈ closure (unboundedExteriorComponentRows C inputs).exterior) :
    e.1 ∈ unboundedFrontierVertexSet C inputs ∧
      e.2 ∈ unboundedFrontierVertexSet C inputs :=
  endpoints_mem_unboundedFrontierVertexSet_of_edge_openSegment_frontier
    (edge_openSegment_frontier_of_edge_openSegment_closure he hclosure)

/-- Local propagation data at an interior frontier point of a canonical edge.
The radius is supplied by the finite-drawing edge-isolation lemma; inside that
ball, every nearby drawing point, hence every nearby unbounded-frontier point,
is carried by the same closed edge segment.  The remaining global propagation
step is to prove closure of the unbounded exterior along the whole open segment. -/
structure UnboundedExteriorFrontierEdgeLocalRows
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C)
    (e : PlanarInterface.Edge n)
    (p : PlanarInterface.Point) : Prop where
  edge_mem : e ∈ (canonicalGraph C).edgeSet
  center_in_openSegment :
    PlanarInterface.InOpenSegment p
      ((canonicalGraph C).point e.1)
      ((canonicalGraph C).point e.2)
  center_frontier :
    p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior
  center_mem_closure :
    p ∈ closure (unboundedExteriorComponentRows C inputs).exterior
  center_not_mem_exterior :
    p ∉ (unboundedExteriorComponentRows C inputs).exterior
  exists_local_radius :
    Exists fun radius : Real =>
      0 < radius /\
        (forall q : PlanarInterface.Point,
          q ∈ Metric.ball p radius ->
            q ∈ embeddedEdgeSet C ->
              q ∈ closedSegment
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2)) /\
        (forall q : PlanarInterface.Point,
          q ∈ Metric.ball p radius ->
            q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
              q ∈ closedSegment
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2))
  openSegment_not_mem_exterior :
    forall q : PlanarInterface.Point,
      PlanarInterface.InOpenSegment q
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2) ->
      q ∉ (unboundedExteriorComponentRows C inputs).exterior

/-- An interior point of a canonical edge on the unbounded exterior frontier
has a genuine local edge-isolation row for the actual carrier. -/
theorem unboundedExterior_frontierEdgeLocalRows_of_inOpenSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    {p : PlanarInterface.Point}
    (he : e ∈ (canonicalGraph C).edgeSet)
    (hpEdge :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2))
    (hpFrontier :
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    UnboundedExteriorFrontierEdgeLocalRows C inputs e p := by
  rcases
      exists_ball_forall_mem_closedSegment_of_inOpenSegment
        (C := C) (p := p) (e := e) he hpEdge with
    ⟨radius, hradius_pos, hlocal_drawing⟩
  refine
    { edge_mem := he
      center_in_openSegment := hpEdge
      center_frontier := hpFrontier
      center_mem_closure := frontier_subset_closure hpFrontier
      center_not_mem_exterior := ?_
      exists_local_radius := ?_
      openSegment_not_mem_exterior := ?_ }
  · exact canonicalEdge_inOpenSegment_not_mem_unboundedExterior
      inputs he hpEdge
  · refine ⟨radius, hradius_pos, hlocal_drawing, ?_⟩
    intro q hqball hqFrontier
    exact hlocal_drawing q hqball
      ((unboundedExteriorComponentRows C inputs).frontier_subset_embeddedEdgeSet
        hqFrontier)
  · intro q hq
    exact canonicalEdge_inOpenSegment_not_mem_unboundedExterior
      inputs he hq

namespace UnboundedExteriorFrontierEdgeLocalRows

variable {C : _root_.UDConfig n}
variable {inputs : FinitePlanarOuterComponentInputs C}
variable {e : PlanarInterface.Edge n}
variable {p : PlanarInterface.Point}

/-- The exact missing propagation input for upgrading one local frontier row
to closure along the whole relative interior of the same edge.

The first field is the one-dimensional connectedness/path input for the open
edge interval.  The second says that, within that interval, the locus already
in the exterior closure is relatively open.  Since exterior closure is closed,
these two rows make the closure locus a nonempty clopen subset of the interval,
hence the whole interval. -/
structure OpenSegmentClosurePropagation
    (rows : UnboundedExteriorFrontierEdgeLocalRows C inputs e p) : Prop where
  segment_preconnected :
    IsPreconnected
      ({q : PlanarInterface.Point |
        PlanarInterface.InOpenSegment q
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2)} :
        Set PlanarInterface.Point)
  closure_locus_isOpen :
    IsOpen
      ({q :
          {q : PlanarInterface.Point //
            PlanarInterface.InOpenSegment q
              ((canonicalGraph C).point e.1)
              ((canonicalGraph C).point e.2)} |
          (q : PlanarInterface.Point) ∈
            closure (unboundedExteriorComponentRows C inputs).exterior})

/-- Once the missing open-edge propagation principle is supplied, the desired
whole-open-segment closure row follows from connectedness: the closure locus is
nonempty, open by the supplied local propagation row, and closed because it is
the preimage of the closed set `closure exterior` in the open segment subtype. -/
theorem openSegment_closure_of_propagation
    (rows : UnboundedExteriorFrontierEdgeLocalRows C inputs e p)
    (prop : OpenSegmentClosurePropagation rows) :
    forall q : PlanarInterface.Point,
      PlanarInterface.InOpenSegment q
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2) ->
      q ∈ closure (unboundedExteriorComponentRows C inputs).exterior := by
  let segment : Set PlanarInterface.Point :=
    {q : PlanarInterface.Point |
      PlanarInterface.InOpenSegment q
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2)}
  let closureLocus : Set segment :=
    {q : segment |
      (q : PlanarInterface.Point) ∈
        closure (unboundedExteriorComponentRows C inputs).exterior}
  have hclosed : IsClosed closureLocus := by
    change
      IsClosed
        (((↑) : segment -> PlanarInterface.Point) ⁻¹'
          closure (unboundedExteriorComponentRows C inputs).exterior)
    exact IsClosed.preimage continuous_subtype_val isClosed_closure
  have hopen : IsOpen closureLocus := by
    simpa [closureLocus, segment] using prop.closure_locus_isOpen
  have hpre :
      IsPreconnected (Set.univ : Set segment) := by
    haveI : PreconnectedSpace segment :=
      Subtype.preconnectedSpace (by
        simpa [segment] using prop.segment_preconnected)
    exact preconnectedSpace_iff_univ.mp inferInstance
  have hnonempty : (Set.univ ∩ closureLocus).Nonempty := by
    refine ⟨⟨p, ?_⟩, ?_⟩
    · simpa [segment] using rows.center_in_openSegment
    · exact ⟨Set.mem_univ _, by simpa [closureLocus] using rows.center_mem_closure⟩
  have hsubset : (Set.univ : Set segment) ⊆ closureLocus :=
    hpre.subset_isClopen ⟨hclosed, hopen⟩ hnonempty
  intro q hq
  exact hsubset (Set.mem_univ ⟨q, by simpa [segment] using hq⟩)

/-- A local row reduces a later whole-open-segment frontier propagation theorem
to concrete membership in `unboundedFrontierEdgeSet`. -/
theorem mem_unboundedFrontierEdgeSet_of_openSegment_frontier
    (rows : UnboundedExteriorFrontierEdgeLocalRows C inputs e p)
    (hfrontier :
      forall q : PlanarInterface.Point,
        PlanarInterface.InOpenSegment q
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    e ∈ unboundedFrontierEdgeSet C inputs :=
  mem_unboundedFrontierEdgeSet_of_edge_openSegment_frontier
    rows.edge_mem hfrontier

/-- Closure is the smaller remaining propagation target: the local row already
records that the whole canonical edge interior is outside the exterior. -/
theorem mem_unboundedFrontierEdgeSet_of_openSegment_closure
    (rows : UnboundedExteriorFrontierEdgeLocalRows C inputs e p)
    (hclosure :
      forall q : PlanarInterface.Point,
        PlanarInterface.InOpenSegment q
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        q ∈ closure (unboundedExteriorComponentRows C inputs).exterior) :
    e ∈ unboundedFrontierEdgeSet C inputs := by
  refine rows.mem_unboundedFrontierEdgeSet_of_openSegment_frontier ?_
  intro q hq
  rw [(unboundedExteriorComponentRows C inputs).exterior_open.frontier_eq]
  exact ⟨hclosure q hq, rows.openSegment_not_mem_exterior q hq⟩

/-- The missing propagation principle gives the whole-open-segment frontier
row, because the local row already records that the edge interior is outside
the exterior component. -/
theorem openSegment_frontier_of_propagation
    (rows : UnboundedExteriorFrontierEdgeLocalRows C inputs e p)
    (prop : OpenSegmentClosurePropagation rows) :
    forall q : PlanarInterface.Point,
      PlanarInterface.InOpenSegment q
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2) ->
      q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
  intro q hq
  rw [(unboundedExteriorComponentRows C inputs).exterior_open.frontier_eq]
  exact
    ⟨openSegment_closure_of_propagation rows prop q hq,
      rows.openSegment_not_mem_exterior q hq⟩

/-- Final local-row handoff under the explicit open-edge propagation
principle. -/
theorem mem_unboundedFrontierEdgeSet_of_propagation
    (rows : UnboundedExteriorFrontierEdgeLocalRows C inputs e p)
    (prop : OpenSegmentClosurePropagation rows) :
    e ∈ unboundedFrontierEdgeSet C inputs :=
  rows.mem_unboundedFrontierEdgeSet_of_openSegment_frontier
    (openSegment_frontier_of_propagation rows prop)

/-- Relative openness of the exterior-closure locus along one open edge is the
only remaining local input needed to promote a local frontier point on that
edge to membership in the selected unbounded-frontier edge carrier. -/
theorem mem_unboundedFrontierEdgeSet_of_local_closure_locus_isOpen
    (rows : UnboundedExteriorFrontierEdgeLocalRows C inputs e p)
    (hopen :
      IsOpen
        ({q :
            {q : PlanarInterface.Point //
              PlanarInterface.InOpenSegment q
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2)} |
          (q : PlanarInterface.Point) ∈
            closure (unboundedExteriorComponentRows C inputs).exterior})) :
    e ∈ unboundedFrontierEdgeSet C inputs :=
  rows.mem_unboundedFrontierEdgeSet_of_propagation
    { segment_preconnected := by
        exact isPreconnected_inOpenSegment
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2)
      closure_locus_isOpen := hopen }

end UnboundedExteriorFrontierEdgeLocalRows

/-- A directly usable local propagation handoff: one interior point of a
canonical edge on the unbounded exterior frontier, plus relative openness of
the exterior-closure locus along the edge, selects the edge in the concrete
unbounded-frontier carrier. -/
theorem mem_unboundedFrontierEdgeSet_of_inOpenSegment_frontier_and_closure_locus_isOpen
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    {p : PlanarInterface.Point}
    (he : e ∈ (canonicalGraph C).edgeSet)
    (hpEdge :
      PlanarInterface.InOpenSegment p
        ((canonicalGraph C).point e.1)
        ((canonicalGraph C).point e.2))
    (hpFrontier :
      p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior)
    (hopen :
      IsOpen
        ({q :
            {q : PlanarInterface.Point //
              PlanarInterface.InOpenSegment q
                ((canonicalGraph C).point e.1)
                ((canonicalGraph C).point e.2)} |
          (q : PlanarInterface.Point) ∈
            closure (unboundedExteriorComponentRows C inputs).exterior})) :
    e ∈ unboundedFrontierEdgeSet C inputs := by
  let rows :
      UnboundedExteriorFrontierEdgeLocalRows C inputs e p :=
    unboundedExterior_frontierEdgeLocalRows_of_inOpenSegment_frontier
      he hpEdge hpFrontier
  exact
    rows.mem_unboundedFrontierEdgeSet_of_local_closure_locus_isOpen
      hopen

/-- Pointwise relative metric neighborhoods along an open edge prove that the
exterior-closure locus is open in the open-segment subtype.  This is the
topological adapter used after the local exterior-sector proof supplies a
small relative interval of points still in the unbounded exterior closure. -/
theorem openSegment_closure_locus_isOpen_of_forall_relative_ball_closure
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (hlocal :
      forall q : PlanarInterface.Point,
        PlanarInterface.InOpenSegment q
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun r : Real =>
            0 < r /\
              forall z : PlanarInterface.Point,
                z ∈ Metric.ball q r ->
                PlanarInterface.InOpenSegment z
                  ((canonicalGraph C).point e.1)
                  ((canonicalGraph C).point e.2) ->
                z ∈ closure (unboundedExteriorComponentRows C inputs).exterior) :
    IsOpen
      ({q :
          {q : PlanarInterface.Point //
            PlanarInterface.InOpenSegment q
              ((canonicalGraph C).point e.1)
              ((canonicalGraph C).point e.2)} |
        (q : PlanarInterface.Point) ∈
          closure (unboundedExteriorComponentRows C inputs).exterior}) := by
  rw [Metric.isOpen_iff]
  intro q hq
  rcases hlocal (q : PlanarInterface.Point) q.property hq with
    ⟨r, hrpos, hball⟩
  refine ⟨r, hrpos, ?_⟩
  intro z hz
  exact hball (z : PlanarInterface.Point) (by simpa using hz) z.property

/-- One-sided exterior-sector witness rows erase to the relative-closure row
used by boundary-edge propagation.

The source row says that, around each edge point already known to be in the
exterior closure, every nearby point of the same open edge has exterior points
arbitrarily close to it.  By the metric closure criterion, each such nearby
edge point is in the exterior closure, which is exactly the `hlocal` shape
consumed by `boundary_cycle_edge_openSegment_frontier_of_inOpenSegment_frontier_and_relative_ball_closure`. -/
theorem relative_ball_closure_of_forall_nearby_edge_point_exterior_points
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {e : PlanarInterface.Edge n}
    (hnear :
      forall q : PlanarInterface.Point,
        PlanarInterface.InOpenSegment q
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun r : Real =>
            0 < r /\
              forall z : PlanarInterface.Point,
                z ∈ Metric.ball q r ->
                PlanarInterface.InOpenSegment z
                  ((canonicalGraph C).point e.1)
                  ((canonicalGraph C).point e.2) ->
                forall eps : Real,
                  0 < eps ->
                    Exists fun y : PlanarInterface.Point =>
                      y ∈ (unboundedExteriorComponentRows C inputs).exterior /\
                        dist y z < eps) :
      forall q : PlanarInterface.Point,
        PlanarInterface.InOpenSegment q
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun r : Real =>
            0 < r /\
              forall z : PlanarInterface.Point,
                z ∈ Metric.ball q r ->
                PlanarInterface.InOpenSegment z
                  ((canonicalGraph C).point e.1)
                  ((canonicalGraph C).point e.2) ->
                z ∈ closure (unboundedExteriorComponentRows C inputs).exterior := by
  intro q hq hqclosure
  rcases hnear q hq hqclosure with ⟨r, hrpos, hpoints⟩
  refine ⟨r, hrpos, ?_⟩
  intro z hzball hzseg
  rw [Metric.mem_closure_iff]
  intro eps heps
  rcases hpoints z hzball hzseg eps heps with ⟨y, hyExterior, hydist⟩
  exact ⟨y, hyExterior, by simpa [dist_comm] using hydist⟩

/-- Residual local exterior-side source for an interior point of a canonical
edge.  Once one point of the open edge is on the unbounded exterior frontier,
every open-edge point already in the exterior closure has a relative
neighborhood whose nearby open-edge points are limits of actual exterior
points. -/
def InteriorEdgeNearbyExteriorPointSource
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
    e ∈ (canonicalGraph C).edgeSet ->
    PlanarInterface.InOpenSegment p
      ((canonicalGraph C).point e.1)
      ((canonicalGraph C).point e.2) ->
    p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
      forall q : PlanarInterface.Point,
        PlanarInterface.InOpenSegment q
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun r : Real =>
            0 < r /\
              forall z : PlanarInterface.Point,
                z ∈ Metric.ball q r ->
                PlanarInterface.InOpenSegment z
                  ((canonicalGraph C).point e.1)
                  ((canonicalGraph C).point e.2) ->
                forall eps : Real,
                  0 < eps ->
                    Exists fun y : PlanarInterface.Point =>
                      y ∈ (unboundedExteriorComponentRows C inputs).exterior /\
                        dist y z < eps

/-- Sharper local edge-side source for the nearby-exterior-points row.

For each same-edge closure point, a small interval of nearby edge points is
bordered by a local open preconnected patch of the selected exterior
component.  The patch formulation is the non-circular geometric input: the
downstream nearby-points row only reads off that every nearby edge point lies
in the closure of an actual exterior-side neighborhood. -/
def InteriorEdgeLocalExteriorSideSource
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
    e ∈ (canonicalGraph C).edgeSet ->
    PlanarInterface.InOpenSegment p
      ((canonicalGraph C).point e.1)
      ((canonicalGraph C).point e.2) ->
    p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
      forall q : PlanarInterface.Point,
        PlanarInterface.InOpenSegment q
          ((canonicalGraph C).point e.1)
          ((canonicalGraph C).point e.2) ->
        q ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun r : Real =>
            0 < r /\
              forall z : PlanarInterface.Point,
                z ∈ Metric.ball q r ->
                PlanarInterface.InOpenSegment z
                  ((canonicalGraph C).point e.1)
                  ((canonicalGraph C).point e.2) ->
                  Exists fun side : Set PlanarInterface.Point =>
                    IsOpen side /\
                      IsPreconnected side /\
                        side ⊆ (unboundedExteriorComponentRows C inputs).exterior /\
                          side ⊆ Metric.ball z r /\
                            z ∈ closure side

/-- Stricter local side-selection source for an interior point of a canonical
edge.  Instead of allowing an arbitrary exterior patch, it asks for the actual
connected component of the local exterior
`exterior ∩ Metric.ball z r` that accumulates at each nearby edge point `z`.

This is the honest local half-neighborhood selection still missing from the
finite drawing/topological component rows: once the relevant local component is
selected, its openness, preconnectedness, and containment properties are
formal consequences of `connectedComponentIn`. -/
def InteriorEdgeLocalExteriorSideComponentSource
    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point},
    e ∈ (canonicalGraph C).edgeSet ->
    PlanarInterface.InOpenSegment p
      ((canonicalGraph C).point e.1)
      ((canonicalGraph C).point e.2) ->
    p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
      forall q : PlanarInterface.Point,
        PlanarInterface.InOpenSegment q
