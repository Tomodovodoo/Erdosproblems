  incidentUnboundedFrontierEdgeSource_of_interiorClosure_and_interiorCarrier
    (C := C) (inputs := inputs)
    (interior_frontier_edge_carrier_membership_source_of_fixed_side_halfballs
      (C := C) (inputs := inputs))
    interior_closure

