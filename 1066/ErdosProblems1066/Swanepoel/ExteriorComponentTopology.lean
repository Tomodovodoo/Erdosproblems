/-- Existential boundary-cycle version of
`cyclicCoverageLocalSectorRows_of_boundaryCycle_complete`. -/
noncomputable def cyclicCoverageLocalSectorRows_of_exists_boundaryCycle_complete
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (exists_unboundedFrontierCarrierBoundaryCycle :
      Exists fun B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C =>
