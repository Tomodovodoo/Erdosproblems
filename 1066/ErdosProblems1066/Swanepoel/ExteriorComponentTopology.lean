      O B hperiod tail_eq frontier_iff_tail edge_openSegment_frontier)

/-- Raw-face-orbit start-identification reducer for the actual boundary-cycle
frontier-equivalence rows.

This removes the bookkeeping residuals from
`ofRawFaceSuccOrbitBoundaryRows` in the common case where the selected raw
face-successor orbit is identified with the first dart of an existing honest
`FaceDartOrbitExteriorCarrierRows` package.  The actual boundary cycle is the
stored face-orbit boundary; the period and tail identifications are derived
from the face-successor permutation, and the consecutive edge-frontier row is
transported directly from that stored boundary. -/
def ofFaceDartOrbitRawFaceSuccOrbitStartRows
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit rows.rotation start)
    (hstart :
      start = rows.orbit.dart ⟨0, rows.orbit.boundary.length_pos⟩) :
    ActualBoundaryCycleFrontierEquivalenceRows C inputs := by
  let B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C :=
    rows.orbit.boundary
  let hperiod : B.length = O.period :=
    rows.rawFaceSuccOrbit_period_eq_of_start_zero O hstart
  let tail_eq :
      forall k : Fin B.length,
        (O.dart (Fin.cast hperiod k)).tail = B.vertex k :=
    rows.rawFaceSuccOrbit_tail_eq_of_start_zero O hstart hperiod
  let frontier_iff_tail :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin O.period => (O.dart k).tail = v :=
    rows.frontier_iff_rawFaceSuccOrbit_tail O hperiod tail_eq
  let edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior := by
    intro k p hp
    let j : Fin B.length := Fin.cast hperiod.symm k
    have hcast : Fin.cast hperiod j = k := by
      ext
      simp [j]
    have htail :
        (O.dart k).tail = B.vertex j := by
      simpa [hcast] using tail_eq j
    have hcast_succ :
        Fin.cast hperiod (PlanarInterface.cyclicSucc B.length_pos j) =
          PlanarInterface.cyclicSucc O.period_pos k := by
      calc
        Fin.cast hperiod (PlanarInterface.cyclicSucc B.length_pos j) =
            PlanarInterface.cyclicSucc O.period_pos (Fin.cast hperiod j) := by
              ext
              simp [PlanarInterface.cyclicSucc, hperiod]
        _ = PlanarInterface.cyclicSucc O.period_pos k := by
              rw [hcast]
    have htail_succ :
        (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail =
          B.vertex (PlanarInterface.cyclicSucc B.length_pos j) := by
      rw [← hcast_succ]
      exact tail_eq (PlanarInterface.cyclicSucc B.length_pos j)
    exact
      rows.orbit_edge_openSegment_frontier j p (by
        simpa [htail, htail_succ] using hp)
  exact
    ofRawFaceSuccOrbitBoundaryRows
      O B hperiod tail_eq frontier_iff_tail edge_openSegment_frontier

/-- Claim `S2-agent-actual-boundary-cycle-frontier-equivalence`, raw-orbit
start-identification form.

The remaining source residual is now just the honest
`FaceDartOrbitExteriorCarrierRows` package for the selected unbounded exterior
face boundary, plus the proof that the chosen raw face-successor orbit starts
at that package's first dart. -/
theorem S2_agent_actual_boundary_cycle_frontier_equivalence_of_faceDartOrbit_rawFaceSuccOrbitStartRows
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit rows.rotation start)
    (hstart :
      start = rows.orbit.dart ⟨0, rows.orbit.boundary.length_pos⟩) :
    Exists fun B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C =>
      (forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin B.length => B.vertex k = v) ∧
        (forall k : Fin B.length,
          forall p : PlanarInterface.Point,
            PlanarInterface.InOpenSegment p
              ((canonicalGraph C).point (B.vertex k))
              ((canonicalGraph C).point
                (B.vertex (PlanarInterface.cyclicSucc B.length_pos k))) ->
            p ∈ frontier
              (unboundedExteriorComponentRows C inputs).exterior) :=
  S2_agent_actual_boundary_cycle_frontier_equivalence
    (ofFaceDartOrbitRawFaceSuccOrbitStartRows rows O hstart)

/-- Raw-orbit start-identification form of the actual boundary
edge-membership source. -/
theorem S2_agent_actual_boundary_edge_mem_source_of_faceDartOrbit_rawFaceSuccOrbitStartRows
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit rows.rotation start)
    (hstart :
      start = rows.orbit.dart ⟨0, rows.orbit.boundary.length_pos⟩) :
    BoundaryCycleEdgeMemSource C inputs :=
