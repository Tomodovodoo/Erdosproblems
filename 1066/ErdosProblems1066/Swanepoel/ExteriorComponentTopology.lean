/-- Final non-source S2 wrapper: once a concrete exterior boundary cycle and
the four explicit geometric/frontier source rows are supplied, the existing
complete boundary-carrier reducer packages them as the exterior frontier
carrier rows.  This wrapper deliberately does not assert that such a boundary
cycle exists. -/
theorem exteriorFrontierCarrierRows_of_inputs
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
    (faceSuccRows :
      _root_.ErdosProblems1066.Swanepoel.GeometricRotationSystem.GeometricBoundarySuccessorRows
        C B)
    (frontier_iff_cycle_vertex :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin B.length => B.vertex k = v)
    (cycle_edge_openSegment_frontier :
      forall k : Fin B.length,
