          UnboundedFrontierCarrierLocalSectorRowsAt inputs a)) :=
  FaceDartOrbitExteriorCarrierRows.toCyclicCoverageLocalSectorRows
    (faceDartOrbitExteriorCarrierRows_of_boundaryCarrierRows
    inputs R B faceRows frontier_iff_cycle_vertex
    cycle_edge_openSegment_frontier incident_only_pred_succ)

/-- Boundary-cycle carrier facts with selected consecutive frontier edges fill
the compact S2 source package directly.  This consumes only the boundary cycle,
the vertex/frontier equivalence, consecutive membership in the concrete
unbounded-frontier edge set, and the incident-edge completeness row. -/
noncomputable def cyclicCoverageLocalSectorRows_of_boundaryCycle_complete
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
    (frontier_iff_cycle_vertex :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin B.length => B.vertex k = v)
    (cycle_edge_mem :
      forall k : Fin B.length,
        (B.vertex k,
            B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
            unboundedFrontierEdgeSet C inputs ∨
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
            B.vertex k) ∈
            unboundedFrontierEdgeSet C inputs)
    (hcomplete :
      BoundaryCycleIncidentFrontierEdgeCompleteness inputs B) :
    Nonempty
      (UnboundedFrontierCarrierCyclicCoverageRows C inputs ×
        (forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
          UnboundedFrontierCarrierLocalSectorRowsAt inputs a)) := by
  classical
  refine ⟨(?_, ?_)⟩
  · exact
      unboundedFrontierCarrierCyclicCoverageRows_of_boundaryCycle
        B frontier_iff_cycle_vertex cycle_edge_mem
  · intro a
    have hfrontier :
        (canonicalGraph C).point a.1 ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior :=
      mem_unboundedFrontierVertexSet_iff.1 a.2
    let k : Fin B.length :=
      Classical.choose ((frontier_iff_cycle_vertex a.1).1 hfrontier)
    have hk : B.vertex k = a.1 :=
      Classical.choose_spec ((frontier_iff_cycle_vertex a.1).1 hfrontier)
    let pred := PlanarInterface.cyclicPred B.length_pos k
    let succ := PlanarInterface.cyclicSucc B.length_pos k
    have hsucc_pred :
        PlanarInterface.cyclicSucc B.length_pos pred = k := by
      dsimp [pred]
      exact PlanarInterface.cyclicSucc_cyclicPred B.length_pos k
    have hleft_edge :
        (a.1, B.vertex pred) ∈ unboundedFrontierEdgeSet C inputs ∨
          (B.vertex pred, a.1) ∈ unboundedFrontierEdgeSet C inputs := by
      have hedge :
          (B.vertex pred, B.vertex k) ∈
              unboundedFrontierEdgeSet C inputs ∨
            (B.vertex k, B.vertex pred) ∈
              unboundedFrontierEdgeSet C inputs := by
        simpa [pred, hsucc_pred] using cycle_edge_mem pred
      rcases hedge with hedge | hedge
      · right
        simpa [hk] using hedge
      · left
        simpa [hk] using hedge
    have hright_edge :
        (a.1, B.vertex succ) ∈ unboundedFrontierEdgeSet C inputs ∨
          (B.vertex succ, a.1) ∈ unboundedFrontierEdgeSet C inputs := by
      have hedge :
          (B.vertex k, B.vertex succ) ∈
              unboundedFrontierEdgeSet C inputs ∨
            (B.vertex succ, B.vertex k) ∈
              unboundedFrontierEdgeSet C inputs := by
        simpa [succ] using cycle_edge_mem k
      rcases hedge with hedge | hedge
      · left
        simpa [hk] using hedge
      · right
        simpa [hk] using hedge
    have hpred_ne_succ : B.vertex pred ≠ B.vertex succ := by
      intro h
      have hidx : pred = succ := B.simple h
      exact
        (PlanarInterface.cyclicPred_ne_cyclicSucc_of_three_le
          B.length_pos B.length_ge_three k)
          (by simpa [pred, succ] using hidx)
    refine
      { left := B.vertex pred
        right := B.vertex succ
        left_edge := hleft_edge
        right_edge := hright_edge
        heads_ne := hpred_ne_succ
        only := ?_ }
    intro b hab
    have honly :=
      incident_only_pred_succ_of_boundaryCycleIncidentFrontierEdgeCompleteness
        hcomplete k a b hk.symm hab
    simpa [pred, succ] using honly

/-- Complete boundary-cycle rows also source the closed-segment chain for the
actual selected frontier-edge carrier.

The incident-completeness row is what prevents selected frontier chords: it
lets arbitrary selected edges attach to the boundary carrier chain at a
predecessor or successor side. -/
noncomputable def unboundedFrontierEdgeCarrierSegmentChainConnected_of_boundaryCycle_complete
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
    (frontier_iff_cycle_vertex :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin B.length => B.vertex k = v)
    (cycle_edge_mem :
      forall k : Fin B.length,
        (B.vertex k,
            B.vertex (PlanarInterface.cyclicSucc B.length_pos k)) ∈
            unboundedFrontierEdgeSet C inputs ∨
          (B.vertex (PlanarInterface.cyclicSucc B.length_pos k),
            B.vertex k) ∈
            unboundedFrontierEdgeSet C inputs)
    (hcomplete :
      BoundaryCycleIncidentFrontierEdgeCompleteness inputs B) :
    UnboundedFrontierEdgeCarrierSegmentChainConnected inputs := by
  let R : UnitDistanceRotationSystem C :=
    UnitDistanceRotationSystem.ofBoundaryCycle B
  let faceRows : UnitDistanceCycleFaceSuccRows C R B :=
    UnitDistanceCycleFaceSuccRows.ofBoundaryCycle B
  let rows : FaceDartOrbitExteriorCarrierRows C inputs :=
    faceDartOrbitExteriorCarrierRows_of_boundaryCarrierRows_complete
      inputs R B faceRows frontier_iff_cycle_vertex
      (cycle_edge_openSegment_frontier_of_unboundedFrontierEdgeSet_or_symm
        cycle_edge_mem)
      hcomplete
  exact rows.edgeCarrierSegmentChainConnected

/-- Complete boundary-cycle rows, plus the existing edge-interior nearby
exterior-point source, fill the compact preconnectedness source rows. -/
noncomputable def unboundedExteriorFrontierPreconnectedSourceRows_of_boundaryCycle_complete
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
