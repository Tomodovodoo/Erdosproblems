    (C : _root_.UDConfig n)
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall A B : Set PlanarInterface.Point,
    IsClosed A ->
      IsClosed B ->
        Disjoint A B ->
          frontier (unboundedExteriorComponentRows C inputs).exterior =
              A ∪ B ->
            Exists fun K₁ : Set PlanarInterface.Point =>
              Exists fun K₂ : Set PlanarInterface.Point =>
                IsClosed K₁ /\
                  IsClosed K₂ /\
                    Disjoint K₁ K₂ /\
                      embeddedEdgeSet C = K₁ ∪ K₂ /\
                        A ⊆ K₁ /\
                          B ⊆ K₂

