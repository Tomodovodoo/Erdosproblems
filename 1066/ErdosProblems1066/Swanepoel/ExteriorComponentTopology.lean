/-- A connected finite two-regular graph mapped injectively into the
unit-distance graph gives the actual boundary edge-membership source, provided
its vertices are exactly the exterior-frontier vertices and its edges are
selected unbounded-frontier edges up to orientation. -/
theorem boundaryCycleEdgeMemSource_of_connected_two_regular_frontier_graph_edge_mem
    {V : Type u} [Fintype V]
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (F : SimpleGraph V) [DecidableRel F.Adj]
    (hconn : F.Connected)
    (hdegree_two : forall v : V,
      @SimpleGraph.degree V F v (F.neighborSetFintype v) = 2)
    (phi : SimpleGraph.Hom F (GraphBridge.unitDistanceSimpleGraph C))
    (hphi : Function.Injective phi)
    (hfrontier :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun x : V => phi x = v)
    (edge_mem :
      forall {x y : V}, F.Adj x y ->
        (phi x, phi y) ∈ unboundedFrontierEdgeSet C inputs ∨
          (phi y, phi x) ∈ unboundedFrontierEdgeSet C inputs) :
    ActualBoundaryCycleFrontierEquivalenceRows.BoundaryCycleEdgeMemSource
      C inputs := by
  classical
  have hdegree_two' : forall v : V, F.degree v = 2 := by
    intro v
    simpa using hdegree_two v
  rcases
      exists_unitDistanceCycleBoundary_covering_spanning_cycle_hom_edge_lifts
        (C := C) F phi hphi
        (connected_two_regular_spanning_cycle F hconn hdegree_two') with
    ⟨B, hcover, himage, hedge_lifts⟩
  refine ⟨B, ?_, ?_⟩
  · intro v
    constructor
    · intro hv
      rcases (hfrontier v).1 hv with ⟨x, hx⟩
      rcases hcover x with ⟨k, hk⟩
      exact ⟨k, hk.trans hx⟩
    · rintro ⟨k, hk⟩
      rcases himage k with ⟨x, hx⟩
      exact (hfrontier v).2 ⟨x, hx.symm.trans hk⟩
  · intro k
    rcases hedge_lifts k with ⟨x, y, hxy, hk, hsucc⟩
    rcases edge_mem hxy with hforward | hreverse
    · left
      simpa [hk, hsucc] using hforward
    · right
      simpa [hk, hsucc] using hreverse

/-- Claim `S2-agent-raw-orbit-cycle-boundary-constructor`, cycle-graph route.

The raw face-successor orbit is used as the finite cycle graph itself:
vertices are raw tails, successor adjacency is supplied by the face-successor
endpoint chaining, and selected boundary-edge membership comes from the raw
open-segment frontier row. -/
theorem S2_agent_raw_cyclegraph_boundary_source_route
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C} {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (period_ge_three : 3 <= O.period)
    (tail_injective :
      Function.Injective fun k : Fin O.period => (O.dart k).tail)
    (frontier_iff_tail : forall v : Fin n,
      (canonicalGraph C).point v ∈
          frontier (unboundedExteriorComponentRows C inputs).exterior ↔
        Exists fun k : Fin O.period => (O.dart k).tail = v)
    (edge_openSegment_frontier :
      forall k : Fin O.period, forall p : PlanarInterface.Point,
        PlanarInterface.InOpenSegment p
          ((canonicalGraph C).point (O.dart k).tail)
          ((canonicalGraph C).point
            (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
        p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    ActualBoundaryCycleFrontierEquivalenceRows.BoundaryCycleEdgeMemSource
      C inputs := by
  classical
  let F : SimpleGraph (Fin O.period) := SimpleGraph.cycleGraph O.period
  let phi : SimpleGraph.Hom F (GraphBridge.unitDistanceSimpleGraph C) := {
    toFun := fun k => (O.dart k).tail
    map_rel' := by
      intro i j hij
      rcases cycleGraph_adj_eq_cyclicSucc_or_eq_cyclicPred
          O.period_pos period_ge_three hij with hsucc | hpred
      · subst j
        exact rawFaceSuccOrbit_tail_adj_cyclicSucc O i
      · subst j
        have hpred_succ :
            PlanarInterface.cyclicSucc O.period_pos
                (PlanarInterface.cyclicPred O.period_pos i) = i :=
          PlanarInterface.cyclicSucc_cyclicPred O.period_pos i
        exact (GraphBridge.unitDistanceSimpleGraph C).symm (by
          simpa [hpred_succ] using
            rawFaceSuccOrbit_tail_adj_cyclicSucc O
              (PlanarInterface.cyclicPred O.period_pos i)) }
  exact
    boundaryCycleEdgeMemSource_of_connected_two_regular_frontier_graph_edge_mem
      (inputs := inputs)
      F
      (hconn := by
        rw [SimpleGraph.connected_iff]
        exact ⟨SimpleGraph.cycleGraph_preconnected,
          Fin.pos_iff_nonempty.mp O.period_pos⟩)
      (hdegree_two := by
        intro v
        exact cycleGraph_degree_two_of_three_le period_ge_three v)
      phi
      tail_injective
      (by
        intro v
        simpa [phi] using frontier_iff_tail v)
      (by
        intro x y hxy
        rcases cycleGraph_adj_eq_cyclicSucc_or_eq_cyclicPred
            O.period_pos period_ge_three hxy with hsucc | hpred
        · subst y
          simpa [phi] using
            rawFaceSuccOrbit_edge_mem_unboundedFrontierEdgeSet_or_symm
              O edge_openSegment_frontier x
        · subst y
          have hpred_succ :
              PlanarInterface.cyclicSucc O.period_pos
                  (PlanarInterface.cyclicPred O.period_pos x) = x :=
            PlanarInterface.cyclicSucc_cyclicPred O.period_pos x
          rcases
              rawFaceSuccOrbit_edge_mem_unboundedFrontierEdgeSet_or_symm
                O edge_openSegment_frontier
                (PlanarInterface.cyclicPred O.period_pos x) with
            hforward | hreverse
          · right
            simpa [phi, hpred_succ] using hforward
          · left
            simpa [phi, hpred_succ] using hreverse)

/-- Consecutive raw frontier-edge rows place every raw tail in the concrete
unbounded-frontier carrier vertex set. -/
