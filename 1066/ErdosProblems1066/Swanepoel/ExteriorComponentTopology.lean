            rows.orbit.boundary.vertex i j) :
    ¬ Exists fun i : Fin rows.orbit.boundary.length =>
      Exists fun j : Fin rows.orbit.boundary.length =>
        i ≠ j ∧
          rows.orbit.boundary.vertex i = rows.orbit.boundary.vertex j := by
  rintro ⟨i, j, hij, hsame⟩
  exact hij (rows.boundary_vertex_injective_of_noCutVertex hrows hsame)

/-- Nodup form of the face-orbit no-cut repeat handoff. -/
theorem boundary_vertices_nodup_of_noCutVertex
    (rows : FaceDartOrbitExteriorCarrierRows C inputs)
    (hrows :
      forall {i j : Fin rows.orbit.boundary.length},
        i ≠ j ->
        rows.orbit.boundary.vertex i = rows.orbit.boundary.vertex j ->
          RepeatedExteriorBoundarySeparationRows C
            rows.orbit.boundary.vertex i j) :
    (List.ofFn rows.orbit.boundary.vertex).Nodup :=
  exterior_boundary_vertices_nodup_of_noCutVertex
    rows.orbit.boundary.vertex inputs.noCutVertex hrows

end FaceDartOrbitExteriorCarrierRows

/-- The remaining exterior-cycle source after the drawing-complement row:
choose a unit-distance cycle whose vertices are exactly the graph vertices on
the exterior frontier. -/
structure ExteriorFrontierCycleRows
