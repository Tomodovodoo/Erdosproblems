          Exists fun k : Fin B.length => B.vertex k = v := by
  let rows :=
    unboundedExteriorFrontierCycleRows_of_rawFaceSuccOrbit_sourceRows
      O edge_frontier_point nearby_edge_point_exterior_points connectedRows
      raw_pred_succ_tail_ne localSectorRows repeated_tail_rows
  refine ⟨rows.boundary, ?_⟩
  intro v
  simpa [rows, unboundedExteriorFrontierCycleRows_of_rawFaceSuccOrbit_sourceRows,
    unboundedExteriorFrontierCycleRows_of_rawFaceSuccOrbit,
    unboundedExteriorFrontierCycleRows_of_carrier,
    unboundedExteriorFrontierCycleRows_of_connected_two_regular_frontier_graph,
    unboundedExteriorFrontierCycleRowsOfBoundary] using
    rows.frontier_iff_cycle_vertex v

/-- Existential boundary-cycle projection of
`unboundedExteriorFrontierCycleRows_of_rawFaceSuccOrbit`.

The result is a genuine `JordanBoundaryConcrete.UnitDistanceCycleBoundary C`
with exactly the unbounded exterior-frontier graph vertices.  The remaining
carrier-specific rows, if the final S2 package is needed, are consecutive
membership in `unboundedFrontierEdgeSet` for this chosen boundary and the
incident frontier-edge completeness row. -/
theorem exists_unboundedExteriorFrontierCycleBoundary_of_rawFaceSuccOrbit
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    {R : UnitDistanceRotationSystem C}
    {start : UnitDistanceDart C}
    (O : UnitDistanceRotationSystem.RawFaceSuccOrbit R start)
    (period_ge_three : 3 <= O.period)
    (tail_injective :
      Function.Injective fun k : Fin O.period => (O.dart k).tail)
    (frontier_iff_tail :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin O.period => (O.dart k).tail = v)
    (edge_openSegment_frontier :
      forall k : Fin O.period,
        forall p : PlanarInterface.Point,
          PlanarInterface.InOpenSegment p
            ((canonicalGraph C).point (O.dart k).tail)
            ((canonicalGraph C).point
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ->
          p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    Exists fun B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C =>
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin B.length => B.vertex k = v := by
  let rows :=
    unboundedExteriorFrontierCycleRows_of_rawFaceSuccOrbit
      O period_ge_three tail_injective frontier_iff_tail
      edge_openSegment_frontier
  refine ⟨rows.boundary, ?_⟩
  intro v
  simpa [rows, unboundedExteriorFrontierCycleRows_of_rawFaceSuccOrbit,
    unboundedExteriorFrontierCycleRows_of_carrier,
    unboundedExteriorFrontierCycleRows_of_connected_two_regular_frontier_graph,
    unboundedExteriorFrontierCycleRowsOfBoundary] using
    rows.frontier_iff_cycle_vertex v

/-- The concrete ordered-edge carrier graph can fill the honest carrier row
once its remaining geometric facts are proved: connectedness, degree two, and
the fact that every selected ordered edge has its whole relative interior on
the unbounded exterior frontier. -/
noncomputable def exteriorFrontierCarrierRows_of_frontierCarrierGraph
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    [DecidableRel (unboundedFrontierCarrierGraph C inputs).Adj]
    (hconn : (unboundedFrontierCarrierGraph C inputs).Connected)
    (hdegree_two :
      forall v : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        @SimpleGraph.degree _
          (unboundedFrontierCarrierGraph C inputs) v
          ((unboundedFrontierCarrierGraph C inputs).neighborSetFintype v) =
            2)
    (hedge_frontier :
      forall e : PlanarInterface.Edge n,
        e ∈ unboundedFrontierEdgeSet C inputs ->
          forall p : PlanarInterface.Point,
            PlanarInterface.InOpenSegment p
              ((canonicalGraph C).point e.1)
              ((canonicalGraph C).point e.2) ->
            p ∈ frontier (unboundedExteriorComponentRows C inputs).exterior) :
    ExteriorFrontierCarrierRows C inputs where
  V := {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs}
  instFintype := inferInstance
  F := unboundedFrontierCarrierGraph C inputs
  instDecidableAdj := inferInstance
  phi := unboundedFrontierCarrierGraphHom C inputs
  phi_injective := unboundedFrontierCarrierGraphHom_injective C inputs
  connected := hconn
  degree_two := hdegree_two
  vertex_image_iff_frontier :=
    unboundedFrontierCarrierGraph_vertex_image_iff_frontier C inputs
  edge_openSegment_frontier := by
    intro x y hxy p hp
    exact
      unboundedFrontierCarrierGraph_openSegment_frontier_of_adj
        (C := C) (inputs := inputs)
        hedge_frontier hxy p hp

/-- Version of the concrete-carrier constructor using the named whole-edge
frontier row. -/
noncomputable def exteriorFrontierCarrierRows_of_frontierCarrierGraph_whole
    {C : _root_.UDConfig n}
