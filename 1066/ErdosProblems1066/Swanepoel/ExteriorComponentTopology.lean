        C B k other

/-- Point-ray form of the open-segment local exterior angular residual.

This is the genuinely local source row left after removing the graph-dart
angle bookkeeping: a nearby actual unbounded-frontier point in the relative
interior of a third incident edge has its ray from the boundary vertex in the
predecessor/successor exterior sector. -/
abbrev BoundaryFrontierOpenSegmentLocalExteriorSector
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall (k : Fin B.length) (eps : Real) (q : PlanarInterface.Point)
      (other : Fin n),
    q ∈ Metric.ball ((canonicalGraph C).point (B.vertex k)) eps ->
    q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
    (canonicalGraph C).Adj (B.vertex k) other ->
    PlanarInterface.InOpenSegment q
      ((canonicalGraph C).point (B.vertex k))
      ((canonicalGraph C).point other) ->
    other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
    other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
      BoundaryPredSuccPointAngularBetween C B k q

/-- Local propagation row for the open-segment source.

Starting from one actual exterior-frontier point in the relative interior of a
third incident edge, the closure locus of the unbounded exterior is locally open
inside that same edge interior.  Together with the connected open segment, this
upgrades the whole third-edge interior to frontier membership. -/
abbrev BoundaryFrontierOpenSegmentRelativeClosurePropagation
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C) : Prop :=
  forall (k : Fin B.length) (q : PlanarInterface.Point) (other : Fin n),
    q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
    (canonicalGraph C).Adj (B.vertex k) other ->
    PlanarInterface.InOpenSegment q
      ((canonicalGraph C).point (B.vertex k))
      ((canonicalGraph C).point other) ->
    other ≠ B.vertex (PlanarInterface.cyclicPred B.length_pos k) ->
    other ≠ B.vertex (PlanarInterface.cyclicSucc B.length_pos k) ->
      forall z : PlanarInterface.Point,
        PlanarInterface.InOpenSegment z
          ((canonicalGraph C).point (B.vertex k))
          ((canonicalGraph C).point other) ->
        z ∈ closure (unboundedExteriorComponentRows C inputs).exterior ->
          Exists fun r : Real =>
            0 < r /\
              forall y : PlanarInterface.Point,
                y ∈ Metric.ball z r ->
                PlanarInterface.InOpenSegment y
                  ((canonicalGraph C).point (B.vertex k))
                  ((canonicalGraph C).point other) ->
                y ∈ closure (unboundedExteriorComponentRows C inputs).exterior

/-- The boundary open-segment propagation row follows from the sharper
interior-edge carrier source.  Once the incident edge is already selected in
`unboundedFrontierEdgeSet`, its whole open segment is frontier by definition,
so every relative neighborhood along that segment is trivially in the exterior
closure. -/
theorem boundary_frontier_openSegment_relativeClosurePropagation_of_interior_edge_mem
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (interior_edge_mem :
      InteriorFrontierEdgeCarrierMembershipSource C inputs) :
    BoundaryFrontierOpenSegmentRelativeClosurePropagation inputs B := by
  intro k q other hqfrontier hadj hqopen _hother_pred _hother_succ
    _z _hzopen _hzclosure
  rcases hadj with hedge | hedge
  · have hedge_frontier :
        (B.vertex k, other) ∈ unboundedFrontierEdgeSet C inputs :=
      interior_edge_mem hedge hqopen hqfrontier
    refine ⟨1, by norm_num, ?_⟩
    intro y _hyball hyopen
    exact
      frontier_subset_closure
        ((mem_unboundedFrontierEdgeSet_iff.1 hedge_frontier).2 y hyopen)
  · have hedge_frontier :
        (other, B.vertex k) ∈ unboundedFrontierEdgeSet C inputs :=
      interior_edge_mem hedge (inOpenSegment_symm hqopen) hqfrontier
    refine ⟨1, by norm_num, ?_⟩
    intro y _hyball hyopen
    exact
      frontier_subset_closure
        ((mem_unboundedFrontierEdgeSet_iff.1 hedge_frontier).2 y
          (inOpenSegment_symm hyopen))

/-- Boundary-cycle specialization of the global interior relative-ball closure
row.  This removes the boundary-specific propagation assumption whenever the
existing interior-edge closure row is available. -/
theorem boundary_frontier_openSegment_relativeClosurePropagation_of_interior_relative_ball_closure
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (interior_relative_ball_closure :
      InteriorRelativeBallClosureRow C inputs) :
    BoundaryFrontierOpenSegmentRelativeClosurePropagation inputs B :=
  boundary_frontier_openSegment_relativeClosurePropagation_of_interior_edge_mem
    (C := C) (inputs := inputs) (B := B)
    (interior_frontier_edge_carrier_membership_source_of_relative_ball_closure
      interior_relative_ball_closure)

/-- Boundary-cycle specialization of the nearby-exterior-points source.  The
metric closure adapter is the existing `S2_agent_interior_relative_ball_closure_source`;
the boundary row is only its incident-edge restriction. -/
theorem boundary_frontier_openSegment_relativeClosurePropagation_of_nearby_edge_point_exterior_points
    {C : _root_.UDConfig n} {inputs : FinitePlanarOuterComponentInputs C}
    {B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C}
    (nearby_edge_point_exterior_points :
