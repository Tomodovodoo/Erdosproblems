/-! ## Finite-label distance-row adapters -/

/-- Finite label rows sufficient to build the raw Figure 8 distance witnesses:
four unit-distance adjacencies and the two distinctness facts used for
separation. -/
abbrev Figure8FiniteLabelAdjacencyDistinctnessRows {n : Nat}
    (C : _root_.UDConfig n) (good : Nat -> Prop) : Prop :=
  forall {i j : Nat},
    1 <= i -> i + 1 < j -> j <= 10 ->
    Not (good i) -> Not (good j) ->
      Exists fun p : Fin n =>
      Exists fun qi : Fin n =>
      Exists fun qj : Fin n =>
      Exists fun s : Fin n =>
      Exists fun r : Fin n =>
        GraphBridge.UnitDistanceAdj C p qi /\
          GraphBridge.UnitDistanceAdj C p qj /\
          GraphBridge.UnitDistanceAdj C qi s /\
          GraphBridge.UnitDistanceAdj C qj r /\
          Ne qi qj /\
          Ne s r

/-- Finite label rows sufficient to build the raw Figure 9 distance witnesses:
four unit-distance adjacencies and the four distinctness facts used for
separation. -/
abbrev Figure9FiniteLabelAdjacencyDistinctnessRows {n : Nat}
    (C : _root_.UDConfig n) (good : Nat -> Prop) : Prop :=
  forall {i : Nat},
    1 <= i -> i + 1 <= 10 ->
    Not (good i) -> Not (good (i + 1)) ->
      Exists fun p : Fin n =>
      Exists fun qi : Fin n =>
      Exists fun qj : Fin n =>
      Exists fun s : Fin n =>
      Exists fun r : Fin n =>
        GraphBridge.UnitDistanceAdj C p qi /\
          GraphBridge.UnitDistanceAdj C p qj /\
          GraphBridge.UnitDistanceAdj C qi s /\
          GraphBridge.UnitDistanceAdj C qj r /\
          Ne qi qj /\
          Ne p s /\
          Ne p r /\
          Ne s r

/-- Convert finite Figure 8 label adjacency/distinctness rows to the existing
point-valued raw distance witness rows. -/
def figure8DistanceWitnessRows_of_finiteLabelAdjacencyDistinctnessRows
    {n : Nat} {C : _root_.UDConfig n} {good : Nat -> Prop}
    (H : Figure8FiniteLabelAdjacencyDistinctnessRows C good) :
    ExactFigureRowsAssemblyW32.Figure8DistanceWitnessRows good := by
  intro i j hi hsep hj hbad_i hbad_j
  rcases H hi hsep hj hbad_i hbad_j with
    ⟨p, qi, qj, s, r, hp_qi, hp_qj, hqi_s, hqj_r, hqi_qj, hs_r⟩
  exact
    Exists.intro (C.pts p)
      (Exists.intro (C.pts qi)
        (Exists.intro (C.pts qj)
          (Exists.intro (C.pts s)
            (Exists.intro (C.pts r)
              (AngleBridgeFacts.Figure8DistanceData.ofUDConfigAdj C
                hp_qi hp_qj hqi_s hqj_r hqi_qj hs_r)))))

/-- Convert finite Figure 9 label adjacency/distinctness rows to the existing
point-valued raw distance witness rows. -/
def figure9DistanceWitnessRows_of_finiteLabelAdjacencyDistinctnessRows
    {n : Nat} {C : _root_.UDConfig n} {good : Nat -> Prop}
    (H : Figure9FiniteLabelAdjacencyDistinctnessRows C good) :
    ExactFigureRowsAssemblyW32.Figure9DistanceWitnessRows good := by
  intro i hi hi_next hbad_i hbad_next
  rcases H hi hi_next hbad_i hbad_next with
    ⟨p, qi, qj, s, r, hp_qi, hp_qj, hqi_s, hqj_r, hqi_qj, hp_s,
      hp_r, hs_r⟩
  exact
    Exists.intro (C.pts p)
      (Exists.intro (C.pts qi)
        (Exists.intro (C.pts qj)
          (Exists.intro (C.pts s)
            (Exists.intro (C.pts r)
              (AngleBridgeFacts.Figure9DistanceData.ofUDConfigAdj C
                hp_qi hp_qj hqi_s hqj_r hqi_qj hp_s hp_r hs_r)))))

