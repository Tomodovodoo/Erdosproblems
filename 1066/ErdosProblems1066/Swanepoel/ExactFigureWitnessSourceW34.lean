def selectedFigureWitnessSourceFieldsOfLocalExactAngleData
    (F :
      LocalExactAngleDataExtraction.{u}
        payForCut topologyArc lemma8) :
    SelectedFigureWitnessSourceFields.{u}
      payForCut topologyArc lemma8 :=
  FigureWitnessConcreteW27.selectedFigureWitnessFamily_of_localExactAngleDataFamily
    F

theorem selectedFigureWitnessSourceFields_nonempty_of_localExactAngleData
    (F :
      LocalExactAngleDataExtraction.{u}
        payForCut topologyArc lemma8) :
    Nonempty
      (SelectedFigureWitnessSourceFields.{u}
        payForCut topologyArc lemma8) :=
  Nonempty.intro
    (selectedFigureWitnessSourceFieldsOfLocalExactAngleData F)

def localSelectedDistanceContainmentExtractionOfLocalExactAngleData
    {n : Nat} {C : _root_.UDConfig n}
    {localLabels :
      M8ConstructionInterface.M8LocalLabels C}
    {turnBounds : M8ConstructionInterface.M8TurnBounds}
    (D :
      FigureExactAngleCertificateInhabitationW22.LocalExactAngleData
        localLabels turnBounds) :
    ExactFigureRowsAssemblyW32.LocalHonestEuclideanInequalitySourceFields
      localLabels turnBounds where
  figure8 :=
    Figure8EuclideanFactsConcrete.Figure8ExplicitEuclideanFacts.ofContainmentInterface
      D.toLocalExactCertificate.figure8.toContainmentInterface
  figure9_left :=
    Figure9EuclideanFactsConcrete.Figure9ExplicitEuclideanFacts.ofContainmentInterface
      D.toLocalExactCertificate.figure9.toContainmentInterface

def selectedDistanceContainmentExtractionOfLocalExactAngleData
    (F :
      LocalExactAngleDataExtraction.{u}
        payForCut topologyArc lemma8) :
    LocalSelectedDistanceContainmentExtraction.{u}
      payForCut topologyArc lemma8 :=
  fun C hmin =>
    localSelectedDistanceContainmentExtractionOfLocalExactAngleData
      (F.row C hmin)

theorem selectedDistanceContainmentExtraction_nonempty_of_localExactAngleData
    (F :
      LocalExactAngleDataExtraction.{u}
        payForCut topologyArc lemma8) :
    Nonempty
      (LocalSelectedDistanceContainmentExtraction.{u}
        payForCut topologyArc lemma8) :=
  Nonempty.intro
    (selectedDistanceContainmentExtractionOfLocalExactAngleData F)

def localWindowContainmentFieldsOfLocalExactAngleData
    (F :
      LocalExactAngleDataExtraction.{u}
        payForCut topologyArc lemma8) :
    FigureExactAngleCertificateInhabitationW22.LocalWindowContainmentFieldsFamily.{u}
      payForCut topologyArc lemma8 :=
  fun C hmin =>
    (F.row C hmin).toLocalExactCertificate.toLocalWindowContainmentFields

theorem localWindowContainmentFields_nonempty_of_localExactAngleData
    (F :
      LocalExactAngleDataExtraction.{u}
        payForCut topologyArc lemma8) :
    Nonempty
      (FigureExactAngleCertificateInhabitationW22.LocalWindowContainmentFieldsFamily.{u}
        payForCut topologyArc lemma8) :=
  Nonempty.intro
    (localWindowContainmentFieldsOfLocalExactAngleData F)

theorem localExactAngleData_nonempty_of_localWindowContainmentFields
    (h :
      Nonempty
        (FigureExactAngleCertificateInhabitationW22.LocalWindowContainmentFieldsFamily.{u}
          payForCut topologyArc lemma8)) :
    Nonempty
      (LocalExactAngleDataExtraction.{u}
        payForCut topologyArc lemma8) := by
  cases h with
  | intro W =>
      exact
        Nonempty.intro
          (FigureExactAngleCertificateInhabitationW22.LocalExactAngleDataFamily.ofLocalWindowContainmentFieldsFamily
            W)

theorem localWindowContainmentFields_nonempty_iff_localExactAngleData :
    Nonempty
        (FigureExactAngleCertificateInhabitationW22.LocalWindowContainmentFieldsFamily.{u}
          payForCut topologyArc lemma8) <->
      Nonempty
        (LocalExactAngleDataExtraction.{u}
          payForCut topologyArc lemma8) := by
  constructor
  case mp =>
    exact localExactAngleData_nonempty_of_localWindowContainmentFields
  case mpr =>
    intro h
    cases h with
    | intro F =>
        exact localWindowContainmentFields_nonempty_of_localExactAngleData F

/-! ## W32 row assembly from the exact extraction source -/

def exactFigureRowsAssemblyFamilyOfLocalExactAngleData
    (F :
      LocalExactAngleDataExtraction.{u}
        payForCut topologyArc lemma8) :
    ExactFigureRowsAssemblyW32.ExactFigureRowsAssemblyFamily.{u}
      payForCut topologyArc lemma8 :=
  ExactFigureRowsAssemblyW32.exactFigureRowsAssemblyFamily_of_selectedFigureWitnessFieldsAndEuclideanSources
    (selectedFigureWitnessSourceFieldsOfLocalExactAngleData F)
    (selectedDistanceContainmentExtractionOfLocalExactAngleData F)

theorem row_E22_E23_of_localExactAngleData_via_selectedDistanceContainment
    (F :
      LocalExactAngleDataExtraction.{u}
        payForCut topologyArc lemma8)
    {n : Nat} (C : _root_.UDConfig n)
    (hmin : IsMinimalClearedFailure C) :
    Lemma10AnalyticBridge.HonestFigure8SeparatedWindowLowerE22
        (BaseInputs payForCut topologyArc lemma8 C hmin).localLabels.predicates
        (BaseInputs payForCut topologyArc lemma8 C hmin).turnBounds.turn /\
      Lemma10AnalyticBridge.HonestFigure9AdjacentWindowLowerE23
        (BaseInputs payForCut topologyArc lemma8 C hmin).localLabels.predicates
        (BaseInputs payForCut topologyArc lemma8 C hmin).turnBounds.turn :=
  (selectedDistanceContainmentExtractionOfLocalExactAngleData F C hmin).E22_E23

theorem exactFigureRowsAssemblyBlocker_of_localExactAngleData
    (F :
      LocalExactAngleDataExtraction.{u}
        payForCut topologyArc lemma8) :
    ExactFigureRowsAssemblyW32.ExactFigureRowsAssemblyBlocker.{u}
      payForCut topologyArc lemma8 :=
  Nonempty.intro
    (exactFigureRowsAssemblyFamilyOfLocalExactAngleData F)

theorem exactFigureRowsAssemblyBlocker_iff_localExactAngleData :
    ExactFigureRowsAssemblyW32.ExactFigureRowsAssemblyBlocker.{u}
        payForCut topologyArc lemma8 <->
      Nonempty
        (LocalExactAngleDataExtraction.{u}
          payForCut topologyArc lemma8) :=
  (ExactFigureRowsAssemblyW32.exactFigureRowsAssemblyBlocker_iff_exactE22E23SourceBlocker
    (payForCut := payForCut) (topologyArc := topologyArc)
    (lemma8 := lemma8)).trans
    (FigureExactAngleSourceW28.exactE22E23SourceBlocker_iff_localExactAngleDataFamily
      (payForCut := payForCut) (topologyArc := topologyArc)
      (lemma8 := lemma8))

theorem missing_exactFigureRowsAssemblyBlocker_iff_no_localExactAngleData :
    Not
        (ExactFigureRowsAssemblyW32.ExactFigureRowsAssemblyBlocker.{u}
          payForCut topologyArc lemma8) <->
      Not
        (Nonempty
          (LocalExactAngleDataExtraction.{u}
            payForCut topologyArc lemma8)) :=
  not_congr
    (exactFigureRowsAssemblyBlocker_iff_localExactAngleData
      (payForCut := payForCut) (topologyArc := topologyArc)
      (lemma8 := lemma8))

