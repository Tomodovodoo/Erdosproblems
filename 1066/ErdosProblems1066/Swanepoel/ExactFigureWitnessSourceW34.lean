      BoundaryLabelCertificateAssembly.M8FiniteBoundaryFrameCoreLabelCertificate
        D connectedNoCut hmin)
    (H :
      forall (i : Nat) (hi : 1 <= i) (hi5 : i <= 5),
        BoundaryLabelCertificateAssembly.M8FiniteBoundaryFrameCoreLabelCertificate.BadAdjacencyLocalLabelIncidenceRowAt
          K i hi (by omega)) :
    K23ObstructionConcrete.M8LocalLabelBadAdjacencyCrossAdjacencyRows
      K.toM8LocalLabels := by
  let Hfinite :=
    BoundaryLabelCertificateAssembly.M8FiniteBoundaryFrameCoreLabelCertificate.badAdjacencyFiniteLabelIncidenceRowsOfLocalLabelRowAt
      (K := K) H
  exact
    { adj_q1_s2 := by
        simpa
          [K23ObstructionConcrete.M8LocalLabelBadAdjacencyCrossAdjacencyRows,
            K23ObstructionConcrete.M8BadAdjacencyCrossAdjacencyRowAt,
            K23ObstructionConcrete.m8BadAdjacencyLeftTriangleIndexOfNat,
            K23ObstructionConcrete.m8BadAdjacencyRightExtraIndexOfNat,
            BoundaryLabelCertificateAssembly.M8FiniteBoundaryFrameCoreLabelCertificate.BadAdjacencyFiniteLabelIncidenceRowAt]
          using Hfinite.adj_q1_s2
      adj_q2_s3 := by
        simpa
          [K23ObstructionConcrete.M8LocalLabelBadAdjacencyCrossAdjacencyRows,
            K23ObstructionConcrete.M8BadAdjacencyCrossAdjacencyRowAt,
            K23ObstructionConcrete.m8BadAdjacencyLeftTriangleIndexOfNat,
            K23ObstructionConcrete.m8BadAdjacencyRightExtraIndexOfNat,
            BoundaryLabelCertificateAssembly.M8FiniteBoundaryFrameCoreLabelCertificate.BadAdjacencyFiniteLabelIncidenceRowAt]
          using Hfinite.adj_q2_s3
      adj_q3_s4 := by
        simpa
          [K23ObstructionConcrete.M8LocalLabelBadAdjacencyCrossAdjacencyRows,
            K23ObstructionConcrete.M8BadAdjacencyCrossAdjacencyRowAt,
            K23ObstructionConcrete.m8BadAdjacencyLeftTriangleIndexOfNat,
            K23ObstructionConcrete.m8BadAdjacencyRightExtraIndexOfNat,
            BoundaryLabelCertificateAssembly.M8FiniteBoundaryFrameCoreLabelCertificate.BadAdjacencyFiniteLabelIncidenceRowAt]
          using Hfinite.adj_q3_s4
      adj_q4_s5 := by
        simpa
          [K23ObstructionConcrete.M8LocalLabelBadAdjacencyCrossAdjacencyRows,
            K23ObstructionConcrete.M8BadAdjacencyCrossAdjacencyRowAt,
            K23ObstructionConcrete.m8BadAdjacencyLeftTriangleIndexOfNat,
            K23ObstructionConcrete.m8BadAdjacencyRightExtraIndexOfNat,
            BoundaryLabelCertificateAssembly.M8FiniteBoundaryFrameCoreLabelCertificate.BadAdjacencyFiniteLabelIncidenceRowAt]
          using Hfinite.adj_q4_s5
      adj_q5_s6 := by
        simpa
          [K23ObstructionConcrete.M8LocalLabelBadAdjacencyCrossAdjacencyRows,
            K23ObstructionConcrete.M8BadAdjacencyCrossAdjacencyRowAt,
            K23ObstructionConcrete.m8BadAdjacencyLeftTriangleIndexOfNat,
            K23ObstructionConcrete.m8BadAdjacencyRightExtraIndexOfNat,
            BoundaryLabelCertificateAssembly.M8FiniteBoundaryFrameCoreLabelCertificate.BadAdjacencyFiniteLabelIncidenceRowAt]
          using Hfinite.adj_q5_s6 }

/-- The generated local-label bad-adjacency incidence rows supply the exact
