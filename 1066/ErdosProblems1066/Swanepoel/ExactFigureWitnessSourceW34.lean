/-! ## Selected-frame Figure 8 row inputs -/

/-- Selected-frame Figure 8 Euclidean witnesses supply the raw distance-row
input needed by the final S5 bridge. -/
def figure8DistanceWitnessRowsForFrameCyclicSource_of_selectedFigureWitnessFields
    {P :
      FrameCyclicSourcePackage.{u}
        payForCut topologyArc}
    (W : SelectedFigureWitnessSourceFieldsForFrameCyclicSource P) :
    Figure8DistanceWitnessRowsForFrameCyclicSource P := by
  intro n C hmin i j hi hsep hj hbad_i hbad_j
  let D := (W.row C hmin).figure8Euclidean
    (i := i) (j := j) hi hsep hj hbad_i hbad_j
  exact
    Exists.intro D.p
      (Exists.intro D.qi
        (Exists.intro D.qj
          (Exists.intro D.s
            (Exists.intro D.r D.distanceData))))

/-- Selected-frame exact inequality rows supply the universal Figure 8
central-angle containment input needed by the final S5 bridge. -/
def figure8CentralAngleContainmentRowsForFrameCyclicSource_of_exactInequalities
    {P :
      FrameCyclicSourcePackage.{u}
        payForCut topologyArc}
    (H : LocalExactFigureAngleInequalitiesForFrameCyclicSource P) :
    Figure8CentralAngleContainmentRowsForFrameCyclicSource P :=
  fun C hmin => (H C hmin).figure8

/-- The named positive Figure 8 angle row is exactly the central-angle
containment row consumed by the S5 exact assembly. -/
theorem figure8CentralAngleContainmentRowsForFrameCyclicSource_of_centralAngleLeSeparatedTurnRows
    {P :
      FrameCyclicSourcePackage.{u}
        payForCut topologyArc}
    (H :
      Figure8CentralAngleLeSeparatedTurnRowsForFrameCyclicSource P) :
    Figure8CentralAngleContainmentRowsForFrameCyclicSource P :=
  H

/-- Selected-frame Figure 8 witnesses and exact inequalities give exactly
the two Figure 8 row inputs expected by the final S5 bridge. -/
theorem figure8RowsForFrameCyclicSource_of_selectedFigureWitnessFields_and_exactInequalities
    {P :
      FrameCyclicSourcePackage.{u}
        payForCut topologyArc}
    (W : SelectedFigureWitnessSourceFieldsForFrameCyclicSource P)
    (H : LocalExactFigureAngleInequalitiesForFrameCyclicSource P) :
    Figure8DistanceWitnessRowsForFrameCyclicSource P /\
      Figure8CentralAngleContainmentRowsForFrameCyclicSource P :=
  And.intro
    (figure8DistanceWitnessRowsForFrameCyclicSource_of_selectedFigureWitnessFields
      W)
    (figure8CentralAngleContainmentRowsForFrameCyclicSource_of_exactInequalities
      H)

/-- The selected-frame component surface supplies both final Figure 8 row
inputs: distance witnesses and universal central-angle containment. -/
theorem figure8RowsForFrameCyclicSource_of_components
    {P :
      FrameCyclicSourcePackage.{u}
        payForCut topologyArc}
    (H : LocalExactAngleDataComponentsForFrameCyclicSource P) :
    Figure8DistanceWitnessRowsForFrameCyclicSource P /\
      Figure8CentralAngleContainmentRowsForFrameCyclicSource P := by
  cases H with
  | intro W Hineq =>
      exact
        figure8RowsForFrameCyclicSource_of_selectedFigureWitnessFields_and_exactInequalities
          W Hineq

