/-- The remaining noncollision row needed to package a bad-adjacency finite
label incidence as selected Figure 9 distance data. -/
theorem rightP_badAdjacencyLeft_ne_r_badAdjacencyRight
    {n : Nat} {C : _root_.UDConfig n}
    {D : PlanarBoundaryClosure.PlanarBoundaryData.{u}
      (BoundaryFaceCountingToM8.CanonicalUDGraph C)}
    {connectedNoCut : CutVertexClosure.PreconnectedNoCutVertexCertificate C}
    {hmin : IsMinimalClearedFailure C}
    (K :
      BoundaryLabelCertificateAssembly.M8FiniteBoundaryFrameCoreLabelCertificate
        D connectedNoCut hmin)
    {i : Nat} (hi : 1 <= i) (hi10 : i <= 10) :
    Not
      (K.spine.rightP (badAdjacencyLeftExtraOfNat i hi hi10) =
        K.lemma8.r (badAdjacencyRightExtraOfNat i hi hi10)) := by
  intro h
  have hp :
      K.spine.rightP (badAdjacencyLeftExtraOfNat i hi hi10) =
        K.spine.leftP (badAdjacencyRightExtraOfNat i hi hi10) :=
    rightP_badAdjacencyLeft_eq_leftP_badAdjacencyRight
      (K := K) hi hi10
  exact
    K.lemma8.r_not_forbidden
      (badAdjacencyRightExtraOfNat i hi hi10)
      (Or.inl (h.symm.trans hp))

/-- A single finite bad-adjacency incidence row, together with the finite
frame-core labels, packages as selected Figure 9 distance data for the K23
cross pair `q_i, s_{i+1}`. -/
def k23CrossFigure9DistanceRowAtOfFiniteLabelIncidenceRowAt
    {n : Nat} {C : _root_.UDConfig n}
    {D : PlanarBoundaryClosure.PlanarBoundaryData.{u}
      (BoundaryFaceCountingToM8.CanonicalUDGraph C)}
    {connectedNoCut : CutVertexClosure.PreconnectedNoCutVertexCertificate C}
    {hmin : IsMinimalClearedFailure C}
    (K :
      BoundaryLabelCertificateAssembly.M8FiniteBoundaryFrameCoreLabelCertificate
        D connectedNoCut hmin)
    {i : Nat} (hi : 1 <= i) (hi10 : i <= 10)
    (H :
      BadAdjacencyFiniteLabelIncidenceRowAt K i hi hi10) :
    K23ObstructionConcrete.M8BadAdjacencyCrossFigure9DistanceRowAt
      C K.toM8LocalLabels.labels i hi hi10 := by
  let left := badAdjacencyLeftExtraOfNat i hi hi10
  let right := badAdjacencyRightExtraOfNat i hi hi10
  refine
    Exists.intro (C.pts (K.spine.rightP left))
      (Exists.intro (C.pts (K.spine.centerQ right))
        (Exists.intro (C.pts (K.lemma8.r right)) ?_))
  exact
    AngleBridgeFacts.Figure9DistanceData.ofUDConfigAdj C
      (by
        exact
          GraphBridge.unitDistanceAdj_symm C
            (K.spine.centerQ_adj_rightP left))
      (by
        have hcp :
            GraphBridge.UnitDistanceAdj C
              (K.spine.centerQ right) (K.spine.rightP left) := by
          simpa [left, right,
            rightP_badAdjacencyLeft_eq_leftP_badAdjacencyRight
              (K := K) hi hi10] using
            K.spine.centerQ_adj_leftP right
        exact GraphBridge.unitDistanceAdj_symm C hcp)
      (by
        simpa [left, right,
          K23ObstructionConcrete.m8BadAdjacencyLeftTriangleIndexOfNat,
          K23ObstructionConcrete.m8BadAdjacencyRightExtraIndexOfNat,
          badAdjacencyLeftExtraOfNat, badAdjacencyRightExtraOfNat,
          badAdjacencyLemma10IndexOfNat] using H)
      (by
        exact K.lemma8.r_neighbor right)
      (by
        exact
          centerQ_badAdjacencyLeft_ne_centerQ_badAdjacencyRight
            (K := K) hi hi10)
      (by
        exact rightP_badAdjacencyLeft_ne_s_right (K := K) hi hi10)
      (by
        exact rightP_badAdjacencyLeft_ne_r_badAdjacencyRight K hi hi10)
      (by
        intro hsr
        exact K.lemma8.r_ne_s right hsr.symm)

/-- Five finite bad-adjacency incidence rows supply selected Figure 9
distance data for the five K23 cross pairs. -/
def k23CrossFigure9DistanceRowsOfFiniteLabelIncidenceRows
    {n : Nat} {C : _root_.UDConfig n}
    {D : PlanarBoundaryClosure.PlanarBoundaryData.{u}
      (BoundaryFaceCountingToM8.CanonicalUDGraph C)}
    {connectedNoCut : CutVertexClosure.PreconnectedNoCutVertexCertificate C}
    {hmin : IsMinimalClearedFailure C}
    (K :
      BoundaryLabelCertificateAssembly.M8FiniteBoundaryFrameCoreLabelCertificate
        D connectedNoCut hmin)
    (H : BadAdjacencyFiniteLabelIncidenceRows K) :
    K23CrossFigure9DistanceRowsForLocalLabels K.toM8LocalLabels where
  fig9_q1_s2 :=
    k23CrossFigure9DistanceRowAtOfFiniteLabelIncidenceRowAt
      (i := 1) K (by omega) (by omega) H.adj_q1_s2
  fig9_q2_s3 :=
    k23CrossFigure9DistanceRowAtOfFiniteLabelIncidenceRowAt
      (i := 2) K (by omega) (by omega) H.adj_q2_s3
  fig9_q3_s4 :=
    k23CrossFigure9DistanceRowAtOfFiniteLabelIncidenceRowAt
      (i := 3) K (by omega) (by omega) H.adj_q3_s4
  fig9_q4_s5 :=
    k23CrossFigure9DistanceRowAtOfFiniteLabelIncidenceRowAt
      (i := 4) K (by omega) (by omega) H.adj_q4_s5
  fig9_q5_s6 :=
    k23CrossFigure9DistanceRowAtOfFiniteLabelIncidenceRowAt
      (i := 5) K (by omega) (by omega) H.adj_q5_s6

/-- The generated local-label bad-adjacency incidence rows are exactly the
K23 cross-adjacency rows for the same assembled local labels. -/
def k23CrossAdjacencyRowsForLocalLabels_of_badAdjacencyLocalLabelRowAt
    {n : Nat} {C : _root_.UDConfig n}
    {D : PlanarBoundaryClosure.PlanarBoundaryData.{u}
      (BoundaryFaceCountingToM8.CanonicalUDGraph C)}
