  forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
      {start : UnitDistanceDart C},
    UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
      start.tail = e.1 ->
        start.head = e.2 ->
          forall m : Nat,
            (forall q : PlanarInterface.Point,
              PlanarInterface.InOpenSegment q
                ((canonicalGraph C).point (rawIterDart start m).tail)
                ((canonicalGraph C).point (rawIterDart start m).head) ->
              q ∈ frontier
                (unboundedExteriorComponentRows C inputs).exterior) ->
            forall htail :
              ((geometricUnitDistanceRotationSystem C).faceSucc
                  (rawIterDart start m)).tail ∈
                unboundedFrontierVertexSet C inputs,
              Exists fun hhead :
                ((geometricUnitDistanceRotationSystem C).faceSucc
                    (rawIterDart start m)).head ∈
                  unboundedFrontierVertexSet C inputs =>
                Exists fun tailRows :
                  UnboundedFrontierCarrierLocalSectorRowsAt inputs
                    ⟨((geometricUnitDistanceRotationSystem C).faceSucc
                        (rawIterDart start m)).tail, htail⟩ =>
                  Exists fun _headRows :
                    UnboundedFrontierCarrierLocalSectorRowsAt inputs
                      ⟨((geometricUnitDistanceRotationSystem C).faceSucc
                          (rawIterDart start m)).head, hhead⟩ =>
                    ((geometricUnitDistanceRotationSystem C).faceSucc
                        (rawIterDart start m)).head = tailRows.left ∨
                      ((geometricUnitDistanceRotationSystem C).faceSucc
                        (rawIterDart start m)).head = tailRows.right

/-- Strict local transition source for selected raw-orbit `faceSucc` edges.

For each selected Nat-indexed raw iterate whose current open segment is on the
actual unbounded frontier, the geometric `faceSucc` head only has to be one of
the two selected local-sector heads at the `faceSucc` tail.  This is the
minimal local-sector transition row needed to prove selected carrier-edge
membership for the successor edge: it does not ask for a sector row at the
successor head, a completed boundary cycle, or a global orientation row. -/
def RawOrbitIteratedFaceSuccLocalSectorTransitionNoOrbitSource
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
      {start : UnitDistanceDart C},
    UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
      start.tail = e.1 ->
        start.head = e.2 ->
          forall m : Nat,
            (forall q : PlanarInterface.Point,
              PlanarInterface.InOpenSegment q
                ((canonicalGraph C).point (rawIterDart start m).tail)
                ((canonicalGraph C).point (rawIterDart start m).head) ->
              q ∈ frontier
                (unboundedExteriorComponentRows C inputs).exterior) ->
            forall htail :
              ((geometricUnitDistanceRotationSystem C).faceSucc
                  (rawIterDart start m)).tail ∈
                unboundedFrontierVertexSet C inputs,
              Exists fun tailRows :
                UnboundedFrontierCarrierLocalSectorRowsAt inputs
                  ⟨((geometricUnitDistanceRotationSystem C).faceSucc
                      (rawIterDart start m)).tail, htail⟩ =>
                ((geometricUnitDistanceRotationSystem C).faceSucc
                    (rawIterDart start m)).head = tailRows.left ∨
                  ((geometricUnitDistanceRotationSystem C).faceSucc
                    (rawIterDart start m)).head = tailRows.right

set_option linter.style.longLine false in
/-- Geometric-sector source for the selected raw-orbit `faceSucc` transition.

Given a sharp boundary-free local angular source, this row says that the
geometric `faceSucc` head of each selected frontier iterate lies in the open
angular sector determined by the two selected local frontier heads at the
successor tail.  The reducer below turns this sector fact into the concrete
carrier transition row by the genuine sorted-list no-between theorem. -/
def RawOrbitIteratedFaceSuccHeadBetweenLocalAngularNoOrbitSource
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (localAngularSource :
      BoundaryFreeLocalSectorGeometricAngularSource inputs) : Prop :=
  forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
      {start : UnitDistanceDart C},
    UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
      start.tail = e.1 ->
        start.head = e.2 ->
          forall m : Nat,
            (forall q : PlanarInterface.Point,
              PlanarInterface.InOpenSegment q
                ((canonicalGraph C).point (rawIterDart start m).tail)
                ((canonicalGraph C).point (rawIterDart start m).head) ->
              q ∈ frontier
                (unboundedExteriorComponentRows C inputs).exterior) ->
            forall htail :
              ((geometricUnitDistanceRotationSystem C).faceSucc
                  (rawIterDart start m)).tail ∈
                unboundedFrontierVertexSet C inputs,
              let d : UnitDistanceDart C := rawIterDart start m
              let succ := (geometricUnitDistanceRotationSystem C).faceSucc d
              let a :
                  {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
                ⟨succ.tail, htail⟩
              BoundaryFreeGraphVertexAngularBetween C succ.tail
                (Classical.choose (localAngularSource a))
                (Classical.choose
                  (Classical.choose_spec (localAngularSource a)))
                succ.head

