set_option linter.style.longLine false in
/-- Two non-wrap neighbour-selection rows with the same middle head have
matching indices in the genuine sorted outgoing-dart list. -/
theorem graphVertexGeometricAngularNeighborSelectionRow_index_succ_eq_of_shared_middle
    {C : _root_.UDConfig n}
    {center left middle right : Fin n}
    (leftMiddle :
      GeometricRotationSystem.GraphVertexGeometricAngularNeighborSelectionRow
        C center left middle)
    (middleRight :
      GeometricRotationSystem.GraphVertexGeometricAngularNeighborSelectionRow
        C center middle right) :
    leftMiddle.index + 1 = middleRight.index := by
  classical
  let i : Nat := leftMiddle.index + 1
  let j : Nat := middleRight.index
  have hi :
      i < (geometricOutgoingDartList C center).length := by
    simpa [i] using leftMiddle.index_succ_lt
  have hj :
      j < (geometricOutgoingDartList C center).length := by
    exact Nat.lt_trans (Nat.lt_succ_self middleRight.index)
      middleRight.index_succ_lt
  have hsame :
      (dartFromGeometricList C center i hi).head =
        (dartFromGeometricList C center j hj).head := by
    rw [← leftMiddle.right_eq, ← middleRight.left_eq]
  rcases Nat.lt_trichotomy i j with hij | hij | hij
  · have hlt :
        graphDartArg (canonicalGeometricGraph C) center
            (dartFromGeometricList C center i hi).head <
          graphDartArg (canonicalGeometricGraph C) center
            (dartFromGeometricList C center j hj).head :=
      graphDartArg_lt_of_dartFromGeometricList_index_lt
        C center hi hj hij
    rw [hsame] at hlt
    exact (False.elim ((lt_irrefl _) hlt))
  · simpa [i, j] using hij
  · have hlt :
        graphDartArg (canonicalGeometricGraph C) center
            (dartFromGeometricList C center j hj).head <
          graphDartArg (canonicalGeometricGraph C) center
            (dartFromGeometricList C center i hi).head :=
      graphDartArg_lt_of_dartFromGeometricList_index_lt
        C center hj hi hij
    rw [hsame] at hlt
    exact (False.elim ((lt_irrefl _) hlt))

