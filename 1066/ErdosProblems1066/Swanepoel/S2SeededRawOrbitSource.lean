/-- Successor interior-frontier points plus the exact non-carrier residual
prove the selected `faceSucc` head-between source.

The proof uses the actual geometric successor dart, takes the supplied
frontier point on its open segment as a W3 germ at the successor tail, and then
applies the third-germ angular row from the local angular source. -/
theorem
    rawOrbitIteratedFaceSuccHeadBetweenLocalAngularNoOrbitSource_of_successorPoint_notLocalCarrier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (localAngularSource :
      BoundaryFreeLocalSectorGeometricAngularSource inputs)
    (successorPoint :
      RawOrbitIteratedFaceSuccInteriorFrontierPointNoOrbitSource inputs)
    (notLocalCarrier :
      RawOrbitIteratedFaceSuccHeadNotLocalAngularCarrierNoOrbitSource
        inputs localAngularSource) :
    RawOrbitIteratedFaceSuccHeadBetweenLocalAngularNoOrbitSource
      inputs localAngularSource := by
  classical
  intro e p start edgeRows htail hhead m current_frontier hsucc_tail
  let d : UnitDistanceDart C := rawIterDart start m
  let succ := (geometricUnitDistanceRotationSystem C).faceSucc d
  let a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨succ.tail, by simpa [succ, d] using hsucc_tail⟩
  let left : Fin n := Classical.choose (localAngularSource a)
  let right : Fin n :=
    Classical.choose (Classical.choose_spec (localAngularSource a))
  have hsource :
      ((a.1, left) ∈ unboundedFrontierEdgeSet C inputs ∨
          (left, a.1) ∈ unboundedFrontierEdgeSet C inputs) ∧
        ((a.1, right) ∈ unboundedFrontierEdgeSet C inputs ∨
          (right, a.1) ∈ unboundedFrontierEdgeSet C inputs) ∧
        left ≠ right ∧
        Nonempty
          (GeometricRotationSystem.GraphVertexGeometricAngularNeighborSelectionRow
            C a.1 left right) ∧
          forall (ε : Real) (q : PlanarInterface.Point) (x : Fin n),
            q ∈ Metric.ball ((canonicalGraph C).point a.1) ε ->
              q ∈ frontier (unboundedExteriorComponentRows C inputs).exterior ->
                (canonicalGraph C).Adj a.1 x ->
                  q ∈ vertexIncidentGermW3 C a.1 x ε ->
                    q ≠ (canonicalGraph C).point a.1 ->
                      x ≠ left ->
                        x ≠ right ->
                          BoundaryFreeGraphVertexAngularBetween
                            C a.1 left right x :=
    Classical.choose_spec (Classical.choose_spec (localAngularSource a))
  have hnot :
      succ.head ≠ left ∧ succ.head ≠ right := by
    simpa [RawOrbitIteratedFaceSuccHeadNotLocalAngularCarrierNoOrbitSource,
      a, left, right, succ, d] using
      notLocalCarrier edgeRows htail hhead m current_frontier
        (by simpa [succ, d] using hsucc_tail)
