def RawOrbitIteratedFaceSuccSuccessorLocalTwoGermRowsNoOrbitSource
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
      {start : UnitDistanceDart C},
    UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
      start.tail = e.1 ->
        start.head = e.2 ->
          forall m : Nat,
            (forall q : PlanarInterface.Point,
              PlanarInterface.InOpenSegment q
                ((canonicalGraph C).point (rawIterDart start m).tail)
                ((canonicalGraph C).point (rawIterDart start m).head) ->
              q ∈ frontier
                (unboundedExteriorComponentRows C inputs).exterior) ->
            forall htail :
              ((geometricUnitDistanceRotationSystem C).faceSucc
                  (rawIterDart start m)).tail ∈
                unboundedFrontierVertexSet C inputs,
              Exists fun hhead :
                ((geometricUnitDistanceRotationSystem C).faceSucc
                    (rawIterDart start m)).head ∈
                  unboundedFrontierVertexSet C inputs =>
                Exists fun tailRows :
                  UnboundedFrontierCarrierLocalTwoGermRowsAt inputs
                    ⟨((geometricUnitDistanceRotationSystem C).faceSucc
                        (rawIterDart start m)).tail, htail⟩ =>
                  Exists fun _headRows :
                    UnboundedFrontierCarrierLocalTwoGermRowsAt inputs
                      ⟨((geometricUnitDistanceRotationSystem C).faceSucc
                          (rawIterDart start m)).head, hhead⟩ =>
                    ((geometricUnitDistanceRotationSystem C).faceSucc
                        (rawIterDart start m)).head = tailRows.left ∨
                      ((geometricUnitDistanceRotationSystem C).faceSucc
                        (rawIterDart start m)).head = tailRows.right

set_option linter.style.longLine false in
/-- Pointwise local two-germ rows and the selected geometric successor edge
source fill the exact orbit-free selected successor local two-germ source. -/
theorem
    rawOrbitIteratedFaceSuccSuccessorLocalTwoGermRowsNoOrbitSource_of_selected_edgeSource_localTwoGermRows
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (localTwoGermRows :
      forall a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs},
        UnboundedFrontierCarrierLocalTwoGermRowsAt inputs a)
    (edgeSource :
      RawOrbitIteratedFaceSuccFrontierEdgeNoOrbitSource inputs) :
    RawOrbitIteratedFaceSuccSuccessorLocalTwoGermRowsNoOrbitSource inputs := by
  intro e p start edgeRows htail hhead m current_frontier htail_succ
  let d : UnitDistanceDart C := rawIterDart start m
  let succ := (geometricUnitDistanceRotationSystem C).faceSucc d
  have hsucc_edge :
      (succ.tail, succ.head) ∈ unboundedFrontierEdgeSet C inputs ∨
        (succ.head, succ.tail) ∈ unboundedFrontierEdgeSet C inputs := by
    simpa [succ, d] using
      edgeSource edgeRows htail hhead m current_frontier
  have hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
    unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
  have hsucc_head :
      succ.head ∈ unboundedFrontierVertexSet C inputs := by
    rcases hsucc_edge with hsucc_edge | hsucc_edge
    · exact
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole hsucc_edge).2
    · exact
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole hsucc_edge).1
  let tailVertex :
      {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨succ.tail, by simpa [succ, d] using htail_succ⟩
  let headVertex :
      {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨succ.head, hsucc_head⟩
  let tailRows := localTwoGermRows tailVertex
  let headRows := localTwoGermRows headVertex
  have hadj :
      (unboundedFrontierCarrierGraph C inputs).Adj tailVertex headVertex := by
    rcases hsucc_edge with hsucc_edge | hsucc_edge
    · exact
        unboundedFrontierCarrierGraph_adj_of_ordered_edge
          (by simpa [tailVertex, headVertex, succ, d] using hsucc_edge)
    · exact
        unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm
          (by simpa [tailVertex, headVertex, succ, d] using hsucc_edge)
  have hhead_two_germ :
      succ.head = tailRows.left ∨ succ.head = tailRows.right := by
    simpa [tailRows, headVertex] using
      tailRows.toLocalSectorRowsAt.only headVertex hadj
  exact
    ⟨by simpa [succ, d] using hsucc_head,
      by simpa [succ, d, tailVertex] using tailRows,
      by simpa [succ, d, headVertex] using headRows,
      by simpa [succ, d, tailVertex, tailRows] using hhead_two_germ⟩

