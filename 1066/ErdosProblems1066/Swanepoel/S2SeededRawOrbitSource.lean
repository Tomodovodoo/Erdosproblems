/-- A unit-distance dart whose whole open segment lies on the actual
unbounded exterior frontier is one of the two orientations of the supplied
boundary cycle.

The proof uses one midpoint frontier point to select the concrete
`unboundedFrontierEdgeSet` carrier edge, identifies the tail as a boundary
vertex, and then applies the local two-germ row at that boundary vertex to
force the head to be either the successor or predecessor boundary vertex. -/
theorem unitDistanceDart_boundary_or_reverse_of_openSegment_frontier
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (B : JordanBoundaryConcrete.UnitDistanceCycleBoundary C)
    (frontier_iff_cycle_vertex :
      forall v : Fin n,
        (canonicalGraph C).point v ∈
            frontier (unboundedExteriorComponentRows C inputs).exterior ↔
          Exists fun k : Fin B.length => B.vertex k = v)
    (sectorRows :
      forall k : Fin B.length,
        BoundaryVertexExteriorSectorRowsAt inputs B k)
    (d : UnitDistanceDart C)
    (hd :
      forall q : PlanarInterface.Point,
        PlanarInterface.InOpenSegment q
          ((canonicalGraph C).point d.tail)
          ((canonicalGraph C).point d.head) ->
        q ∈ frontier
          (unboundedExteriorComponentRows C inputs).exterior) :
    Exists fun k : Fin B.length =>
      d = UnitDistanceDart.ofBoundary B k ∨
        d.reverse = UnitDistanceDart.ofBoundary B k := by
  classical
  let q : PlanarInterface.Point :=
    PlanarInterface.segmentPoint
      ((canonicalGraph C).point d.tail)
      ((canonicalGraph C).point d.head)
      (1 / 2 : Real)
  have hqopen :
      PlanarInterface.InOpenSegment q
        ((canonicalGraph C).point d.tail)
        ((canonicalGraph C).point d.head) := by
    simpa [q] using
      midpoint_inOpenSegment
        ((canonicalGraph C).point d.tail)
        ((canonicalGraph C).point d.head)
  have hqfrontier :
      q ∈ frontier
        (unboundedExteriorComponentRows C inputs).exterior :=
    hd q hqopen
  have hsource :
      InteriorFrontierEdgeCarrierMembershipSource C inputs :=
    interiorFrontierEdgeCarrierMembershipSource_of_frontier_edge_point
  have hedge_or :
      (d.tail, d.head) ∈ unboundedFrontierEdgeSet C inputs ∨
        (d.head, d.tail) ∈ unboundedFrontierEdgeSet C inputs := by
    rcases UnitDistanceDart.canonicalAdj d with he | he
    · left
      exact
        hsource
          (e := (d.tail, d.head))
          (p := q)
          he hqopen hqfrontier
    · right
      exact
        hsource
          (e := (d.head, d.tail))
          (p := q)
          he (inOpenSegment_symm hqopen) hqfrontier
  have htail_mem :
      d.tail ∈ unboundedFrontierVertexSet C inputs := by
    rcases hedge_or with hedge | hedge
    · exact
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          (C := C) (inputs := inputs)
          unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
          hedge).1
    · exact
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          (C := C) (inputs := inputs)
          unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
          hedge).2
  have htail_frontier :
      (canonicalGraph C).point d.tail ∈
        frontier (unboundedExteriorComponentRows C inputs).exterior :=
    mem_unboundedFrontierVertexSet_iff.1 htail_mem
  rcases (frontier_iff_cycle_vertex d.tail).1 htail_frontier with
    ⟨k, hk_tail⟩
  have hedge_at_k :
      (B.vertex k, d.head) ∈ unboundedFrontierEdgeSet C inputs ∨
        (d.head, B.vertex k) ∈ unboundedFrontierEdgeSet C inputs := by
    rcases hedge_or with hedge | hedge
    · left
      simpa [hk_tail] using hedge
    · right
      simpa [hk_tail] using hedge
  rcases (sectorRows k).local_two_germ d.head hedge_at_k with
    hhead_pred | hhead_succ
  · let pred : Fin B.length := PlanarInterface.cyclicPred B.length_pos k
    refine ⟨pred, Or.inr ?_⟩
    have hsucc_pred :
        PlanarInterface.cyclicSucc B.length_pos pred = k := by
      simp [pred]
    exact
      UnitDistanceDart.eq_ofBoundary_of_tail_head B pred d.reverse
        (by simpa [pred] using hhead_pred)
        (by simpa [hsucc_pred] using hk_tail.symm)
  · refine ⟨k, Or.inl ?_⟩
    exact
      UnitDistanceDart.eq_ofBoundary_of_tail_head B k d
        hk_tail.symm
        (by simpa using hhead_succ)

