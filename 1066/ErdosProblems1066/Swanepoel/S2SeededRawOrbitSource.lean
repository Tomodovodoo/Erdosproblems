        UnboundedFrontierCarrierLocalTwoGermRowsAt inputs a)
    (edgeSource :
      RawOrbitIteratedFaceSuccFrontierEdgeNoOrbitSource inputs) :
    RawOrbitIteratedFaceSuccSuccessorLocalTwoGermRowsNoOrbitSource inputs := by
  intro e p start edgeRows htail hhead m current_frontier htail_succ
  let d : UnitDistanceDart C := rawIterDart start m
  let succ := (geometricUnitDistanceRotationSystem C).faceSucc d
  have hsucc_edge :
      (succ.tail, succ.head) ∈ unboundedFrontierEdgeSet C inputs ∨
        (succ.head, succ.tail) ∈ unboundedFrontierEdgeSet C inputs := by
    simpa [succ, d] using
      edgeSource edgeRows htail hhead m current_frontier
  have hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
    unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
  have hsucc_head :
      succ.head ∈ unboundedFrontierVertexSet C inputs := by
    rcases hsucc_edge with hsucc_edge | hsucc_edge
    · exact
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole hsucc_edge).2
    · exact
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole hsucc_edge).1
  let tailVertex :
      {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨succ.tail, by simpa [succ, d] using htail_succ⟩
  let headVertex :
      {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨succ.head, hsucc_head⟩
  let tailRows := localTwoGermRows tailVertex
  let headRows := localTwoGermRows headVertex
  have hadj :
      (unboundedFrontierCarrierGraph C inputs).Adj tailVertex headVertex := by
    rcases hsucc_edge with hsucc_edge | hsucc_edge
    · exact
