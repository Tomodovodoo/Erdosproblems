set_option linter.style.longLine false in
/-- A non-wrap no-between row restricts to the left subinterval once a middle
head is strictly between the two endpoint heads. -/
theorem graphVertexAngularNoBetweenRows_left_subinterval
    {C : _root_.UDConfig n}
    {center left middle right : Fin n}
    (rows :
      GeometricRotationSystem.GraphVertexAngularNoBetweenRows
        C center left right)
    (hleft_middle :
      graphDartArg (canonicalGeometricGraph C) center left <
        graphDartArg (canonicalGeometricGraph C) center middle)
    (hmiddle_right :
      graphDartArg (canonicalGeometricGraph C) center middle <
        graphDartArg (canonicalGeometricGraph C) center right) :
    GeometricRotationSystem.GraphVertexAngularNoBetweenRows
      C center left middle := by
  refine
    { angle := hleft_middle
      no_between := ?_ }
  intro other hAdj hother_left hother_middle hbetween
  by_cases hother_right : other = right
  · have hright_middle :
      graphDartArg (canonicalGeometricGraph C) center right <
        graphDartArg (canonicalGeometricGraph C) center middle := by
      simpa [hother_right] using hbetween.2
    exact (not_lt_of_ge (le_of_lt hmiddle_right)) hright_middle
  · exact
      (rows.no_between other hAdj hother_left hother_right)
        (by
          exact ⟨hbetween.1, lt_trans hbetween.2 hmiddle_right⟩)

set_option linter.style.longLine false in
/-- A non-wrap no-between row restricts to the right subinterval once a middle
head is strictly between the two endpoint heads. -/
theorem graphVertexAngularNoBetweenRows_right_subinterval
    {C : _root_.UDConfig n}
    {center left middle right : Fin n}
    (rows :
      GeometricRotationSystem.GraphVertexAngularNoBetweenRows
        C center left right)
    (hleft_middle :
      graphDartArg (canonicalGeometricGraph C) center left <
        graphDartArg (canonicalGeometricGraph C) center middle)
    (hmiddle_right :
      graphDartArg (canonicalGeometricGraph C) center middle <
        graphDartArg (canonicalGeometricGraph C) center right) :
    GeometricRotationSystem.GraphVertexAngularNoBetweenRows
      C center middle right := by
  refine
    { angle := hmiddle_right
      no_between := ?_ }
  intro other hAdj hother_middle hother_right hbetween
  by_cases hother_left : other = left
  · have hmiddle_left :
      graphDartArg (canonicalGeometricGraph C) center middle <
        graphDartArg (canonicalGeometricGraph C) center left := by
      simpa [hother_left] using hbetween.1
    exact (not_lt_of_ge (le_of_lt hleft_middle)) hmiddle_left
  · exact
      (rows.no_between other hAdj hother_left hother_right)
        (by
          exact ⟨lt_trans hleft_middle hbetween.1, hbetween.2⟩)

set_option linter.style.longLine false in
/-- Local-angular rows plus strict successor-tail order fill the strict
successor-tail no-between source.

The carrier source supplies the incident left/right adjacencies and the
