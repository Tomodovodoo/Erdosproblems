def RawOrbitIteratedFaceSuccHeadBetweenLocalAngularNoOrbitSource
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (localAngularSource :
      BoundaryFreeLocalSectorGeometricAngularSource inputs) : Prop :=
  forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
