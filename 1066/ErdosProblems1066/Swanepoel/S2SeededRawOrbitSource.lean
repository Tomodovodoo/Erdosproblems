set_option linter.style.longLine false in
/-- Selected `faceSucc` transition against the S2-A boundary-free local rows.

For each selected Nat-indexed raw iterate, once the current open segment is on
the actual unbounded exterior frontier, the genuine geometric successor head
is required only to be one of the two local two-germ heads supplied by the
boundary-free source at the successor tail.  This row is deliberately smaller
than a selected-successor local-two-germ package: the S2-A rows remain a
separate input. -/
def RawOrbitIteratedFaceSuccBoundaryFreeLocalTwoGermTransitionNoOrbitSource
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (localSource : BoundaryFreeNoThirdGermSource inputs) : Prop :=
  forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
      {start : UnitDistanceDart C},
    UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
      start.tail = e.1 ->
        start.head = e.2 ->
          forall m : Nat,
            (forall q : PlanarInterface.Point,
              PlanarInterface.InOpenSegment q
                ((canonicalGraph C).point (rawIterDart start m).tail)
                ((canonicalGraph C).point (rawIterDart start m).head) ->
              q ∈ frontier
                (unboundedExteriorComponentRows C inputs).exterior) ->
            forall htail :
              ((geometricUnitDistanceRotationSystem C).faceSucc
                  (rawIterDart start m)).tail ∈
                unboundedFrontierVertexSet C inputs,
              let d : UnitDistanceDart C := rawIterDart start m
              let succ := (geometricUnitDistanceRotationSystem C).faceSucc d
              let a :
                  {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
                ⟨succ.tail, htail⟩
              succ.head = (localSource.toLocalTwoGermRows a).left ∨
                succ.head = (localSource.toLocalTwoGermRows a).right

set_option linter.style.longLine false in
/-- Selected successor edge propagation and boundary-free local two-germ rows
fill the exact orbit-free local two-germ transition row.

This is the CW source cut: the only propagation input is the selected
Nat-indexed geometric `faceSucc` edge source, and the local two-germ heads are
read directly from `BoundaryFreeNoThirdGermSource`. -/
theorem
    rawOrbitIteratedFaceSuccBoundaryFreeLocalTwoGermTransitionNoOrbitSource_of_boundaryFree_selectedEdgeSource
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (localSource : BoundaryFreeNoThirdGermSource inputs)
    (edgeSource :
      RawOrbitIteratedFaceSuccFrontierEdgeNoOrbitSource inputs) :
    RawOrbitIteratedFaceSuccBoundaryFreeLocalTwoGermTransitionNoOrbitSource
      localSource := by
  intro e p start edgeRows htail hhead m current_frontier hsucc_tail
  let d : UnitDistanceDart C := rawIterDart start m
  let succ := (geometricUnitDistanceRotationSystem C).faceSucc d
  have hsucc_edge :
      (succ.tail, succ.head) ∈ unboundedFrontierEdgeSet C inputs ∨
        (succ.head, succ.tail) ∈ unboundedFrontierEdgeSet C inputs := by
    simpa [succ, d] using
      edgeSource edgeRows htail hhead m current_frontier
  have hwhole :
      UnboundedFrontierEdgeSetWholeOpenSegmentFrontier C inputs :=
    unboundedFrontierEdgeSetWholeOpenSegmentFrontier_of_definition
  have hsucc_head :
      succ.head ∈ unboundedFrontierVertexSet C inputs := by
    rcases hsucc_edge with hsucc_edge | hsucc_edge
    · exact
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole hsucc_edge).2
    · exact
        (endpoints_mem_unboundedFrontierVertexSet_of_unboundedFrontierEdgeSet
          hwhole hsucc_edge).1
  let tailVertex :
      {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨succ.tail, by simpa [succ, d] using hsucc_tail⟩
  let headVertex :
      {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨succ.head, hsucc_head⟩
  let tailRows := localSource.toLocalTwoGermRows tailVertex
  have hadj :
      (unboundedFrontierCarrierGraph C inputs).Adj tailVertex headVertex := by
    rcases hsucc_edge with hsucc_edge | hsucc_edge
    · exact
        unboundedFrontierCarrierGraph_adj_of_ordered_edge
          (by simpa [tailVertex, headVertex, succ, d] using hsucc_edge)
    · exact
        unboundedFrontierCarrierGraph_adj_of_ordered_edge_symm
          (by simpa [tailVertex, headVertex, succ, d] using hsucc_edge)
  have hhead_two_germ :
      succ.head = tailRows.left ∨ succ.head = tailRows.right := by
    simpa [tailRows, headVertex] using
      tailRows.toLocalSectorRowsAt.only headVertex hadj
  simpa [RawOrbitIteratedFaceSuccBoundaryFreeLocalTwoGermTransitionNoOrbitSource,
    tailVertex, tailRows, succ, d] using hhead_two_germ

