    ⟨succ.tail, by simpa [succ, d] using hsucc_tail⟩
  rcases
      successorTailRows edgeRows htail hhead m current_frontier
        (by simpa [succ, d] using hsucc_tail) with
    ⟨leftHeadRow, headRightRow, _hchain⟩
