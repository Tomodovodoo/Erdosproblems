theorem
    rawOrbitIteratedFaceSuccHeadLocalAngularSuccessorTailGeometricNoBetweenRowsNoOrbitSource_of_localAngularStrictOrder
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (localAngularSource :
      BoundaryFreeLocalSectorGeometricAngularSource inputs)
    (strictOrder :
      RawOrbitIteratedFaceSuccHeadLocalAngularStrictOrderNoOrbitSource
        inputs
        (localAngularCarrierLeft localAngularSource)
        (localAngularCarrierRight localAngularSource)) :
    RawOrbitIteratedFaceSuccHeadLocalAngularSuccessorTailGeometricNoBetweenRowsNoOrbitSource
      inputs
      (localAngularCarrierLeft localAngularSource)
      (localAngularCarrierRight localAngularSource) := by
  classical
  intro e p start edgeRows htail hhead m current_frontier hsucc_tail
  let d : UnitDistanceDart C := rawIterDart start m
  let succ := (geometricUnitDistanceRotationSystem C).faceSucc d
  let a : {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
    ⟨succ.tail, hsucc_tail⟩
  let left : Fin n := localAngularCarrierLeft localAngularSource a
  let right : Fin n := localAngularCarrierRight localAngularSource a
  have hsource :=
    Classical.choose_spec (Classical.choose_spec (localAngularSource a))
  have hleft_canonical_a : (canonicalGraph C).Adj a.1 left := by
    rcases hsource.1 with hleft_edge | hleft_edge
    · exact unboundedFrontierEdgeSet_adj hleft_edge
    · exact canonicalAdj_symm (unboundedFrontierEdgeSet_adj hleft_edge)
  have hright_canonical_a : (canonicalGraph C).Adj a.1 right := by
    rcases hsource.2.1 with hright_edge | hright_edge
    · exact unboundedFrontierEdgeSet_adj hright_edge
    · exact canonicalAdj_symm (unboundedFrontierEdgeSet_adj hright_edge)
  have hleft_adj : GraphBridge.UnitDistanceAdj C succ.tail left :=
    ((canonicalGraph C).adj_iff_unitDistanceAdj a.1 left).1
      hleft_canonical_a
  have hhead_adj : GraphBridge.UnitDistanceAdj C succ.tail succ.head :=
    ((canonicalGraph C).adj_iff_unitDistanceAdj succ.tail succ.head).1
      (UnitDistanceDart.canonicalAdj succ)
  have hright_adj : GraphBridge.UnitDistanceAdj C succ.tail right :=
    ((canonicalGraph C).adj_iff_unitDistanceAdj a.1 right).1
      hright_canonical_a
  have carrierRows_a :
      GeometricRotationSystem.GraphVertexAngularNoBetweenRows
        C a.1 left right := by
    have row :
        GeometricRotationSystem.GraphVertexGeometricAngularNeighborSelectionRow
          C a.1 left right :=
      Classical.choice hsource.2.2.2.1
    exact
      GeometricRotationSystem.graphVertexAngularNoBetweenRows_of_geometricAngularNeighborSelectionRow
        row
  have carrierRows :
      GeometricRotationSystem.GraphVertexAngularNoBetweenRows
        C succ.tail left right :=
    carrierRows_a
  have hstrict :
      graphDartArg (canonicalGeometricGraph C) succ.tail left <
          graphDartArg (canonicalGeometricGraph C) succ.tail succ.head ∧
        graphDartArg (canonicalGeometricGraph C) succ.tail succ.head <
          graphDartArg (canonicalGeometricGraph C) succ.tail right := by
    have hstrict_raw :=
      strictOrder edgeRows htail hhead m current_frontier hsucc_tail
    change
      graphDartArg (canonicalGeometricGraph C) succ.tail left <
          graphDartArg (canonicalGeometricGraph C) succ.tail succ.head ∧
        graphDartArg (canonicalGeometricGraph C) succ.tail succ.head <
          graphDartArg (canonicalGeometricGraph C) succ.tail right at hstrict_raw
    exact hstrict_raw
  have leftNoBetween :
      GeometricRotationSystem.GraphVertexAngularNoBetweenRows
        C succ.tail left succ.head :=
    graphVertexAngularNoBetweenRows_left_subinterval carrierRows
      hstrict.1 hstrict.2
  have rightNoBetween :
      GeometricRotationSystem.GraphVertexAngularNoBetweenRows
        C succ.tail succ.head right :=
    graphVertexAngularNoBetweenRows_right_subinterval carrierRows
      hstrict.1 hstrict.2
  change
    GraphBridge.UnitDistanceAdj C succ.tail left ∧
      GraphBridge.UnitDistanceAdj C succ.tail succ.head ∧
      GraphBridge.UnitDistanceAdj C succ.tail right ∧
      GeometricRotationSystem.GraphVertexAngularNoBetweenRows
        C succ.tail left succ.head ∧
      GeometricRotationSystem.GraphVertexAngularNoBetweenRows
        C succ.tail succ.head right
  exact
    ⟨hleft_adj, hhead_adj, hright_adj, leftNoBetween, rightNoBetween⟩

