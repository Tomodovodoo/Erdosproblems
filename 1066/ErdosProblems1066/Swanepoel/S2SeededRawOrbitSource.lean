      start.tail = e.1 ->
        start.head = e.2 ->
          forall _O :
            UnitDistanceRotationSystem.RawFaceSuccOrbit
              (geometricUnitDistanceRotationSystem C)
              start,
            forall m : Nat,
              (forall q : PlanarInterface.Point,
                PlanarInterface.InOpenSegment q
                  ((canonicalGraph C).point (rawIterDart start m).tail)
                  ((canonicalGraph C).point (rawIterDart start m).head) ->
                q ∈ frontier
                  (unboundedExteriorComponentRows C inputs).exterior) ->
              Exists fun q : PlanarInterface.Point =>
                PlanarInterface.InOpenSegment q
                  ((canonicalGraph C).point
                    ((geometricUnitDistanceRotationSystem C).faceSucc
                      (rawIterDart start m)).tail)
                  ((canonicalGraph C).point
                    ((geometricUnitDistanceRotationSystem C).faceSucc
                      (rawIterDart start m)).head) ∧
                q ∈ frontier
                  (unboundedExteriorComponentRows C inputs).exterior

