      graphDartArg (canonicalGeometricGraph C) center left <
        graphDartArg (canonicalGeometricGraph C) center middle)
    (hmiddle_right :
      graphDartArg (canonicalGeometricGraph C) center middle <
        graphDartArg (canonicalGeometricGraph C) center right) :
    GeometricRotationSystem.GraphVertexAngularNoBetweenRows
      C center left middle := by
  refine
    { angle := hleft_middle
      no_between := ?_ }
  intro other hAdj hother_left hother_middle hbetween
  by_cases hother_right : other = right
  · have hright_middle :
      graphDartArg (canonicalGeometricGraph C) center right <
        graphDartArg (canonicalGeometricGraph C) center middle := by
      simpa [hother_right] using hbetween.2
    exact (not_lt_of_ge (le_of_lt hmiddle_right)) hright_middle
  · exact
      (rows.no_between other hAdj hother_left hother_right)
        (by
          exact ⟨hbetween.1, lt_trans hbetween.2 hmiddle_right⟩)

