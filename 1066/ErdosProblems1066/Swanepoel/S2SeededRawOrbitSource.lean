    exact ((canonicalGraph C).adj_iff_unitDistanceAdj succ.tail (left a)).1
      hcanonical
  have hhead_adj : GraphBridge.UnitDistanceAdj C succ.tail succ.head := by
    have hcanonical : (canonicalGraph C).Adj succ.tail succ.head := by
      rw [leftHeadRow.right_eq]
