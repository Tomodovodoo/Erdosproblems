/-- Pointwise local-sector source for a geometric face-successor edge.

The current dart already has its whole open segment on the frontier.  The
successor tail is therefore a frontier vertex; this source asks for local-sector
rows at that successor tail and at the successor head, plus the geometric
identification that the successor head is one of the two sector heads selected
at the successor tail. -/
def FaceSuccSuccessorLocalSectorRowsSource
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall d : UnitDistanceDart C,
    (forall q : PlanarInterface.Point,
      PlanarInterface.InOpenSegment q
        ((canonicalGraph C).point d.tail)
        ((canonicalGraph C).point d.head) ->
      q ∈ frontier
        (unboundedExteriorComponentRows C inputs).exterior) ->
      forall htail :
        ((geometricUnitDistanceRotationSystem C).faceSucc d).tail ∈
          unboundedFrontierVertexSet C inputs,
        Exists fun hhead :
          ((geometricUnitDistanceRotationSystem C).faceSucc d).head ∈
            unboundedFrontierVertexSet C inputs =>
          Exists fun tailRows :
            UnboundedFrontierCarrierLocalSectorRowsAt inputs
              ⟨((geometricUnitDistanceRotationSystem C).faceSucc d).tail,
                htail⟩ =>
            Exists fun _headRows :
              UnboundedFrontierCarrierLocalSectorRowsAt inputs
                ⟨((geometricUnitDistanceRotationSystem C).faceSucc d).head,
                  hhead⟩ =>
              ((geometricUnitDistanceRotationSystem C).faceSucc d).head =
                  tailRows.left ∨
                ((geometricUnitDistanceRotationSystem C).faceSucc d).head =
                  tailRows.right

/-- Orbit-free selected local-sector source for successor darts.

This is the selected raw-iterate version of
`FaceSuccSuccessorLocalSectorRowsSource`: the only darts considered are
`rawIterDart start m` coming from a selected exterior seed, and no finite
raw-orbit object is quantified. -/
def RawOrbitIteratedFaceSuccSuccessorLocalSectorRowsNoOrbitSource
    {C : _root_.UDConfig n}
