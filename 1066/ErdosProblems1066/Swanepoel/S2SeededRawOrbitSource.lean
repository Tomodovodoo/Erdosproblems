/-- A raw finite orbit indexes the same geometric iterates modulo its period. -/
theorem rawIterDart_eq_rawOrbit_dart_mod
    {C : _root_.UDConfig n}
    {start : UnitDistanceDart C}
    (O :
      UnitDistanceRotationSystem.RawFaceSuccOrbit
        (geometricUnitDistanceRotationSystem C) start)
    (m : Nat) :
    rawIterDart start m =
      O.dart ⟨m % O.period, Nat.mod_lt m O.period_pos⟩ := by
  let R : UnitDistanceRotationSystem C := geometricUnitDistanceRotationSystem C
  have hmod :
      (R.faceSuccPerm ^ (m % O.period)) start =
        (R.faceSuccPerm ^ m) start := by
    have hperiodPow :
        (R.faceSuccPerm ^ (O.period * (m / O.period))) start = start := by
      rw [pow_mul]
      exact
        Equiv.Perm.pow_apply_eq_self_of_apply_eq_self
          O.period_return (m / O.period)
    calc
      (R.faceSuccPerm ^ (m % O.period)) start
          = (R.faceSuccPerm ^ (m % O.period))
              ((R.faceSuccPerm ^ (O.period * (m / O.period))) start) := by
            rw [hperiodPow]
      _ = (R.faceSuccPerm ^
              (m % O.period + O.period * (m / O.period))) start := by
            rw [pow_add]
            rfl
      _ = (R.faceSuccPerm ^ m) start := by
            rw [Nat.mod_add_div]
  have hdart :
      O.dart ⟨m % O.period, Nat.mod_lt m O.period_pos⟩ =
        (R.faceSuccPerm ^ (m % O.period)) start := by
    simpa [R] using
      O.dart_eq_iterate ⟨m % O.period, Nat.mod_lt m O.period_pos⟩
  simpa [rawIterDart, R, hdart] using hmod.symm

