    ⟨q, hqopen, hqfrontier⟩
  let ε : Real := dist q ((canonicalGraph C).point succ.tail) + 1
  have hqball :
      q ∈ Metric.ball ((canonicalGraph C).point succ.tail) ε := by
    simp [ε, Metric.mem_ball]
  have hqgerm :
      q ∈ vertexIncidentGermW3 C succ.tail succ.head ε := by
    exact ⟨hqball, inOpenSegment_mem_closedSegment (by simpa [succ, d] using hqopen)⟩
  have hqcenter :
      q ≠ (canonicalGraph C).point succ.tail := by
    have hpoint_ne :
        (canonicalGraph C).point succ.tail ≠
          (canonicalGraph C).point succ.head :=
      canonical_adj_point_ne (UnitDistanceDart.canonicalAdj succ)
    exact left_ne_of_inOpenSegment hpoint_ne (by simpa [succ, d] using hqopen)
  have hadj : (canonicalGraph C).Adj succ.tail succ.head :=
    UnitDistanceDart.canonicalAdj succ
  have hbetween :
      BoundaryFreeGraphVertexAngularBetween C succ.tail left right succ.head :=
    hsource.2.2.2.2 ε q succ.head
      (by simpa [a, succ] using hqball)
      (by simpa [succ, d] using hqfrontier)
      (by simpa [a, succ] using hadj)
      (by simpa [a, succ] using hqgerm)
      (by simpa [a, succ] using hqcenter)
      hnot.1 hnot.2
  simpa [RawOrbitIteratedFaceSuccHeadBetweenLocalAngularNoOrbitSource,
    a, left, right, succ, d] using hbetween

