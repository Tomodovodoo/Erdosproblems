set_option autoImplicit false

/-!
# S2 seeded raw-orbit source selection

This file owns the source-selection layer for S2: choose an actual unbounded
exterior frontier seed, orient it into the geometric raw face-successor orbit,
and feed the remaining boundary-free source rows into the checked raw-coverage
route.  Local two-germ/no-third-germ topology stays in
`S2BoundaryFreeRawSource`; this file only selects the raw orbit and erases the
source package to the existing S2 theorem.
-/

noncomputable section

namespace ErdosProblems1066
namespace Swanepoel
namespace ExteriorComponentTopology

open JordanTopologyFactsConcrete
open JordanTopologyFactsConcrete.MinimalFailureTopology
open FinitePlaneDrawing
open GeometricRotationSystem
open S2LocalTwoGermAssembly

variable {n : Nat}

/-- The `m`th geometric face-successor iterate from a selected start dart.
Keeping this as a named abbreviation makes the orientation-aware source rows
readable without adding another topology layer. -/
def rawIterDart
    {C : _root_.UDConfig n}
    (start : UnitDistanceDart C) (m : Nat) : UnitDistanceDart C :=
  ((geometricUnitDistanceRotationSystem C).faceSuccPerm ^ m) start

/-- Source row saying that every dart of every selected geometric raw orbit
has its open unit segment on the actual unbounded exterior frontier.

The quantification starts from an already selected
`UnboundedExteriorFrontierEdgeLocalRows` seed, so this row is not allowed to
choose a downstream boundary cycle. -/
def RawOrbitDartEdgeFrontierSource
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
      {start : UnitDistanceDart C},
    UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
      start.tail = e.1 ->
        start.head = e.2 ->
          forall O :
            UnitDistanceRotationSystem.RawFaceSuccOrbit
              (geometricUnitDistanceRotationSystem C)
              start,
            forall k : Fin O.period,
              forall q : PlanarInterface.Point,
                PlanarInterface.InOpenSegment q
                  ((canonicalGraph C).point (O.dart k).tail)
                  ((canonicalGraph C).point (O.dart k).head) ->
                q ∈ frontier
                  (unboundedExteriorComponentRows C inputs).exterior

/-- Dart-edge frontier membership supplies the selected raw edge-membership row
needed by the actual-arc route.

This is a source reducer only: it turns the whole-open-segment frontier row for
each selected raw dart into membership of the corresponding consecutive-tail
edge in the concrete unbounded frontier edge carrier. -/
theorem rawOrbitEdgeMemSource_of_dartEdgeFrontierSource
    {C : _root_.UDConfig n}
    {inputs : FinitePlanarOuterComponentInputs C}
    (source : RawOrbitDartEdgeFrontierSource inputs) :
    forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
        {start : UnitDistanceDart C},
      UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
      start.tail = e.1 ->
      start.head = e.2 ->
      forall O :
        UnitDistanceRotationSystem.RawFaceSuccOrbit
          (geometricUnitDistanceRotationSystem C) start,
        forall k : Fin O.period,
          ((O.dart k).tail,
              (O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail) ∈
              unboundedFrontierEdgeSet C inputs ∨
            ((O.dart (PlanarInterface.cyclicSucc O.period_pos k)).tail,
                (O.dart k).tail) ∈
              unboundedFrontierEdgeSet C inputs := by
  intro e p start edgeRows htail hhead O k
  exact
    rawFaceSuccOrbit_edge_mem_unboundedFrontierEdgeSet_or_symm_of_dart_edge_openSegment_frontier
      (C := C) (inputs := inputs)
      (R := geometricUnitDistanceRotationSystem C) (start := start) O
      (source edgeRows htail hhead O) k

/-- Source row reducing raw-orbit dart-frontier membership to the start dart
and one exterior-oriented `faceSucc` step. -/
def RawOrbitStartAndSuccessorFrontierSource
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
      {start : UnitDistanceDart C},
    UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
      start.tail = e.1 ->
        start.head = e.2 ->
          (forall q : PlanarInterface.Point,
            PlanarInterface.InOpenSegment q
              ((canonicalGraph C).point start.tail)
              ((canonicalGraph C).point start.head) ->
            q ∈ frontier
              (unboundedExteriorComponentRows C inputs).exterior) ∧
          (forall d : UnitDistanceDart C,
            (forall q : PlanarInterface.Point,
              PlanarInterface.InOpenSegment q
                ((canonicalGraph C).point d.tail)
                ((canonicalGraph C).point d.head) ->
              q ∈ frontier
                (unboundedExteriorComponentRows C inputs).exterior) ->
            Exists fun q : PlanarInterface.Point =>
              PlanarInterface.InOpenSegment q
                ((canonicalGraph C).point
                  ((geometricUnitDistanceRotationSystem C).faceSucc d).tail)
                ((canonicalGraph C).point
                  ((geometricUnitDistanceRotationSystem C).faceSucc d).head) ∧
              q ∈ frontier
                (unboundedExteriorComponentRows C inputs).exterior)

/-- Orientation-aware one-step source row for a selected raw exterior orbit.

Unlike `FaceSuccFrontierEdgeSource`, this row does not assert that `faceSucc`
preserves the unbounded frontier for both orientations of every frontier edge.
It only asks for preservation along the iterates of the selected
exterior-oriented start dart. -/
def RawOrbitIteratedFaceSuccFrontierEdgeSource
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C) : Prop :=
  forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
      {start : UnitDistanceDart C},
    UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
      start.tail = e.1 ->
        start.head = e.2 ->
          forall _O :
            UnitDistanceRotationSystem.RawFaceSuccOrbit
              (geometricUnitDistanceRotationSystem C)
              start,
            forall m : Nat,
              (forall q : PlanarInterface.Point,
                PlanarInterface.InOpenSegment q
                  ((canonicalGraph C).point (rawIterDart start m).tail)
                  ((canonicalGraph C).point (rawIterDart start m).head) ->
                q ∈ frontier
                  (unboundedExteriorComponentRows C inputs).exterior) ->
              let d : UnitDistanceDart C := rawIterDart start m
              (((geometricUnitDistanceRotationSystem C).faceSucc d).tail,
                  ((geometricUnitDistanceRotationSystem C).faceSucc d).head) ∈
                  unboundedFrontierEdgeSet C inputs ∨
                (((geometricUnitDistanceRotationSystem C).faceSucc d).head,
                  ((geometricUnitDistanceRotationSystem C).faceSucc d).tail) ∈
                  unboundedFrontierEdgeSet C inputs

