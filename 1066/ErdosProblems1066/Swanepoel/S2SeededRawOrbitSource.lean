    have hcanonical : (canonicalGraph C).Adj succ.tail (left a) := by
      rw [leftHeadRow.left_eq]
      exact
        UnitDistanceDart.canonicalAdj
          (dartFromGeometricList C succ.tail leftHeadRow.index
            (Nat.lt_trans (Nat.lt_succ_self leftHeadRow.index)
