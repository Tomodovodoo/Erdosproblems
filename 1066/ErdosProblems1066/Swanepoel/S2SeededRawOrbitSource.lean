    (transitionRows :
      RawOrbitIteratedFaceSuccLocalSectorTransitionNoOrbitSource inputs) :
    RawOrbitIteratedFaceSuccInteriorFrontierPointNoOrbitSource inputs := by
  intro e p start edgeRows htail hhead m current_frontier
