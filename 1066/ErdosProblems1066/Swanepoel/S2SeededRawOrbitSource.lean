    ⟨left, right, hunreach⟩
  let G := GraphBridge.unitDistanceSimpleGraph C
  let cut : Fin n := (rows.O.dart i).tail
  let s : Set (Fin n) := {cut}ᶜ
  let left' : s :=
    ⟨(rows.O.dart left.1).tail, by
      simpa [cut, s] using left.2.2⟩
  let right' : s :=
    ⟨(rows.O.dart right.1).tail, by
      simpa [cut, s] using right.2.2⟩
  let H := G.induce s
  let comp : H.ConnectedComponent := H.connectedComponentMk left'
  let side : Fin n -> Bool := fun v =>
    if hv : v ≠ cut then
      decide ((⟨v, by simpa [s] using hv⟩ : s) ∈ comp.supp)
    else
      false
  refine ⟨left, right, side, ?_, ?_, ?_⟩
  · dsimp [side, comp, H, left', cut]
    rw [dif_pos left.2.2]
    simp [SimpleGraph.ConnectedComponent.mem_supp_iff]
  · dsimp [side, comp, H, left', right', cut]
    rw [dif_pos right.2.2]
    rw [decide_eq_false_iff_not]
    intro hright_mem
    exact hunreach (SimpleGraph.ConnectedComponent.exact hright_mem.symm)
  · intro a b ha_cut hb_cut ha_side hb_side hAdj
    dsimp [side] at ha_side hb_side
    rw [dif_pos ha_cut] at ha_side
    rw [dif_pos hb_cut] at hb_side
    let a' : s := ⟨a, by simpa [s, cut] using ha_cut⟩
    let b' : s := ⟨b, by simpa [s, cut] using hb_cut⟩
    have ha_mem : a' ∈ comp.supp := by
      dsimp [a']
      exact of_decide_eq_true ha_side
    have hb_not_mem : b' ∉ comp.supp := by
      dsimp [b']
      exact of_decide_eq_false hb_side
    have hAdjH : H.Adj a' b' := by
      simpa [H, G, a', b'] using hAdj
    exact hb_not_mem
      (SimpleGraph.ConnectedComponent.mem_supp_of_adj_mem_supp
        comp ha_mem hAdjH)

