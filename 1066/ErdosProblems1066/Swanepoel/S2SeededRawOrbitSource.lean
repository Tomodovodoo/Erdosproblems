at each selected geometric `faceSucc` successor tail, the left carrier, the
selected `faceSucc` head, and the right carrier are entries `i`, `i+1`, and
`i+2` of the genuine sorted outgoing-dart list.  It keeps the residual at the
real geometric list level and does not use selected-edge equality,
endpoint-only/no-chord rows, final cycle rows, actual-boundary rows, induced
frontier graphs, arbitrary carrier/cycle rows, synthetic enclosures, or
identity angular order. -/
def RawOrbitIteratedFaceSuccHeadLocalAngularSuccessorTailGeometricTripleIndexNoOrbitSource
    {C : _root_.UDConfig n}
    (inputs : FinitePlanarOuterComponentInputs C)
    (left right :
      {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} -> Fin n) :
    Prop :=
  forall {e : PlanarInterface.Edge n} {p : PlanarInterface.Point}
      {start : UnitDistanceDart C},
    UnboundedExteriorFrontierEdgeLocalRows C inputs e p ->
      start.tail = e.1 ->
        start.head = e.2 ->
          forall m : Nat,
            (forall q : PlanarInterface.Point,
              PlanarInterface.InOpenSegment q
                ((canonicalGraph C).point (rawIterDart start m).tail)
                ((canonicalGraph C).point (rawIterDart start m).head) ->
              q ∈ frontier
                (unboundedExteriorComponentRows C inputs).exterior) ->
            forall htail :
              ((geometricUnitDistanceRotationSystem C).faceSucc
                  (rawIterDart start m)).tail ∈
                unboundedFrontierVertexSet C inputs,
              let d : UnitDistanceDart C := rawIterDart start m
              let succ := (geometricUnitDistanceRotationSystem C).faceSucc d
              let a :
                  {v : Fin n // v ∈ unboundedFrontierVertexSet C inputs} :=
                ⟨succ.tail, htail⟩
              Exists fun i : Nat =>
                Exists fun hi_two :
                  i + 2 < (geometricOutgoingDartList C succ.tail).length =>
                  left a =
                    (dartFromGeometricList C succ.tail i
                      (Nat.lt_trans (Nat.lt_succ_self i)
                        (Nat.lt_of_succ_lt hi_two))).head ∧
                  succ.head =
                    (dartFromGeometricList C succ.tail (i + 1)
                      (Nat.lt_of_succ_lt hi_two)).head ∧
                  right a =
                    (dartFromGeometricList C succ.tail (i + 2)
                      hi_two).head

